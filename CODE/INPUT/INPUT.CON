onevent EVENT_WEAPKEY4 // HIGHWIRE/CHAINGUN
state disable_weap_key

	ife CHARSELECT 1
		{
		ifand TRIGGER_BASE_SCENE 8 nullop else
			ifl CHARSHADE 10
			{
			sound SELECT
			set CHARSHADE 20
			set CHAR 3
			}
		}

ife fire_mode_menu 1
ifand GUN_AMMO_TYPES 4
ifg magnum_shells 0
ife kickbackpic 0
	{
		ife player[].weapon_pos 0
		{
		ife cur_weap 9
		ifand weap_special[9] 4
			{
			ifand AMMO_TYPES[cur_weap] 1 { xorvar AMMO_TYPE 1 setarray AMMO_TYPES[cur_weap] AMMO_TYPE add explosive_shells ALTMAG }
			ifand AMMO_TYPES[cur_weap] 4 { xorvar AMMO_TYPE 4 setarray AMMO_TYPES[cur_weap] AMMO_TYPE add flechete_shells ALTMAG }
			ifand AMMO_TYPES[cur_weap] 1024 { xorvar AMMO_TYPE 1024 setarray AMMO_TYPES[cur_weap] AMMO_TYPE add dragon_shells ALTMAG }
			ifand AMMO_TYPES[cur_weap] 65536 { xorvar AMMO_TYPE 65536 setarray AMMO_TYPES[cur_weap] AMMO_TYPE add silverb_shells ALTMAG }
			
			ifand AMMO_TYPES[cur_weap] 64 break else { quote 286 xorvar AMMO_TYPE 64 setarray AMMO_TYPES[cur_weap] AMMO_TYPE
			getp[].ammo_amount 2 temp3 add temp3 ALTMAG setp[].ammo_amount 2 temp3 }
			set ALTMAG 0
			state lower_weapon
			}
			else
		ifn cur_weap 0
		ifand gun_firemode_two 8
			{
			set AMMO_TYPE_2 AMMO_TYPES[15]
			ifand AMMO_TYPES[15] 1 { xorvar AMMO_TYPE_2 1 setarray AMMO_TYPES[15] AMMO_TYPE_2 add explosive_shells alt_slot2_mag  }
			ifand AMMO_TYPES[15] 4 { xorvar AMMO_TYPE_2 4 setarray AMMO_TYPES[15] AMMO_TYPE_2 add flechete_shells alt_slot2_mag  }
			ifand AMMO_TYPES[15] 1024 { xorvar AMMO_TYPE_2 1024 setarray AMMO_TYPES[15] AMMO_TYPE_2 add dragon_shells alt_slot2_mag }
			ifand AMMO_TYPES[15] 65536 { xorvar AMMO_TYPE_2 65536 setarray AMMO_TYPES[15] AMMO_TYPE_2 add silverb_shells alt_slot2_mag }
			
			ifand AMMO_TYPES[15] 64 break else { quote 286 xorvar AMMO_TYPE_2 64 setarray AMMO_TYPES[15] AMMO_TYPE_2
			getp[].ammo_amount 2 temp3 add temp3 alt_slot2_mag setp[].ammo_amount 2 temp3 }
			state lower_weapon
			ifn gun_mag -1
				{
				ife CHAR 0 ife cur_weap 2 set alt_slot2_mag 0
				ife CHAR 7 ife cur_weap 2 set alt_slot2_mag 0
				ife CHAR 12 ife cur_weap 2 set alt_slot2_mag 0
				}
			}
		else
			{
			ifand AMMO_TYPES[cur_weap] 1
				{ xorvar AMMO_TYPE 1 setarray AMMO_TYPES[cur_weap] AMMO_TYPE ifn gun_mag -1 ifn cur_weap 0 add explosive_shells slot2_mag }
			ifand AMMO_TYPES[cur_weap] 4
				{ xorvar AMMO_TYPE 4 setarray AMMO_TYPES[cur_weap] AMMO_TYPE ifn gun_mag -1 ifn cur_weap 0 add flechete_shells slot2_mag }
			ifand AMMO_TYPES[cur_weap] 1024
				{ xorvar AMMO_TYPE 1024 setarray AMMO_TYPES[cur_weap] AMMO_TYPE ifn gun_mag -1 ifn cur_weap 0 add dragon_shells slot2_mag }
			ifand AMMO_TYPES[cur_weap] 65536
				{ xorvar AMMO_TYPE 65536 setarray AMMO_TYPES[cur_weap] AMMO_TYPE ifn gun_mag -1 ifn cur_weap 0 add silverb_shells slot2_mag }
				
			ifand AMMO_TYPES[cur_weap] 64 break else
				{
				quote 286 xorvar AMMO_TYPE 64 setarray AMMO_TYPES[cur_weap] AMMO_TYPE
				ifn gun_mag -1 ifn cur_weap 0 { getp[].ammo_amount 2 temp3 add temp3 slot2_mag setp[].ammo_amount 2 temp3 }
				}
			state lower_weapon
			state empty_shotgun
			}
		}
	set fire_mode_menu 0
	set RETURN -1
	}
else
ife fire_mode_menu 7 // 40mm Plasma shell
ifg fortymm_plasma 0
ife kickbackpic 0
	{
		ifand AMMO_TYPES[cur_weap] 256 break else { xorvar AMMO_TYPE 256 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
		ifand AMMO_TYPES[cur_weap] 32 { xorvar AMMO_TYPE 32 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
		ifand AMMO_TYPES[cur_weap] 128 { xorvar AMMO_TYPE 128 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
		state lower_weapon
	set fire_mode_menu 0
