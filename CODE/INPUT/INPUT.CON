			{
			ifand gun_firemode 32768 { quote 273 xorvar gun_firemode 32768 } else
			{ quote 272 xorvar gun_firemode 32768 }
			ifand gun_firemode 16384 xorvar gun_firemode 16384
			set weap_show 130
			state lower_weapon
