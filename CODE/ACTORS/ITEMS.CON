defstate OLDKEYSTATE

ifspritepal 0
{

ifaction 0
	{
	cstat 0
	sizeat 32 32
	
	set command 256
	action ZERO
	}

ifrnd 1 spawn GLINT

  state can_pickup_item
  ife actor_return 1
	  {
		ifactor FLAMEKEY { ifand OLDKEYS 1 break xor OLDKEYS 1 userquote 155 } 
		ifactor SPIDERKEY { ifand OLDKEYS 2 break xor OLDKEYS 2 userquote 157 } 
		ifactor DAGGERKEY { ifand OLDKEYS 4 break xor OLDKEYS 4 userquote 159 } 
		ifactor MOONKEY { ifand OLDKEYS 8 break xor OLDKEYS 8 userquote 161 } 
		ifactor SKULLKEY { ifand OLDKEYS 16 break xor OLDKEYS 16 userquote 163 } 
		ifactor EYEKEY { ifand OLDKEYS 32 break xor OLDKEYS 32 userquote 240 } 
		
		ifactor DIAMOND_KEY { ifand NORMAL_KEYS 1 break xor NORMAL_KEYS 1 userquote 20033 } 
		ifactor CLUB_KEY { ifand NORMAL_KEYS 2 break xor NORMAL_KEYS 2 userquote 20034 } 
		ifactor SPADE_KEY { ifand NORMAL_KEYS 4 break xor NORMAL_KEYS 4 userquote 20035 } 
		ifactor HEART_KEY { ifand NORMAL_KEYS 8 break xor NORMAL_KEYS 8 userquote 20036 } 
		ifactor NORMAL_KEY5 { ifand NORMAL_KEYS 16 break xor NORMAL_KEYS 16 userquote 20037 }

			state white_flash
			ifactor NORMAL_KEY5 nullop else spritepal 15
			state display_key

		ifmultiplayer
			ife COOP 1
				{
				state RADIO_KEY_SOUNDS
				qgetsysstr 356 STR_PLAYERNAME
				qstrcat 356 663
				userquote 356
				}

		state getcode
	  }
}
ends

