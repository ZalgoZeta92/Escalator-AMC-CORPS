				  add temp 1
				  setp[].max_player_health temp
				  set pmax_hp_countd -300
				  add TREASURE_FOUND 1
				  state PICKUP_DISPLAY
				  geta[].picnum picked_up_tile
				  setarray picked_up_inven[1] 60
				  set item_amount -1
				  userquote 1700
				  state quikget
				  }
