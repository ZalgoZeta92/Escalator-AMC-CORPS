// PICKUP CODE----------------------------ITEMS!-------------------------------------------------

action DECORATION 0

move ITEM_FORWARD 15 -5

defstate ITEM_SETTINGS
seta[].mdflags 16
ife opt_high_vis_items YES { ifand command 16 nullop else xor command 16 }
else ife opt_high_vis_items NO { ifand command 16 xor command 16 }
ifand sprite[].cstat 16 { ifand sprite[].cstat 4 nullop else action DECORATION } else
ifand sprite[].cstat 32768 nullop else { fall cstat 0 }
ifn xvel_saved 0
	{
	ife CHARSELECT 0
		{
		ifand xvel_saved 1 ifn CHAR 0 killit
		ifand xvel_saved 2 ifn CHAR 1 killit
		ifand xvel_saved 4 ifn CHAR 2 killit
		ifand xvel_saved 8 ifn CHAR 3 killit
		ifand xvel_saved 16 ifn CHAR 4 killit
		ifand xvel_saved 32 ifn CHAR 5 killit
		ifand xvel_saved 64 ifn CHAR 6 killit
		ifand xvel_saved 128 ifn CHAR 7 killit
		ifand xvel_saved 256 ifn CHAR 13 killit
		}
	}
ends

defstate RADIO_KEY_SOUNDS
ife CHAR 0 set playsound J_GOTKEY
ife CHAR 1 set playsound Z_GOTKEY
ife CHAR 2 set playsound M_GOTKEY
ife CHAR 3 set playsound R_GOTKEY
ife CHAR 4 set playsound S_GOTKEY
ife CHAR 5 set playsound RN_GOTKEY
ife CHAR 6 set playsound G_GOTKEY
ife CHAR 7 set playsound MS_GOTKEY
ife CHAR 13 set playsound MC_GOTKEY
ife CHAR 17 set playsound KG_GOTKEY
ife CHAR C_WHEATON set playsound WH_GOTKEY
	soundoncevar playsound
	ife fake_shrunk 1 setactorsoundpitch THISACTOR playsound 512
ends

appendevent EVENT_LOADACTOR
switch sprite[].picnum
	case HEAVYHBOMB seta[].picnum 3689 break
	case 9098 seta[].picnum 9087 break // failsafe
	case STEROIDS
	case BOOTS
	case HEATSENSOR
	case HEAVYARMOUR
	case AIRTANK
	case HOLODUKE
	case JETPACK
	case FIRSTAID
	// ammo
	case AMMO
	case FREEZEAMMO
	case SHOTGUNAMMO
	case CHAINGUNSPRITE
	case AMMOLOTS
	case CRYSTALAMMO
	case GROWAMMO
	case BATTERYAMMO
	case DEVISTATORAMMO
	case RPGAMMO
	case HBOMBAMMO
	case 3689
	// base weapons
	case RPGSPRITE
	case SHOTGUNSPRITE
	case FIRSTGUNSPRITE
	case TRIPBOMBSPRITE
	case DEVISTATORSPRITE
	case FREEZESPRITE
	case SHRINKERSPRITE
	// temp weapon melee
	case 12200 // SW sword pickup
	case 20101 // Beam sabre
	case MOPSPRITE
	case BLOODY_MOPSPRITE
	case SWORDSPRITE
	case CHAINSAWSPRITE
	case AXE_SPRITE
	case VORPAL_SWORD_SPRITE
	// temp weapon guns
	case RIOTGUN_MINIGUN_SPRITE
	case 16087 // upg riotgun minigun
	case RIOTGUN_GRENADEL_SPRITE
	case NAILGUN_SPRITE
	case DARTGUN_SPRITE
	case M60_SPRITE
	case ZMISSILELSPRITE
	case M960_SPRITE
	case GOROHEADSPRITE
	case RIPPER_HEART
	case M16SPRITE
	case P90_SPRITE
	case JUGGERNAUT_PICKUP
	case MP40SPRITE
	case FNFALSPRITE
	case AK114SPRITE
	case JPLASMASPRITE
	case LIZMANFGUNSPRITE
	case FLAMETHROWERSPRITE
	case MINISHRINKERSPRITE
	case PROTO_SHRINKER_SPRITE
	case BARRETTRIFLESPRITE
	case SMGSPRITE
	case BLOODSTAFFSPRITE
	case LIZMANGUNSPRITE
	case ZCHAINGUN_SPRITE
	case RAILGUN_SPRITE
	case AR65_SPRITE
	case HELL_NAILER_SPRITE
	case PIGCOPGUNSPRITE
	case SKULLDUSTERSPRITE
	case FLESHSQUIRTERSPRITE
	case STYGIANGUNSPRITE
	case SAWNOFFSPRITE
	case TOMMYGUNSPRITE
	case RIOTGUNSPRITE
	case CROSSBOWSPRITE
	case MIAGUNSPRITE
	case LASERGUNSPRITE
	case TMISSILELSPRITE
	case ENG_SMG_SPRITE
	case ROT_BOLT_SPRITE
	case RW_CROSSBOW_SPRITE
	case UDP45_SPRITE
	case GARAND_SPRITE
	case MG42_SPRITE
	case PHPLASMA_SPRITE
	case MOSSBERG_SPRITE
	// alt ammo types
	case SILVERAMMO_DRUM
	case FORTYMM_NADES
	case FORTYMM_CASELESS
	case FORTYMM_SLUGS
	case FORTYMM_ELECTRO
	case FORTYMM_CRYO
	case FORTYMM_SHELLS
	case EXPL_SHELLS
	case FLECHETE_SHELLS
	case TESLA_AMMO_SPRITE
	case SILVER_CROSSBOW_BOLTS
	case VOID_CROSSBOW_BOLTS
	case ORANGE_MANA_PICKUP
	case GREEN_MANA_PICKUP
	case BLUE_MANA_PICKUP
	case PURPLE_MANA_PICKUP
	case MICRO_TORPEDO_PACK
	case MAGNUM_SHELLS
	case DRAGONS_SHELLS
	case HEAT_SEEK_CARD_PICKUP
	case ATOMIC_BOMB_PICKUP
	case DUP_MISSILES_PICKUP
	case SILVERBALL_SHELLS
	// health items
	case HYPOSPRAY
	case HPOTION
	case HFLASK
	case HCUP
	case TWENTYKIT
	case HPOWDER
	case BRIMSTONE
	case 18424
	case 18682
	case 20158
	case 20159
	case TWENTYFIVEKIT
	case SIXPAK
	case COLA
	case GOLD_AMULET
	case COOKIE
	// pickups
	case MEGASPHERE
	case SWORD_RAMPAGE
	case INVINCIBILITY
	case SPIRIT_ARMOUR
	case FIRE_ARMOUR
	case SUPER_ARMOUR
	case BASIC_ARMOUR
	case REBREATHER
	case FIRESUIT
	case GASMASK
	case FLIPPER
	case O2CANISTER
	case HEAT_SINK_PACK
	case C4_EXPLOSIVE
	case ASTRIKE_MARKER
	case FIREWALL_CHIP
	case COG_PICKUP
	case TOOLBOX_PICKUP
	case 3636 // box of supplies
	case GENERICKEY
	case JANE_WINGSUIT
		 state GETITEM_SETTINGS
	 break
	case 12087 // SW sword planted
	 state GETLOTAG
	 break
	case 16011
	case 29684
	 state GETHITAGLOTAG
	 break
	case SHIELD
		ife sector[].lotag 32767
		ife VOLUME 0
		ife LEVEL 7
			cactor HEAVYARMOUR
		state GETITEM_SETTINGS
		break
	endswitch
endevent

defstate can_pickup_item
set actor_return 0
  ifmove RESPAWN_ACTOR_FLAG
	state respawnit
  else
	ifp pshrunk
	  set actor_return 0
	else
	  ifp palive
		ifcount 6
		  ifpdistl RETRIEVEDISTANCE // quote check OK
			  ifcanseetarget
				set actor_return 1
ends

include CODE/ACTORS/ITEMS/TEMPWEP.CON // Temp Weapons
include CODE/ACTORS/ITEMS/UNIQUES.CON // Unique items, unlocks .etc
include CODE/ACTORS/ITEMS/WEAPONS.CON // Weapons
include CODE/ACTORS/ITEMS/AMMO.CON // Ammo, speciality Ammo .etc


spriteshadow STEROIDS
actor STEROIDS
state ITEM_SETTINGS

  state can_pickup_item
  ife actor_return 1
	ifpinventory GET_STEROIDS 400
				  {
				  ife player[].steroids_amount 0
					  {
					  setp[].inven_icon 2
					  setp[].invdisptime 60
					  }
					
					set booster_amount STEROID_AMOUNT
					addinventory GET_STEROIDS STEROID_AMOUNT
					state blue_flash
					setarray picked_up_inven[2] 60
					state PICKUP_DISPLAY
					getav[PLAYER_IDENTITY].c_steroids picked_up_tile
					set item_amount 100

					// info quote depends on character

					switch CHAR
						case C_JAMES
							userquote 1741
							break
						case C_ZAXTOR
							userquote 1742
							break
						case C_MERLIJN
							userquote 1743
							break
						case C_HIGHWIRE
							userquote 1744
							break
						case C_SANG
						case C_CULTIST
							userquote 1745
							break
						case C_RUSTY
							userquote 1746
							break
						case C_GEOFFREY
							userquote 1747
							break
						case C_MIKKO
							userquote 1748
							break
						case C_BOMBSHELL
							userquote 1765
							break
						case C_MAARTEN
							userquote 1754
							break
						case C_JANE
							userquote 1762
							break
						case C_MICKY
							userquote 1749
							break
						case C_SNOWFALL
							userquote 1750
							break
						case C_ROSA 
							userquote 1769
							break
						case C_KAGURA
							userquote 1751
							break
						case C_WHEATON
							userquote 1748
							break
						default
							break
					endswitch


					ifspawnedby STEROIDS
					  state getcode
					else
					  state quikget
				  }
enda

spriteshadow BOOTS
actor BOOTS
state ITEM_SETTINGS

  state can_pickup_item
  ife actor_return 1
	{
		ife PERSONNEL_RESEARCH[26] 2 // protector drone acid topic?
		{
			ife CHAR 7 set temp 700
			else ife CHAR 11 set temp 500
			else ife CHAR 2 set temp 500
			else set temp 300
		}
		else
		{
			ife CHAR 7 set temp 600
			else ife CHAR 11 set temp 400
			else ife CHAR 2 set temp 400
			else set temp BOOT_AMOUNT
		}

		// stop here if we have more than max boot amount
		ifge player[].boot_amount temp
			break
		setp[].boot_amount temp
		state blue_flash
		setarray picked_up_inven[7] 60
		state PICKUP_DISPLAY
		getav[PLAYER_IDENTITY].c_boots picked_up_tile
		set item_amount -1
		setp[].invdisptime 60

		userquote 1704

		ifspawnedby BOOTS
			state getcode
		else
			state quikget
	  }
enda

spriteshadow HEATSENSOR
actor HEATSENSOR
state ITEM_SETTINGS

  state can_pickup_item
  ife actor_return 1
	  {
		  ife player[].heat_amount 0
			  {
			  setp[].inven_icon 5
			  setp[].invdisptime 60
			  }
		  addinventory GET_HEATS HEAT_AMOUNT
		  state blue_flash
		   setarray picked_up_inven[5] 60
		   state PICKUP_DISPLAY
		   getav[PLAYER_IDENTITY].c_nvg_normal picked_up_tile
		   set item_amount 100
			userquote 1706

			ifspawnedby HEATSENSOR
			  state getcode
			else
			  state quikget
	  }
enda

spriteshadow HEAVYARMOUR
useractor notenemy HEAVYARMOUR



state ITEM_SETTINGS
sizeat 24 24

  state can_pickup_item
  ife actor_return 1
	   ifl PARMOUR 200
		{
	    state PICKUP_DISPLAY
		getav[PLAYER_IDENTITY].c_heavy_armour picked_up_tile
		set item_amount 200
		state blue_flash
		set armour_type 1
		setp[].shield_amount 200
		userquote 1707
		ifspawnedby HEAVYARMOUR state getcode
		else state quikget
		}
enda

spriteshadow SHIELD
actor SHIELD
state ITEM_SETTINGS

  state can_pickup_item
  ife actor_return 1
	  ifl PARMOUR 100
		ife CHARSELECT 0
		{
		ife CHEST_LOADOUT[CHAR] 4 // Spirit armour
			{
			ifl PARMOUR 50
			setp[].shield_amount 50
			ifl P_SPIRIT_ARMOUR 75 set P_SPIRIT_ARMOUR 75
			state PICKUP_DISPLAY
			state blue_flash
			set armour_type 0
			getav[PLAYER_IDENTITY].c_armour picked_up_tile
			set item_amount 50
			state PICKUP_DISPLAY
			set picked_up_tile 117
			set item_amount 75
			}
		else
			{
			setp[].shield_amount 100
			state blue_flash
			state PICKUP_DISPLAY
			set armour_type 0
			getav[PLAYER_IDENTITY].c_armour picked_up_tile
			set item_amount 100
			}

		userquote 1708
		ifspawnedby SHIELD
		  state getcode
		else
		  state quikget
	  }
enda

spriteshadow AIRTANK
actor AIRTANK
state ITEM_SETTINGS

  state can_pickup_item
  ife actor_return 1
	ifpinventory GET_SCUBA SCUBA_AMOUNT
	  {
	  ife CHAR 0 addinventory GET_SCUBA 12800 else
		addinventory GET_SCUBA SCUBA_AMOUNT
		state blue_flash
				   setarray picked_up_inven[6] 60
				   state PICKUP_DISPLAY
				   getav[PLAYER_IDENTITY].c_scuba picked_up_tile
				   set item_amount 100

		userquote 1709
		ifspawnedby AIRTANK
		  state getcode
		else
		  state quikget
	  }
enda

spriteshadow HOLODUKE
actor HOLODUKE

ife CHAR 13
 ifspritepal 0
	{
	ife PERSONNEL_RESEARCH[2] 2 spritepal 16 else spritepal 3
	}
state ITEM_SETTINGS

  state can_pickup_item
  ife actor_return 1
	ifpinventory GET_HOLODUKE HOLOPLYR_AMOUNT
	  {
		  ife player[].holoduke_amount 0
			  {
			  setp[].inven_icon 3
			  setp[].invdisptime 60
			  }
		  ife CHAR 0 ifg player[].holoduke_amount 899 break
		  ife CHAR 4 ifg player[].holoduke_amount 599 break
		  ife CHAR 6 ifg player[].holoduke_amount 299 break
		  ife CHAR 9 ifg player[].holoduke_amount 599 break
	    ife CHAR 0 addinventory GET_HOLODUKE 900
		else
	    ife CHAR 4
			{
			ifspawnedby LOST addinventory GET_HOLODUKE 200
			else ifspawnedby SPIRIT addinventory GET_HOLODUKE 200
			else addinventory GET_HOLODUKE 600
			}
		else
	    ife CHAR 6 addinventory GET_HOLODUKE 300
		else
	    ife CHAR 9 addinventory GET_HOLODUKE 600
		else
		addinventory GET_HOLODUKE HOLOPLYR_AMOUNT
		state blue_flash
		getp[].holoduke_amount holoduke_amount
		setarray picked_up_inven[3] 60
		state PICKUP_DISPLAY
		getav[PLAYER_IDENTITY].c_holoduke picked_up_tile
		ife CHAR 2 set item_amount -1 // Merlijn's shield
		else ife CHAR 3 set item_amount 2 // Highwire's radio
		else ife CHAR 5 set item_amount 3 // Rusty's belt
		else ife CHAR 7 set item_amount -1 // Mikko's backpack
		else ife CHAR 13 set item_amount -1 // Micky's turret
		else set item_amount 100
		// info quote depends on character

		switch CHAR
			case C_JAMES
				userquote 1752
				break
			case C_ZAXTOR
				userquote 1753
				break
			case C_MERLIJN
				userquote 1754
				break
			case C_HIGHWIRE
				userquote 1755
				break
			case C_SANG
				userquote 1756
				break
			case C_RUSTY
				userquote 1757
				break
			case C_GEOFFREY
				userquote 1758
				break
			case C_MIKKO
				userquote 1759
				break
			case C_CULTIST
				userquote 1756
				break
			case C_BOMBSHELL
			userquote 1760
				break
			case C_MAARTEN
			userquote 1764
				break
			case C_JANE
			userquote 1766
				break
			case C_MICKY
				userquote 1760
				break
			case C_SNOWFALL
				userquote 1761
				break
			case C_ROSA 
				userquote 1768
				break
			case C_KAGURA
				userquote 1767
				break
			case C_WHEATON
				userquote 1755
				break
			default
				break
		endswitch

		ifspawnedby HOLODUKE
		  state getcode
		else
		  state quikget
	  }

enda

spriteshadow JETPACK
actor JETPACK
state ITEM_SETTINGS

  state can_pickup_item
  ife actor_return 1
	ifpinventory GET_JETPACK JETPACK_AMOUNT
	  {
		  ife player[].jetpack_amount 0
			  {
			  setp[].inven_icon 4
			  setp[].invdisptime 60
			  }
	  ife PERSONNEL_RESEARCH[28] 2
			{
			ife CHAR 14 addinventory GET_JETPACK 4000
			else addinventory GET_JETPACK 2400
			}
		else
			{
			ife CHAR 14 addinventory GET_JETPACK 3200
			else addinventory GET_JETPACK JETPACK_AMOUNT
			}

		setarray picked_up_inven[4] 60
		state blue_flash
		state PICKUP_DISPLAY
		getav[PLAYER_IDENTITY].c_jetpack picked_up_tile
		userquote 88
		set item_amount 100

		ifspawnedby JETPACK
		  state getcode
		else
		  state quikget
	  }
enda

spriteshadow JANE_WINGSUIT
useractor notenemy JANE_WINGSUIT
sizeat 32 32
state ITEM_SETTINGS

state can_pickup_item
  ife actor_return 1
	ife CHAR 12
	  {
	    set jane_wings 1
		setp[].jetpack_amount 1600
		setarray picked_up_inven[4] 60
		state blue_flash
		state PICKUP_DISPLAY
		set picked_up_tile JANE_WINGSUIT
		userquote 88
		set item_amount 100
		setp[].invdisptime 60

		state quikget
	  }
enda

defstate display_key
	state getfactornormalizedframerate
	set DISP_KEY -150
	mul DISP_KEY NORMALIZED_FACTOR
	set DISP_KEY_PIC sprite[].picnum
	set DISP_KEY_PAL sprite[].pal
	
	state PICKUP_DISPLAY
	set picked_up_tile sprite[].picnum
	set item_amount -1			
	state white_flash
ends

spriteshadow KEY_CARD
useractor notenemy KEY_CARD
sizeat 28 28
state ITEM_SETTINGS

  state can_pickup_item
  ife actor_return 1
	  {
		switch sprite[].pal
		case 0
		case 21
		case 23
			 ifpinventory GET_ACCESS 0 break
			ifspritepal 0 userquote 20000
			ifspritepal 21 userquote 20001
			ifspritepal 23 userquote 20002
			addinventory GET_ACCESS 1
			break
		endswitch

		ifspritepal 12 { ifand ACCESSKEY2 1 break add ACCESSKEY2 1 userquote 20003 } else
		ifspritepal 11 { ifand ACCESSKEY2 2 break add ACCESSKEY2 2 userquote 20004 } else
		ifspritepal 15 { ifand ACCESSKEY2 4 break add ACCESSKEY2 4 userquote 20005 } else
		ifspritepal 49 { ifand ACCESSKEY2 8 break add ACCESSKEY2 8 userquote 20006 } else
		ifspritepal 10 { ifand ACCESSKEY2 16 break add ACCESSKEY2 16 userquote 20007 } else
		ifspritepal 36 { ifand ACCESSKEY2 32 break add ACCESSKEY2 32 userquote 20008 } else
		ifspritepal 16 { ifand ACCESSKEY2 64 break add ACCESSKEY2 64 userquote 20009 }

		state display_key

		ifmultiplayer
			ife COOP 1
				{
				state RADIO_KEY_SOUNDS
				qgetsysstr 356 STR_PLAYERNAME
				qstrcat 356 663
				userquote 356
				}

		state getcode
	  }
enda


useractor notenemy ACCESSCARD2
enda

spriteshadow 17031
useractor notenemy 17031 // Floppy disk
sizeat 14 14

  state can_pickup_item
  ife actor_return 1
	  {
		ifspritepal 0 { ifand FLOPPY_DISK 1 break add FLOPPY_DISK 1 userquote 20010 }
		ifspritepal 11 { ifand FLOPPY_DISK 2 break add FLOPPY_DISK 2 userquote 20011 }
		ifspritepal 21 { ifand FLOPPY_DISK 4 break add FLOPPY_DISK 4 userquote 20012 }
		ifspritepal 23 { ifand FLOPPY_DISK 8 break add FLOPPY_DISK 8 userquote 20013 }

		state display_key

		ifmultiplayer
			ife COOP 1
				{
				state RADIO_KEY_SOUNDS
				qgetsysstr 356 STR_PLAYERNAME
				qstrcat 356 663
				userquote 356
				}

		state getcode
	  }
enda

spriteshadow 25499
useractor notenemy 25499 // sextant
sizeat 24 24
ifrnd 1 spawn GLINT

  state can_pickup_item
  ife actor_return 1
	  {
		ifand WORLD_TRIGGER 32 break 
		userquote 20014
		xorvar WORLD_TRIGGER 32
		state display_key
		state getcode
	  }
enda

spriteshadow 16219
useractor notenemy 16219 // mystic Ashes
sizeat 24 24
ifrnd 1 spawn GLINT

  state can_pickup_item
  ife actor_return 1
	  {
		ifand WORLD_TRIGGER 64 break 
		xorvar WORLD_TRIGGER 64
		ife CHAR 17
			{
			screensound KG_ASHES
			ife gp_subt 0
				{
				set subt_id 13020
				set gp_subt 95
				}
			}
		userquote 20015
		state white_flash
		state display_key
		state getcode
	  }
enda

spriteshadow 3349
useractor notenemy 3349 // organ sheet music
sizeat 16 16
ifrnd 1 spawn GLINT

  state can_pickup_item
  ife actor_return 1
	  {
	    ifand WORLD_TRIGGER 128 break 
		xorvar WORLD_TRIGGER 128
		userquote 20016
		state white_flash
		state display_key
		state getcode
	  }
enda

spriteshadow SW_OLDKEY
useractor notenemy SW_OLDKEY

ifspritepal 23 spritepal 83
sizeat 32 32

  state can_pickup_item
  ife actor_return 1
	  {
		ifspritepal 15 { ifand SW_KEYS 16 break xorvar SW_KEYS 16 userquote 20017 } 
		ifspritepal 12 { ifand SW_KEYS 32 break xorvar SW_KEYS 32 userquote 20018 } 
		ifspritepal 83 { ifand SW_KEYS 64 break xorvar SW_KEYS 64 userquote 20019 } 
		ifspritepal 10 { ifand SW_KEYS 128 break xorvar SW_KEYS 128 userquote 20020 }

		state display_key

		ifmultiplayer
			ife COOP 1
				{
				state RADIO_KEY_SOUNDS
				qgetsysstr 356 STR_PLAYERNAME
				qstrcat 356 663
				userquote 356
				}

		state getcode
	  }
enda

spriteshadow SW_TECHCARD
useractor notenemy SW_TECHCARD

  ifspritepal 3
  {
	 changespritestat THISACTOR 0
	 break
  }
sizeat 28 28

  state can_pickup_item
  ife actor_return 1
	  {
		ifspritepal 0 { ifand SW_KEYS 1 break add SW_KEYS 1 userquote 20021 } 
		ifspritepal 10 { ifand SW_KEYS 2 break add SW_KEYS 2 userquote 20022 } 
		ifspritepal 11 { ifand SW_KEYS 4 break add SW_KEYS 4 userquote 20023 } 
		ifspritepal 23 { ifand SW_KEYS 8 break add SW_KEYS 8 userquote 20024 }

		state display_key

		ifmultiplayer
			ife COOP 1
				{
				state RADIO_KEY_SOUNDS
				qgetsysstr 356 STR_PLAYERNAME
				qstrcat 356 663
				userquote 356
				}

		state getcode
	  }
enda

spriteshadow BLUEPLUG
useractor notenemy BLUEPLUG

  ifspritepal 3
  {
	 changespritestat THISACTOR 0
	 break
  }
sizeat 28 28

