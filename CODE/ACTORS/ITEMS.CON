spriteshadow 21232
useractor notenemy 21232 // Chryssalid virus pickup/use actor

ifaction 0
{
ife hitag_saved 1 cstat 32768
action FORM
}

ife hitag_saved 1
	{
		ifp palive
	     ifpdistl 2048
		  {
		  state pickup_prompt
		   ifhitspace
		      {
			  sound PUT_ON_EQUIP
			 ifaction ZERO break
			 ifn lotag_saved 0
					{
					operateactivators lotag_saved THISACTOR
					operaterespawns lotag_saved
					operatemasterswitches lotag_saved
					}
			   cstat 0
			   action ZERO
			   }
		  }

	}
else
	{
		ifp pshrunk nullop
		else
		  ifp palive
			ifpdistl 1024
		  {
			  ifn lotag_saved 0
					{
					operateactivators lotag_saved THISACTOR
					operaterespawns lotag_saved
					operatemasterswitches lotag_saved
					}
				string 20060
				state display_key
				state getcode
		  }
	}
enda

