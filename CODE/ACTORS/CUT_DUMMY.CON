{
ifcount 26
	{
	action HIGH_CROUCH
	resetcount
	}
}

ifaction HIGH_CROUCH
{
checkactivatormotion lotag_saved
ife RETURN 1
	{
	action HIGH_ROLL
	move HIGHROLL geth
	soundonce P_ROLL
	}
}

ifaction HIGH_ROLL
{
ifactioncount 4 move STOP
ifactioncount 6
	{
	move STOP
	action HIGH_RCROUCH
	set temp9 0
	}
}

ifaction HIGH_RCROUCH
{


ifactioncount 4
	{
	ifg slot1_mag 0
		{
		move STOP
		action HIGH_SHOOT
		ife SPECIALIST_EQUIPMENT[106] 2 globalsound SURV_FIR
		else ife SPECIALIST_EQUIPMENT[10] 2 globalsound KASHTAN_FIRE
		else ife SPECIALIST_EQUIPMENT[39] 2 globalsound SKORP_FIRE
		else ife SPECIALIST_EQUIPMENT[32] 2 globalsound AUTOMAG_FIRE
		else globalsound TOKAROVFIRE
		set gunsmoke_angle -512
		shoot FAKE_BULLET
		state spawn_gunsmoke
		flash
		state npc_pistolshell
		sub slot1_mag 1
		add temp9 1
		resetactioncount
		}
	else
	ife slot1_mag 0
		{
		move STOP
		globalsound DRY_FIRE
		globalsound ROHSHIT
		action HIGH_CROUCH
		resetactioncount
		}

	}
}

ifaction HIGH_SHOOT
{
ifactioncount 2 { ifg temp9 2 action HIGH_CROUCH else action HIGH_RCROUCH resetactioncount }
}

