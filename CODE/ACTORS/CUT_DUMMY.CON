	{
	ifrnd 1 soundonce MOUSE_CLICK_ON
	ifcount 90 { ifrnd 8 soundonce MASH else soundonce TYPING_SOUND resetcount }
	}
ifspritepal 3
	{
	ife CHAR 0 ife CHARSELECT 0 { cactor 21559 sizeat 28 28 } // spawn empty chair if playing as James
