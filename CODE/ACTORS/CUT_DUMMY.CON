	{
	ifactorsound THISACTOR PINBALL nullop else
		{
		ifrnd 64 sound BS_DAMN1
		else ifrnd 128 sound BS_DAMN2
		ifrnd 192 sound BS_YESS
		else sound BS_GOTWEP5
		move 0
