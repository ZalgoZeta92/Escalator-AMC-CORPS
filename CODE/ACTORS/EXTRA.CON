		ifg temp 4
			{
			setp[].sound_pitch 0
			ife CHAR 12 soundonce SPACESUIT_OFF
			ife CHAR 13 soundonce SPACESUIT_OFF
			ife CHAR 14 soundonce SPACESUIT_OFF
			ife SPACE_SUIT 1 soundonce SPACESUIT_OFF
			set inspace 0
			set temp 0
