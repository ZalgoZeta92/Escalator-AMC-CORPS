// *************************************************
// TRIGGER STUFF
// ACTIVATE STUFF IF INVENTORY INVEN ACTIVE
// ACTIVATE IF NEAR
// Set hitag to -1 to activate regardless of player position (use to rig effects together I guess)
// *************************************************

spritenopal 3347
useractor notenemy 3347
cstat 32768
sleeptime 0
ife hitag_saved 0
	set hitag_saved 1024

ifn xvel_saved 0
{
	action ZERO

	checkactivatormotion xvel_saved
	set MASTERSWITCH_SUBSCRIBE xvel_saved

	ife RETURN 1 { action 0 set xvel_saved 0 }
	else ife MASTERSWITCH_RETURN 1
	{
		action 0
		set xvel_saved 0
		set MASTERSWITCH_RETURN 0
	}
}

ifaction 0
{
	ife hitag_saved -1
	{
		set temp 1
	}
	else
	ifspritepal 60
	{
		ifcansee ifcanseetarget { spritepal 0 set temp 1 }
	}
	else
	ifspritepal 6
	{
	ife CHARSELECT 1 nullop else ifpdistl 1024 set temp 1
	}
	else
	ife sprite[].ang 512
	{
	ife sprite[].sectnum player[].cursectnum // same sector
	 ifg player[].posz sprite[].z // player is lower than the actor?
	  set temp 1
	}
	else
	{
		dist temp6 THISACTOR player[].i

		ifl temp6 hitag_saved
			set temp 1
			else set temp 0
	}

	// either no distance check needed, or player is closer than given distance
	ife temp 1
	{
		ifg extra_saved 0
			screensound extra_saved


		ifspritepal 0 set actor_return 1
		ifspritepal 100  ife player_in_vehicle 0 set actor_return 1
		ifspritepal 1 { ifg GOT_EXPLOSIVE 0 set actor_return 1 }
		ifspritepal 2 { ifg GAS_MASK 0 set actor_return 1 }
		ifspritepal 3 { ifg TOOLBOX 0 set actor_return 1 }
		ifspritepal 4 { ifg JUMP_BOOTS 0 set actor_return 1 }
		ifspritepal 6 set actor_return 1
		ifspritepal 7 { ifcansee ifp pfacing set actor_return 1 }
		ifspritepal 8 { ifn player_using_mech -1 set actor_return 1 }
		ifspritepal 11 { ifn player_using_hovercraft -1 set actor_return 1 }
		ifspritepal 10 { ife temple_key 4 set actor_return 1 ifand temple_key 1 set actor_return 1 }
		ifspritepal 15 { ifand OLDKEYS 1 set actor_return 1 }
		ifspritepal 23 { ifand player[].got_access 23 set actor_return 1 }
		ife actor_return 1
		{
		operateactivators lotag_saved THISACTOR
		operaterespawns lotag_saved
		operatemasterswitches lotag_saved
		killit
		}
	}
}

