{
	ifcansee
	ifcanseetarget
	 ifpdistl 2048
	 ife inspace 0
		{
		add temp 1
		ifg temp 4
			{
			ife CHAR 12 soundonce SPACESUIT_ON
			ife CHAR 13 soundonce SPACESUIT_ON
			ife CHAR 14 soundonce SPACESUIT_ON
			ife SPACE_SUIT 1 soundonce SPACESUIT_ON
			set inspace 1
			set temp 0
			}
		}
}
