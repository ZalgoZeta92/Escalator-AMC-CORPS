action OPEN_SECOND 2


useractor notenemy ENVIRO_SUIT_SWITCH

ifpdistl 1548
 ifp palive
  ifp pfacing
   ifcansee
   {
	state use_prompt
	ife use_action_allowed 1
	{
	  set hit_key 30
	  stopsound PLYR_SEARCH
	  stopsound PLYR_SEARCH2
		ifaction 0 // Close the outer door
			{
			ife FIRE_SUIT 1 break
			sound M_SWITCH
			operateactivators lotag_saved THISACTOR
			operaterespawns lotag_saved
			operatemasterswitches lotag_saved
			action OPEN_FIRST
			}
			else
		ifaction OPEN_FIRST // Open the inner door
			{
			ife FIRE_SUIT 0 // if the player is out of enviro-suit, open outer door
				{
				sound M_SWITCH
				operateactivators lotag_saved THISACTOR
				operaterespawns lotag_saved
				operatemasterswitches lotag_saved
				action 0
				}
				else // open inner door
				{
				action OPEN_SECOND
				sound IW_SWITCH
				operateactivators hitag_saved THISACTOR
				operaterespawns hitag_saved
				operatemasterswitches hitag_saved
				}
			}
			else
		ifaction OPEN_SECOND
			{
			action OPEN_FIRST
			sound IW_SWITCH
			operateactivators hitag_saved THISACTOR
			operaterespawns hitag_saved
			operatemasterswitches hitag_saved
			}
		state setIgnoreUse
	  }
	}
enda

