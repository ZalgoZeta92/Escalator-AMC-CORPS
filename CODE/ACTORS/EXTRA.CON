	else ifspritepal 21 xorvar ABYSS_KEYS 2
	else ifspritepal 23 xorvar ABYSS_KEYS 4
	else ifspritepal 11 xorvar ABYSS_KEYS 8
	else ifspritepal 49 xorvar ABYSS_KEYS 16
	resetcount
	}
}
ends

