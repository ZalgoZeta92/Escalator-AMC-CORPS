			set weather_type 1
			set rainstart -8
			set raining -8
			set rainradius 12000
			set snowceiling 65536
			set ceiltext -1
			}
			else
		ife temp2 1 // Feburary?
			{
			set RAINREPLACE 0
			set weather_type 1
			set rainstart -8
			set raining -8
			set rainradius 12000
			set snowceiling 65536
			set ceiltext -1
