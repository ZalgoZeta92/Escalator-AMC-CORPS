	ifinwater { action BIG_FIREDIE move STOP }
	ifonwater { action BIG_FIREDIE move STOP }
	ifhitweapon ifdead { action BIG_FIREDIE move STOP }
	}

ifaction BEYT_FIRERUN
	{
	add INTERNALCOUNT 1
	ifpdistl 16384 soundonce FIRE_CRACKLE
	ifrnd 8 { shoot SPARK espawn BIG_SMOKE geta[RETURN].z temp sub temp 8096 seta[RETURN].z temp seta[RETURN].pal 17 }
	ifg INTERNALCOUNT 130
	 ifrnd 32
		{
		ifrnd 128 spawn BURNING else spawn BURNING2
		ifrnd 128 cstat 4 else cstat 0
		action BEYT_FIREBOD
		move STOP
		}
	 ifrnd 8 { move ASSONFIRE geth randomangle }
	 ifnotmoving { move ASSONFIRE geth randomangle }
	ifinwater { action BEYT_FIREBOD spawn BURNING2 move STOP }
	ifonwater { action BEYT_FIREBOD spawn BURNING2 move STOP }
	ifhitweapon ifdead { action BEYT_FIREBOD spawn BURNING2 spawn BIG_SMOKE move STOP }
	}

ifaction BURN_OUT
ifactioncount 4
	{
	ifrnd 128
	cstat 4
	else
	cstat 0
	spriteflags 1
	seta[].pal sector[].floorpal
	seta[].shade sector[].floorshade
	action BURNED_OUT
	move STOP
	}

ifaction ZOMB_FIREDIE ifactioncount 4 { shoot SPARK shoot SPARK shoot SPARK shoot SPARK action ZOMB_FIREBOD move STOP }
ifaction FIREDIE ifactioncount 5 { shoot SPARK shoot SPARK shoot SPARK shoot SPARK action FIREBOD move STOP }
ifaction LIZ_FIREDIE ifactioncount 5 { shoot SPARK shoot SPARK shoot SPARK shoot SPARK action LIZ_FIREBOD move STOP }
ifaction PIG_FIREDIE ifactioncount 5 { shoot SPARK shoot SPARK shoot SPARK shoot SPARK action PIG_FIREBOD move STOP }
ifaction BIG_FIREDIE ifactioncount 5 { shoot SPARK shoot SPARK shoot SPARK shoot SPARK action BIG_FIREBOD move STOP }

ifaction ZOMB_FIREBOD { move STOP cstat 0 ifcansee nullop else action BURN_OUT }
ifaction LIZ_FIREBOD { move STOP cstat 0 ifcansee nullop else action BURN_OUT }
ifaction PIG_FIREBOD { move STOP cstat 0 ifcansee nullop else action BURN_OUT }
ifaction BIG_FIREBOD { move STOP cstat 0 ifcansee nullop else action BURN_OUT }
ifaction FIREBOD { move STOP cstat 0 ifcansee nullop else action BURN_OUT }


