// *************************************************
// VR STATION POD => hitag value = Requires firewall chip in place before being able to use. The value must match the hitag of the firewall slot
// *************************************************

action P_NEAR -5557
action P_ENEAR -5570

useractor notenemy VR_BOOTH

	ifaction 0
	{
		seta[].blend 255
		set temp 0
		for temp sprofstat 1
		{
			  ife sprite[temp].picnum DOORTRANSPORTEXIT
			{
				getav[temp].hitag_saved temp3
				ife lotag_saved temp3
				{
					geta[temp].x ENDPOINTX
					geta[temp].y ENDPOINTY
					geta[temp].z ENDPOINTZ
					geta[temp].ang temp7
					set temp 16383
				}
			}
		}
		action ZERO
	}

	ifpdistl 2048
	  ifcansee
	  ifp palive
	   ifp pfacing
	  ifaction ZERO
	{
		ife CHAR 6 { sound RED_COMPBEEP ifspritepal 2 action P_ENEAR else action P_NEAR }
		ife CHAR 7 { sound RED_COMPBEEP ifspritepal 2 action P_ENEAR else action P_NEAR }
	}

	ifaction P_NEAR
	{
		ifpdistl 1024
		  ifcansee
		  ifp pfacing
		  ifp palive
		{
			switch CHAR
				case 6
				case 7
				case 16
					set pprompt_icon 2119
					set player_use 0
					ife use_action_allowed 1
					{
						state setIgnoreUse

						set temp 0
						set hit_key 30

						ifn hitag_saved 0
						{
							ife FIREWALL_ID hitag_saved
								set temp 1
							else
							{
								set door_locked 0
								set key_icon FIREWALL_CHIP
								set key_pal 0
								set temp 0
							}
						}
						else
							set temp 1

						ife temp 1
						{
							ifspritepal 0
							{
								globalsound ENTER_VR
								set CONTROL_VR APLAYER
								set VR_ACTION_POINTS 10
							}
							else ifspritepal 3
							{
								globalsound ENTER_VR
								set CONTROL_VR APLAYER
								set VR_ACTION_POINTS 10
							}
							state fade_in_white
							set vr_goggles_anim 26
							sound PUT_ON_EQUIP
							action ONE
						}
					}
					break
				default
					break
			endswitch
		}
		else ifpdistg 2048
			action ZERO
	}

	ifaction P_ENEAR
	{
		ifpdistl 1024
		  ifcansee
		  ifp pfacing
		  ifp palive
		{
			switch CHAR
				case 6
				case 7
				case 16
					set pprompt_icon 2119
					set player_use 0
					ife use_action_allowed 1
					{
						state setIgnoreUse

						set hit_key 30
						set screen_pal_override 10
						set VR_ACTION_POINTS 0
						set cus_fadew 0
						set cus_fade_duration 5
						sound EQUIPMENT_OFF
						set cus_fadetics 1
						globalsound EXIT_VR
						set CONTROL_VR -1
						seta[temp9].xrepeat 0
						ifn extra_saved -1
						{
							operateactivators extra_saved THISACTOR
							operaterespawns extra_saved
							operatemasterswitches extra_saved
						}
						action FORM
					}
					break
				default
					break
			endswitch
		}
		else
		ifpdistg 2048 action ZERO
	}

	ifaction ONE // entering
	{
		add INTERNALCOUNT 1
		geta[].sectnum upd_sect
		updatesectorz ENDPOINTX ENDPOINTY ENDPOINTZ upd_sect
		 ifn upd_sect -1
		  ifg INTERNALCOUNT 26
		{
			 ifmultiplayer nullop
			 else // spawn player duplicate for cameras .etc
				 {
				 espawn DUMMY_PLAYER
				 setactorvar[RETURN].extra_saved CHAR
				 state SPAWN_IN_FRONT
				 setactorvar[RETURN].temp9 CONTROL_VR
				 }
			setp[].cursectnum upd_sect
			setp[].posx ENDPOINTX
			setp[].posy ENDPOINTY
			setp[].posz ENDPOINTZ
			setp[].ang temp7
			set INTERNALCOUNT 0
			ifspritepal 3 killit
			action ZERO
		}
		else
		 ife upd_sect -1
		{
			quote 513
			killit
		}
	}

	ifaction FORM // exit
	{
		set vr_goggles_anim -26
		geta[].sectnum upd_sect
		updatesectorz ENDPOINTX ENDPOINTY ENDPOINTZ upd_sect
		 ifn upd_sect -1
		{
			setp[].cursectnum upd_sect
			setp[].posx ENDPOINTX
			setp[].posy ENDPOINTY
			setp[].posz ENDPOINTZ
			setp[].ang temp7
			set INTERNALCOUNT 0
			ifspritepal 3 killit
			action ZERO
		}
		else
		 ife upd_sect -1
		{
			quote 513
			killit
		}
	}

enda

useractor notenemy VR_SWITCH

ifaction 0
{
seta[].blend 255
cstator 273
action ZERO
}

ifaction ZERO
{
ifspritepal 36 // If it's a virus door
			{
			ife HACK_UNLOCK hitag_saved
				{
				action UNLOCKED
				soundonce VR_HACK
				cstat 18
				resetcount
				set HACK_UNLOCK -1
				}
			}
else
ifspritepal 49 // If it's a download door
			{
			ife HACK_UNLOCK hitag_saved
				{
				action UNLOCKED
				soundonce VR_HACK
				cstat 18
				resetcount
				set HACK_UNLOCK -1
				}
			}
else
ifpdistl 1024
 ifp pfacing
  ifp palive
	ifcansee
	{
	state use_prompt
	 ife use_action_allowed 1
		{
		set hit_key 30
		ifspritepal 0 // If it's blue, it's a free door
			{
			action ONE
			soundonce VR_HACK
			cstat 18
			}
		else ifspritepal 11 // If it's green, it needs one point
			{
			ifg VR_ACTION_POINTS 0
				{
				action ONE
				soundonce VR_HACK
				cstat 18
				sub VR_ACTION_POINTS 1
				}
			else
				{
				soundonce VR_FAIL
				}
			}
		else ifspritepal 23 // If it's yellow, it needs two points
			{
			ifg VR_ACTION_POINTS 1
				{
				action ONE
				soundonce VR_HACK
				cstat 18
				sub VR_ACTION_POINTS 2
				}
			else
				{
				soundonce VR_FAIL
				}
			}
		else ifspritepal 21 // If it's red, it needs three points
			{
			ifg VR_ACTION_POINTS 2
				{
				action ONE
				soundonce VR_HACK
				cstat 18
				sub VR_ACTION_POINTS 3
				}
			else
				{
				soundonce VR_FAIL
				}
			}
		else ifspritepal 13 // If it's black, it's free but can short out and subtract points
			{
			ifrnd 128
				{
				action UNLOCKED
				soundonce VR_HACK
				cstat 18
				}
			else
				{
				sub VR_ACTION_POINTS 4
				ifl VR_ACTION_POINTS 0 set VR_ACTION_POINTS 0
				wackplayer
				soundonce THUNDERBALL_HIT
				palfrom 40 0 0 40
				soundonce VR_FAIL
				action UNLOCKED
				cstat 18
				}
			}
		state setIgnoreUse
		}
	}
}

ifaction ONE
{
ife CONTROL_VR -1
	{
	seta[].cstat cstat_saved
	action ZERO
	}
}

