	 ifand sector[].ceilingstat 8192 nullop else { espawn TARGETFX setav[RETURN].is_flammable 1 }
	 ifspritepal 3 nullop
	 else
		 {
		  ifrnd 128
			cstat 5
		  else
			cstat 1
		randvar g_temp 32
		ifactor 23543 add g_temp 128 else
		add g_temp sprite[].xrepeat
		seta[].xrepeat g_temp
		seta[].yrepeat g_temp
		}
	action ZERO
	}

ifaction ZERO
	{
	switch sprite[].picnum // exception list for trees to not spawn leafs
		case 9223
		case 9224
		case 4718
		case 4720
		case 4722
		case 5675
		case 5835
		case 7944
		case 8670
