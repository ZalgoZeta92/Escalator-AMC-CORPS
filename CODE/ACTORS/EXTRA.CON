// *************************************************
// Kiros works on somethings like this.
// There should multiple actors (picnum) in one if/else code
// This makes it more easier to manage similar lore objects.
// *************************************************

// Wooden Barrier with many varieties.

defstate Woodfencestate
ifaction 0
{
cstator 257
action ZERO
}

ifhitweapon
{
	shoot WOODSCRAP
ifdead
	{
		shoot WOODSCRAP
		shoot WOODSCRAP
		shoot WOODSCRAP
		shoot WOODSCRAP
		shoot WOODSCRAP
		shoot WOODSCRAP
		sound WOOD_DEBRIS
	killit
	}
}
else
ifpdistl 2560
ife player_in_vehicle 1
{
		shoot WOODSCRAP
		shoot WOODSCRAP
		shoot WOODSCRAP
		shoot WOODSCRAP
		shoot WOODSCRAP
		shoot WOODSCRAP
		sound WOOD_DEBRIS
	killit
	}

ends

