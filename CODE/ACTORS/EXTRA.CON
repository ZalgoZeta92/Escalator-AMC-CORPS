spriteshadow 33646

action ROBO_WALK 5 4 5 1 16
action ROBOM_GETD 25 1 5
action ROBOM_CLEAN 30 2 5 1 24
action ROBOM_UP 25 1 5

move ROBOM_WALK 48 0

useractor notenemy 33646
fall
ifaction 0
	{

	ifrnd 32 spritepal 21
	else ifrnd 32 spritepal 11
	else ifrnd 32 spritepal 49
	else ifrnd 32 spritepal 15
	else ifrnd 32 spritepal 10
	else spritepal 0
	ifand BASE_COSMETICS 64 action FIVE_ANG else killit
	}

ifaction FIVE_ANG
{
move STOP
ifrnd 96 { move ROBOM_WALK randomangle action ROBO_WALK }
}
else
ifaction ROBO_WALK
{
move ROBOM_WALK geth
ifnotmoving { move ROBOM_WALK randomangle geth }
else ifrnd 4 { action ROBOM_GETD resetactioncount }
}
else
ifaction ROBOM_GETD
{
move STOP
ifactioncount 2 action ROBOM_CLEAN
}
else
ifaction ROBOM_CLEAN
{
move STOP
ifrnd 8 { move ROBOM_WALK randomangle action ROBOM_UP resetactioncount }
}
else
ifaction ROBOM_UP
{
move STOP
ifactioncount 2 action ROBO_WALK
}
