spritenoshade 30139
spritenopal 30139

action PLAYER_DSTAR 34

useractor notenemy 30139

	sizeat 8 8
	seta[].shade -127
	seta[].blend 255
	cstat 514
	// pivot
	geta[myowner].x x
	geta[myowner].y y
	geta[myowner].z z
	ifspawnedby APLAYER { action PLAYER_DSTAR set dazed_count p_dazed_count spritepal 32 } else
	{ getav[myowner].dazed_count dazed_count spritepal 7 }

	// me
	set temp2 x
	ifspawnedby MONGUR add temp2 1024 else
	add temp2 512

	rotatepoint x y temp2 y temp4 mx my

	add temp4 32

	ifg temp4 2048
		sub temp4 2048

	seta[].x mx
	seta[].y my
	ifspawnedby MONGUR sub z 32768
	else ifspawnedby APLAYER sub z 8192
	else sub z 16384
