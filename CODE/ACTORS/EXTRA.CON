// *************************************************

// 1 = Elder Key
// 2 = Spider Key
// 4 = Eagle Key
// 8 = Moon key
// 16 = Skull key
// 32 = Eye Key

action PADLOCKUN 0 7 1 1 10
action PADLOCKUNL 6

defstate old_key_locks
		ife hitag_saved 0 // Generic Key
			{
			ifg GENERIC_KEYS 0
				{
				ifactor OLDLOCK action UNLOCKING else
				{ stopsound OLDKEY_LOCKED globalsound OLDKEY_UNLOCK userquote 8 action PADLOCKUN }
				qsprintf KEY_INSERT KEY_INSERT2 20066
				userquote KEY_INSERT
				}
				else
				{
				set PLAYER_VOICEOVER 3 set door_locked 0 set key_icon GENERICKEY
				qsprintf KEY_NEED_Q KEY_NEED_Q2 20066
				userquote KEY_NEED_Q
				}
			}
		else
		ifand hitag_saved 1 // Flame Key
			{
			ifand OLDKEYS 1
				{
