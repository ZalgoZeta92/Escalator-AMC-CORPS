// *************************************************

useractor notenemy 3638 // lockpick icon

switch CHAR
	case 3
	case 12
	case 18
	 ifpdistl 8192
	  ife lock_picking 0
		{
		cstat 146
		seta[].blend 255
		geta[].xrepeat temp
		add temp 1 ifg temp 24 set temp 18
		seta[].xrepeat temp
		seta[].yrepeat temp
		}
	else
		cstat 32768
	break
	default
		cstat 32768
	break
	endswitch

checkactivatormotion lotag_saved
ife RETURN 1 killit
checkactivatormotion hitag_saved
ife RETURN 1 killit

enda

defstate locked_door_sounds
ifspritepal 0 sound LOCKED_DOOR1 else
ifspritepal 1 sound LOCKED_GATE1 else
ifspritepal 2 sound LOCKED_DOOR2 else
ifspritepal 3 sound LOCKED_HITECH1 else
ifspritepal 4 sound LOCKED_DOOR3 else
ifspritepal 5 sound LOCKED_DOOR4 else
ifspritepal 6 sound LOCKED_HITECH2 else
ifspritepal 7 sound LOCKED_GATE2 else
ifspritepal 8 sound LOCKED_HITECH3 else
ifspritepal 20 { sound LOCKED_DOOR2 set INTERNALCOUNT 20 }
ends

action LOCK_DOOR_A -9

useractor notenemy 3744
cstator 1

	ifaction 0 action LOCK_DOOR_A

	ifn xvel_saved 0
	{
		sleeptime 0
		checkactivatormotion xvel_saved
		ife RETURN 1 killit
	}

ifn owner_saved 0
 ife lock_id THISACTOR
	{
	ife use_action_allowed 1
		{
		set lock_temp lock_picking
		sub lock_temp lock_angle
		ifg lock_temp -44
		 ifl lock_temp 44
			{
			set PLAYER_VOICEOVER 50
			sound OLDKEY_UNLOCK
			sound CHAINSNAP
			set lock_picking -1
			}
		else
			{
			set lock_picking 0
			set lock_id -1
			}
		state setIgnoreUse
		}
	else
	  ife lock_picking -1
		{
		operateactivators owner_saved THISACTOR
		set lock_picking -1
		killit
		}
	}

ifpdistl 1024
 ifp pfacing
  ifp palive
  {
  ifn hitag_saved 0
	  {
	  ifg GENERIC_KEYS 0 state unlock_door_prompt else
	  ifg owner_saved 0
		{
		 ife CHAR 3 state unlock_door_prompt else
		  ife CHAR 12 state unlock_door_prompt else
		  ife CHAR 18 state unlock_door_prompt else
		  state use_prompt
		}
	  else
	  state use_prompt
	  }
	else
	ifg owner_saved 0
		{
			ife lock_id -1
			{
			  ife CHAR 3 state unlock_door_prompt else
			  ife CHAR 12 state unlock_door_prompt else
			  ife CHAR 18 state unlock_door_prompt else
			  state use_prompt
			}
		}
   ife use_action_allowed 1
		{
		set hit_key 30
		ifg owner_saved 0
			{
			switch CHAR
			case 3
			case 12
			case 18
				randvar lock_picking 2048
				set lock_id THISACTOR
				break
			default
				ifn hitag_saved 0
				 ifg GENERIC_KEYS 0
					{
					sub GENERIC_KEYS 1
					globalsound OLDKEY_UNLOCK
					operateactivators hitag_saved THISACTOR
					killit
					}
				else
					{
					ifn hitag_saved 0 { set PLAYER_VOICEOVER 3 set door_locked 0 set key_icon GENERICKEY }
					ifg VOLUME 4 quote 452
					else quote 451
					}
				break
				endswitch
			}
		else
		ifn lotag_saved 0
			{
			ifspritepal 16 nullop else
				{
				set PLAYER_VOICEOVER 4
				quote 219
				}
			state locked_door_sounds
			}
			else
		ifn hitag_saved 0
		 ifg GENERIC_KEYS 0
			{
			sub GENERIC_KEYS 1
			globalsound OLDKEY_UNLOCK
			operateactivators hitag_saved THISACTOR
			killit
			}
		else
		ifn xvel_saved 0 // display "locked, it must open somewhere else" message along with a sound if the XVEL is not activated yet.
		{
			checkactivatormotion xvel_saved
			ife RETURN 1 killit
			else
			{
				quote 233
				state locked_door_sounds
			}
		}
		else
			{
			ifn hitag_saved 0 { set PLAYER_VOICEOVER 3 set door_locked 0 set key_icon GENERICKEY } else quote 4
			set temp9 26
			state locked_door_sounds
			}
		state setIgnoreUse
		}
 }

 ifn INTERNALCOUNT 0
 {
 sub INTERNALCOUNT 1
 ife INTERNALCOUNT 1 soundonce PISS_OFF
 }

 ifg temp9 0
	{
	sub temp9 1
	 ife temp9 1
		set PLAYER_VOICEOVER 5
	}

ifn lotag_saved 0
{
cstator 256

ifpdistl 1024
 ifp pfacing
  ifand BITS_PRESS 4194304 // quick kicking?
	{
	ifg GOT_KNIFE 0
	ifl KNIFE_ATTACK 28 // if they have a knife, disable it for the kick
		{
		set KNIFE_ATTACK 28
		ife CHAR 12 soundonce SERVO else
		ife CHAR 2 soundonce H_ARMOUR_ROLL else
		soundonce JMOVE5
		set SPIN_KICK 0
		}
	}

ifhitweapon
	{
	ifspritepal 16
		{
		globalsound BUST_CONCRETE
		operateactivators lotag_saved THISACTOR
		killit
		}
		else
		{
		ifwasweapon KNEE
			{
			stopsound KICK_HIT
			ifspritepal 16
			globalsound BUST_CONCRETE
			else
				{
				globalsound DOOR_KICK
				shoot WOODSCRAP shoot WOODSCRAP shoot WOODSCRAP shoot WOODSCRAP shoot WOODSCRAP shoot WOODSCRAP
				}
			quake 5
			operateactivators lotag_saved THISACTOR
			killit
			}
			else strength 1
		}
	}
}


