action D2OPENED 6 1 1 1 0
action D2CLOSE  6 7 1 -1 5

useractor notenemy 18201

ifaction 0
{
cstat 273
set INTERNALCOUNT 0
action D2CLOSED
break
}

ifaction D2CLOSED
{
ifn hitag_saved 0
	{
	sleeptime 0
	ifpdistl 1536 ifp pfacing { state use_prompt ife use_action_allowed 1 { set hit_key 30 set door_locked 0 set key_icon 3587 soundonce LOCKED_HITECH2 state setIgnoreUse } }
	checkactivatormotion hitag_saved
	ife RETURN 1
		{
		sound SOPEN
		action D2OPEN
		}
	}
	else
 ifpdistl 1536
  ifp pfacing
   ifp palive
	{
	  state use_prompt
		ife use_action_allowed 1
		{
		set hit_key 30
		sound SOPEN
		action D2OPEN
		state setIgnoreUse
		}
	}
 }

ifaction D2OPEN
ifactioncount 7
{
action D2OPENED
}

ifaction D2OPENED
{
cstat 16
ifn hitag_saved 0 nullop else
	{
	ifcount 1
		{
		add INTERNALCOUNT 1
		resetcount
		}
	ife INTERNALCOUNT 128
		{
		sound SCLOSE
		action D2CLOSE
		set INTERNALCOUNT 0
		}
	}
}


ifaction D2CLOSE
{
	ifactioncount 7
	{
	action D2CLOSED
	cstat 273
	}
}

