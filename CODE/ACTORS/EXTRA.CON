								set DISP_KEY -150
								mul DISP_KEY NORMALIZED_FACTOR
								set DISP_KEY_PAL 15
								set DISP_KEY_PIC 9714
								}
							}
					}
				}
		}
	}
   sizeto 16 16
   cstat 1152
   ifaction 0 action ZERO
   }
   else
   {
   action 0
   sizeat 2 2
   cstat 32768
   }
ends

