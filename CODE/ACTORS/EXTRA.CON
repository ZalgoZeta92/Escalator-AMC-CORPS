// ------------------------------------------------------------
// GAS!
// ------------------------------------------------------------

defstate gas_stuff
ifn player_in_vehicle 1
	{
	ife FIRE_SUIT 0
		ife GAS_MASK 0
		   {
		  set ingas 10
		  soundonce CHOKING
		  getp[].posxv temp div temp 2 setp[].posxv temp div temp 2
		  getp[].posyv temp div temp 2 setp[].posyv temp div temp 2
		  switch CHAR
			  case 12
			  case 13
			  case 14
			  ifg PARMOUR 0 { getp[].shield_amount temp sub temp 1 setp[].shield_amount temp }
			  else addphealth -1
		  break
			  default
			  addphealth -1
		  break
		  endswitch
		  set screen_pal_override 2
		  palfrom 40 20 20 0
		   }
		else
		  {
		  setp[].sound_pitch -256
		  ife ingas 0 { set gas_mask_anim 0 soundonce PUT_ON_EQUIP }
		  set ingas 30
		  ife FIRE_SUIT 0 set GAS_MASK 2
		  set screen_pal_override 2
		   }
	}
ends

defstate heat_stuff
ife player_in_vehicle 0
	{
		soundonce COOKINGDEEPFRIER
		ife FIRE_SUIT 0
		   {
		  getp[].posxv temp div temp 2 setp[].posxv temp div temp 2
		  getp[].posyv temp div temp 2 setp[].posyv temp div temp 2
		  addphealth -2
		  palfrom 40 60 0 0
		   }
		else
		ife FIRE_SUIT 1 palfrom 10 60 0 0
	}
ends

var gassedheated -1 0
useractor notenemy 7924
	cstat 32768
	ifaction ZERO
	{
		set gassedheated -1
		ifn yvel_saved 0
		{
			checkactivatormotion yvel_saved
			ife RETURN 1 action 0
		}
	}
	else ifaction 0
	{
		ife zvel_saved 1 { action ZERO set zvel_saved 0 }
		ifn xvel_saved 0
		{
			checkactivatormotion xvel_saved
			ife RETURN 1 action ZERO
		}

		ife gassedheated THISACTOR // being gassed/heated
		{
			state hard_removefollower
			ifspritepal 0 state gas_stuff
			else ifspritepal 2 state heat_stuff
		}

		ife hitag_saved 1
		{
			// gas mode activates sector-based and stays active until we meet a sector with hitag 2 in it
			// this overrules any "extra" value stuff cause I can't be bothered to untangle that
			ife gassedheated -1
			ife sprite[PLAYER_IDENTITY].sectnum sprite[].sectnum
				set gassedheated THISACTOR
		}
		else ife hitag_saved 2
		{
			ife sprite[PLAYER_IDENTITY].sectnum sprite[].sectnum
				set gassedheated -1
		}
		else ifl extra_saved 1
		{
			ifpdistl 6000 state hard_removefollower
			  ifpdistl 5000
			  ifcansee
			{
				ifspritepal 0 state gas_stuff
				else ifspritepal 2 state heat_stuff
			}
		}
		else ife extra_saved 1
		{
			getp[].i PLAYER_IDENTITY
			ife sprite[PLAYER_IDENTITY].sectnum sprite[].sectnum
			{
				state hard_removefollower
				ifspritepal 0 state gas_stuff
				else ifspritepal 2 state heat_stuff
			}
		}
		else ife extra_saved 2
		{
			getp[].i PLAYER_IDENTITY

			ife sprite[PLAYER_IDENTITY].sectnum sprite[].sectnum
			  ifg player[].posz sprite[].z
			{
				state hard_removefollower
				ifspritepal 0 state gas_stuff
				else ifspritepal 2 state heat_stuff
			}
		}
		else
		{
			dist temp6 THISACTOR player[].i
			ifl temp6 extra_saved
			{
				state hard_removefollower
				ifcansee
				{
					ifspritepal 0 state gas_stuff
					else ifspritepal 2 state heat_stuff
				}
			}
		}
		ifspritepal 3
		{
			ifpdistl 1024
			{
				stopsound JGASMASK
				setp[].sound_pitch 0
				set screen_pal_override 10
				ifg ingas 0 sub ingas 1
				killit
			}
		}
	}

enda

