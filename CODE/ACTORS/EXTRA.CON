		case 23655
		case 23656
		case 23657
		case 23543
		case 23548
		case 23549
		case 22743
		case 34551
			break
		default
			ifpdistl 8192 ifrnd 2 money 1
			break
	endswitch

	seta[].pal sector[].floorpal
	state GREEN_BOOK_ARTIFACT
	ifhitweapon
		{
		ifwasweapon RADIUSEXPLOSION
			{
			set fire_damage 96
			}
		else
		ifwasweapon ATOM_BOMB
			{
			set fire_damage 96
			}
		else
		ifwasweapon RPG
			{
			set fire_damage 96
			}
		}

ifpdistl 3072
ife player_in_vehicle 1
	{
	cstat 0
	quake 13
