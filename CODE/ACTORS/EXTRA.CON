// *************************************************
// TIME ZONE STUFF
// *************************************************

var HUB_MAP 0 0

useractor notenemy 11493
cstat 32768

ife sprite[].ang 1024
	{
	ife sprite[].sectnum player[].cursectnum set actor_return 1
	}
	else set actor_return 1

ife actor_return 1
	{
	ifspritepal 0 nullop // For future stuff....
	else
	ifspritepal 1 { set TIMEZONE 1 ifl max_ally 4 set max_ally 4 killit } // Highwire Revolution period
	else
	ifspritepal 2 { set HUB_MAP 1 } // base
	else
	ifspritepal 3 { set TIMEZONE 2 killit } // Micky Begins
	else
	ifspritepal 4 { set TIMEZONE 3 killit } // turns snow into fire particles
	else
	ifspritepal 5 { set TIMEZONE 5 killit } // Snowfall future
	else
	ifspritepal 6 { set TIMEZONE 6 set GOT_KNIFE 0 killit  } // Snowfall VR stuff
	else
	ifspritepal 8 { set TIMEZONE 8 killit } // VR stuff (also used in one of the old EDF missions...)
	else
	ifspritepal 9 { set TIMEZONE 9 killit } // cutscene
	else
	ifspritepal 10 { set TIMEZONE 10 killit } // Ringworld
	else
	ifspritepal 11 // Ringworld town hub
		{
		set TIMEZONE 10
		ifand ELYSION_QUEST 4096 { ifand CHAR_APP 64 nullop else xor CHAR_APP 64 } // James quest done?
		ifand ELYSION_QUEST 131072 { ifand CHAR_APP 4 nullop else xor CHAR_APP 4 } // Merlijn quest done?
		ifand ELYSION_QUEST 512 { ifand CHAR_APP 32 nullop else xor CHAR_APP 32 } // Rusty quest done?
		ifand ELYSION_QUEST 64 { ifand CHAR_APP 128 nullop else xor CHAR_APP 128 }  // Micky quest done?
		}
	else
	ifspritepal 12 { set TIMEZONE 11 killit } // Ringworld
	else
	ifspritepal 13 // James Hell Arc stuff
		{
		set TIMEZONE 13
		readarrayfromfile SPECIALIST_EQUIPMENT F_SPECIAL_LOADOUT_AMCTC
		ife SPECIALIST_EQUIPMENT[108] 0 // unlock and enable flamberge the first time
			{
			setarray SPECIALIST_EQUIPMENT[108] 2
			ife SPECIALIST_EQUIPMENT[88] 2 setarray SPECIALIST_EQUIPMENT[88] 1
			ife SPECIALIST_EQUIPMENT[44] 2 setarray SPECIALIST_EQUIPMENT[44] 1
			ife SPECIALIST_EQUIPMENT[36] 2 setarray SPECIALIST_EQUIPMENT[36] 1
			ife SPECIALIST_EQUIPMENT[28] 2 setarray SPECIALIST_EQUIPMENT[28] 1
			ife SPECIALIST_EQUIPMENT[2] 2 setarray SPECIALIST_EQUIPMENT[2] 1
			}
		ife SPECIALIST_EQUIPMENT[111] 0 // unlock and equip super shotgun
			{
			setarray SPECIALIST_EQUIPMENT[111] 2
			ife SPECIALIST_EQUIPMENT[53] 2 setarray SPECIALIST_EQUIPMENT[53] 1
			ife SPECIALIST_EQUIPMENT[25] 2 setarray SPECIALIST_EQUIPMENT[25] 1
			ife SPECIALIST_EQUIPMENT[61] 2 setarray SPECIALIST_EQUIPMENT[61] 1
			ife JAMES_JACKH 1 { set JAMES_JACKH 0 savegamevar JAMES_JACKH }
			}
		ife SPECIALIST_EQUIPMENT[110] 0 // unlock and equip Plasma SMG
			{
			setarray SPECIALIST_EQUIPMENT[110] 2
			ife SPECIALIST_EQUIPMENT[55] 2 setarray SPECIALIST_EQUIPMENT[55] 1
			ife SPECIALIST_EQUIPMENT[8] 2 setarray SPECIALIST_EQUIPMENT[8] 1
			ife SPECIALIST_EQUIPMENT[15] 2 setarray SPECIALIST_EQUIPMENT[15] 1
			}
		ife SPECIALIST_EQUIPMENT[142] 0 // unlock and equip Aion-35
			{
			setarray SPECIALIST_EQUIPMENT[142] 2
			ife SPECIALIST_EQUIPMENT[78] 2 setarray SPECIALIST_EQUIPMENT[78] 1
			ife SPECIALIST_EQUIPMENT[84] 2 setarray SPECIALIST_EQUIPMENT[84] 1
			ife SPECIALIST_EQUIPMENT[45] 2 setarray SPECIALIST_EQUIPMENT[45] 1
			}
		ife SPECIALIST_EQUIPMENT[109] 0 // unlock and equip Abyssal RPG
			{
			setarray SPECIALIST_EQUIPMENT[109] 2
			ife SPECIALIST_EQUIPMENT[77] 2 setarray SPECIALIST_EQUIPMENT[77] 1
			}
		ife SPECIALIST_EQUIPMENT[121] 0 // unlock and equip Super Nailgun
			{
			setarray SPECIALIST_EQUIPMENT[121] 2
			ife SPECIALIST_EQUIPMENT[72] 2 setarray SPECIALIST_EQUIPMENT[72] 1
			ife SPECIALIST_EQUIPMENT[22] 2 setarray SPECIALIST_EQUIPMENT[22] 1
			}
		writearraytofile SPECIALIST_EQUIPMENT F_SPECIAL_LOADOUT_AMCTC
		killit
		} // James in Hell/Abyss
	else
	ifspritepal 20 { set TIMEZONE 20 killit } // Post-Ringworld
	else
	ifspritepal 21 { ifpdistl 2048 { set just_changed 1 set TIMEZONE 21 killit } }
	else
	ifspritepal 22 set TIMEZONE 22 // Atlantis Arisen
	else
	ifspritepal 23 set TIMEZONE 23 //Prison
	else
	ifspritepal 100 { ifpdistl 2048 set TIMEZONE 0 }
	}
enda

