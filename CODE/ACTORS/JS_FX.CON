ifspritepal 33 // air current
{
ifn lotag_saved 0
	{
	checkactivatormotion lotag_saved
	ife RETURN 1 set lotag_saved 0
	}
else
	{
	ife hitag_saved 0 set hitag_saved 256
	getp[].i PLAYER_IDENTITY
		ife sprite[PLAYER_IDENTITY].sectnum sprite[].sectnum
		{
		ifp phigher nullop
			else
				{
				ife player[].jumping_toggle 0
					{
					setp[].jumping_counter 361
					setp[].jumping_toggle 1
					}
				setp[].falling_counter 0
				getp[].poszv temp
				sub temp hitag_saved
				setp[].poszv temp
				getp[].posz temp2
				sub temp2 8
				setp[].posz temp2
				}
		}
	}
}
