ifspritepal 47 // Organ
{
ifpdistl 1024
 ifp pfacing
	{
	state use_prompt
	 ifhitspace
	  ifcount 13
		{
		ife WORLD_TRIGGER 128 // has sheet music?
			{
			screensound ORGAN_P
			operateactivators lotag_saved THISACTOR
			state lower_weapon
			set hit_key 30
			set WORLD_TRIGGER 0
			}
		else
		switch CHAR
		case 2
		case 3
		case 11
		case 12
		case 17
			soundonce ORGAN
			state lower_weapon
			set hit_key 30
			break
		default
			userquote 410
			set hit_key 30
			break
		endswitch
		resetcount
		}
	}
}
