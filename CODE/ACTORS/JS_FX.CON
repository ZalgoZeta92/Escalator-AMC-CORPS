		set temp 0
		whilevarn temp 16384
		{
		  ifn sprite[temp].statnum 1024
		  {
			geta[temp].picnum temp2
			ife temp2 SHOOTME
			{
			seta[temp].xrepeat 0
			seta[temp].yrepeat 0
			}
		  }
		  add temp 1
		}
		killit
	}
}
