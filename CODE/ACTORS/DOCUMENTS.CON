				}

ends

action DOC_SHEET -5300
action DOC_CLIPBOARD -210
action DOC_BOOK -1708

var document_read -1 2
useractor notenemy 9695
sleeptime 0
ifaction 0
{
espawn 3798
set actor_return RETURN
set temp9 0
ifspritepal 1
	{
	spritepal 0
	action DOC_SHEET
	}
else
ifspritepal 2
	{
	spritepal 0
	action DOC_CLIPBOARD
	}
else
ifspritepal 3
	{
	spritepal 0
	action DOC_BOOK
	}
else
	{
	action ZERO
	cstat 32768
	}
}

ife temp9 0
{
ifpdistl 2048
	ifrnd 8 spawn GLINT
	else
ifrnd 4 spawn GLINT
}

ifn owner_saved -1
{
checkactivatormotion owner_saved
ife RETURN 1
	{
	set temp9 1
	ifn lotag_saved 0 soundoncevar lotag_saved
	set DOCUMENT hitag_saved
	ife extra_saved -1 set MAXPAGES 0
	ifg extra_saved 0 { set MAXPAGES extra_saved set PAGENUMBER 0 }
		ifn zvel_saved 0 set document_scale zvel_saved
		else set document_scale -1
		
	set document_read THISACTOR

	ifaction DOC_BOOK set PAGETURNSOUND 1199 else
	set PAGETURNSOUND xvel_saved
	lockplayer 13
	seta[actor_return].pal 13
	state setIgnoreUse
	}
	
	ife document_read THISACTOR
	 ife use_action_allowed 1
		{
		ifn lotag_saved 0 soundoncevar lotag_saved
		state document_evidence
		set DOCUMENT -1
		set MAXPAGES 0
		set PAGETURNSOUND 0
		set temp9 1
		set document_read -1
		state setIgnoreUse
		}
	
}
else
ifpdistl 1024
{
ifn DOCUMENT -1
	{
	ife DOCUMENT 7935 // audio log?
		{
		ifactorsound THISACTOR lotag_saved
			setmusicvolume 25
			else
			{
			sound AUDIO_LOG
			setmusicvolume 100
			state document_evidence
			set DOCUMENT -1
			set MAXPAGES 0
			set PAGETURNSOUND 0
			set temp9 1
			resetcount
			}
		}
	ife use_action_allowed 1
		{
		ifaction DOC_BOOK soundonce BOOK_CLOSE
		else ifspritepal 5 soundonce BOOK_CLOSE
		state document_evidence
		set DOCUMENT -1
		set MAXPAGES 0
		set PAGETURNSOUND 0
		set temp9 1
		seta[actor_return].pal 13
		state setIgnoreUse
		}
	}
else
 ifp pfacing
  ifcansee
  ife DOCUMENT -1
  {
   state read_prompt
   ife use_action_allowed 1
		{
		set hit_key 30
		set temp9 1
		ifaction DOC_BOOK soundonce BOOK_OPEN
		else ifspritepal 5 soundonce BOOK_OPEN
		else ifn lotag_saved 0 soundoncevar lotag_saved
		else soundonce READ_DOCUMENT
		set DOCUMENT hitag_saved
		ife extra_saved -1 set MAXPAGES 0
		ifg extra_saved 0 { set MAXPAGES extra_saved set PAGENUMBER 0 }
		ifn zvel_saved 0 set document_scale zvel_saved
		else set document_scale -1

		// A bit hacky - add yvel_saved to STORY_TRIGGER2, only when triggered for the first time
		// Use this to tie map story progression to whether or not the player found certain documents
		ife document_read -1
			ifg yvel_saved 0 { add STORY_TRIGGER2 yvel_saved }
		set document_read THISACTOR

		ifaction DOC_BOOK set PAGETURNSOUND 1199 else
		set PAGETURNSOUND xvel_saved
		lockplayer 13
		state setIgnoreUse
		}
   }
}
enda
