						set DOCUMENT -1
						killit
						}
				}
			// ======================================================
			// EPISODE 5 DOCUMENTS
			// ======================================================
			ifge DOCUMENT 26099 // Are they reading the dean's confession
			ifle DOCUMENT 26100
				{
				readgamevar EVIDENCE_EP5
				ifand EVIDENCE_EP5 1 set DOCUMENT -1
					else
						{
						xorvar EVIDENCE_EP5 1
						savegamevar EVIDENCE_EP5
						add TREASURE_FOUND 4
