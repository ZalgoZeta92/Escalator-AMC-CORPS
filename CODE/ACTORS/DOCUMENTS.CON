			ife DOCUMENT 38823 // Are they reading the dean's confession
				{
				readgamevar EVIDENCE_EP5
				ifand EVIDENCE_EP5 128 set DOCUMENT -1
					else
						{
						xorvar EVIDENCE_EP5 128
						savegamevar EVIDENCE_EP5
						add TREASURE_FOUND 4
