				}
			ifg DOCUMENT 13912 // Are they reading Dr Jekyl's diary?
			 ifl DOCUMENT 13916
				{
				readgamevar EVIDENCE
				ifand EVIDENCE 512 set DOCUMENT -1
					else
						{
						xorvar EVIDENCE 512
						savegamevar EVIDENCE
