setp[].gotweapon 9 temp_equip[16] // Freezer
setp[].ammo_amount 9 temp_equip[17]
setp[].gotweapon 11 temp_equip[18] // Expander
setp[].ammo_amount 11 temp_equip[19]

set p_def_health_char CHAR
state player_default_health 
ife ARTIFACTS_LOADOUT[CHAR] 11 add p_default_health 20
ife MEAL_BUFF[CHAR] 1 add p_default_health 10
ife temp_equip[20] 0 setarray temp_equip[20] p_default_health
seta[PLAYER_IDENTITY].extra temp_equip[20] // set player initial health
set PHEALTH temp_equip[20]

ife temp_equip[21] 0 setarray temp_equip[21] p_default_health
setp[].max_player_health temp_equip[21] // set player initial max health
set pmax_health temp_equip[21]

setp[].shield_amount temp_equip[22]
