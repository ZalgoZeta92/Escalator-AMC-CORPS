setp[].ammo_amount 4 temp_equip[9]

setp[].ammo_amount 5 temp_equip[10] // grenade ammo
ifg Player_equip[10] 0 setp[].gotweapon 5 1

setp[].gotweapon 6 temp_equip[11] // Shrinker
setp[].ammo_amount 6 temp_equip[12]
setp[].gotweapon 7 temp_equip[13] // Devistator
setp[].ammo_amount 7 temp_equip[14]
