defstate read_player_equipment

ife CHAR C_JAMES copy James_equip[0] temp_equip[0] 256
else ife CHAR C_ZAXTOR copy Zaxtor_equip[0] temp_equip[0] 256
else ife CHAR C_MERLIJN copy Merlijn_equip[0] temp_equip[0] 256
