else ife CHAR C_JANE copy Jane_equip[0] temp_equip[0] 256

set temp_weap temp_equip[43]
ife temp_weap 44 set JUGGERN_SUIT 1 else set JUGGERN_SUIT 0
set normal_ammo temp_equip[113]
setp[].ammo_amount 0 temp_equip[1]
setp[].gotweapon 1 temp_equip[2]
