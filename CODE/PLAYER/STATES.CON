defstate player_default_health 
ife p_def_health_char C_JAMES
	{
	ifand CHAR_APP 512 set p_default_health 200
	else set p_default_health 100
	}
ife p_def_health_char C_ZAXTOR set p_default_health 255
ife p_def_health_char C_MERLIJN { set p_default_health 200 setp[].ammo_amount 1 3 }
ife p_def_health_char C_HIGHWIRE set p_default_health 100
ife p_def_health_char C_SANG
	{
	ife PERSONNEL_RESEARCH[10] 2 set p_default_health 100 
	else ifand CHAR_APP 2 set p_default_health 100
	else set p_default_health 75
	}
ife p_def_health_char C_RUSTY
	{
	ife PERSONNEL_RESEARCH[6] 2 set p_default_health 140
	else set p_default_health 120
	}
ife p_def_health_char C_GEOFFREY
	{
	ife PERSONNEL_RESEARCH[6] 2 set p_default_health 140
	else set p_default_health 120
	}
ife p_def_health_char C_MIKKO
{
ifand CHAR_APP 8 // Neo Mikko
	{
	ife PERSONNEL_RESEARCH[6] 2 // Both
	ife PERSONNEL_RESEARCH[9] 2
		set p_default_health 250
	else
	ife PERSONNEL_RESEARCH[6] 2 // Cybertour sheathing
		set p_default_health 220
	else
	ife PERSONNEL_RESEARCH[9] 2 // MS Corp ceramic plating
		set p_default_health 230
	else
		set p_default_health 200
	}
else
	{
	ife PERSONNEL_RESEARCH[6] 2 // Both
	ife PERSONNEL_RESEARCH[9] 2
		set p_default_health 200
	else
	ife PERSONNEL_RESEARCH[6] 2 // Cybertour sheathing
		set p_default_health 170
	else
	ife PERSONNEL_RESEARCH[9] 2 // MS Corp ceramic plating
		set p_default_health 180
	else 
		set p_default_health 150
	}
}
ife p_def_health_char C_CULTIST set p_default_health 100
ife p_def_health_char C_BOMBSHELL set p_default_health 100
ife p_def_health_char C_MAARTEN set p_default_health 150
ife p_def_health_char C_JANE set p_default_health 100
ife p_def_health_char C_MICKY set p_default_health 100
ife p_def_health_char 15 set p_default_health 75 // suitless micky
ife p_def_health_char C_SNOWFALL
	{
	set P_ENERGYSHIELD P_MAX_SHIELD
	ife PERSONNEL_RESEARCH[10] 2 set p_default_health 75 else
	set p_default_health 50
	}
ife p_def_health_char C_ROSA set p_default_health 150
ife p_def_health_char C_KAGURA
	{
	ife PERSONNEL_RESEARCH[6] 2 set p_default_health 120
	else set p_default_health 100
	}
ife p_def_health_char C_WHEATON
	{
	ife PERSONNEL_RESEARCH[6] 2 set p_default_health 80 
	else set p_default_health 70
	}
ife p_def_health_char C_CASSANDRA set p_default_health 200
ends

defstate long_arm_tilenum
switch CHAR
case 0 ifand CHAR_APP 512 set tilenum 19873 else set tilenum 17424 break
case 1 set tilenum 17430 break
case 2 ifand CHAR_APP 4 set tilenum 17436 else set tilenum 17432 break
case 3 ifand CHAR_APP 16 set tilenum 17428 else set tilenum 17423 break
case 4 ifand CHAR_APP 2 set tilenum 23869 else set tilenum 17429 break
case 5 ifand CHAR_APP 65536 set tilenum 17438 else set tilenum 17433 break
case 6 set tilenum 17427 break
case 7 set tilenum 17426 break
case 10 set tilenum 17425 break
case 11 set tilenum 17439 break
case 12 set tilenum 12183 break
case 13 set tilenum 17428 break
case 14 set tilenum 20881 break
case 16 set tilenum 32352 break
case 17 set tilenum 12184 break
case 18 set tilenum 17437 break
default set tilenum 17429 break
endswitch
ends

defstate trigger_bayonet_check
ifand BITS_PRESS 4194304
ife kickbackpic 0
ifge p_stamina 15
ifg SPIN_KICK 11
ifg TWIRL_KICK 19
ifg ROUNDHOUSE_KICK 26
ifg SLIDE_KICK 26
ifg FLYING_KICK 26
ife FIRE_SUIT 0
	 {
	 set weapon_bayonet 1
	 setp[].kickback_pic 4
	 setp[].quick_kick 0
	 sub p_stamina 15
	 set KNIFE_ATTACK 26
	 set QUICKK 13
	 }						
ife weapon_bayonet 1 ifand BITS_PRESS 4 set weapon_bayonet 0
ends

// hitscan weapon that changes damage type depending on enemy faction
defstate janus_weapon_system
			setarray shoot_mode[cur_weap] 0
            state hitscanToFromPlayer

            ifn hitsprite -1
            {
                getav[hitsprite].actor_type temp
				switch temp 
				case TYPE_ARMOURED
				case TYPE_ARMOURED_HELMET
				case TYPE_ROBOTIC
				case TYPE_VEHICLE
					setarray shoot_mode[cur_weap] 1 // anti-armour 
					break
				case TYPE_CHITIN
					setarray shoot_mode[cur_weap] 2 // hollowpoint 
					break
				case TYPE_SUPERNATURAL
                    setarray shoot_mode[cur_weap] 3 // supernatural 
					break
				case TYPE_BEYOND_THING
					setarray shoot_mode[cur_weap] 4 // incendiary 
					break
				default 
					setarray shoot_mode[cur_weap] 0 // normal
					break
				endswitch
            }
			
	ife shoot_mode[cur_weap] 0 
		{ 
		set weapon_type 0 
		ife cur_weap 1 set WEAPON1_SHOOTS ZRIFLESHOTU 
		else ife cur_weap 3 set WEAPON3_SHOOTS ZRIFLESHOTU 
		else ife cur_weap 6 set WEAPON6_SHOOTS ZRIFLESHOTU 
		else ife cur_weap 7 set WEAPON7_SHOOTS ZRIFLESHOTU 
		else ife cur_weap 9 set WEAPON9_SHOOTS ZRIFLESHOTU 
		} 
	else ife shoot_mode[cur_weap] 1 
		{ 
		set weapon_type 1 
		ife cur_weap 1 set WEAPON1_SHOOTS ARMOUR_PIERCING_SHOT 
		else ife cur_weap 3 set WEAPON3_SHOOTS ARMOUR_PIERCING_SHOT 
		else ife cur_weap 6 set WEAPON6_SHOOTS ARMOUR_PIERCING_SHOT 
		else ife cur_weap 7 set WEAPON7_SHOOTS ARMOUR_PIERCING_SHOT 
		else ife cur_weap 9 set WEAPON9_SHOOTS ARMOUR_PIERCING_SHOT 
		} 
	else ife shoot_mode[cur_weap] 2 
		{ 
		set weapon_type 2 
		ife cur_weap 1 set WEAPON1_SHOOTS HOLLOW_POINT_SHOT 
		else ife cur_weap 3 set WEAPON3_SHOOTS HOLLOW_POINT_SHOT 
		else ife cur_weap 6 set WEAPON6_SHOOTS HOLLOW_POINT_SHOT 
		else ife cur_weap 7 set WEAPON7_SHOOTS HOLLOW_POINT_SHOT 
		else ife cur_weap 9 set WEAPON9_SHOOTS HOLLOW_POINT_SHOT 
		} 
	else ife shoot_mode[cur_weap] 3 
		{ 
		set weapon_type 7 
		ife cur_weap 1 set WEAPON1_SHOOTS SILVERAMMOSHOT 
		else ife cur_weap 3 set WEAPON3_SHOOTS SILVERAMMOSHOT 
		else ife cur_weap 6 set WEAPON6_SHOOTS SILVERAMMOSHOT 
		else ife cur_weap 7 set WEAPON7_SHOOTS SILVERAMMOSHOT 
		else ife cur_weap 9 set WEAPON9_SHOOTS SILVERAMMOSHOT 
		} 
	else ife shoot_mode[cur_weap] 4 
		{ 
		set weapon_type 4 
		ife cur_weap 1 set WEAPON1_SHOOTS FIRE_BULLET 
		else ife cur_weap 3 set WEAPON3_SHOOTS FIRE_BULLET 
		else ife cur_weap 6 set WEAPON6_SHOOTS FIRE_BULLET 
		else ife cur_weap 7 set WEAPON7_SHOOTS FIRE_BULLET 
		else ife cur_weap 9 set WEAPON9_SHOOTS FIRE_BULLET 
		} 
	ends

defstate TURNOFF_NVG
ife player[].heat_on 1
{
set screen_pal_override 10
palfrom 30 0 0 0
ife CHAR 0 sound JAMES_HEATOFF
else ife CHAR 3 sound HIGH_HEATOFF
else ife CHAR 4 sound SHEAT_EYEGLASS
else ife CHAR 6 sound GEO_HEATOFF
else ife CHAR 7 sound MIK_HEATOFF
else ife CHAR 9 sound SHEAT_EYEGLASS
else ife CHAR 10 sound MIK_HEATOFF
else ife CHAR 13 sound HIGH_HEATOFF
else sound NITEVISION_ON
setp[].heat_on 0
}
ends

defstate toggle_bipod
        ifp pstanding
		 ife player[].weapon_pos 0
            {
            state checkwall
            ife WALL_CLOSE 1
                {
                ifcount 16
                    {
                        espawn 3630
                        set temp3 player[].posx
                        add temp3 256
                        rotatepoint player[].posx player[].posy temp3 player[].posy player[].ang temp5 temp6
                        seta[RETURN].x temp5
                        seta[RETURN].y temp6
                        state lower_weapon
                        xorvar gun_firemode 512
                        soundonce PUT_ON_EQUIP
                        resetcount
                    }
                }
            }
ends

defstate toggle_suppressor
	ifand gun_firemode 1024 nullop // disable if akimbo
	else
	ifcount 13
		{
		ife kickbackpic 0
			{
			ifand gun_firemode_two 2048 soundonce SUPPR_OFF else soundonce SUPPR_ON
			xorvar gun_firemode_two 2048
			setplayer[].weapon_pos 10
			}
		resetcount
		}
ends

defstate toggle_laser_sight
    ifcount 13
        {
        ife kickbackpic 0
            {
            ifand gun_firemode 2048 soundonce LASERSIGHT_OFF else soundonce LASERSIGHT_ON
            xorvar gun_firemode 2048
            }
        resetcount
        }
ends

defstate toggle_duel_tube
	ifcount 13
		  ife shotgun_load 0
			{
			sound JMOVE8
			ifand gun_firemode_two 8
				{
				quote 294
				xorvar gun_firemode_two 8
				}
				else
				{
				quote 295
				xorvar gun_firemode_two 8
				}
			resetcount
			}
ends

defstate holozoom_altfire
ifcount 13
	{
	sound JMOVE8
	ifand gun_firemode 16384
		{
		set hide_xhair 0
		xorvar gun_firemode 16384
		}
	else
		{
		set hide_xhair 1
		xorvar gun_firemode 16384
		ifand gun_firemode 32768 xorvar gun_firemode 32768
		}
	resetcount
	}
ends

defstate scope_altfire
ifcount 13
	{
	sound SCOPE_ZOOM
	ife scope 0 set scope 1 else set scope 0
	resetcount
	}
ends

defstate scifi_scope_altfire
   ifcount 13
        {
        state TURNOFF_NVG
        ife scope 0
            {
            set scope 2
            set scope_pal 1
            sound SCIFI_ZOOM_IN
            }
        else
            {
            set scope 0
            sound SCIFI_ZOOM_OUT
            }
        resetcount
        }
ends

defstate phantom_horse_summon
ifand BITS_PRESS P_SPRINTING
 ifp prunning
  ife phantom_ride 0
   ifand BASE_COSMETICS 32
	{
	ifhitspace { wackplayer sound HORSE_CRACK screensound PH_HORSE palfrom 16 16 0 16 set phantom_ride 300 }
	}
	
ifg phantom_ride 0
	{
	sub phantom_ride 1
	setplayer[].weapon_pos 10
	ifle phantom_ride 2 { palfrom 16 16 0 16 sound PH_STOP set phantom_ride -300 }
	ifand BITS_PRESS P_SPRINTING nullop else 
		{
		set temp 300
		sub temp phantom_ride
		inv temp
		set phantom_ride temp
		palfrom 8 16 0 16
		}
	}
else ifl phantom_ride 0 // cooldown
	{
	add phantom_ride 1
	ife phantom_ride -1 screensound PH_COOLD
	}
ends

defstate phantom_bike_summon
ifand BITS_PRESS P_SPRINTING
 ifp prunning
  ife phantom_ride 0
   ifand BASE_COSMETICS 32
	{
	ifhitspace { wackplayer sound PH_BIKE palfrom 16 16 set phantom_ride 300 }
	}
	
ifg phantom_ride 0
	{
	sub phantom_ride 1
	setplayer[].weapon_pos 10
	ifle phantom_ride 2 { palfrom 16 16 0 16 sound EBIKE_SKIDDING stopsound EBIKE_RUN set phantom_ride -300 }
	ifand BITS_PRESS P_SPRINTING nullop else 
		{
		set temp 300
		sub temp phantom_ride
		inv temp
		set phantom_ride temp
		palfrom 8 16 0 16
		}
	}
else ifl phantom_ride 0 // cooldown
	{
	add phantom_ride 1
	ife phantom_ride -1 screensound EBIKE_ACTIVE
	}
ends

defstate nano_board_summon
ifand BITS_PRESS P_SPRINTING
 ifp prunning
  ife phantom_ride 0
   ifand BASE_COSMETICS 128
	{
	ifhitspace { wackplayer sound NANOB_RD palfrom 16 0 16 set phantom_ride 300 }
	}
	
ifg phantom_ride 0
	{
	sub phantom_ride 1
	setplayer[].weapon_pos 10
	ifle phantom_ride 2 { palfrom 16 16 0 16 set phantom_ride -300 }
	ifand BITS_PRESS P_SPRINTING nullop else 
		{
		set temp 300
		sub temp phantom_ride
