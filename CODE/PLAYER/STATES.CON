		set phantom_ride temp
		palfrom 8 0 16
		}
	}
else ifl phantom_ride 0 // cooldown
	{
	add phantom_ride 1
	ife phantom_ride -1 screensound NANOB_ON
	}
ends

defstate proll_forward
	sub p_stamina 80
	getp[].falling_counter temp5 div temp5 2 setp[].falling_counter temp5
	ife CHAR 2 soundonce H_ARMOUR_ROLL
	soundonce NINJA_ROLL
	getp[].ang knockbackang
	set knockbackheight 2048
	set knockback2 8
	setp[].quick_kick 0
	set ROLL_FORWARDS 0
	state landsounds
	set INTERNALCOUNT_3 26
ends

// this is a state incase I want/need to elaborate on this
defstate pfakebullet
setprojectile[FAKE_BULLET].velmult 4
eshoot FAKE_BULLET
geta[RETURN].z temp
sub temp 768
seta[RETURN].z temp
setprojectile[FAKE_BULLET].velmult 2
ends

