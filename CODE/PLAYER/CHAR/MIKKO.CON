	ife cur_weap 7
		{
		set alt_fire_type 0
		set reload_type 4
		set weapon_type 9
		set GUN_VOLUME 24
		set GUN_ACCURACY 8
		set GUN_SIZE 3
		set GUN_HANDS 2
		set GUN_AMMO_TYPES 0
		set gun_mag -1
		

		set GUN_MAX_SPREAD 24
		
		ifg GUN_HEAT[cur_weap] 120
			{
			setp[].reloading 1
			soundonce AR73_OVERHEAT
			soundonce MDF_COOL_D
			setp[].kickback_pic 5
			}
		ifg GUN_HEAT[cur_weap] 40
			{
			ifg kickbackpic 10 { set gunsmoke_z 9144 set gunsmoke_angle 74 }
			else { set gunsmoke_z 8644 set gunsmoke_angle 64 }
			state spawn_gunsmoke_z
			}
		ife kickbackpic 14
			{
			set temp9 GUN_HEAT[cur_weap]
			sub temp9 3
			setarray GUN_HEAT[cur_weap] temp9
			ifl GUN_HEAT[cur_weap] 20
				{
				stopsound AR73_OVERHEAT soundonce PANFL_C setarray GUN_HEAT[cur_weap] 0
				}
			}
			ife kickbackpic 15
			{
			ifg GUN_HEAT[cur_weap] 20 setp[].kickback_pic 14
			}
			ife kickbackpic 33 soundonce PANFL_C
		
		switch kickbackpic
		case 1
		case 2
		case 3
			add gun_grace 1
			ifge gun_grace 15 add gun_spread 8
			espawn SOUND_SPRITE
			set gun_recoil 4
			state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp PANFL_F
			shoot SCIFI_SHELL
			break
		endswitch
		
		}

	}
else 
{
