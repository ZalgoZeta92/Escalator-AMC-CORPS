	ife cur_weap 3
	{
	set alt_fire_type 20
	set GUN_VOLUME 9
	set GUN_ACCURACY 16
	set GUN_SIZE 2
	set GUN_HANDS 2
	set GUN_AMMO_TYPES 0
	set GUN_MAX_SPREAD 24
	set gun_mag slot3_mag
	ifand MIKKO_UPGRADE 8 set max_slot3_mag 60 else set max_slot3_mag 25

	ifand BITS_PRESS 16384
		{
		ifcount 16
			{
			ifand MIKKO_UPGRADE 16 // Hollow point upgrade?
				{
				ife shoot_mode[cur_weap] 0 { setarray shoot_mode[cur_weap] 1 quote 1603 }
				else ife shoot_mode[cur_weap] 1 { setarray shoot_mode[cur_weap] 2 quote 1604 }
				else ife shoot_mode[cur_weap] 2 { setarray shoot_mode[cur_weap] 0 quote 1602 }
				}
				else
				{
				ife shoot_mode[cur_weap] 0 { setarray shoot_mode[cur_weap] 1 quote 1603 }
				else ife shoot_mode[cur_weap] 1 { setarray shoot_mode[cur_weap] 0 quote 1602 }
				}
			soundonce WEAP_FIRE_MODE
			resetcount
			}
		}

	ife shoot_mode[cur_weap] 1
		{
		set weapon_type 1
		set WEAPON3_SHOOTS ARMOUR_PIERCING_SHOT
		ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MSRIFLE_AP }
		}
	else
	ife shoot_mode[cur_weap] 2
		{
		ifand MIKKO_UPGRADE 16 nullop else setarray shoot_mode[cur_weap] 0 // failsafe in case upgrade gets taken away
		set weapon_type 2
		set WEAPON3_SHOOTS HOLLOW_POINT_SHOT
		ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MSRIFLE_HP }
		}
	else
		{
		set weapon_type 0
		set WEAPON3_SHOOTS MSCORP_SHOT
		ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp 647 }
		}

		ife kickbackpic 2
			{
			ifge gun_grace 10 add gun_spread 8
			set gunsmoke_angle 64
			state spawn_gunsmoke
			set gun_recoil 4
			state pfakebullet
			}
		ife kickbackpic 10
			{
			ifand MIKKO_UPGRADE 8 sound DRUM_OUT else
			state ar_mag_out_sounds
			ife slot3_mag 0
				{
				ifand MIKKO_UPGRADE 8 shoot SCIFI_BIG_MAG else shoot BIG_RIFLE_MAG
				}
			}

		ife kickbackpic 24
			{
			ifand MIKKO_UPGRADE 8 sound DRUM_IN else
			state ar_mag_in_sounds
			ifl cur_ammo max_slot3_mag set slot3_mag cur_ammo else set slot3_mag max_slot3_mag
			}

  ifl slot3_mag 1
   ife kickbackpic 0
	   ife player[].weapon_pos 0
		{
   		ifn cur_ammo 0
   			{
   			setp[].reloading 1
   			setp[].kickback_pic 6
			}
		}
   }
}

