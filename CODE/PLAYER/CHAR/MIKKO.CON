// Mikko's alternate fire code ==================================================================================================

defstate mikko_alt_fire

ife CHAR 7
{
 ife cur_weap 1
    {
    ife SPECIALIST_EQUIPMENT[4] 2 // MDF magnum?
	 ifand MAGIC_UPGRADE[7] 1
        {
        // GUN_CHARGE
        ifand BITS_PRESS 64
          ife kickbackpic_2 0
		   ifg p_blue_mana 0
                {
                ifl GUN_CHARGE 90
                    {
					ife PERSONNEL_RESEARCH[41] 2 add GUN_CHARGE 4 else
                    add GUN_CHARGE 2
                    clamp GUN_CHARGE 0 90
                    }
                }
        }
	 ife SPECIALIST_EQUIPMENT[174] 2 // Judgement
        {
        ifcount 16
            {
            ife shoot_mode[cur_weap] 0 { setarray shoot_mode[cur_weap] 1 quote 1607 }
            else ife shoot_mode[cur_weap] 1 { setarray shoot_mode[cur_weap] 2 quote 1608 }
            else ife shoot_mode[cur_weap] 2 { setarray shoot_mode[cur_weap] 0 quote 1602 }
            soundonce WEAP_FIRE_MODE
            resetcount
            }
        }
    }
    ife cur_weap 2 // shotgun
    {
    ife alt_fire_type 20
       {
        ife kickbackpic 0
            {
            ifg slot2_mag 1
                {
                ifand gun_firemode 256 nullop else
                    {
                    setp[].kickback_pic 1
                    xorvar gun_firemode 256
                    }
                }
            else ifg slot2_mag 0 setp[].kickback_pic 1
            }
       }
    }
    ife cur_weap 3
	 ife alt_fire_type 20
        {
        ifcount 16
            {
            ifand MIKKO_UPGRADE 16 // Hollow point upgrade?
                {
                ife shoot_mode[cur_weap] 0 { setarray shoot_mode[cur_weap] 1 quote 1603 }
                else ife shoot_mode[cur_weap] 1 { setarray shoot_mode[cur_weap] 2 quote 1604 }
                else ife shoot_mode[cur_weap] 2 { setarray shoot_mode[cur_weap] 0 quote 1602 }
                }
                else
                {
                ife shoot_mode[cur_weap] 0 { setarray shoot_mode[cur_weap] 1 quote 1603 }
                else ife shoot_mode[cur_weap] 1 { setarray shoot_mode[cur_weap] 0 quote 1602 }
                }
            soundonce WEAP_FIRE_MODE
            resetcount
            }
        }

	ife cur_weap 9
	ife alt_fire_type 20
	{
	  ife kickbackpic_2 0
	   ife weaponcount 0
	    ifge p_green_mana 1
		 ifand MAGIC_UPGRADE[7] 2
			{
			set kickbackpic_2 1
			sub p_green_mana 1
			}
	}
}

ends

defstate PS_MIKKO
{
set P_GENDER MALE

setp[].knuckle_incs 0

qputs 3 Medikit

qputs 90 MS-Corp Mech
qputs 12 Summoned MS-Corp Mech!

ife HELMET_LOADOUT[CHAR] 4
	{
	qputs 101 Ghost vision goggles
	qputs 106 Ghost vision on
	qputs 107 Ghost vision off
	}
else
ife HEAT_GOGGLES 1
	{
	qputs 101 Heat sensor
	qputs 106 Heat sensor on
	qputs 107 Heat sensor off
	}
else
	{
	qputs 101 Night sensor
	qputs 106 Night sensor on
	qputs 107 Night sensor off
	}

qputs 6 Protective suit!
qputs 75 Protective suit: %d %
set temp player[].boot_amount
ife PERSONNEL_RESEARCH[26] 2 div temp 7 else div temp 6
qsprintf 75 75 temp

qputs 89 Aqualung

qputs 47 Ammo Backpack
qputs 48 Ammo Backpack
qputs 49 Ammo Backpack not found yet!
qputs 51 Ammo Backpack
qstrcpy 91 51

qputs 88 Jetfuel
qputs 50 Jetfuel not found yet!
qputs 52 Jetfuel on
qputs 53 Jetfuel off

qputs 102 We're gonna fry your ass, Sandt!

setarray p_max_ammo[4]  100

setarray p_max_ammo[9]  300

ifand CHAR_APP 8 
	{
	set CKNEE 34299 
	set JUMP_BOOTS 1
	
	set p_stamina 600
	set pmax_stamina 600
	
	// doesn't need oxygen
	setp[].airleft 390

	// no falling damage
		ife player[].jumping_counter 0
		  ifg player[].falling_counter 8
		  ifl player[].falling_counter 61
			setplayer[THISACTOR].falling_counter 8
	}
else
	set CKNEE 7053

set fist_tile 3154

set CKEYCARDTILE 6969
set CKEYCARDTILE2 6968
set CKEYCARDTILE3 6967
set CTRIPBOMB 6966
set CDETON 2570
set CTIP 6964
set CHOLDING_R 9429
set CHOLDING_L 9429
set CHOLDING_3 12111

set C_ARM_1 7026
set C_ARM_2 9010
set C_ARM_3 38364

set C_PUNCH 12240

set C_PISTOL_R 8989
set C_PISTOL_L 8989

set c_medikit 7085
set c_steroids 7166
set c_holoduke 7091
set c_jetpack 7083

set c_nvg_heat 7086
set c_nvg_normal 7088

setuserdef[].userquote_xoffset -25
setuserdef[].userquote_yoffset 105

state DISP_nvg

set c_scuba 7090
set c_boots 7087
set c_armour 7084
set c_heavy_armour 7089

set C_HAND_1 7901
set C_HAND_2 7902

ifg AGENT_FATIGUE[CHAR] 5000 ifg SKILL_LEVEL 2 set pmax_stamina 100 else
set pmax_stamina 140

set CPIPEBOMB 7115

ifn player[].holoduke_on -1
{
stopsound TELEPORTER
soundonce EQUIPMENT_OFF
spawn SHOTGUNAMMO
spawn SHOTGUNAMMO
spawn AMMO
spawn AMMO
spawn AMMO
spawn BATTERYAMMO
spawn BATTERYAMMO
spawn RPGAMMO
spawn CRYSTALAMMO
spawn DEVISTATORAMMO
spawn FREEZEAMMO
spawn GROWAMMO
spawn TRIPBOMBSPRITE
spawn TRIPBOMBSPRITE
spawn TRIPBOMBSPRITE
setp[].holoduke_amount 0
}

ife player[].steroids_amount 398
{
sound SOMETHINGHITFORCE
spawn TRANSPORTERBEAM
spawn MS_CORP_MECH
}

ife player[].steroids_amount 30 sound POWERUP_LOW
ife player[].steroids_amount 60 sound POWERUP_LOW
ife player[].steroids_amount 90 sound POWERUP_LOW
ife player[].steroids_amount 120 sound POWERUP_LOW
ife player[].steroids_amount 150 sound POWERUP_LOW

// weapon pickup sounds
setarray wep_get_sound[1] PICK_PISTOL
setarray wep_get_sound[2] PICK_SHOTG
setarray wep_get_sound[3] PICK_SMG
setarray wep_get_sound[4] PICK_BIGGUN


setarray wep_get_sound[7] PICK_BIGGUN
setarray wep_get_sound[9] PICK_ENERG

// select sounds
set WEAPON1_SELECTSOUND SELECT_PISTOL
set WEAPON2_SELECTSOUND SELECT_SHOTGUN
set WEAPON3_SELECTSOUND SELECT_ASSAULTR
set WEAPON4_SELECTSOUND SELECT_WEAPON
set WEAPON6_SELECTSOUND SELECT_HT_BIGGUN
set WEAPON7_SELECTSOUND SELECT_BIG_WEAPON
set WEAPON9_SELECTSOUND SELECT_HT_ASSAULTR
set WEAPON11_SELECTSOUND SELECT_HT_BIGGUN

// MELEE
ife temp_weap 0
{
	set WEAPON0_TOTALTIME 17
	set WEAPON0_HOLDDELAY 17
	set WEAPON0_FIREDELAY 7
	set WEAPON0_FIRESOUND 532
	set WEAPON0_SHOOTS 5357

ife cur_weap 0
	{
	set weapon_type 0
	set gun_mag -1
	set GUN_HANDS 1
	ife kickbackpic 15 { sound PUNCH shoot 5357 }
	}
}


// PISTOL
ife SPECIALIST_EQUIPMENT[174] 2 // Using Judgement?
	{
	setarray p_max_ammo[1]  200
	setarray WEAPON_TILE[1] 39000
	ifand guns_akimbo 4 setarray weap_special[1] 20481 else
	setarray weap_special[1] 20480
	setarray W_AMMO_TILE[1] 7076
	setarray ammo_amount[1] 25

	set WEAPON1_CLIP 0
	set WEAPON1_HOLDDELAY 0
	set WEAPON1_FIREDELAY 2
	set WEAPON1_SPAWNTIME 2
	set WEAPON1_SPAWN 0
	set WEAPON1_INITIALSOUND 0
	set WEAPON1_SOUND2TIME 0
	set WEAPON1_SOUND2SOUND 0
	set WEAPON1_RELOADSOUND1 4
	set WEAPON1_RELOADSOUND2 4
	set WEAPON1_FIRESOUND 4
	

		ife cur_weap 1
		{
		set alt_fire_type 0
		set GUN_SIZE 1
		set GUN_AMMO_TYPES 0
		set GUN_MAX_SPREAD 48
		
		ifand BITS_PRESS 16384 // firemode key
		{
		    ifcount 16
            {
            ife shoot_mode[cur_weap] 0 { setarray shoot_mode[cur_weap] 1 quote 1607 }
            else ife shoot_mode[cur_weap] 1 { setarray shoot_mode[cur_weap] 2 quote 1608 }
            else ife shoot_mode[cur_weap] 2 { setarray shoot_mode[cur_weap] 0 quote 1602 }
            soundonce WEAP_FIRE_MODE
            resetcount
            }
		}
		
		ife shoot_mode[cur_weap] 0 
			{
			set weapon_type 1
			set WEAPON1_FLAGS 68
			set WEAPON1_TOTALTIME 3
			set WEAPON1_SHOOTS ZRIFLESHOTU
			set gun_sound JUDGE_F1
			}
		else
		ife shoot_mode[cur_weap] 1
			{
			set weapon_type 2
			set WEAPON1_FLAGS 64
			set WEAPON1_TOTALTIME 5
			set WEAPON1_SHOOTS FIRE_BULLET
			set gun_sound JUDGE_F2
			}
		else
		ife shoot_mode[cur_weap] 2
			{
			set weapon_type 9
			set WEAPON1_FLAGS 16448
			set WEAPON1_TOTALTIME 4
			set WEAPON1_SHOOTS 9361
			set gun_sound JUDGE_F3
			}
		
		ifand gun_firemode 64 // akimbo?
			{
			set max_slot1_mag 50
			set GUN_HANDS 2
			set GUN_VOLUME 32
			ife shoot_mode[cur_weap] 0 set GUN_ACCURACY 8 else
			set GUN_ACCURACY 16
			set WEAPON1_SHOTSPERBURST 2
			set WEAPON1_RELOAD 76
			ife kickbackpic 2
				{ 
				shoot NINEMM_SHELL set gunsmoke_angle 96  state spawn_gunsmoke
				shoot NINEMM_SHELL_LEFT set gunsmoke_angle 96  state spawn_gunsmoke
				ifn shoot_mode[cur_weap] 2 { state pfakebullet state pfakebullet_left }
				sub slot1_mag 2
				ife shoot_mode[cur_weap] 0 add gun_spread 8 else add gun_spread 12
				set gun_recoil 6
				espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp gun_sound 
				espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp gun_sound
				}
			ife kickbackpic 16 { sound MSPISTOL_MAGOUT ife reload_empty 1 shoot PISTOL_MAGAZINE }
			ife kickbackpic 35
				{
				sound MSPISTOL_MAGIN		
				ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
				div slot1_mag 2
				}
			ife kickbackpic 49 { sound MSPISTOL_MAGOUT ife reload_empty 1 shoot PISTOL_MAGAZINE }
			ife kickbackpic 57 sound GRAB_MAG
			ife kickbackpic 68
				{
				sound MSPISTOL_MAGIN		
				ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
				}
			ife kickbackpic 75 set reload_empty 0
			}
		else
			{
			set max_slot1_mag 25
			set GUN_HANDS 1
			set GUN_VOLUME 16
			ife shoot_mode[cur_weap] 0 set GUN_ACCURACY 4 else
			set GUN_ACCURACY 8
			set WEAPON1_SHOTSPERBURST 1
			set WEAPON1_RELOAD 43
			ife kickbackpic 2
				{ 
				shoot NINEMM_SHELL set gunsmoke_angle 96  state spawn_gunsmoke
				ifn shoot_mode[cur_weap] 2 state pfakebullet
				sub slot1_mag 1
				ife shoot_mode[cur_weap] 0 add gun_spread 6 else add gun_spread 8
				set gun_recoil 4
				espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp gun_sound 
				}
			ife kickbackpic 16 { sound MSPISTOL_MAGOUT ife reload_empty 1 { ifand MIKKO_UPGRADE 1 shoot PISTOL_MAGAZINE else shoot PISTOL_MAGAZINE } }
			ife kickbackpic 35
				{
				sound MSPISTOL_MAGIN		
				ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
				}
			}
			ife kickbackpic 24 sound GRAB_MAG

			ifg kickbackpic 2
			 ifl kickbackpic 10
			  ife allow_fire YES
				{
				ifand BITS_PRESS 4 ifg slot1_mag 0 setplayer[].kickback_pic 1
				}


		set gun_mag slot1_mag
		ife kickbackpic 3 ifvarl gun_mag 6 sound MAG_LOW

		ifl slot1_mag 1
		 ife player[].weapon_pos 0
		  ife kickbackpic 0
			{
			getp[].ammo_amount 1 cur_ammo
			ifn cur_ammo 0
				{
				setp[].reloading 1
				setp[].kickback_pic 6
				set reload_empty 1
				}
			}
		}
	}
else
ife SPECIALIST_EQUIPMENT[43] 2 // Using the golden rose?
{
setarray p_max_ammo[1]  120
setarray WEAPON_TILE[1] 13483
setarray weap_special[1] 0
setarray W_AMMO_TILE[1] 6851
setarray ammo_amount[1] 7

set WEAPON1_CLIP 0
set WEAPON1_RELOAD 47
set WEAPON1_HOLDDELAY 0
set WEAPON1_SHOOTS GOLDEN_SHOT_HIGH
set WEAPON1_SPAWNTIME 2
set WEAPON1_SPAWN NINEMM_SHELL
set WEAPON1_SHOTSPERBURST 1
set WEAPON1_INITIALSOUND 0
set WEAPON1_FIRESOUND 4
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 9
set WEAPON1_FLAGS 16384

set WEAPON1_SELECTSOUND SELECT_HT_PISTOL

ife cur_weap 1
	{
	set alt_fire_type 0
	set weapon_type 3
	set GUN_VOLUME 40
	set GUN_ACCURACY 2
	set GUN_MAX_SPREAD 48
	set GUN_SIZE 1
	set GUN_HANDS 1
	set GUN_AMMO_TYPES 0
	set gun_mag slot1_mag
	set max_slot1_mag 7
	ife kickbackpic 2
			{
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp GOLD_R_FIRE
			sub slot1_mag 1
			set gunsmoke_angle 64 state spawn_gunsmoke
			state pfakebullet
			}

		ifg kickbackpic 2
		 ifl kickbackpic 10
		  ife allow_fire YES
			{
			ifand BITS_PRESS 4
				{
				ifg slot1_mag 0 setplayer[].kickback_pic 1 else sound DRY_FIRE
				}
			}

		ife kickbackpic 3
			{
			set gun_recoil 7
			add gun_spread 20
			}

		ife kickbackpic 12 sound GR_RHAM
		ife kickbackpic 24 sound GR_ROUT

		ife kickbackpic 30 state revolver_eject

		ife kickbackpic 39
		{
		sound GR_RIN
		ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
		}

		ifl slot1_mag 1
		   ife player[].weapon_pos 0
		  ife kickbackpic 0
			{
			ifn cur_ammo 0
				{
				setp[].reloading 1
				setp[].kickback_pic 6
				}
			}
	}

}
else
ife SPECIALIST_EQUIPMENT[4] 2 // Using the MDF magnum?
{
// PISTOL
setarray p_max_ammo[1]  160
setarray WEAPON_TILE[1] 11101
setarray weap_special[1] 0
ifand MAGIC_UPGRADE[7] 1 setarray weap_special[1] 16384
setarray W_AMMO_TILE[1] 22644
setarray ammo_amount[1] 8

set WEAPON1_CLIP 0
set WEAPON1_RELOAD 44
set WEAPON1_HOLDDELAY 0
set WEAPON1_SPAWNTIME 2
set WEAPON1_SPAWN NINEMM_SHELL
set WEAPON1_INITIALSOUND 0
set WEAPON1_FIRESOUND 4
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 9
set WEAPON1_FLAGS 16386
set WEAPON1_SHOOTS RMAXREVOLVERSHOT
set WEAPON1_SHOTSPERBURST 1

set WEAPON1_SELECTSOUND SELECT_HT_PISTOL

ife cur_weap 1
	{
	set alt_fire_type 0
	set weapon_type 0
	set GUN_VOLUME 40
	set GUN_ACCURACY 2
	set GUN_MAX_SPREAD 48
	set GUN_SIZE 1
	set GUN_HANDS 1
	ifand MAGIC_UPGRADE[7] 1 set GUN_AMMO_TYPES 8192 else set GUN_AMMO_TYPES 0
	set gun_mag slot1_mag
	set max_slot1_mag 8

		ifg kickbackpic_2 0
		{
		add kickbackpic_2 1
		ifg kickbackpic_2 4 set kickbackpic_2 0
		}

	ifg GUN_CHARGE 0
	{
	ife kickbackpic 0
		{
		ifand BITS_PRESS 64
		 ifg p_blue_mana 0
		  ifl GUN_CHARGE 90
			{
			ifge GUN_CHARGE 10
				{
				ifactorsound THISACTOR WEAP_CHARGE nullop else
				sound WEAP_CHARGE
				}
			ife GUN_CHARGE 10 sub p_blue_mana 1
			ife GUN_CHARGE 20 sub p_blue_mana 1
			ife GUN_CHARGE 30 sub p_blue_mana 1
			ife GUN_CHARGE 40 sub p_blue_mana 1
			ife GUN_CHARGE 50 sub p_blue_mana 1
			ife GUN_CHARGE 60 sub p_blue_mana 1
			ife GUN_CHARGE 70 sub p_blue_mana 1
			ife GUN_CHARGE 80 sub p_blue_mana 1
			ife GUN_CHARGE 90 sub p_blue_mana 1
			set temp6 GUN_CHARGE
			mul temp6 4
			setactorsoundpitch THISACTOR WEAP_CHARGE temp6
			}
			else
			ifge GUN_CHARGE 10
			{
			ifand BITS_PRESS 64 break
			sound MDF_ICE_FIRE
			set temp8 360
			set temp6 GUN_CHARGE
			mul temp6 8
			sub temp8 temp6
			setactorsoundpitch THISACTOR MDF_ICE_FIRE temp8
			stopsound WEAP_CHARGE
			ifge GUN_CHARGE 10 shoot ICE_BEAM
			ifge GUN_CHARGE 20 shoot ICE_BEAM
			ifge GUN_CHARGE 30 shoot ICE_BEAM
			ifge GUN_CHARGE 40 shoot ICE_BEAM
			ifge GUN_CHARGE 50 shoot ICE_BEAM
			ifge GUN_CHARGE 60 shoot ICE_BEAM
			ifge GUN_CHARGE 70 shoot ICE_BEAM
			ifge GUN_CHARGE 80 shoot ICE_BEAM
			ifge GUN_CHARGE 90 shoot ICE_BEAM
			set kickbackpic_2 1
			set GUN_CHARGE 0
			}
		}
	}

	ife kickbackpic_2 2 set gun_recoil 6

	ife kickbackpic 2
			{
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SILVER_T_FIRE
			shoot NINEMM_SHELL
			sub slot1_mag 1
			set gunsmoke_angle 64 state spawn_gunsmoke
			state pfakebullet
			}
	ife kickbackpic 3
		{
		set gun_recoil 7
		add gun_spread 20
		}

		ifg kickbackpic 2
		 ifl kickbackpic 10
		  ife allow_fire YES
			{
			ifand BITS_PRESS 4
				{
				ifg slot1_mag 0 setplayer[].kickback_pic 1 else sound DRY_FIRE
				}
			}

		ife kickbackpic 15 sound SILVER_T_RELOAD
		ife kickbackpic 24 ife slot1_mag 0 shoot HEAVY_PISTOL_MAG

		ife kickbackpic 40
		{
		ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
		}

		ifl slot1_mag 1
		   ife player[].weapon_pos 0
		  ife kickbackpic 0
		{
			ifn cur_ammo 0
				{
				setp[].reloading 1
				setp[].kickback_pic 6
				}
		}

	}

	}
else // Default MS CORP pistol
{
setarray p_max_ammo[1]  300
ifand MIKKO_UPGRADE 4 setarray WEAPON_TILE[1] 7133
else setarray WEAPON_TILE[1] 7067
ifand guns_akimbo 4 setarray weap_special[1] 20481 else
setarray weap_special[1] 20480
setarray W_AMMO_TILE[1] 7076
setarray ammo_amount[1] 25

set WEAPON1_CLIP 0
set WEAPON1_HOLDDELAY 0
ifand MIKKO_UPGRADE 4 set WEAPON1_TOTALTIME 3 
else set WEAPON1_TOTALTIME 4
set WEAPON1_FIREDELAY 2
set WEAPON1_SPAWNTIME 2
set WEAPON1_SPAWN 0
set WEAPON1_INITIALSOUND 0
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4
set WEAPON1_FLAGS 70
set WEAPON1_FIRESOUND 4
set WEAPON1_SHOOTS ARMOUR_PIERCING_SHOT

	ife cur_weap 1
	{
	set alt_fire_type 5
	set weapon_type 1
	set GUN_SIZE 0
	set GUN_AMMO_TYPES 0
	ifand MIKKO_UPGRADE 2 set GUN_MAX_SPREAD 32 else
	set GUN_MAX_SPREAD 64
	
	ifand gun_firemode 64 // akimbo?
		{
		ifand MIKKO_UPGRADE 1 set max_slot1_mag 80 else set max_slot1_mag 40
		set GUN_HANDS 2
		set GUN_VOLUME 32
		set GUN_ACCURACY 8
		set WEAPON1_SHOTSPERBURST 2
		set WEAPON1_RELOAD 76
		ife kickbackpic 2
			{ 
			shoot NINEMM_SHELL set gunsmoke_angle 96  state spawn_gunsmoke
			shoot NINEMM_SHELL_LEFT set gunsmoke_angle 96  state spawn_gunsmoke
			state pfakebullet state pfakebullet_left
			sub slot1_mag 2
			add gun_spread 12
			set gun_recoil 6
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MSPISTOL_FIRE 
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MSPISTOL_FIRE
			}
		ife kickbackpic 16 { sound MSPISTOL_MAGOUT ife reload_empty 1 { ifand MIKKO_UPGRADE 1 shoot PISTOL_MAGAZINE else shoot PISTOL_MAGAZINE } }
		ife kickbackpic 35
			{
			sound MSPISTOL_MAGIN		
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			div slot1_mag 2
			}
		ife kickbackpic 49 { sound MSPISTOL_MAGOUT ife reload_empty 1 { ifand MIKKO_UPGRADE 1 shoot PISTOL_MAGAZINE else shoot PISTOL_MAGAZINE } }
		ife kickbackpic 57 sound GRAB_MAG
		ife kickbackpic 68
			{
			sound MSPISTOL_MAGIN		
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}
		ife kickbackpic 75 set reload_empty 0
		}
	else
		{
		ifand MIKKO_UPGRADE 1 set max_slot1_mag 40 else set max_slot1_mag 20
		set GUN_HANDS 1
		set GUN_VOLUME 16
		set GUN_ACCURACY 4
		set WEAPON1_SHOTSPERBURST 1
		set WEAPON1_RELOAD 43
		ife kickbackpic 2
			{ 
			shoot NINEMM_SHELL set gunsmoke_angle 96  state spawn_gunsmoke
			state pfakebullet
			sub slot1_mag 1
			add gun_spread 8
			set gun_recoil 4
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MSPISTOL_FIRE 
			}
		ife kickbackpic 16 { sound MSPISTOL_MAGOUT ife reload_empty 1 { ifand MIKKO_UPGRADE 1 shoot PISTOL_MAGAZINE else shoot PISTOL_MAGAZINE } }
		ife kickbackpic 35
			{
			sound MSPISTOL_MAGIN		
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}
		}
		ife kickbackpic 24 sound GRAB_MAG

	set gun_mag slot1_mag
	ife kickbackpic 3 ifvarl gun_mag 6 sound MAG_LOW
	ifl kickbackpic 7
	 ife player[].weapon_pos 0
		{
		state spawn_lasersite
		seta[RETURN].x hitx
		seta[RETURN].y hity
		seta[RETURN].z hitz
		ifand SPECIALIST_CUSTOM[4] 1073741824 seta[RETURN].pal 1
		else ifand SPECIALIST_CUSTOM[4] 2147483648 seta[RETURN].pal 8
		else seta[RETURN].pal 0
		}

  	ifl slot1_mag 1
     ife player[].weapon_pos 0
   	  ife kickbackpic 0
		{
		getp[].ammo_amount 1 cur_ammo
		ifn cur_ammo 0
			{
			setp[].reloading 1
			setp[].kickback_pic 6
			set reload_empty 1
			}
		}
	}
}

// SHOTGUN
ife SPECIALIST_EQUIPMENT[30] 2 // Using the MS-Corp assault shotgun?
{
setarray WEAPON_TILE[2] 13424
setarray W_AMMO_TILE[2] 7077
setarray ammo_amount[2] 8
setarray weap_special[2] 4

ife BELT_LOADOUT[CHAR] 5 setarray p_max_ammo[2]  60 else
setarray p_max_ammo[2]  50

set WEAPON2_CLIP 0
set WEAPON2_RELOAD 63
set WEAPON2_FIREDELAY 2
set WEAPON2_TOTALTIME 7
set WEAPON2_HOLDDELAY 32
set WEAPON2_FLAGS 0
set WEAPON2_SHOOTS 2613
set WEAPON2_SPAWNTIME 5
set WEAPON2_SPAWN 0
set WEAPON2_SHOTSPERBURST 7
set WEAPON2_INITIALSOUND 0
set WEAPON2_FIRESOUND 4
set WEAPON2_SOUND2TIME 15
set WEAPON2_SOUND2SOUND 4
set WEAPON2_RELOADSOUND1 4
set WEAPON2_RELOADSOUND2 5

	ife cur_weap 2
	{
	set reload_type 2
	set weapon_type 2
	set GUN_VOLUME 70
	set GUN_ACCURACY 32
	set GUN_SIZE 2
	set GUN_HANDS 2
	set GUN_AMMO_TYPES 0
	set gun_mag alt_slot2_mag
	set max_alt_slot2_mag 10

	setarray needs_pump[cur_weap] 0
	
	set alt_fire_type 5

	ife kickbackpic 0
	ifand BITS_PRESS 4
		  ifg alt_slot2_mag 0
		   ife player[].ammo_amount 2 0
		   ifn need_to_fire 1
		   ife player[].weapon_pos 0
			{
			getp[].ammo_amount 2 temp2
			add temp2 1
			setp[].ammo_amount 2 temp2
			setp[].kickback_pic 1
			set need_to_fire 1
			}
	ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MS_AS_FIRE state pfakebullet_shotgun }
	ife kickbackpic 3
	ife need_to_fire 1
		{
		setp[].ammo_amount 2 0
		set need_to_fire 0
		}

			ife kickbackpic 2
				{
				set LAST_SHELL_FIRED 0
				sub alt_slot2_mag 1
				getp[].ammo_amount 2 temp2
				add temp2 1
				setp[].ammo_amount 2 temp2
				set gunsmoke_angle 96
				state spawn_gunsmoke
				set gun_recoil 6
				}
			ife kickbackpic 3 state eject_shot_shell
			ife kickbackpic 10 state JMOVESOUND2

			ife kickbackpic 23 { sound DRUM_OUT ife alt_slot2_mag 0 shoot DRUMMAGAZINE }

			ife kickbackpic 43
			{
			sound DRUM_IN
			set temp5 alt_slot2_mag
			set temp6 max_alt_slot2_mag
			sub temp6 temp5
				ifg temp6 cur_ammo
					{
					add alt_slot2_mag cur_ammo
					setp[].ammo_amount 2 0
					}
					else
					{
					getp[].ammo_amount 2 temp4 sub temp4 temp6 setp[].ammo_amount 2 temp4
					set alt_slot2_mag max_alt_slot2_mag
					}
			}

		ifl alt_slot2_mag 1
		   ife player[].weapon_pos 0
			ife kickbackpic 0
		   {
		   ifn cur_ammo 0
			   {
			   setp[].reloading 1
			   setp[].kickback_pic 6
			   }
			}

	}
}
else // USING THE MSC-12?
ife SPECIALIST_EQUIPMENT[85] 2
{
