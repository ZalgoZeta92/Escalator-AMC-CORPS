		ifg GUN_HEAT[cur_weap] 120
			{
			setp[].reloading 1
			soundonce AR73_OVERHEAT
			soundonce MDF_COOL_D
			soundonce EXPANDERSHOOT
			shoot GROWSPARK shoot GROWSPARK shoot GROWSPARK shoot GROWSPARK shoot GROWSPARK shoot GROWSPARK shoot GROWSPARK shoot GROWSPARK shoot GROWSPARK
			setp[].kickback_pic 5
			}
		ifg GUN_HEAT[cur_weap] 40
			{

