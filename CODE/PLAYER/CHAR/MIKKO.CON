set WEAPON2_SOUND2SOUND 4
set WEAPON2_RELOADSOUND1 4
set WEAPON2_RELOADSOUND2 5

ife cur_weap 2
	{
	set reload_type 1
	set weapon_type 3
	set alt_fire_type 0
		set max_slot2_mag 8
		clamp slot2_mag 0 max_slot2_mag
		set gun_mag slot2_mag
		set GUN_VOLUME 70
		set GUN_SIZE 1
		set GUN_HANDS 2
		set GUN_ACCURACY 16
		set GUN_MAX_SPREAD 48
		set GUN_AMMO_TYPES 0
		setarray needs_pump[cur_weap] 0

		set WEAPON2_SHOOTS GOLDEN_SHOT_LOW
		set WEAPON2_FIRESOUND 4

		ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MIK_GOLD_SHOTGUN state pfakebullet_shotgun }

	ifg shotgun_load 0
		{
		setp[].reloading 1
	    ifl kickbackpic 17 setp[].kickback_pic 17
	    ife kickbackpic 21 sub shotgun_load 1
	    ife kickbackpic 24 setp[].kickback_pic 17
		ifand BITS_PRESS 4 ifg slot2_mag 0 ifg kickbackpic 21 ife allow_fire YES { set shotgun_load 0 setp[].reloading 0 setplayer[].kickback_pic 1 }
		}

		ife kickbackpic 0
		{
		state shotgun_load_check
		ifand BITS_PRESS 4
			  ifg slot2_mag 0
			   ife player[].ammo_amount 2 0
			   ife player[].weapon_pos 0
				{
				getp[].ammo_amount 2 hold_ammo_temp
				add hold_ammo_temp 1
				clamp hold_ammo_temp 0 100
				setp[].ammo_amount 2 hold_ammo_temp
				set need_to_fire 1
				setp[].kickback_pic 1
				}
		}
		ife kickbackpic 4
		{
		add gun_spread 16
		ife need_to_fire 1
			{
			getp[].ammo_amount 2 hold_ammo_temp
			sub hold_ammo_temp 1
			clamp hold_ammo_temp 0 100
			setp[].ammo_amount 2 hold_ammo_temp
			set need_to_fire 0
			}
		}
		ife player[].reloading 1
			{
			ife kickbackpic 20
				{
				state sg_shell_sounds
				add slot2_mag 1
				getp[].ammo_amount 2 hold_ammo_temp
				sub hold_ammo_temp 1
				clamp hold_ammo_temp 0 100
				setp[].ammo_amount 2 hold_ammo_temp
				}
			}
			else
			{
			ife kickbackpic 0 ifg slot2_mag 0 ife needs_pump[cur_weap] 1 setp[].kickback_pic 8
			ife kickbackpic 2
				{
				sub slot2_mag 1
				ife AMMO_TYPES[cur_weap] 0
					{
					getp[].ammo_amount 2 hold_ammo_temp
					add hold_ammo_temp 1
					setp[].ammo_amount 2 hold_ammo_temp
					}
				set gun_recoil 6
				}
		ife kickbackpic 3
		{ set gunsmoke_angle 64 state spawn_gunsmoke setprojectile[SHOTG_SHELL].pal 40 eshoot SHOTG_SHELL setprojectile[SHOTG_SHELL].pal 0 }
		   }
	}
}
else // Using MS-Corp default shotgun?
{
ifand MIKKO_UPGRADE 32 setarray WEAPON_TILE[2] 6977 else setarray WEAPON_TILE[2] 7068

setarray W_AMMO_TILE[2] 7077
setarray ammo_amount[2] 8
setarray weap_special[2] 16384
setarray p_max_ammo[2]  60

set WEAPON2_CLIP 0
set WEAPON2_RELOAD 13
set WEAPON2_FIREDELAY 2
set WEAPON2_TOTALTIME 28
set WEAPON2_HOLDDELAY 0
set WEAPON2_FLAGS 1024
set WEAPON2_SHOOTS 2613
set WEAPON2_SPAWNTIME 24
set WEAPON2_SPAWN 0
set WEAPON2_SHOTSPERBURST 7
set WEAPON2_INITIALSOUND 0
set WEAPON2_SOUND2TIME 15
set WEAPON2_SOUND2SOUND MSSHOTGUN_PUMP
set WEAPON2_RELOADSOUND1 4
set WEAPON2_RELOADSOUND2 5

ife cur_weap 2
	{
	set reload_type 1
	set alt_fire_type 20
	ife needs_pump[cur_weap] 1 set max_slot2_mag 10 else set max_slot2_mag 11
	set gun_mag slot2_mag
	set GUN_VOLUME 70
	set GUN_SIZE 1
	set GUN_HANDS 2
	ifand gun_firemode 256
	{
	ifand MIKKO_UPGRADE 32 set GUN_ACCURACY 16 else
	set GUN_ACCURACY 64
	}
	else
	set GUN_ACCURACY 16
	set GUN_AMMO_TYPES 5
	set WEAPON2_FIRESOUND 4

	ifand AMMO_TYPES[cur_weap] 1
	{
	set weapon_type 8
	set WEAPON2_SHOOTS 9361
	ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp EXPL_SHELL_FIRE }
	ife explosive_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 1 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
	}
	else
	ifand AMMO_TYPES[cur_weap] 4
	{
	set weapon_type 9
	ife ARTIFACTS_LOADOUT[CHAR] 7 set WEAPON2_SHOOTS 6816 else
	ife WEAPONS_RESEARCH[RS_W_LAVA_NAILS] 2 set WEAPON2_SHOOTS LAVA_NAIL else
	set WEAPON2_SHOOTS 6826
	ife kickbackpic 2 
	{ espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT ife WEAPONS_RESEARCH[RS_W_LAVA_NAILS] 2 setactorvar[RETURN].temp LAVAN_FIRE
	else setactorvar[RETURN].temp FLECH_SHELL_FIRE }
	ife flechete_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 4 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
	}
	else
	ifand AMMO_TYPES[cur_weap] 64
	{
	set weapon_type 0
	set WEAPON2_SHOOTS RMAXREVOLVERSHOT
	ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MAGNUM_SHOTGUN }
	ife magnum_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 64 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
	ife kickbackpic 2 state pfakebullet_shotgun
	}
	else
	ifand AMMO_TYPES[cur_weap] 1024
	{
	set weapon_type 8
	set WEAPON2_SHOOTS 22536
	ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp DRAGONS_BR_FIRE }
	ife dragon_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 1024 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
	}
	else
	ifand AMMO_TYPES[cur_weap] 65536
	{
	set weapon_type 7
	set WEAPON2_SHOOTS SILVER_BEARING
	ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SBBALL_FIRE }
	ife silverb_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 65536 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
	}
	else
	{
	set weapon_type 2
	setarray AMMO_TYPES[cur_weap] 0
	set WEAPON2_SHOOTS 2613
	ife kickbackpic 2 { state pfakebullet_shotgun espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MSSHOTGUN_FIRE }
	}

	ifg shotgun_load 0
		{
		setp[].reloading 1
		ife BELT_LOADOUT[CHAR] 5
			{
			ifl kickbackpic 19 setp[].kickback_pic 19
			ife kickbackpic 21 sub shotgun_load 1
			ife kickbackpic 24 setp[].kickback_pic 19
			}
		else
			{
			ifl kickbackpic 17 setp[].kickback_pic 17
			ife kickbackpic 21 sub shotgun_load 1
			ife kickbackpic 24 setp[].kickback_pic 24
			}
		ifand BITS_PRESS 4 ifg slot2_mag 0 ifg kickbackpic 21 ife allow_fire YES { set shotgun_load 0 setp[].reloading 0 setplayer[].kickback_pic 1 }
		}

	ife kickbackpic 0
	{
	state shotgun_load_check
	ifand BITS_PRESS 4
		  ifg slot2_mag 0
		   ife player[].ammo_amount 2 0
		    ife player[].weapon_pos 0
			{
			getp[].ammo_amount 2 hold_ammo_temp
			clamp hold_ammo_temp 0 100
			add hold_ammo_temp 1
			setp[].ammo_amount 2 hold_ammo_temp
			set need_to_fire 1
			setp[].kickback_pic 1
			}
	}
	ife kickbackpic 5
	ife need_to_fire 1
		{
		getp[].ammo_amount 2 hold_ammo_temp
		sub hold_ammo_temp 1
		clamp hold_ammo_temp 0 100
		setp[].ammo_amount 2 hold_ammo_temp
		set need_to_fire 0
		}
	ife slot2_mag 0 ife kickbackpic 0 setarray needs_pump[cur_weap] 1
	ife player[].reloading 1
		{
		ife kickbackpic 20
			{
			state sg_shell_sounds
			add slot2_mag 1
			ifand AMMO_TYPES[cur_weap] 1 { set LAST_SHELL_FIRED 1 sub explosive_shells 1 }
			else ifand AMMO_TYPES[cur_weap] 4 { set LAST_SHELL_FIRED 4 sub flechete_shells 1 }
			else ifand AMMO_TYPES[cur_weap] 64 { set LAST_SHELL_FIRED 64 sub magnum_shells 1 }
			else ifand AMMO_TYPES[cur_weap] 1024 { set LAST_SHELL_FIRED 1024 sub dragon_shells 1 }
			else ifand AMMO_TYPES[cur_weap] 65536 { set LAST_SHELL_FIRED 65536 sub silverb_shells 1 }
			else
				{
				set LAST_SHELL_FIRED 0
				getp[].ammo_amount 2 hold_ammo_temp
				sub hold_ammo_temp 1
				clamp hold_ammo_temp 0 100
				setp[].ammo_amount 2 hold_ammo_temp
				}
			}
		}
		else
		{
		ife kickbackpic 0 ifg slot2_mag 0 ife needs_pump[cur_weap] 1 setp[].kickback_pic 8
		ife kickbackpic 2
			{
			sub slot2_mag 1
			ife AMMO_TYPES[cur_weap] 0
				{
				getp[].ammo_amount 2 hold_ammo_temp
				add hold_ammo_temp 1
				setp[].ammo_amount 2 hold_ammo_temp
				}
			set gun_recoil 6
			}
	    ife kickbackpic 3
		{ ifand gun_firemode 256 { state eject_shot_shell setp[].kickback_pic 1  xorvar gun_firemode 256 } set gunsmoke_angle 64 state spawn_gunsmoke }
		ife kickbackpic 24
			{
			ife needs_pump[cur_weap] 1 setarray needs_pump[cur_weap] 0
			else // If it didn't need pumping, eject a shell
			state eject_shot_shell
			}
	   }
	}
}

