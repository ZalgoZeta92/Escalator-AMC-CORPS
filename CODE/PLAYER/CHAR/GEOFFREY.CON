// FREEZER
ife SPECIALIST_EQUIPMENT[141] 2 // Coatl
{
setarray p_max_ammo[9]  400
setarray WEAPON_TILE[9] 29912
setarray weap_special[9] 0
setarray W_AMMO_TILE[9] 6127
setarray ammo_amount[9] 100

set WEAPON9_FIREDELAY 2

set WEAPON9_TOTALTIME 3
set WEAPON9_INITIALSOUND 0
set WEAPON9_FIRESOUND 4
set WEAPON9_SHOTSPERBURST 1
set WEAPON9_FLAGS 4

set WEAPON9_SELECTSOUND SELECT_HMG

	ife cur_weap 9
	{
	set alt_fire_type 5
	set GUN_VOLUME 20
	set GUN_HANDS 2

	set GUN_AMMO_TYPES 0

	set GUN_SIZE 1
	set GUN_ACCURACY 8
	set GUN_MAX_SPREAD 32
	set gun_mag slot9_mag
	set max_slot9_mag 100
	set reload_frame_partial 42
	set reload_frame 5
	set reload_type 6

	state janus_weapon_system

	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp GHMG_F }
	ife kickbackpic 2 { set gun_recoil 4 state pfakebullet ifge gun_grace 20 add gun_spread 7 }
	ifg kickbackpic 0 ifl kickbackpic 5 { set gun_pushback_power -1 state gun_pushback }
	ife kickbackpic 3 { set gunsmoke_angle 64 state spawn_gunsmoke }
	ife kickbackpic 18 sound DRUM_OUT
	ife kickbackpic 30 ife slot9_mag 0 shoot SCIFI_BIG_MAG
	ife kickbackpic 50 sound AK_SLIDE
	ife kickbackpic 35
		{
		sound DRUM_IN
		ifl cur_ammo max_slot9_mag set slot9_mag cur_ammo else set slot9_mag max_slot9_mag
		}
	  ifl slot9_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
	   {
		ifn cur_ammo 0
			{
			set WEAPON9_RELOAD 58
			setp[].reloading 1
			setp[].kickback_pic reload_frame
			}
		}
	}
}
else 
{
setarray WEAPON_TILE[9] 6654
setarray weap_special[9] 16384
setarray W_AMMO_TILE[9] 6646
setarray ammo_amount[9] 30

set WEAPON9_HOLDDELAY 0
set WEAPON9_INITIALSOUND 0

ife cur_weap 9
	{
	set alt_fire_type 1
	set gun_mag -1
	set GUN_ACCURACY 2
	set GUN_MAX_SPREAD 0
	set GUN_SIZE 2
	set GUN_HANDS 2
	set GUN_AMMO_TYPES 0
	getp[].ammo_amount 9 temp
	ifg temp 0 ife camerasprite -1 soundonce SHOCKGUN_IDLE
	ifl temp 3 ifand gun_firemode 16384 xorvar gun_firemode 16384

			ifand gun_firemode 16384
				{
				set GUN_VOLUME 30
				set weapon_type 7
				set WEAPON9_FIRESOUND SHOCKGUN_SNIPE
				set WEAPON9_FIREDELAY 2
				set WEAPON9_TOTALTIME 20
				set WEAPON9_SHOOTS 0
				set WEAPON9_SHOTSPERBURST 3
				set WEAPON9_FLAGS 80

				ife kickbackpic 2 { shoot GREENLASERSHOT shoot GREENLASERSHOT set gun_pushback_power -32 state gun_pushback }
				ife kickbackpic 3 set gun_recoil 8
				}
			else
				{
				set GUN_VOLUME 12
				set weapon_type 9
				set WEAPON9_FIRESOUND 4
				set WEAPON9_FIREDELAY 2
				set WEAPON9_TOTALTIME 3
				set WEAPON9_SHOOTS 6627
				set WEAPON9_SHOTSPERBURST 1
				set WEAPON9_FLAGS 4

				ife kickbackpic 2 { set gun_recoil 3 espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SHOCKGUN_FIRE }
				}


	}
}

