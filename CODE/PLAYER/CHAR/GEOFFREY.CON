	set GUN_HANDS 1
	set GUN_ACCURACY 16
	set GUN_MAX_SPREAD 96
	set GUN_AMMO_TYPES 0

		ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp GEO_AUTOS_FIRE }
	    ife kickbackpic 3 { set gun_recoil 4 set gunsmoke_angle 64 add gun_spread 10 state spawn_gunsmoke setprojectile[SHOTG_SHELL].pal 5 shoot SHOTG_SHELL setprojectile[SHOTG_SHELL].pal 0 }
	}
