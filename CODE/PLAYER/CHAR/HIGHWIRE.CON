	// ifand HIGHWIRE_UPGRADE 1 set max_slot3_mag 75 else set max_slot3_mag 30
	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp AKM_FIRE }
		ife kickbackpic 2 { sub slot3_mag 1 set gun_recoil 4 state pfakebullet
		ifand gun_firemode 16384 set gunsmoke_angle 0 else set gunsmoke_angle 32 state spawn_gunsmoke }
		ife kickbackpic 3 ifge gun_grace 10 add gun_spread 8

		state check_caseless_grenades_avail

		ife kickbackpic 21
			{
			ifand HIGHWIRE_UPGRADE 1 { sound DRUM_OUT ife slot3_mag 0 shoot DRUM_MAG2 }
			else { state bgar_mag_out_sounds  ife slot3_mag 0 shoot RIFLEMAGAZINE }
			}

		ife kickbackpic 26
			{
			ifl slot3_mag 1 { ifand HIGHWIRE_UPGRADE 1 set max_slot3_mag 75 else set max_slot3_mag 30 }
			else { ifand HIGHWIRE_UPGRADE 1 set max_slot3_mag 76 else set max_slot3_mag 31 }
			}

		ife kickbackpic 34
			{
			ifand HIGHWIRE_UPGRADE 1 sound DRUM_IN else state bgar_mag_in_sounds
			ifl cur_ammo max_slot3_mag set slot3_mag cur_ammo else set slot3_mag max_slot3_mag
			}

		ifand gun_firemode 16384
			{
			ifg kickbackpic 6 { set hide_xhair 0 xorvar gun_firemode 16384 }
			}

		ife kickbackpic 40 sound AUG_MOVEMENT

		ife kickbackpic 48 sound AK_SLIDE
		ife gl_countd 16 soundonce GL_RELOAD

		ife kickbackpic 55 sound AUG_MOVEMENT

		ifg gl_countd 0 sub gl_countd 1


  ifl slot3_mag 1
   ife player[].weapon_pos 0
    ife kickbackpic 0
   {
   	ifn cur_ammo 0
   		{
		set WEAPON3_RELOAD 58
   		setp[].reloading 1
   		setp[].kickback_pic 6
		}
	}

			ifg gl_countd 23
