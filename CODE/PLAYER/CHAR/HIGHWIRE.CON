		ife player[].ammo_amount 7 0 { setp[].reloading 0 setp[].kickback_pic 0 }
		setp[].reloading 1
		ife BELT_LOADOUT[CHAR] 5 ifl kickbackpic 21 setp[].kickback_pic 21
	    else ifl kickbackpic 17 setp[].kickback_pic 17
	    ife kickbackpic 42 { ifg slot7_mag 0 set reload_empty 0 setp[].kickback_pic 30 }
		ifand BITS_PRESS 4 ifg slot7_mag 0 ifg kickbackpic 40 { set shotgun_load 0 setp[].reloading 0 setplayer[].kickback_pic 1 }
		}

	ife slot7_mag 0
		 ife player[].weapon_pos 0
			{
			set reload_empty 1
			setarray needs_pump[cur_weap] 1
			ifl player[].ammo_amount 7 max_slot7_mag set shotgun_load player[].ammo_amount 7 else
			set shotgun_load max_slot7_mag
			}

		ife kickbackpic 0 ifg slot7_mag 0 ife needs_pump[cur_weap] 1 setp[].kickback_pic 6 

		ife kickbackpic 20 soundonce AUG_MOVEMENT

	ife player[].reloading 1
	 ifg player[].ammo_amount 7 0
		{
			ife kickbackpic 40 
				{ 
				espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT 
				ife reload_empty 1 setactorvar[RETURN].temp KS23_SLID else setactorvar[RETURN].temp KS23_INS
				sub shotgun_load 1 add slot7_mag 1
				}
		}

	ife kickbackpic 50 soundonce AUG_MOVEMENT

	}
}
else 
{
setarray WEAPON_TILE[7] 5995
setarray W_AMMO_TILE[7] 5989
setarray ammo_amount[7] 6
setarray weap_special[7] 0
setarray p_max_ammo[7]  50

set WEAPON7_FIREDELAY 2
set WEAPON7_TOTALTIME 16
set WEAPON7_RELOAD 54
set WEAPON7_INITIALSOUND 0
set WEAPON7_SHOOTS 5968
set WEAPON7_FIRESOUND 4
set WEAPON7_SHOTSPERBURST 1
set WEAPON7_FLAGS 0

	ife cur_weap 7
	{
	set alt_fire_type 20
	set reload_type 5
	set weapon_type 4
	set GUN_VOLUME 60
	set GUN_SIZE 2
	set GUN_HANDS 2
	ifand MAGIC_UPGRADE[3] 1 set GUN_AMMO_TYPES 32768
	else set GUN_AMMO_TYPES 0
	set GUN_ACCURACY 8
	set GUN_MAX_SPREAD 0
	ifg slot7_mag 6 set slot7_mag 6
	set max_slot7_mag 6
	set gun_mag slot7_mag
	
	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp RGL_FIRE }
	ife kickbackpic 2 sub slot7_mag 1
	ife kickbackpic 3 { set gun_recoil 6
	set gunsmoke_angle 64 state spawn_gunsmoke }
	ife kickbackpic 4 { set gun_pushback_power -96 state gun_pushback }
	ife kickbackpic 6 soundonce ROTATEBARREL

	ifg kickbackpic_2 0
		{
		add kickbackpic_2 1
		ifge kickbackpic_2 9 set kickbackpic_2 0
		ife kickbackpic_2 3 { set gun_recoil 6
		set gunsmoke_angle 64 state spawn_gunsmoke }
		}

	ifg shotgun_load 0
		{
		ife player[].ammo_amount 7 0 { setp[].reloading 0 setp[].kickback_pic 0 }
		setp[].reloading 1
	    ifl kickbackpic 17 setp[].kickback_pic 17
	    ife kickbackpic 42 setp[].kickback_pic 30
		ifand BITS_PRESS 4 ifg slot7_mag 0 ifg kickbackpic 40 { set shotgun_load 0 setp[].reloading 0 setplayer[].kickback_pic 1 }
		}

	ife slot7_mag 0
		 ife player[].weapon_pos 0
			{
			ifl player[].ammo_amount 7 max_slot7_mag set shotgun_load player[].ammo_amount 7 else
			set shotgun_load max_slot7_mag
			}

		ife kickbackpic 20 soundonce J_GL_OPEN

	ife player[].reloading 1
	 ifg player[].ammo_amount 7 0
		{
		ifand HIGHWIRE_UPGRADE 128 // quickloader? do 2 at a time
			{
			ife kickbackpic 40 
				{ 
				espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp RGL_PUTIN
				ifg shotgun_load 1 { sub shotgun_load 2 add slot7_mag 2 }
				else { sub shotgun_load 1 add slot7_mag 1 }
				}
			ife kickbackpic 41 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp RGL_PUTIN }
			}
		else // normal reload
			{
			ife kickbackpic 40 
				{ 
				espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp RGL_PUTIN
				sub shotgun_load 1 add slot7_mag 1
				}
			}
		}

	ife kickbackpic 50 soundonce J_GL_CLOSE

	}
}

