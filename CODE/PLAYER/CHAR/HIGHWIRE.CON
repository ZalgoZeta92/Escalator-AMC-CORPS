set WEAPON1_FIRESOUND 4
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 5

set WEAPON1_SELECTSOUND SILVER_T_SPIN

ife CHARSELECT 0
	{
	set WEAPON1_FLAGS 16384
	}

	ife cur_weap 1
	{
	set alt_fire_type 0
	set weapon_type 0
	set GUN_VOLUME 50
	set GUN_AMMO_TYPES 0
	set GUN_ACCURACY 4
	set GUN_MAX_SPREAD 64
	set GUN_HANDS 1
	set GUN_SIZE 0
	set gun_mag slot1_mag
	set max_slot1_mag 8
	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp AUTOMAG_FIRE state pfakebullet }
	ife kickbackpic 2
			{
			shoot NINEMM_SHELL
			set gun_recoil 6
			sub slot1_mag 1
			set gunsmoke_angle 64 state spawn_gunsmoke
			}
		ife kickbackpic 3 add gun_spread 20
		ife kickbackpic 20 { sound AUTOMAG_RELOAD ife slot1_mag 0 shoot HEAVY_PISTOL_MAG }

		ife kickbackpic 42
			{
			ife slot1_mag 0 sound AUTOMAG_SLIDE
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}

		ifl slot1_mag 1
		 ife player[].weapon_pos 0
		  ife kickbackpic 0
			{
			ifn cur_ammo 0
				{
				setp[].reloading 1
				setp[].kickback_pic 6
				}
			}
	}
}
else ife SPECIALIST_EQUIPMENT[106] 2 // Survival revolver
{
setarray p_max_ammo[1]  150
setarray WEAPON_TILE[1] 29856
setarray weap_special[1] 16384
setarray W_AMMO_TILE[1] 6847
setarray ammo_amount[1] 10

set WEAPON1_CLIP 0
set WEAPON1_RELOAD 40
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 7
set WEAPON1_HOLDDELAY 0
set WEAPON1_FLAGS 16448
set WEAPON1_SPAWNTIME -1
set WEAPON1_SPAWN 0
set WEAPON1_SHOTSPERBURST 0
set WEAPON1_INITIALSOUND 0
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4

set WEAPON1_FIRESOUND 4
set WEAPON1_SHOOTS 2537

ife cur_weap 1
	{
	set alt_fire_type 0
	set weapon_type 3
	set max_slot1_mag 5
	set gun_mag slot1_mag
	set GUN_VOLUME 14
	set GUN_ACCURACY 4
	set GUN_MAX_SPREAD 64
	set GUN_SIZE 0
	set GUN_AMMO_TYPES 0
	set GUN_HANDS 1

	ifg kickbackpic_2 0
		{
		add kickbackpic_2 1
		ife kickbackpic_2 2
			{
			sub slot1_mag 1
			getp[].ammo_amount 1 temp
			sub temp 1
			setp[].ammo_amount 1 temp
			shoot FLARE_PROJ
			espawn SOUND_SPRITE
			state SPAWN_IN_PLAYER_FRONT
			setactorvar[RETURN].temp SURV_FLR
			}

		ife kickbackpic_2 3
			{
			add gun_spread 20
			set gun_recoil 6
			}

		ife kickbackpic_2 4
			{
			set gunsmoke_angle 144 state spawn_gunsmoke
			}
		ifge kickbackpic_2 7 set kickbackpic_2 0
		}

	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SURV_FIR state pfakebullet }
	ife kickbackpic 2 sub slot1_mag 1

	ife kickbackpic 3
		{
		add gun_spread 20
		set gun_recoil 6
		}

	ife kickbackpic 4
		{
		set gunsmoke_angle 144 state spawn_gunsmoke
		}
	ife kickbackpic 15 sound GR_ROUT
	ife kickbackpic 23
		{
		state revolver_silver_eject
		sub slot1_mag temp4
		}
	ife kickbackpic 27 sound GR_RIN
	ife kickbackpic 28
		{
		ifl cur_ammo 6 set slot1_mag cur_ammo else set slot1_mag max_slot1_mag
		}
		ife kickbackpic 32 sound GR_RHAM
		
	ifg kickbackpic 1
	 ifl kickbackpic 9
		{
		ifand BITS_PRESS 4 ifg slot1_mag 0 
			{
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SURV_FIR state pfakebullet
			setplayer[].kickback_pic 1
			}
		}


		  ifl slot1_mag 1
		   ife player[].weapon_pos 0
			ife kickbackpic 0
		   {
		   ifg cur_ammo 0
			   {
			   setp[].reloading 1
			   setp[].kickback_pic 6
			   }
		   }

	}
}
else // Tokarov?
{
setarray p_max_ammo[1]  200
setarray WEAPON_TILE[1] 5990
ifand guns_akimbo 4 setarray weap_special[1] 4097 else setarray weap_special[1] 4096
setarray W_AMMO_TILE[1] 5981
setarray ammo_amount[1] 16

set WEAPON1_CLIP 0
set WEAPON1_HOLDDELAY 0
set WEAPON1_SHOOTS ZRIFLESHOTU
set WEAPON1_SPAWNTIME 0
set WEAPON1_SPAWN 0
set WEAPON1_INITIALSOUND 0
set WEAPON1_FIRESOUND 4
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 5

ife CHARSELECT 0
{
ifand HIGHWIRE_UPGRADE 4 set WEAPON1_FLAGS 64 else
set WEAPON1_FLAGS 16448
}


	ife cur_weap 1
	{
	set alt_fire_type 0
	set weapon_type 0
	set GUN_AMMO_TYPES 0
	set GUN_SIZE 0
	set gun_mag slot1_mag
	
		ifand gun_firemode 64 // akimbo?
		{
		set WEAPON1_SHOTSPERBURST 2
		set WEAPON1_RELOAD 77
		set GUN_HANDS 2
		set GUN_VOLUME 32
		ifand HIGHWIRE_UPGRADE 8 set GUN_ACCURACY 8 else set GUN_ACCURACY 32
		set GUN_MAX_SPREAD 48
		ifand HIGHWIRE_UPGRADE 2 set max_slot1_mag 40 else set max_slot1_mag 16
		ife kickbackpic 1 
			{ 
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp TOKAROVFIRE 
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp TOKAROVFIRE 
			}
		ife kickbackpic 2
				{
				state pfakebullet
				state pfakebullet_left
				shoot NINEMM_SHELL
				shoot NINEMM_SHELL_LEFT
				set gun_recoil 6
				sub slot1_mag 2
				set gunsmoke_angle 64 state spawn_gunsmoke
				set gunsmoke_angle -64 state spawn_gunsmoke
				}
		ife kickbackpic 3 add gun_spread 10
		ife kickbackpic 16 { sound TMAGOUT ife slot1_mag 0 { ifand HIGHWIRE_UPGRADE 2 shoot SMGMAGAZINE else shoot PISTOL_MAGAZINE } }

		ife kickbackpic 35
			{
			sound TMAGIN
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			div slot1_mag 2
			}
		ife kickbackpic 51 { sound TMAGOUT ife slot1_mag 0 { ifand HIGHWIRE_UPGRADE 2 shoot SMGMAGAZINE else shoot PISTOL_MAGAZINE } }
		ife kickbackpic 69
			{
			sound TMAGIN
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}
		}
	else
		{
		set WEAPON1_SHOTSPERBURST 1
		set WEAPON1_RELOAD 43
		set GUN_HANDS 1
		set GUN_VOLUME 16
		ifand HIGHWIRE_UPGRADE 8 set GUN_ACCURACY 4 else set GUN_ACCURACY 16
		set GUN_MAX_SPREAD 24
		ifand HIGHWIRE_UPGRADE 2 set max_slot1_mag 20 else set max_slot1_mag 8
		ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp TOKAROVFIRE  }
		ife kickbackpic 2
				{
				state pfakebullet
				shoot NINEMM_SHELL
				set gun_recoil 3
				sub slot1_mag 1
				set gunsmoke_angle 64 state spawn_gunsmoke
				}
		ife kickbackpic 3 add gun_spread 5
		ife kickbackpic 35
			{
			sound TMAGIN
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}
		}
	
		ife kickbackpic 16 { sound TMAGOUT ife slot1_mag 0 { ifand HIGHWIRE_UPGRADE 2 shoot SMGMAGAZINE else shoot PISTOL_MAGAZINE } }

		ife kickbackpic 35
			{
			sound TMAGIN
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}

		ifl slot1_mag 1
		   ife player[].weapon_pos 0
		  ife kickbackpic 0
			{
			ifn cur_ammo 0
				{
				setp[].reloading 1
				setp[].kickback_pic 6
				}
			}
	}
}

// SHOTGUN
ife SPECIALIST_EQUIPMENT[13] 2 // Using the Saiga-12?
{
ife BELT_LOADOUT[CHAR] 5 setarray p_max_ammo[2]  60 else
setarray p_max_ammo[2]  50
setarray WEAPON_TILE[2] 12095
setarray W_AMMO_TILE[2] 5225
setarray ammo_amount[2] 8

set WEAPON2_CLIP 0
set WEAPON2_FIREDELAY 2
set WEAPON2_TOTALTIME 4
set WEAPON2_HOLDDELAY 0
set WEAPON2_FLAGS 17408
set WEAPON2_SHOOTS 2613
set WEAPON2_SPAWNTIME 24
set WEAPON2_SPAWN 0
set WEAPON2_SHOTSPERBURST 7
set WEAPON2_INITIALSOUND 0
set WEAPON2_FIRESOUND 4
set WEAPON2_SOUND2TIME 15
set WEAPON2_SOUND2SOUND 0
set WEAPON2_RELOADSOUND1 0
set WEAPON2_RELOADSOUND2 0

	ife cur_weap 2
	{
	set weapon_type 2
	set reload_type 2
	set alt_fire_type 1
		set gun_mag alt_slot2_mag
		set max_alt_slot2_mag 8
		setarray weap_special[2] 16388
		set GUN_VOLUME 70
		set GUN_AMMO_TYPES 0
		set GUN_MAX_SPREAD 32
		set GUN_SIZE 2
		set GUN_HANDS 2
		set reload_frame_partial 41

		ifand gun_firemode 16384
			{
			set GUN_ACCURACY 12
			ifg kickbackpic 6 { set hide_xhair 0 xorvar gun_firemode 16384 }
			}
			else
			set GUN_ACCURACY 20
		ifand BITS_PRESS 4
		  ifg alt_slot2_mag 0
		   ife player[].ammo_amount 2 0
		   ife need_to_fire 0
		   ife player[].weapon_pos 0
			{
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SAIGA12_FIRE
			setp[].ammo_amount 2 1
			setp[].kickback_pic 1
			set need_to_fire 1
			}
		ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SAIGA12_FIRE }
		ife kickbackpic 2 // IF THE SHOTGUN ANIMATION IS ON IT'S 2nd FRAME MOVE THE PLAYERS SCREEN UP...
		{
		state pfakebullet_shotgun
		sub alt_slot2_mag 1
		ife need_to_fire 1 set need_to_fire 0 else
			{
			getp[].ammo_amount 2 temp2
			add temp2 1
			setp[].ammo_amount 2 temp2
			}

		set gun_recoil 6

		set gun_pushback_power -32
		state gun_pushback

		set gunsmoke_angle 64 state spawn_gunsmoke
		}
		ife kickbackpic 3 add gun_spread 12

		ifand AMMO_TYPES[cur_weap] 1 { xorvar AMMO_TYPE 1 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
		ifand AMMO_TYPES[cur_weap] 4 { xorvar AMMO_TYPE 4 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }

		ife kickbackpic 52 sound VAL_SLIDE

		ife kickbackpic 3 shoot SHOTG_SHELL

	  ifl alt_slot2_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
	   {
	   ifn cur_ammo 0
		   {
		   set WEAPON2_RELOAD 61
		   setp[].reloading 1
		   setp[].kickback_pic reload_frame
		   }
		}

	ife kickbackpic 15 state bgar_mag_out_sounds
	ife kickbackpic 16 ife alt_slot2_mag 0 shoot RIFLEMAGAZINE
	ife kickbackpic 37
		{
		state bgar_mag_in_sounds
			set temp5 alt_slot2_mag
			set temp6 max_alt_slot2_mag
			sub temp6 temp5

				ifg temp6 cur_ammo
					{
					add alt_slot2_mag cur_ammo
					setp[].ammo_amount 2 0
					}
					else
					{
					getp[].ammo_amount 2 temp4 sub temp4 temp6 setp[].ammo_amount 2 temp4
					set alt_slot2_mag max_alt_slot2_mag
					}
		}

	}

}
else
ife SPECIALIST_EQUIPMENT[65] 2 // Using the Golden Triple threat?
{
ife BELT_LOADOUT[CHAR] 5 setarray p_max_ammo[2]  72 else
setarray p_max_ammo[2]  60
setarray WEAPON_TILE[2] 19774
setarray W_AMMO_TILE[2] 5982
setarray ammo_amount[2] 8
