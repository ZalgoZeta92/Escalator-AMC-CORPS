	set GUN_HANDS 2
	set gun_mag -1
	set GUN_AMMO_TYPES 0
	set GUN_ACCURACY 8
	set GUN_MAX_SPREAD 0
	}
}

// FREEZER
ife SPECIALIST_EQUIPMENT[35] 2 // PKM?
{
setarray p_max_ammo[9]  300
setarray WEAPON_TILE[9] 13456
setarray weap_special[9] 0
setarray W_AMMO_TILE[9] 13457
setarray ammo_amount[9] 40

set WEAPON9_FIREDELAY 2
// set WEAPON9_RELOAD 78
set WEAPON9_TOTALTIME 4
set WEAPON9_INITIALSOUND 0
set WEAPON9_SHOOTS MSCORP_SHOT
set WEAPON9_FIRESOUND 4
set WEAPON9_SHOTSPERBURST 1
set WEAPON9_FLAGS 4

	ife cur_weap 9
	{
	set weapon_type 0
	set alt_fire_type 0
	set GUN_VOLUME 25
	set GUN_HANDS 2
	set GUN_AMMO_TYPES 0
	set GUN_SIZE 3
	set GUN_ACCURACY 16
	set GUN_MAX_SPREAD 64
	set gun_mag slot9_mag
	set max_slot9_mag 100
	set reload_frame_partial 78

		ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp PKM_FIRE }
		ife kickbackpic 2 { set gun_recoil 5 state pfakebullet }
		ifg kickbackpic 0 ifl kickbackpic 5 { set gun_pushback_power -1 state gun_pushback }

	ife kickbackpic 3 { ifge gun_grace 20 add gun_spread 16 set gunsmoke_angle 64 state spawn_gunsmoke }

	ife kickbackpic 14 sound PKM_COVER_U
	ife kickbackpic 26 sound PKM_BOX_OUT
	ife kickbackpic 40 sound PKM_BOX_IN
	ife kickbackpic 48 sound PKM_CHAIN
	ife kickbackpic 75 sound PKM_COVER_D
	ife kickbackpic 87 sound FG42_COCK

	ife kickbackpic 52
		{
		ifl cur_ammo max_slot9_mag set slot9_mag cur_ammo else set slot9_mag max_slot9_mag
		}


	  ifl slot9_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
	   {
		ifn cur_ammo 0
			{
			set WEAPON9_RELOAD 98
			setp[].reloading 1
			setp[].kickback_pic 5
			}
		}

	}
}
else
ife SPECIALIST_EQUIPMENT[11] 2 // RPKM?
{
setarray p_max_ammo[9] 400
setarray WEAPON_TILE[9] 11880
ifand MAGIC_UPGRADE[3] 2 setarray weap_special[9] 16384
else setarray weap_special[9] 0
setarray W_AMMO_TILE[9] 6127
setarray ammo_amount[9] 80

set WEAPON9_FIREDELAY 2

set WEAPON9_TOTALTIME 4
set WEAPON9_INITIALSOUND 0
set WEAPON9_SHOOTS ARMOUR_PIERCING_SHOT
set WEAPON9_FIRESOUND 4
set WEAPON9_SHOTSPERBURST 1
set WEAPON9_FLAGS 4

set WEAPON9_SELECTSOUND SELECT_AK

	ife cur_weap 9
	{
	set weapon_type 0
	set alt_fire_type 0
	set GUN_VOLUME 20
	set GUN_HANDS 2

	ifand MAGIC_UPGRADE[3] 2 set GUN_AMMO_TYPES 8192
	else set GUN_AMMO_TYPES 0

	set GUN_SIZE 1
	set GUN_ACCURACY 8
	set GUN_MAX_SPREAD 32
	set gun_mag slot9_mag
	set max_slot9_mag 45
	set reload_frame_partial 42


	ifg kickbackpic_2 0
		{
		add kickbackpic_2 1
		ifge kickbackpic_2 3 set kickbackpic_2 0
		ife kickbackpic_2 3 { set gun_recoil 6 
		set gunsmoke_angle 64 state spawn_gunsmoke state pfakebullet }
		}

	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp RPKM_F }
	ife kickbackpic 2 { set gun_recoil 4 state pfakebullet ifge gun_grace 20 add gun_spread 7 }
	ifg kickbackpic 0 ifl kickbackpic 5 { set gun_pushback_power -1 state gun_pushback }
	ife kickbackpic 3 { set gunsmoke_angle 64 state spawn_gunsmoke }
	ife kickbackpic 18 state bgar_mag_out_sounds
	ife kickbackpic 30 ife slot9_mag 0 shoot RIFLEMAGAZINE
	ife kickbackpic 57 sound AK_SLIDE
	ife kickbackpic 35
		{
		state bgar_mag_in_sounds
		ifl cur_ammo max_slot9_mag set slot9_mag cur_ammo else set slot9_mag max_slot9_mag
		}
	  ifl slot9_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
	   {
		ifn cur_ammo 0
			{
			set WEAPON9_RELOAD 58
			setp[].reloading 1
			setp[].kickback_pic 5
			}
		}
	}
}
else // RPK?
{
setarray p_max_ammo[9]  400
setarray WEAPON_TILE[9] 5996
setarray weap_special[9] 16384
setarray W_AMMO_TILE[9] 5980
setarray ammo_amount[9] 75

set WEAPON9_FIREDELAY 2
ifand HIGHWIRE_UPGRADE 256 set WEAPON9_TOTALTIME 3 else
set WEAPON9_TOTALTIME 4
set WEAPON9_INITIALSOUND 0
set WEAPON9_SHOOTS MSCORP_SHOT
set WEAPON9_FIRESOUND 4
set WEAPON9_SHOTSPERBURST 1
set WEAPON9_FLAGS 4

	ife cur_weap 9
	{
	set weapon_type 0
	set alt_fire_type 9
	set GUN_VOLUME 20
	set GUN_HANDS 2
	set GUN_AMMO_TYPES 0
	set GUN_SIZE 2
	set gun_mag slot9_mag
	set max_slot9_mag 75
	set reload_frame_partial 64
	ifand gun_firemode 512 // Tripod active?
		{
		set GUN_ACCURACY 8
		set GUN_MAX_SPREAD 16
		ife kickbackpic 2 { set gun_recoil 3 ifge gun_grace 20 add gun_spread 4 }
		}
	else
		{
		set GUN_ACCURACY 24
		set GUN_MAX_SPREAD 48
		ife kickbackpic 2 { set gun_recoil 5 ifge gun_grace 20 add gun_spread 8 }
		ifg kickbackpic 0 ifl kickbackpic 5 { set gun_pushback_power -6 state gun_pushback }
		}

	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp RPK_FIRE }
	ife kickbackpic 2 { state pfakebullet set gunsmoke_angle 64 state spawn_gunsmoke }
	ife kickbackpic 10 sound AUG_MOVEMENT
	ife kickbackpic 28 soundonce DRUM_OUT
	ife kickbackpic 30 ife slot9_mag 0 shoot DRUM_MAG2

	ife kickbackpic 42
	{
	soundonce DRUM_IN
	ifl cur_ammo max_slot9_mag set slot9_mag cur_ammo else set slot9_mag max_slot9_mag
	}

		ife kickbackpic 60 sound AUG_MOVEMENT

		ife kickbackpic 73 sound AK_SLIDE
		ife gl_countd 83 sound AUG_MOVEMENT

	ifand gun_firemode 512
		{
		ifand BITS_PRESS 64
		ifcount 16
			{
			state lower_weapon
			xorvar gun_firemode 512
			soundonce PUT_ON_EQUIP
			resetcount
			}
		}
		else
		ifp pstanding
		{
		state checkwall
			ife WALL_CLOSE 1
				set player_bipod 0
		}


	  ifl slot9_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
	   {
		ifn cur_ammo 0
			{
			set WEAPON9_RELOAD 85
			setp[].reloading 1
			setp[].kickback_pic 5
			}
		}

	}
}

