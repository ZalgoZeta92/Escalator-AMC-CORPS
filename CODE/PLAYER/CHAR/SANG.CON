		set C_ARM_1 23850
		set C_ARM_2 23849
		set CHOLDING_R 23883
		set CHOLDING_L 23883
		}
	else
		{
		set CKEYCARDTILE 23863
		set CKEYCARDTILE2 23865
		set CKEYCARDTILE3 23866
		set CTRIPBOMB 23864
		set C_HAND_1 6363
		set C_HAND_2 6364
		set CPIPEBOMB 6256
		set CDETON 23846
		set C_ARM_1 23850
		set C_ARM_2 23849
