			set WEAPON3_FIRESOUND 4
			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SUP_TMP }
			ifand gun_firemode 1024 set GUN_VOLUME 8 else set GUN_VOLUME 4
