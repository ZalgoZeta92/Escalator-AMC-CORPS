ife SPECIALIST_EQUIPMENT[92] 2 // using the KRISS?
{
setarray WEAPON_TILE[3] 29145
setarray wep_get_sound[3] PICK_SMG
setarray weap_special[3] 16384
setarray W_AMMO_TILE[3] 5362
setarray ammo_amount[3] 40

