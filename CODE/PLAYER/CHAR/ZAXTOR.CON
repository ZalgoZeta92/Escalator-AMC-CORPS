		set GUN_MAX_SPREAD 16
		}
	set GUN_SIZE 0
	set GUN_VOLUME 6
	set gun_mag -1
	set WEAPON3_SHOTSPERBURST 1
	ifand gun_firemode 1024
		set GUN_HANDS 2
		else
		set GUN_HANDS 1
	ifg kickbackpic_2 0
		{
		add kickbackpic_2 1
		ifg kickbackpic_2 2 set kickbackpic_2 0
		}
	ife kickbackpic_2 2
		{
		state pfakebullet_left
		shoot FIRE_BULLET
		espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp ZAX_SMG
		set gun_recoil 4
		ifge gun_grace 5 add gun_spread 6
		set gunsmoke_angle -64
		state spawn_gunsmoke
		getp[].ammo_amount 3 temp
		ifg temp 0 sub temp 1
		setp[].ammo_amount 3 temp
			randvar temp 1024
			zshoot temp NINEMM_SHELL_LEFT
		}
	ife kickbackpic 2 { set gun_recoil 4 ifge gun_grace 5 add gun_spread 6 espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp ZAX_SMG state pfakebullet }
	}
}

