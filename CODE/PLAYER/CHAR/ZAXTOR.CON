set WEAPON3_SELECTSOUND SELECT_SMG

	ife cur_weap 3
	{
	set alt_fire_type 0
	set weapon_type 0
	set GUN_AMMO_TYPES 0
	ifand ZAXTOR_UPGRADE 16
		{
		ifand gun_firemode 16384
			set GUN_ACCURACY 6
		else
			set GUN_ACCURACY 16
		set GUN_MAX_SPREAD 4
		}
	else
		{
		ifand gun_firemode 16384
			set GUN_ACCURACY 12
