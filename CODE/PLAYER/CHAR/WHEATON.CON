defstate wheaton_alt_fire
/*
ife CHAR 18 // Wheaton
    {

    }
*/
ends

defstate PS_WHEATON
{
set P_GENDER MALE

setuserdef[].userquote_xoffset 0
setuserdef[].userquote_yoffset 130

qputs 90 Vitamin X!
qputs 12 Used Vitamin X!

ife HELMET_LOADOUT[CHAR] 4
	{
	qputs 101 Ghost vision goggles
	qputs 106 Ghost vision on
	qputs 107 Ghost vision off
	}
else
ife HEAT_GOGGLES 1
	{
	qputs 101 Heat vision goggles
	qputs 106 Heat vision on
	qputs 107 Heat vision off
	}
else
	{
	qputs 101 Night vision goggles
	qputs 106 Night vision on
	qputs 107 Night vision off
	}

qputs 6 GiroTek Protective Boots
qputs 75 Protective boots: %d %
set temp player[].boot_amount
ife PERSONNEL_RESEARCH[26] 2 div temp 3 else div temp 2
qsprintf 75 75 temp

qputs 3 Portable Medikit

qputs 89 Airtank

qputs 47 Support Radio
qputs 48 Support Radio
qputs 49 Support Radio not found yet!
qputs 51 Support Radio!
qstrcpy 91 51

qputs 88 Jetpack
qputs 50 Jetpack not found yet!
qputs 52 Jetpack on
qputs 53 Jetpack off

qputs 102 We're gonna fry your ass, Adams!

setp[].knuckle_incs 0

set fist_tile 35918

set CKNEE 35904
set CKEYCARDTILE 35906
set CKEYCARDTILE2 35908
set CKEYCARDTILE3 35909
set CTRIPBOMB 35907

set CDETON 2570
set CTIP 35910

set CPIPEBOMB 35937

set CHOLDING_R 35912
set CHOLDING_L 35912
set CHOLDING_3 35913

set C_ARM_1 35914
set C_ARM_2 35915
set C_ARM_3 35921

set C_PUNCH 35925

set C_PISTOL_R 35920
set C_PISTOL_L 35920

set C_HAND_1 35916
set C_HAND_2 35917

set c_medikit 36072
set c_steroids 36073
set c_jetpack 35846

set c_nvg_heat 35843
set c_nvg_normal 35843

state DISP_nvg

set c_scuba 35845
set c_boots 35842

set c_holoduke 36074

ifg AGENT_FATIGUE[CHAR] 5000 ifg SKILL_LEVEL 2 set pmax_stamina 120 else
set pmax_stamina 150

set c_armour 35844
set c_heavy_armour 35844

ife BELT_LOADOUT[CHAR] 5 setarray p_max_ammo[2]  80 else
setarray p_max_ammo[2]  60
setarray p_max_ammo[3]  400
setarray p_max_ammo[4]  40
setarray p_max_ammo[6]  50

setarray p_max_ammo[11] 100

getp[].holoduke_on temp8
ifn temp8 -1
{

stopsound TELEPORTER
stopsound SOMETHINGHITFORCE
sound RADIO

	espawn EAFSOLDIER_ACTIVE
	espawn EAFSOLDIER_ACTIVE

	getp[].posx temp
	getp[].posy temp2

	set temp3 temp
	add temp3 768

	randvar temp4 2048

	rotatepoint temp temp2 temp3 temp2 temp4 temp5 temp6

	getp[].cursectnum upd_sect
	updatesectorz temp5 temp6 player[].posz upd_sect
	ife upd_sect -1 nullop else
	{

		getp[].posz temp7
		add temp7 5600
		setsprite RETURN temp5 temp6 temp7
	}
	getp[].holoduke_amount temp
	ifle temp 2400 ifg temp 1800 setp[].holoduke_amount 1800
	else ifle temp 1800 ifg temp 1200 setp[].holoduke_amount 1200
	else ifle temp 1200 ifg temp 600 setp[].holoduke_amount 600
	else ifle temp 600 ifg temp 0 setp[].holoduke_amount 0
setp[].holoduke_on -1
}

ife player[].steroids_amount 398
{
sound SOMETHINGHITFORCE
spawn TRANSPORTERBEAM
spawn EAF_MECH
}

ife player[].steroids_amount 30 sound POWERUP_LOW
ife player[].steroids_amount 60 sound POWERUP_LOW
ife player[].steroids_amount 90 sound POWERUP_LOW
ife player[].steroids_amount 120 sound POWERUP_LOW
ife player[].steroids_amount 150 sound POWERUP_LOW

// weapon pickup sounds
setarray wep_get_sound[1] PICK_PISTOL
setarray wep_get_sound[2] PICK_SHOTG
setarray wep_get_sound[3] PICK_RIFLE
setarray wep_get_sound[4] PICK_BIGGUN

setarray wep_get_sound[6] PICK_RIFLE
setarray wep_get_sound[7] PICK_BIGGUN
setarray wep_get_sound[9] PICK_ENERG

// select sounds
set WEAPON1_SELECTSOUND SELECT_PISTOL
set WEAPON2_SELECTSOUND SELECT_SHOTGUN
set WEAPON4_SELECTSOUND SELECT_WEAPON
set WEAPON6_SELECTSOUND SELECT_SNIPER
set WEAPON7_SELECTSOUND SELECT_BIG_WEAPON
set WEAPON9_SELECTSOUND SELECT_HT_BIGGUN
set WEAPON11_SELECTSOUND SELECT_SNIPER

// MELEE
ife temp_weap 0
{
	set WEAPON0_TOTALTIME 17
	set WEAPON0_HOLDDELAY 17
	set WEAPON0_FIREDELAY 7
	set WEAPON0_FIRESOUND 532
	set WEAPON0_SHOOTS 5357

ife cur_weap 0
	{
	set weapon_type 0
	set GUN_HANDS 1
	set gun_mag -1
	ife kickbackpic 15 { sound PUNCH shoot 5357 }
	}
}


// Pistol
ife SPECIALIST_EQUIPMENT[153] 2 // Gold laser gun
{
setarray p_max_ammo[1]  200
setarray WEAPON_TILE[1] 35575
setarray weap_special[1] 0
setarray W_AMMO_TILE[1] 5220
setarray ammo_amount[1] 6

set WEAPON1_CLIP 0
set WEAPON1_RELOAD 40
set WEAPON1_HOLDDELAY 0
set WEAPON1_SHOOTS 19807
set WEAPON1_SPAWNTIME 2
set WEAPON1_SPAWN 0
set WEAPON1_SHOTSPERBURST 1
set WEAPON1_INITIALSOUND 0
set WEAPON1_FIRESOUND 4
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 4

set WEAPON1_FLAGS 16388

	ife cur_weap 1
	{
	set alt_fire_type 0
	set weapon_type 3
	set GUN_VOLUME 2
	set GUN_HANDS 1
	set GUN_AMMO_TYPES 0
	set GUN_MAX_SPREAD 48
	set GUN_SIZE 0
	set GUN_ACCURACY 4
	set WEAPON1_FIREDELAY 2
	set WEAPON1_TOTALTIME 6

	set gun_mag slot1_mag
	set max_slot1_mag 10

		ife kickbackpic 1
			{
			espawn SOUND_SPRITE
			state SPAWN_IN_PLAYER_FRONT
			setactorvar[RETURN].temp LPM_F
			}
		ife kickbackpic 2
			{
			state pfakebullet
			sub slot1_mag 1
			set gun_recoil 8
			}
		ife kickbackpic 3
			{
			add gun_spread 12
			set gunsmoke_angle 64
			state spawn_gunsmoke
			}
		ife kickbackpic 15 sound GPM_REL
		ife kickbackpic 22 ife slot1_mag 0 { sound HEAT_SINK_EJECT shoot HEAT_SINK }

		ife kickbackpic 32
			{
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}


		ifl slot1_mag 1
		   ife player[].weapon_pos 0
		  ife kickbackpic 0
			{
			ifn cur_ammo 0
				{
				set reload_empty 1
				setp[].reloading 1
				setp[].kickback_pic 6
				}
			}
	}
}
else
ife SPECIALIST_EQUIPMENT[150] 2 // Using Longslide pistol?
{
setarray WEAPON_TILE[1] 17982
setarray weap_special[1] 16384
setarray W_AMMO_TILE[1] 5220
setarray ammo_amount[1] 14
setarray p_max_ammo[1]  150

set WEAPON1_FIREDELAY 2
set WEAPON1_HOLDDELAY 6
set WEAPON1_INITIALSOUND 4
set WEAPON1_SHOTSPERBURST 1
set WEAPON1_FIRESOUND 4
set WEAPON1_SPAWN 0
set WEAPON1_CLIP 0

set WEAPON1_RELOAD 43
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4

	ife cur_weap 1
	{
	set alt_fire_type 3
	set GUN_VOLUME 8
	set GUN_HANDS 1
	set GUN_MAX_SPREAD 32
	set GUN_AMMO_TYPES 2
	set GUN_SIZE 0

	ifand gun_firemode 2048 // laser-sight activated = semi-auto mode
		{
		set GUN_ACCURACY 2
		set WEAPON1_FLAGS 16448
		set WEAPON1_TOTALTIME 9
		ifg kickbackpic 1
		 ifl kickbackpic 9
			{
			ifand BITS_PRESS 4 ifg slot1_mag 0 setplayer[].kickback_pic 1
			}
		}
	else // laser-sight off = auto mode
		{
		set WEAPON1_TOTALTIME 5
		set GUN_ACCURACY 12
		set WEAPON1_FLAGS 0
		}

		ifand AMMO_TYPES[cur_weap] 2 // using silver ammo
		 ifg silver_ammo 0
			{
			set weapon_type 7
			set WEAPON1_SHOOTS SILVERAMMOSHOT
			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp TOMMYG_SFIRE set gun_recoil 5 }
			}
		else
		ifand AMMO_TYPES[cur_weap] 32768 // using incendiary ammo
		 ifg incend_ammo 0
			{
			set weapon_type 0
			set WEAPON1_SHOOTS FIRE_BULLET
			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp INCEND_FIRE set gun_recoil 5 }
			}
		else
			{
			set weapon_type 2
			set WEAPON1_SHOOTS RMAXREVOLVERSHOT
			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp LONGSLIDE_SHOOT set gun_recoil 10 }
			}

	set gun_mag slot1_mag
	set max_slot1_mag 8

	ife player[].weapon_pos 0
	 ifand gun_firemode 2048
				{
				state spawn_lasersite
				seta[RETURN].x hitx
				seta[RETURN].y hity
				seta[RETURN].z hitz
				ifand SPECIALIST_CUSTOM[5] 1073741824 seta[RETURN].pal 1
				else ifand SPECIALIST_CUSTOM[5] 2147483648 seta[RETURN].pal 8
				else seta[RETURN].pal 0
				}

		ife kickbackpic 2
			{
			state pfakebullet
			ifand AMMO_TYPES[cur_weap] 2 shoot SRIFLESHELL else shoot NINEMM_SHELL
			}

		ife kickbackpic 3
			{
			ifand AMMO_TYPES[cur_weap] 2 ifg silver_ammo 0 { getp[].ammo_amount 1 temp add temp 1 setp[].ammo_amount 1 temp sub silver_ammo 1 }
			ifand AMMO_TYPES[cur_weap] 32768 ifg incend_ammo 0 { getp[].ammo_amount 1 temp add temp 1 setp[].ammo_amount 1 temp sub incend_ammo 1 }
			sub slot1_mag 1

			// Default back to normal ammo
			ifand AMMO_TYPES[cur_weap] 2 ifle silver_ammo 0 { set slot1_mag 0 setarray AMMO_TYPES[cur_weap] 0 }
			else ifand AMMO_TYPES[cur_weap] 32768 ifle incend_ammo 0 { set slot1_mag 0 setarray AMMO_TYPES[cur_weap] 0 }

			add gun_spread 12
			set gunsmoke_angle 64
			state spawn_gunsmoke
			}


		ife kickbackpic 13 { sound S1911_RELOAD ife slot1_mag 0 { set reload_empty 1 shoot PISTOL_MAGAZINE } }
		ife kickbackpic 15 state JMOVESOUND2
		ife kickbackpic 35
		{
		ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
		}

		  ifl slot1_mag 1
		   ife player[].weapon_pos 0
			ife kickbackpic 0
			 ifn CHARSELECT 1
		   {
		   ifn cur_ammo 0
			   {
			   setp[].reloading 1
			   setp[].kickback_pic 6
			   }
		   }

	}
}
else
{
setarray p_max_ammo[1]  200
setarray WEAPON_TILE[1] 35847
setarray weap_special[1] 1280
setarray W_AMMO_TILE[1] 5220
setarray ammo_amount[1] 8

set WEAPON1_CLIP 0
set WEAPON1_RELOAD 36
set WEAPON1_HOLDDELAY 0
set WEAPON1_SHOOTS RMAXREVOLVERSHOT
set WEAPON1_SPAWNTIME 2
set WEAPON1_SPAWN 0
set WEAPON1_SHOTSPERBURST 0
set WEAPON1_INITIALSOUND 0
set WEAPON1_FIRESOUND 4
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 4

set WEAPON1_FLAGS 16388

	ife cur_weap 1
	{
	ifand WHEATON_UPGRADE 2 set alt_fire_type 5
	else set alt_fire_type 0
	set weapon_type 0
	set GUN_VOLUME 2
	set GUN_HANDS 1
	set GUN_AMMO_TYPES 0
	set GUN_MAX_SPREAD 48
	set GUN_SIZE 0
	set GUN_ACCURACY 4
	set WEAPON1_FIREDELAY 2
	set WEAPON1_TOTALTIME 6

	set gun_mag slot1_mag
	ifand WHEATON_UPGRADE 1 set max_slot1_mag 16 else
	set max_slot1_mag 8

		ife kickbackpic 1
			{
			espawn SOUND_SPRITE
			state SPAWN_IN_PLAYER_FRONT
			setactorvar[RETURN].temp WH_WELROD
			}
		ife kickbackpic 2
			{
			state pfakebullet
			sub slot1_mag 1
			set gun_recoil 8
			}
		ife kickbackpic 3
			{
			shoot NINEMM_SHELL
			add gun_spread 12
			set gunsmoke_angle 64
			state spawn_gunsmoke
			}
		ife kickbackpic 12 { sound DEAGLE_RELOAD ife slot1_mag 0 shoot PISTOL_MAGAZINE }

		ife kickbackpic 29
			{
			sound DEAGLE_MAGIN
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}

			ife kickbackpic 41 ife reload_empty 1 { sound DEAGLE_SLIDE set reload_empty 0 set gun_recoil 2 }

		ifl slot1_mag 1
		   ife player[].weapon_pos 0
		  ife kickbackpic 0
			{
			ifn cur_ammo 0
				{
				set reload_empty 1
				setp[].reloading 1
				setp[].kickback_pic 6
				}
			}
	}
}

ife BELT_LOADOUT[CHAR] 5 setarray p_max_ammo[2]  72 else
setarray p_max_ammo[2]  60

ife SPECIALIST_EQUIPMENT[152] 2 // Gold SPAS-15
{
ife BELT_LOADOUT[CHAR] 5 setarray p_max_ammo[2]  84 else
setarray p_max_ammo[2]  70
setarray WEAPON_TILE[2] 35571
setarray W_AMMO_TILE[2] 5982
setarray ammo_amount[2] 7
setarray weap_special[2] 0

set WEAPON2_CLIP 0
set WEAPON2_RELOAD 36
set WEAPON2_FIREDELAY 3
set WEAPON2_TOTALTIME 7
set WEAPON2_HOLDDELAY 32
set WEAPON2_FLAGS 1024
set WEAPON2_SHOOTS GOLDEN_SHOT_LOW
set WEAPON2_SPAWNTIME 5
set WEAPON2_SPAWN 0
set WEAPON2_SHOTSPERBURST 7
set WEAPON2_INITIALSOUND 0
set WEAPON2_FIRESOUND 4
set WEAPON2_SOUND2TIME 15
set WEAPON2_SOUND2SOUND 4
set WEAPON2_RELOADSOUND1 4
set WEAPON2_RELOADSOUND2 5

	ife cur_weap 2
	{
	set reload_type 2 // shotgun box mag
	set weapon_type 3
	set alt_fire_type 0
	set GUN_VOLUME 70
	set GUN_MAX_SPREAD 24
	set GUN_SIZE 2
	set GUN_HANDS 2
	set GUN_AMMO_TYPES 0
	set gun_mag alt_slot2_mag
	set max_alt_slot2_mag 6

		ifand BITS_PRESS 4
		  ifg alt_slot2_mag 0
		   ife kickbackpic 0
		   ife player[].ammo_amount 2 0
		   ife need_to_fire 0
		   ife player[].weapon_pos 0
			{
			getp[].ammo_amount 2 hold_ammo_temp
			add hold_ammo_temp 1
			setp[].ammo_amount 2 hold_ammo_temp
			espawn SOUND_SPRITE
			state SPAWN_IN_PLAYER_FRONT
			setactorvar[RETURN].temp SPAS15_F
			setp[].kickback_pic 1
			set need_to_fire 1
			}

		ifand gun_firemode 16384
			{
			set GUN_ACCURACY 10
			ifg kickbackpic 6 { xorvar gun_firemode 16384 set hide_xhair 0 }
			}
			else set GUN_ACCURACY 16

	ife kickbackpic 1
		{
		espawn SOUND_SPRITE
		state SPAWN_IN_PLAYER_FRONT
		setactorvar[RETURN].temp SPAS15_F
		}

	ife kickbackpic 2
		{
		state pfakebullet_shotgun
		set gun_recoil 12
		add gun_spread 12
		sub alt_slot2_mag 1
		getp[].ammo_amount 2 hold_ammo_temp
		add hold_ammo_temp 1
		setp[].ammo_amount 2 hold_ammo_temp
		set gunsmoke_angle 96
		state spawn_gunsmoke
		}
			ife kickbackpic 3
			{
			setprojectile[SHOTG_SHELL].pal 40 shoot SHOTG_SHELL setprojectile[SHOTG_SHELL].pal 0
			geta[RETURN].ang temp sub temp 1024 seta[RETURN].ang temp
			ife need_to_fire 1
				{
				setp[].ammo_amount 2 0
				set need_to_fire 0
				}
			}
			ife kickbackpic 10 state JMOVESOUND2
			ife kickbackpic 13 { state bgar_mag_out_sounds ife alt_slot2_mag 0 shoot SHOTGUNBOXMAGAZINE}
			ife kickbackpic 24 state JMOVESOUND2
			ife kickbackpic 32
			{
			state bgar_mag_in_sounds
			set temp5 alt_slot2_mag
			set temp6 max_alt_slot2_mag
			sub temp6 temp5
			ifg temp6 cur_ammo
				{
				add alt_slot2_mag cur_ammo
				setp[].ammo_amount 2 0
				}
			else
				{
				getp[].ammo_amount 2 hold_ammo_temp
				sub hold_ammo_temp temp6
				setp[].ammo_amount 2 hold_ammo_temp
				set alt_slot2_mag max_alt_slot2_mag
				}
			}

		ifl alt_slot2_mag 1
		   ife player[].weapon_pos 0
			ife kickbackpic 0
		   {
		   ifn cur_ammo 0
			   {
			   setp[].reloading 1
			   setp[].kickback_pic 6
			   }
			}
	}
}
else
ife SPECIALIST_EQUIPMENT[119] 2 // player using automatic Onagre?
{
setarray WEAPON_TILE[2] 36071
setarray W_AMMO_TILE[2] 13321
setarray ammo_amount[2] 10
setarray weap_special[2] 0

set WEAPON2_CLIP 0
set WEAPON2_FIREDELAY 2
set WEAPON2_TOTALTIME 5
set WEAPON2_RELOAD 40
set WEAPON2_HOLDDELAY 0
set WEAPON2_FLAGS 0
set WEAPON2_SHOOTS 2613
set WEAPON2_SPAWNTIME 24
set WEAPON2_SPAWN 0
set WEAPON2_SHOTSPERBURST 7
set WEAPON2_INITIALSOUND 0
set WEAPON2_FIRESOUND 4
set WEAPON2_SOUND2TIME 15
set WEAPON2_SOUND2SOUND 0
set WEAPON2_RELOADSOUND1 0
set WEAPON2_RELOADSOUND2 0

	ife cur_weap 2
	{
	set alt_fire_type 0
	set reload_type 2
	set weapon_type 2
		set gun_mag alt_slot2_mag
		set max_alt_slot2_mag 20
		set GUN_VOLUME 50
		set GUN_HANDS 2
		set GUN_ACCURACY 24
		set GUN_MAX_SPREAD 24
		set GUN_SIZE 2
		set GUN_AMMO_TYPES 0

		ife kickbackpic 2
			{
			state pfakebullet_shotgun
			getp[].ammo_amount 2 temp2
			add temp2 1
			setp[].ammo_amount 2 temp2
			sub alt_slot2_mag 1
			}

	ifand BITS_PRESS 4
		  ifg alt_slot2_mag 0
		   ife player[].ammo_amount 2 0
		   ife need_to_fire 0
		   ife player[].weapon_pos 0
			{
			getp[].ammo_amount 2 temp2
			add temp2 1
			setp[].ammo_amount 2 temp2
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp WH_ONSHOTGA
			setp[].kickback_pic 1
			set need_to_fire 1
			}

	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp WH_ONSHOTGA }
	ife kickbackpic 3
		{
		add gun_spread 20
		ife need_to_fire 1
			{
			setp[].ammo_amount 2 0
			set need_to_fire 0
			}
		}
	ife kickbackpic 3 // IF THE SHOTGUN ANIMATION IS ON IT'S 4TH FRAME MOVE THE PLAYERS SCREEN UP...
		{
		set gun_recoil 6
		set gun_pushback_power -64
		state gun_pushback
		set gunsmoke_angle 64 state spawn_gunsmoke
		set gunsmoke_angle 48 state spawn_gunsmoke
		shoot SHOTG_SHELL
		}
	  ifl alt_slot2_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
		   {
		   ifn cur_ammo 0
			   {
			   setp[].reloading 1
			   setp[].kickback_pic 6
			   }
			}
		ife kickbackpic 12 { sound DRUM_OUT ife alt_slot2_mag 0 shoot DRUMMAGAZINE }

		ife kickbackpic 32
			{
			sound DRUM_IN
			set temp6 max_alt_slot2_mag
			sub temp6 alt_slot2_mag

				ifg temp6 cur_ammo
					{
					add alt_slot2_mag cur_ammo
					setp[].ammo_amount 2 0
					}
				else
					{
					getp[].ammo_amount 2 temp4 sub temp4 temp6 setp[].ammo_amount 2 temp4
					set alt_slot2_mag max_alt_slot2_mag
					}
			}
	}
}
else
ife SPECIALIST_EQUIPMENT[118] 2 // Onagre Shotgun
{
setarray WEAPON_TILE[2] 35879
setarray W_AMMO_TILE[2] 5225
setarray ammo_amount[2] 8
setarray weap_special[2] 0

set WEAPON2_CLIP 0
set WEAPON2_RELOAD 36
set WEAPON2_FIREDELAY 2
set WEAPON2_HOLDDELAY 0
set WEAPON2_FLAGS 1024
set WEAPON2_SPAWNTIME 24
set WEAPON2_SPAWN 0
set WEAPON2_SHOTSPERBURST 7
set WEAPON2_INITIALSOUND 0
set WEAPON2_SOUND2TIME 12
set WEAPON2_TOTALTIME 18
set WEAPON2_SOUND2SOUND 4
set WEAPON2_RELOADSOUND1 4
set WEAPON2_RELOADSOUND2 5
set WEAPON2_FIRESOUND 4

ife cur_weap 2
	{
	set alt_fire_type 1
	set reload_type 1
	set weapon_type 2
	set GUN_VOLUME 80
	set GUN_AMMO_TYPES 5
	set GUN_ACCURACY 24
	set GUN_MAX_SPREAD 48
	set GUN_SIZE 2
	set GUN_HANDS 2
	set gun_mag slot2_mag

	ifl slot2_mag 0 set slot2_mag 0
	ifl alt_slot2_mag 0 set alt_slot2_mag 0

	ife kickbackpic 3 add gun_spread 24

		ifand AMMO_TYPES[cur_weap] 1
			{
			set weapon_type 8
			set WEAPON2_SHOOTS 9361
			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp EXPL_SHELL_FIRE }
			ife explosive_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 1 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
			}
		else
		ifand AMMO_TYPES[cur_weap] 4
			{
			set weapon_type 9
			ife ARTIFACTS_LOADOUT[CHAR] 7 set WEAPON2_SHOOTS 6816 else
			ife WEAPONS_RESEARCH[RS_W_LAVA_NAILS] 2 set WEAPON2_SHOOTS LAVA_NAIL else
			set WEAPON2_SHOOTS 6826
			ife kickbackpic 2
			{ espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT ife WEAPONS_RESEARCH[RS_W_LAVA_NAILS] 2 setactorvar[RETURN].temp LAVAN_FIRE
			else setactorvar[RETURN].temp FLECH_SHELL_FIRE }
			ife flechete_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 4 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
			}
		else
		ifand AMMO_TYPES[cur_weap] 64
			{
			set weapon_type 0
			set WEAPON2_SHOOTS RMAXREVOLVERSHOT
			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp MAGNUM_SHOTGUN state pfakebullet_shotgun }
			ife magnum_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 64 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
			}
		else
		ifand AMMO_TYPES[cur_weap] 1024
			{
			set weapon_type 8
			set WEAPON2_SHOOTS 22536
			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp DRAGONS_BR_FIRE }
			ife dragon_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 1024 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
			}
		else
		ifand AMMO_TYPES[cur_weap] 65536
			{
			set weapon_type 7
			set WEAPON2_SHOOTS SILVER_BEARING
			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SBBALL_FIRE }
			ife silverb_shells 0 ife slot2_mag 0 { xorvar AMMO_TYPE 65536 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
			}
		else
			{
			set weapon_type 2
			set WEAPON2_SHOOTS 2613
			ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp WH_ONSHOTG }
			ife kickbackpic 2 state pfakebullet_shotgun
			}

	ifg shotgun_load 0
		{
		setp[].reloading 1
		ife BELT_LOADOUT[CHAR] 5
			{
			ifl kickbackpic 19 setp[].kickback_pic 19
			ife kickbackpic 21 sub shotgun_load 1
			ife kickbackpic 25 setp[].kickback_pic 19
			}
		else
			{
			ifl kickbackpic 19 setp[].kickback_pic 19
			ife kickbackpic 21 sub shotgun_load 1
			ife kickbackpic 27 setp[].kickback_pic 19
			}
		ifand BITS_PRESS 4 ifg slot2_mag 0 ifg kickbackpic 21 { set shotgun_load 0 setp[].reloading 0 setplayer[].kickback_pic 1 espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp WH_ONSHOTG }
		}

	ife kickbackpic 0
	{
	state shotgun_load_check
	ifand BITS_PRESS 4
		{
		getp[].ammo_amount 2 hold_ammo_temp
		  ifg slot2_mag 0
		   ife hold_ammo_temp 0
			{
			add hold_ammo_temp 1
			setp[].ammo_amount 2 hold_ammo_temp
			set need_to_fire 1
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp WH_ONSHOTG
			setp[].kickback_pic 1
			}
		}
	}

	ife kickbackpic 5
	ife need_to_fire 1
		{
		getp[].ammo_amount 2 hold_ammo_temp
		sub hold_ammo_temp 1
		ifl hold_ammo_temp 0 set hold_ammo_temp 0
		setp[].ammo_amount 2 hold_ammo_temp
		set need_to_fire 0
		}

		ife needs_pump[cur_weap] 1 set max_slot2_mag 7 else set max_slot2_mag 8
		ifg slot2_mag max_slot2_mag set slot2_mag max_slot2_mag
		ife slot2_mag 0 ife kickbackpic 0 setarray needs_pump[cur_weap] 1
		ife player[].reloading 1
			{
			ife kickbackpic 22
				{
				ifand gun_firemode 16384 { set hide_xhair 0 xorvar gun_firemode 16384 }
				state sg_shell_sounds
				add slot2_mag 1

				ifand AMMO_TYPES[2] 1
					{
					set LAST_SHELL_FIRED 1
					sub explosive_shells 1
					}
				else
				ifand AMMO_TYPES[2] 4
					{
					set LAST_SHELL_FIRED 4
					sub flechete_shells 1
					}
				else
				ifand AMMO_TYPES[2] 64
					{
					set LAST_SHELL_FIRED 64
					sub magnum_shells 1
					}
				else
				ifand AMMO_TYPES[2] 1024
					{
					set LAST_SHELL_FIRED 1024
					sub dragon_shells 1
					}
				else
				ifand AMMO_TYPES[2] 65536
					{
					set LAST_SHELL_FIRED 65536
					sub silverb_shells 1
					}
				else
					{
					set LAST_SHELL_FIRED 0
					getp[].ammo_amount 2 hold_ammo_temp
					sub hold_ammo_temp 1
					setp[].ammo_amount 2 hold_ammo_temp
					}
				}
			}
		else ife player[].reloading 0
			{
			ife kickbackpic 9 sound WH_ONPUMP
			ife kickbackpic 0 ifg slot2_mag 0 ife needs_pump[cur_weap] 1 setp[].kickback_pic 7
			}
			ife kickbackpic 2
				{
				sub slot2_mag 1

				ifand AMMO_TYPES[2] 1 set LAST_SHELL_FIRED 1
				else
				ifand AMMO_TYPES[2] 4 set LAST_SHELL_FIRED 4
				else
				ifand AMMO_TYPES[2] 64 set LAST_SHELL_FIRED 64
				else
				ifand AMMO_TYPES[2] 1024 set LAST_SHELL_FIRED 1024
				else
				ifand AMMO_TYPES[2] 65536 set LAST_SHELL_FIRED 65536
				else set LAST_SHELL_FIRED 0

				ife AMMO_TYPE 0
					{
					getp[].ammo_amount 2 hold_ammo_temp
					add hold_ammo_temp 1
					setp[].ammo_amount 2 hold_ammo_temp
					}
				}
			ife kickbackpic 3
				{
				ifand gun_firemode_two 8
					{
					ifand AMMO_TYPES[15] 64 { set gun_pushback_power -128 state gun_pushback }
					else set gun_pushback_power -32 state gun_pushback
					}
				else
					{
					ifand AMMO_TYPES[cur_weap] 64 { set gun_pushback_power -128 state gun_pushback }
					else set gun_pushback_power -32 state gun_pushback
					}
				set gun_recoil 16
				}
			ife kickbackpic 4 { set gunsmoke_angle 96 state spawn_gunsmoke }
			ife kickbackpic 16
			 ife player[].reloading 0
				{
				ife needs_pump[cur_weap] 1 setarray needs_pump[cur_weap] 0
				else // If it didn't need pumping, eject a shell
				state eject_shot_shell
				}
			}
}
else
{
setarray WEAPON_TILE[2] 35894
setarray W_AMMO_TILE[2] 5225
setarray ammo_amount[2] 8

set WEAPON2_CLIP 0
set WEAPON2_FIREDELAY 2
set WEAPON2_TOTALTIME 4
set WEAPON2_HOLDDELAY 0
set WEAPON2_FLAGS 17408
set WEAPON2_SHOOTS 2613
set WEAPON2_SPAWNTIME 24
set WEAPON2_SPAWN 0
set WEAPON2_SHOTSPERBURST 7
set WEAPON2_INITIALSOUND 0
set WEAPON2_FIRESOUND 4
set WEAPON2_SOUND2TIME 15
set WEAPON2_SOUND2SOUND 0
set WEAPON2_RELOADSOUND1 0
set WEAPON2_RELOADSOUND2 0

	ife cur_weap 2
	{
	set alt_fire_type 1
	set reload_type 2
	set weapon_type 2
		set gun_mag alt_slot2_mag
		ifand WHEATON_UPGRADE 4 set max_alt_slot2_mag 14
		else set max_alt_slot2_mag 8
		setarray weap_special[2] 16388
		set GUN_VOLUME 70
		set GUN_AMMO_TYPES 0
		set GUN_MAX_SPREAD 32
		set GUN_SIZE 2
		set GUN_HANDS 2
		set reload_frame_partial 41

		ifand gun_firemode 16384
			{
			set GUN_ACCURACY 12
			ifg kickbackpic 6 { set hide_xhair 0 xorvar gun_firemode 16384 }
			}
			else
			set GUN_ACCURACY 20

		ifand BITS_PRESS 4
		  ifg alt_slot2_mag 0
		   ife player[].ammo_amount 2 0
		    ife need_to_fire 0
		     ife player[].weapon_pos 0
			{
			setp[].ammo_amount 2 1
			setp[].kickback_pic 1
			set need_to_fire 1
			}
		ife kickbackpic 2 // IF THE SHOTGUN ANIMATION IS ON IT'S 2nd FRAME MOVE THE PLAYERS SCREEN UP...
		{
		state pfakebullet_shotgun
		espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp WH_SHOTG
		sub alt_slot2_mag 1
		ife need_to_fire 1 set need_to_fire 0 else
			{
			getp[].ammo_amount 2 temp2
			add temp2 1
			setp[].ammo_amount 2 temp2
			}
		set gun_recoil 6
		set gun_pushback_power -32
		state gun_pushback
		set gunsmoke_angle 64 state spawn_gunsmoke
		}
		ife kickbackpic 3 add gun_spread 12

		ifand AMMO_TYPES[cur_weap] 1 { xorvar AMMO_TYPE 1 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }
		ifand AMMO_TYPES[cur_weap] 4 { xorvar AMMO_TYPE 4 setarray AMMO_TYPES[cur_weap] AMMO_TYPE }

		ife kickbackpic 52 sound VAL_SLIDE

		ife kickbackpic 3 shoot SHOTG_SHELL

	  ifl alt_slot2_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
	   {
	   ifn cur_ammo 0
		   {
		   set WEAPON2_RELOAD 61
		   setp[].reloading 1
		   setp[].kickback_pic reload_frame
		   }
		}

	ife kickbackpic 15 state bgar_mag_out_sounds
	ife kickbackpic 16 ife alt_slot2_mag 0 { ifand WHEATON_UPGRADE 4 shoot DRUMMAGAZINE else shoot RIFLEMAGAZINE }
	ife kickbackpic 37
		{
		state bgar_mag_in_sounds
		set temp5 alt_slot2_mag
		set temp6 max_alt_slot2_mag
		sub temp6 temp5

			ifg temp6 cur_ammo
					{
					add alt_slot2_mag cur_ammo
					setp[].ammo_amount 2 0
					}
			else
					{
					getp[].ammo_amount 2 temp4 sub temp4 temp6 setp[].ammo_amount 2 temp4
					set alt_slot2_mag max_alt_slot2_mag
					}
		}

	}
}

// Rifle
ife SPECIALIST_EQUIPMENT[160] 2 // XM8?
{
	setarray p_max_ammo[3]  300
	setarray WEAPON_TILE[3] 38939
	setarray weap_special[3] 17408
	setarray W_AMMO_TILE[3] 15906
	setarray ammo_amount[3] 35

	set WEAPON3_FIREDELAY 3
	set WEAPON3_TOTALTIME 4
