	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp WH_STG29 }

		set WEAPON3_FLAGS 4
		set GUN_ACCURACY 8
		ife kickbackpic 2 { ifge gun_grace 10 add gun_spread 7 state pfakebullet }
		ife kickbackpic 3 set gun_recoil 4
		ife kickbackpic 4
			{
			set gunsmoke_angle 104 state spawn_gunsmoke
			}

		ife kickbackpic 21 sound AUG_MOVEMENT
		ife kickbackpic 15 state JMOVESOUND2
		ife kickbackpic 45 state JMOVESOUND2
		ife kickbackpic 46 soundonce AK_SLIDE
		ife kickbackpic 54 sound AUG_MOVEMENT
		ife kickbackpic 10
			{
			state bgar_mag_out_sounds ife slot3_mag 0 shoot BIG_RIFLE_MAG
			}
		ife kickbackpic 28
