  ifl slot3_mag 1
   ife kickbackpic 0
	   ife player[].weapon_pos 0
		{
   		ifn cur_ammo 0
   			{
   			setp[].reloading 1
			set WEAPON3_RELOAD 58
   			setp[].kickback_pic 6
			}
		}
   }
}
