set WEAPON3_SELECTSOUND SELECT_M16

set WEAPON3_SHOOTS RMAXREVOLVERSHOT
set WEAPON3_FIRESOUND 4

	ife cur_weap 3
	{
	set alt_fire_type 1
	set reload_frame_partial 42
	set weapon_type 0
	set GUN_VOLUME 32
	set GUN_SIZE 2
	set GUN_HANDS 2
	set GUN_AMMO_TYPES 0
	set gun_mag slot3_mag
	set max_slot3_mag 10
	set GUN_MAX_SPREAD 48

	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp BEOW_F }
	ife kickbackpic 2 state pfakebullet

	ifand gun_firemode 16384
		{
		set WEAPON3_FLAGS 16384
		ifg kickbackpic 6 { set hide_xhair 0 xorvar gun_firemode 16384 }
		set GUN_ACCURACY 4
		ife kickbackpic 2 add gun_spread 10
		ife kickbackpic 3
			{
			set gun_recoil 8
			set gunsmoke_angle 104 state spawn_gunsmoke
			}
		ife kickbackpic 4
			{
			set gunsmoke_angle 104 state spawn_gunsmoke
			}
		}
		else
		{
		set WEAPON3_FLAGS 0
		set GUN_ACCURACY 8
		ife kickbackpic 2 ifge gun_grace 10 add gun_spread 20
		ife kickbackpic 3 set gun_recoil 4
		ife kickbackpic 4
			{
			set gunsmoke_angle 104 state spawn_gunsmoke
			}
		}
		
			ife needs_pump[cur_weap] 1 set gun_mag -1 else
			set gun_mag slot3_mag

			ife kickbackpic 12 { state bgar_mag_out_sounds ife slot3_mag 0 shoot RIFLEMAGAZINE }
			ife kickbackpic 33
			{
			state bgar_mag_in_sounds
			ifl cur_ammo max_slot3_mag set slot3_mag cur_ammo else set slot3_mag max_slot3_mag
			}
			ife kickbackpic 15 state JMOVESOUND2
			ife kickbackpic 45 state JMOVESOUND2
			ife kickbackpic 52 soundonce BOLT_CATCH

		ife kickbackpic 0
		ifand BITS_PRESS 128
			{
			 ife needs_pump[cur_weap] 0
			  ife player[].ammo_amount cur_weap 0
				{
				setp[].reloading 1
				setp[].kickback_pic 6
				setarray needs_pump[cur_weap] 1
				}
			}

		ife kickbackpic 20
		 ife needs_pump[cur_weap] 1
			{
			setp[].reloading 1
			setp[].kickback_pic 40
			}

		ifl slot3_mag 1
		   ife player[].weapon_pos 0
			ife kickbackpic 0
		   {
			ifn cur_ammo 0
				{
				set WEAPON3_RELOAD 61
				setp[].reloading 1
				ife needs_pump[cur_weap] 1
					{
					setp[].kickback_pic 28
					setarray needs_pump[cur_weap] 0
					}
				else
				setp[].kickback_pic 6
				}
			}
		
   }
}
else
{
setarray WEAPON_TILE[3] 12908
setarray weap_special[3] 16384
setarray W_AMMO_TILE[3] 12886
setarray ammo_amount[3] 40
