ife SPECIALIST_EQUIPMENT[9] 2 // using the M41C?
{
setarray WEAPON_TILE[3] 11865
setarray weap_special[3] 16384
setarray W_AMMO_TILE[3] 6849
setarray ammo_amount[3] 35

