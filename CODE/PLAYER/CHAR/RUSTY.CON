			set gunsmoke_angle 48 state spawn_gunsmoke
			state gun_pushback set gun_pushback_power -128
			set gun_recoil 16
			}
		ife kickbackpic 8 sound AUG_MOVEMENT
		ife kickbackpic 24 { state bgar_mag_out_sounds ife slot9_mag 0 shoot SHOTGUNBOXMAGAZINE }
		ife kickbackpic 29 { ifl cur_ammo max_slot9_mag set slot9_mag cur_ammo else set slot9_mag max_slot9_mag }
		ife kickbackpic 35 state bgar_mag_in_sounds
		
		ifl slot9_mag 1
		   ife player[].weapon_pos 0
			ife kickbackpic 0
		   {
