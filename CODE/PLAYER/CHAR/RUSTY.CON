// SHRINKER
ife SPECIALIST_EQUIPMENT[154] 2 // Winchester?
{
setarray WEAPON_TILE[6] 34003
setarray W_AMMO_TILE[6] 34011
setarray W_AMMO_TILE[11] 34011
setarray ammo_amount[6] 24
setarray weap_special[6] 512
setarray p_max_ammo[6] 100

set WEAPON6_FIREDELAY 2
set WEAPON6_TOTALTIME 16
set WEAPON6_RELOAD 54
set WEAPON6_INITIALSOUND 0
set WEAPON6_SHOOTS SHOTG_SLUG
set WEAPON6_FIRESOUND 4
set WEAPON6_SHOTSPERBURST 1
set WEAPON6_FLAGS 0

setplayer[THISACTOR].gotweapon 11 0

	ife cur_weap 6
	{
	set alt_fire_type 0
	set reload_type 5
	set weapon_type 0
	set GUN_VOLUME 60
	set GUN_SIZE 2
	set GUN_HANDS 2
	set GUN_AMMO_TYPES 0
	set GUN_ACCURACY 8
	set GUN_MAX_SPREAD 0
	set max_slot6_mag 12  

	ifg slot6_mag max_slot6_mag set slot6_mag max_slot6_mag
	set gun_mag slot6_mag
	
	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp WINCH_F }
	ife kickbackpic 2 { state pfakebullet  sub slot6_mag 1 }
	ife kickbackpic 3 { set gun_recoil 8 add gun_spread 6
	set gunsmoke_angle 64 state spawn_gunsmoke }
	ife kickbackpic 4 { set gun_pushback_power -16 state gun_pushback }
	ife kickbackpic 8 { ifrnd 128 sound WINCH_C1 else sound WINCH_C2 }
	ife kickbackpic 15 
		{
		ife needs_pump[cur_weap] 1 setarray needs_pump[cur_weap] 0 else
		shoot RIFLESHELL
		}


	ifg shotgun_load 0
		{
		ife player[].ammo_amount 6 0 { setp[].reloading 0 setp[].kickback_pic 0 }
		setp[].reloading 1
		ife BELT_LOADOUT[CHAR] 5 ifl kickbackpic 21 setp[].kickback_pic 21
	    else ifl kickbackpic 17 setp[].kickback_pic 17
	    ife kickbackpic 42 { ifg slot6_mag 0 set reload_empty 0 setp[].kickback_pic 30 }
		ifand BITS_PRESS 4 ifg slot6_mag 0 ifg kickbackpic 40 { set shotgun_load 0 setp[].reloading 0 setplayer[].kickback_pic 1 }
		}

	ife slot6_mag 0
		 ife player[].weapon_pos 0
			{
			set reload_empty 1
			setarray needs_pump[cur_weap] 1
			ifl player[].ammo_amount 6 max_slot6_mag set shotgun_load player[].ammo_amount 6 else
			set shotgun_load max_slot6_mag
			}

		ife kickbackpic 0 ifg slot6_mag 0 ife needs_pump[cur_weap] 1 setp[].kickback_pic 6 

		ife kickbackpic 20 soundonce AUG_MOVEMENT

	ife player[].reloading 1
	 ifg player[].ammo_amount 6 0
		{
			ife kickbackpic 40 
				{ 
				espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT 
				ifrnd 128 setactorvar[RETURN].temp WINCH_INS1 else setactorvar[RETURN].temp WINCH_INS2
				ife shotgun_load 1 { sub shotgun_load 1 add slot6_mag 1 } else 
					{
					sub shotgun_load 2 add slot6_mag 2
					}
				}
		}

	ife kickbackpic 50 soundonce AUG_MOVEMENT

	}
}
else
