	set GUN_SIZE 2
	set gun_mag slot3_mag
	
	ifand gun_firemode 16384
		{
		set WEAPON3_SHOTSPERBURST 3
		set WEAPON3_TOTALTIME 4
		set WEAPON3_FLAGS 16456
		set GUN_ACCURACY 2
		switch weaponcount 
			case 1
			case 2
			case 3
			case 4
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp G11_F state pfakebullet
			sub slot3_mag 1
			break
		endswitch
		}
	else 
		{
		set WEAPON3_TOTALTIME 3
		set WEAPON3_SHOTSPERBURST 1
		set WEAPON3_FLAGS 68
		set GUN_ACCURACY 8
		ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp G11_F state pfakebullet sub slot3_mag 1 }
		}

		set GUN_VOLUME 15
		set max_slot3_mag 45
			ife kickbackpic 1 { set gunsmoke_angle 32 set gun_recoil 8 }
			ife kickbackpic 2 ifge gun_grace 10 add gun_spread 8

			ife kickbackpic 9 state bgar_mag_out_sounds
			ife kickbackpic 10 ife slot3_mag 0 shoot SCIFI_BIG_MAG // spawn magazine

			ife kickbackpic 26
				{
				state bgar_mag_in_sounds
				ifl cur_ammo max_slot3_mag set slot3_mag cur_ammo else set slot3_mag max_slot3_mag
				}

	  ifl slot3_mag 1
	   ife player[].weapon_pos 0
	    ife kickbackpic 0
		   {
		   	ifn cur_ammo 0
		   		{
		   		setp[].reloading 1
		   		setp[].kickback_pic 6
				}
			}

	}

}
