defstate RUSTY_REVOLVER_STUFF
set reload_frame 10
	ifand gun_firemode 64 // two of them?
		{
		ifand gun_firemode_two 16 xorvar gun_firemode_two 16
		set GUN_HANDS 2
		set GUN_VOLUME 40
		set GUN_ACCURACY 8
		set WEAPON1_SHOTSPERBURST 2
		set WEAPON1_RELOAD 48
		set GUN_MAX_SPREAD 48
		set max_slot1_mag 12
		ife kickbackpic 2
			{
			state pfakebullet
			state pfakebullet_left
			}
        set WEAPON1_FLAGS 16448
		}
	else
		{
		set GUN_VOLUME 20
		set GUN_ACCURACY 4
		set WEAPON1_SHOTSPERBURST 0
		set WEAPON1_RELOAD 30
		set GUN_MAX_SPREAD 64
		set max_slot1_mag 6

		ife kickbackpic 2 state pfakebullet


		// fan the hammer
		ifand gun_firemode_two 16
			{
			set GUN_HANDS 2
			set WEAPON1_FLAGS 4
			}
		else
			{
			set GUN_HANDS 1
			set WEAPON1_FLAGS 16448
			}
		}

	ife kickbackpic 0
		ife kickbackpic_2 0
		{
		ife SLO_MO_SHOWOFF 1 set kickbackpic_2 1
		 ifand BITS_PRESS 128
			set kickbackpic_2 1
		}
			
	ifg kickbackpic_2 0
		{
		ifand BITS_PRESS 4 set kickbackpic_2 0
		ife kickbackpic_2 1 { set gun_recoil 5 sound R_TWIRL }
		add kickbackpic_2 1
		ifg kickbackpic_2 10 set kickbackpic_2 0
		}

	ifg kickbackpic 1
	 ifl kickbackpic 9
		{
		ifand gun_firemode_two 16
			{
			ife kickbackpic 8
				{
				ife SPECIALIST_EQUIPMENT[41] 2 sound GR_RHAM
				else sound R_HAMMER
				}
			}
		else
			{
			ifand BITS_PRESS 4 ifg slot1_mag 0 setplayer[].kickback_pic 1
			}
		}
ends

// Rusty's alternate fire code ==================================================================================================

defstate rusty_alt_fire

ife CHAR 5
{

 ife cur_weap 1 // fan the hammer
  ife alt_fire_type 20
    {
        ifcount 13
            {
            sound JMOVE4
            setplayer[].weapon_pos 5
            xorvar gun_firemode_two 16
            resetcount
            }
    }
    ife cur_weap 3
    {
        ife kickbackpic 0
        {
            ife SPECIALIST_EQUIPMENT[9] 2 // M41C's flamethrower
            {
            ifg tesla_ammo 0
                {
                ifl gl_countd 43 { sub tesla_ammo 1 set gl_countd 46 }
                }
            else
            soundonce DRY_FIRE
            }
        }
    }

    ife cur_weap 4
    {
         ife kickbackpic 0
            {
                getp[].ammo_amount 4 alt_temp1
                ifg alt_temp1 0
                 {
                 ifg slot4_mag 0
                    {
                    setp[].kickback_pic 2
                    sub wepsway_x 10
                    sub wepsway_y 10          
                    sub alt_temp1 1
                    setp[].ammo_amount 4 alt_temp1
                    sub slot4_mag 1
					ife ARTIFACTS_LOADOUT[CHAR] 7 // book of nails?
						{
						espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp RL_NAILB
						shoot 6816 shoot 6816 shoot 6816 shoot 6816 shoot 6816 shoot 6816 shoot 6816 shoot 6816
						}
					else
					ife WEAPONS_RESEARCH[RS_W_LAVA_NAILS] 2
						{
						espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp LAVAN_FIRE
						shoot LAVA_NAIL shoot LAVA_NAIL shoot LAVA_NAIL shoot LAVA_NAIL shoot LAVA_NAIL shoot LAVA_NAIL shoot LAVA_NAIL shoot LAVA_NAIL
						}
					else
						{
						espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp RL_NAILB
						shoot 6826 shoot 6826 shoot 6826 shoot 6826 shoot 6826 shoot 6826 shoot 6826 shoot 6826
						}
                    }
                else soundonce DRY_FIRE
                }
            }
    }

	ife cur_weap 6
	  ife kickbackpic 0
	   ife alt_fire_type 20
			{
			soundonce MINE_DETONATE
			set remote_detonate 4
			}
		
	ife cur_weap 7
	{
	ifn SPECIALIST_EQUIPMENT[134] 2
	  ife kickbackpic_2 0
	   ife weaponcount 0
	    ifge p_green_mana 4
		 ifand MAGIC_UPGRADE[5] 1
			{
			set kickbackpic_2 1
			sub p_green_mana 4
			}
	}
		
	ife cur_weap 11
	ife kickbackpic 0
			{
			soundonce MINE_DETONATE
			set remote_detonate 4
			}

}

ends

defstate PS_RUSTY // ===============================================================================================================================================================================================
{
set P_GENDER MALE

qputs 3 Coffee Thermos

qputs 6 Heavy duty boots
qputs 75 Heavy duty boots: %d %
set temp player[].boot_amount
ife PERSONNEL_RESEARCH[26] 2 div temp 3 else div temp 2
qsprintf 75 75 temp

ife HELMET_LOADOUT[CHAR] 4
	{
	qputs 101 Ghost vision goggles
	qputs 106 Ghost vision on
	qputs 107 Ghost vision off
	}
else
ife HEAT_GOGGLES 1
	{
	qputs 101 Heat vision shades
	qputs 106 Heat vision on
	qputs 107 Heat vision off
	}
else
	{
	qputs 101 Night vision shades
	qputs 106 Night vision shades on
	qputs 107 Night vision shades off
	}

qputs 90 Turbo Caffeine Pills
qputs 12 Used Turbo Caffeine Pills

qputs 89 Scuba Gear

qputs 47 Throwing Star Belt activated
qputs 48
qputs 49 Throwing Star Belt not found yet!
qputs 51 Throwing Star Belt
qstrcpy 91 51

qputs 88 Hoverwatch
qputs 50 Hoverwatch not found yet!
qputs 52 Hoverwatch on
qputs 53 Hoverwatch off

qputs 102 We're gonna fry your ass, Rusty!

state mind_shield_state

setp[].knuckle_incs 0

getp[].holoduke_on temp
ifn temp -1
{
stopsound TELEPORTER
sound THROWING_STARBELT
shoot 3790
eshoot 3790 geta[RETURN].ang temp add temp 32 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp sub temp 32 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp add temp 96 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp sub temp 96 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp add temp 128 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp sub temp 128 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp add temp 256 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp sub temp 256 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp add temp 384 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp sub temp 384 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp add temp 512 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp sub temp 512 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp add temp 640 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp sub temp 640 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp add temp 768 seta[RETURN].ang temp
eshoot 3790 geta[RETURN].ang temp sub temp 768 seta[RETURN].ang temp

getp[].holoduke_amount temp
ife temp 2399 setp[].holoduke_amount 1600
else ife temp 1599 setp[].holoduke_amount 800
else ife temp 799 { setp[].holoduke_amount 0 setp[].inven_icon 0 }
setp[].holoduke_on -1
}

setarray p_max_ammo[1]  200
setarray p_max_ammo[3]  300
setarray p_max_ammo[4]  80

setarray p_max_ammo[7]  300
setarray p_max_ammo[9]  300
setarray p_max_ammo[11] 10

set CKNEE 6821

ifand CHAR_APP 65536
{
set fist_tile 38248
set CPIPEBOMB 38262
set CTRIPBOMB 38229

set CKEYCARDTILE 38230
set CKEYCARDTILE2 38231
set CKEYCARDTILE3 38232

set CTIP 38225
set CHOLDING_R 38227
set CHOLDING_L 38227
set CHOLDING_3 38240

set C_ARM_1 38253
set C_ARM_2 38238
set C_ARM_3 38239

set C_PUNCH 38233

set C_PISTOL_R 38237
set C_PISTOL_L 38237

set C_HAND_1 38258
set C_HAND_2 38257

set C_UNIQUE_1 6752
}
else
{
set fist_tile 3153
set CPIPEBOMB 6828
set CTRIPBOMB 6863

set CKEYCARDTILE 6787
set CKEYCARDTILE2 6788
set CKEYCARDTILE3 6789

set CDETON 2570
set CTIP 8486
set CHOLDING_R 9439
set CHOLDING_L 9439
set CHOLDING_3 12230

set C_ARM_1 6903
set C_ARM_2 9005
set C_ARM_3 38365

set C_PUNCH 6725

set C_PISTOL_R 8995
set C_PISTOL_L 8995

set C_HAND_1 7840
set C_HAND_2 7841

set C_UNIQUE_1 6778
}

set c_medikit 6869
set c_steroids 6864
set c_holoduke 6871
set c_jetpack 6865

set c_nvg_heat 6877
set c_nvg_normal 6870

setuserdef[].userquote_xoffset -25
setuserdef[].userquote_yoffset 105

state DISP_nvg

set c_scuba 6872
set c_boots 6866
set c_armour 6868
set c_heavy_armour 6867

state phantom_horse_summon

ifg AGENT_FATIGUE[CHAR] 5000 ifg SKILL_LEVEL 2 set pmax_stamina 70
else
	{
	ife PERSONNEL_RESEARCH[25] 2 set pmax_stamina 130 // improved shoes?
	else set pmax_stamina 100
	}
	
ifp pboosted
	{
	ife player[].steroids_amount 398 soundonce DRINKELIXER
	ife player[].steroids_amount 390 { state purple_flash soundonce HEARTBEAT }
	ife player[].steroids_amount 1 { state white_flash soundonce HEARTBEAT }
	}

// weapon pickup sounds
setarray wep_get_sound[1] PICK_PISTOL
setarray wep_get_sound[2] PICK_SHOTG
setarray wep_get_sound[3] PICK_RIFLE
setarray wep_get_sound[4] PICK_BIGGUN

setarray wep_get_sound[6] PICK_PISTOL
setarray wep_get_sound[7] PICK_ENERG
setarray wep_get_sound[9] PICK_RIFLE

// select sounds
set WEAPON1_SELECTSOUND SELECT_PISTOL
set WEAPON2_SELECTSOUND SELECT_SHOTGUN
set WEAPON3_SELECTSOUND SELECT_AK
set WEAPON4_SELECTSOUND SELECT_WEAPON
set WEAPON7_SELECTSOUND SELECT_HT_ASSAULTR
set WEAPON9_SELECTSOUND SELECT_M16
set WEAPON11_SELECTSOUND SELECT_PISTOL

ife SHOOTDYNAMITE THISACTOR { ife ARTIFACTS_LOADOUT[5] 5 { shoot CHARMED_DYNA set artifact_used 60 } else shoot DYNAMITESTICK set SHOOTDYNAMITE -1 }

// MELEE
ife temp_weap 0
{
	set WEAPON0_TOTALTIME 17
	set WEAPON0_HOLDDELAY 17
	set WEAPON0_FIREDELAY 7
	set WEAPON0_FIRESOUND 532
	set WEAPON0_SHOOTS 5357

ife cur_weap 0
	{
	set gun_mag -1
	set GUN_HANDS 1
	ife kickbackpic 15 { sound PUNCH shoot 5357 }
	}
}


// PISTOL
ife SPECIALIST_EQUIPMENT[168] 2 // Gauss Revolvers
	{
	setarray p_max_ammo[1]  120
	setarray WEAPON_TILE[1] 39040
	ifand guns_akimbo 4 setarray weap_special[1] 53249 else setarray weap_special[1] 53248
	setarray W_AMMO_TILE[1] 29755
	setarray ammo_amount[1] 12

	set WEAPON1_CLIP 0
	set WEAPON1_FIREDELAY 2
	set WEAPON1_FLAGS 16448
	set WEAPON1_TOTALTIME 9
	set WEAPON1_RELOAD 30
	set WEAPON1_HOLDDELAY 0
	set WEAPON1_SHOOTS GAUSS_MED
	set WEAPON1_SPAWNTIME 2
	set WEAPON1_SPAWN 0
	set WEAPON1_INITIALSOUND 0
	set WEAPON1_FIRESOUND 4
	set WEAPON1_SOUND2TIME 0
	set WEAPON1_SOUND2SOUND 0
	set WEAPON1_RELOADSOUND1 4
	set WEAPON1_RELOADSOUND2 4

	ife cur_weap 1
	{
	set alt_fire_type 20
	set weapon_type 3
		set GUN_AMMO_TYPES 0
		set GUN_SIZE 0

set reload_frame 10

	ifand gun_firemode 64 // two of them?
		{
		ifand gun_firemode_two 16 xorvar gun_firemode_two 16
		set GUN_HANDS 2
		set GUN_VOLUME 40
		set GUN_ACCURACY 8
		set WEAPON1_SHOTSPERBURST 1
		set WEAPON1_RELOAD 48
		set GUN_MAX_SPREAD 48
		set max_slot1_mag 12
		ife kickbackpic 2
			{
			setprojectile[GAUSS_MED].offset -224
			shoot GAUSS_MED 
			setprojectile[GAUSS_MED].offset 224
			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp GAUSR_F }
			}
        set WEAPON1_FLAGS 16448
		}
	else
		{
		set GUN_VOLUME 20
		set GUN_ACCURACY 4
		set WEAPON1_SHOTSPERBURST 1
		set WEAPON1_RELOAD 30
		set GUN_MAX_SPREAD 64
		set max_slot1_mag 6

		// fan the hammer
		ifand gun_firemode_two 16
			{
			set GUN_HANDS 2
			set WEAPON1_FLAGS 4
			}
		else
			{
			set GUN_HANDS 1
			set WEAPON1_FLAGS 16448
			}
		}


	ifg kickbackpic 1
	 ifl kickbackpic 9
		{
		ifand gun_firemode_two 16
			{
			ife kickbackpic 8 sound GR_RHAM
			}
		else
			{
			ifand BITS_PRESS 4 ifg slot1_mag 0 setplayer[].kickback_pic 1
			}
		}

		ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp GAUSR_F }

		set gun_mag slot1_mag
		ife kickbackpic 2 { ifand gun_firemode 64 sub slot1_mag 2 else sub slot1_mag 1 }
		ife kickbackpic 3 { add gun_spread 16 set gun_recoil 6 }
		ife kickbackpic 4
		{
		set gunsmoke_angle 64 state spawn_gunsmoke ifand gun_firemode 64 { set gunsmoke_angle -64 state spawn_gunsmoke  }
		}

			ife kickbackpic 14
				{
				state revolver_eject
				sub slot1_mag temp4
				}
			ife kickbackpic 16
				{
			   ifl cur_ammo 6 set slot1_mag cur_ammo else set slot1_mag 6
				}

			ife kickbackpic 32 state revolver_2_eject
			ife kickbackpic 34
				{
			    ifl cur_ammo 12 set slot1_mag cur_ammo
				else set slot1_mag 12
				}


	  ifl slot1_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
	   {
	   ifn cur_ammo 0
		   {
		   setp[].reloading 1
		   setp[].kickback_pic 10
		   }
	   }

	}
}
else
ife SPECIALIST_EQUIPMENT[29] 2 // using the microuzi?
{
setarray p_max_ammo[1]  600
setarray WEAPON_TILE[1] 13423
ifand guns_akimbo 4 setarray weap_special[1] 4097 else setarray weap_special[1] 4096
setarray W_AMMO_TILE[1] 5221
setarray ammo_amount[1] 50

set WEAPON1_CLIP 0
set WEAPON1_RELOAD 38
set WEAPON1_HOLDDELAY 0
set WEAPON1_SHOOTS 0
set WEAPON1_SPAWNTIME 2
set WEAPON1_SPAWN 0
set WEAPON1_INITIALSOUND 0
set WEAPON1_FIRESOUND 4
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 3

set WEAPON1_FLAGS 4


	ife cur_weap 1
	{
	set alt_fire_type 0
	set weapon_type 0
	set GUN_AMMO_TYPES 0
	set GUN_SIZE 0
	set gun_mag slot1_mag
	ifand gun_firemode 64 
		{
		set WEAPON1_RELOAD 71
		set WEAPON1_SHOTSPERBURST 2
		set GUN_VOLUME 20
		set GUN_ACCURACY 16
		set GUN_MAX_SPREAD 64
		set GUN_HANDS 2
		set max_slot1_mag 50
		ife kickbackpic 1
				{
				shoot NINEMM_CALIBRE
				shoot NINEMM_CALIBRE
				shoot NINEMM_SHELL
				shoot NINEMM_SHELL_LEFT
				sub slot1_mag 2
				state pfakebullet
				state pfakebullet_left
				set gunsmoke_angle 64 state spawn_gunsmoke
				set gunsmoke_angle -64 state spawn_gunsmoke
				}
			ife kickbackpic 2
				{
				espawn SOUND_SPRITE
				state SPAWN_IN_PLAYER_FRONT
				setactorvar[RETURN].temp MICRO_UZI_F
				espawn SOUND_SPRITE
				state SPAWN_IN_PLAYER_FRONT
				setactorvar[RETURN].temp MICRO_UZI_F
				ifge gun_grace 10 add gun_spread 12
				set gun_recoil 8
				ifvarl gun_mag 6 sound MAG_LOW
				}
	ife kickbackpic 13 { state smg_mag_out_sounds ife slot1_mag 0 shoot SMGMAGAZINE }
	ife kickbackpic 28
			{
			state smg_mag_in_sounds
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			div slot1_mag 2
			}
	ife kickbackpic 45 { state smg_mag_out_sounds ife slot1_mag 0 shoot SMGMAGAZINE }
	ife kickbackpic 61
			{
			state smg_mag_in_sounds
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}
		} 
	else 
		{
		set WEAPON1_RELOAD 38
		set WEAPON1_SHOTSPERBURST 0
		set GUN_VOLUME 10
		set GUN_ACCURACY 8
		set GUN_MAX_SPREAD 32
		set GUN_HANDS 1
		set max_slot1_mag 25
		ife kickbackpic 1
				{
				shoot NINEMM_CALIBRE
				shoot NINEMM_SHELL
				sub slot1_mag 1
				state pfakebullet
				set gunsmoke_angle 64 state spawn_gunsmoke
				}
			ife kickbackpic 2
				{
				espawn SOUND_SPRITE
				state SPAWN_IN_PLAYER_FRONT
				setactorvar[RETURN].temp MICRO_UZI_F
				ifge gun_grace 5 add gun_spread 6
				set gun_recoil 5
				ifvarl gun_mag 6 sound MAG_LOW
				}
	ife kickbackpic 13 { state smg_mag_out_sounds ife slot1_mag 0 shoot SMGMAGAZINE }
	ife kickbackpic 28
			{
			state smg_mag_in_sounds
			ifl cur_ammo max_slot1_mag { set slot1_mag cur_ammo } else set slot1_mag max_slot1_mag
			}
		}


		ifl slot1_mag 1
		   ife player[].weapon_pos 0
		  ife kickbackpic 0
		{
			ifn cur_ammo 0
				{
				setp[].reloading 1
				setp[].kickback_pic 6
				}
		}

	}
}
else
ife SPECIALIST_EQUIPMENT[24] 2 // Remington 1858 pistols?
	{
	setarray p_max_ammo[1]  240
	setarray WEAPON_TILE[1] 13376
	ifand guns_akimbo 4 setarray weap_special[1] 53249 else setarray weap_special[1] 53248
	setarray W_AMMO_TILE[1] 6815
	setarray ammo_amount[1] 18

	set WEAPON1_CLIP 0
	set WEAPON1_FIREDELAY 2
	set WEAPON1_FLAGS 16448
	set WEAPON1_TOTALTIME 9
	set WEAPON1_RELOAD 30
	set WEAPON1_HOLDDELAY 0
	set WEAPON1_SHOOTS 2537
	set WEAPON1_SPAWNTIME 2
	set WEAPON1_SPAWN 0
	set WEAPON1_INITIALSOUND 0
	set WEAPON1_FIRESOUND 4
	set WEAPON1_SOUND2TIME 0
	set WEAPON1_SOUND2SOUND 0
	set WEAPON1_RELOADSOUND1 4
	set WEAPON1_RELOADSOUND2 4

		ife cur_weap 1
		{
		set alt_fire_type 20
		set weapon_type 0
			set GUN_AMMO_TYPES 0
			set GUN_SIZE 0

			state RUSTY_REVOLVER_STUFF

			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp REVOLVER2FIRE }

			set gun_mag slot1_mag

			ife kickbackpic 2 { ifand gun_firemode 64 sub slot1_mag 2 else sub slot1_mag 1 }
			ife kickbackpic 3 { add gun_spread 16 set gun_recoil 6 }
			ife kickbackpic 4 {
			set gunsmoke_angle 64 state spawn_gunsmoke ifand gun_firemode 64 { set gunsmoke_angle -64 state spawn_gunsmoke  } }

			ife kickbackpic 14
				{
				state revolver_silver_eject
				sub slot1_mag temp4
				}
			ife kickbackpic 16
				{
			   ifl cur_ammo 6 set slot1_mag cur_ammo else set slot1_mag 6
				}

			ife kickbackpic 32 state revolver_silver2_eject
			ife kickbackpic 34
				{
			    ifl cur_ammo 12 set slot1_mag cur_ammo
				else set slot1_mag 12
				}

		  ifl slot1_mag 1
		   ife player[].weapon_pos 0
			ife kickbackpic 0
		   {
		   ifn cur_ammo 0
			   {
			   setp[].reloading 1
			   setp[].kickback_pic 10
			   }
		   }

		}
	}
else ife SPECIALIST_EQUIPMENT[41] 2 // Golden revolvers?
	{
	setarray p_max_ammo[1]  120
	setarray WEAPON_TILE[1] 14625
	ifand guns_akimbo 4 setarray weap_special[1] 53249 else setarray weap_special[1] 53248
	setarray W_AMMO_TILE[1] 6851
	setarray ammo_amount[1] 10

	set WEAPON1_CLIP 0
	set WEAPON1_FIREDELAY 2
	set WEAPON1_FLAGS 16448
	set WEAPON1_TOTALTIME 9
	set WEAPON1_RELOAD 30
	set WEAPON1_HOLDDELAY 0
	set WEAPON1_SHOOTS GOLDEN_SHOT_HIGH
	set WEAPON1_SPAWNTIME 2
	set WEAPON1_SPAWN 0
	set WEAPON1_INITIALSOUND 0
	set WEAPON1_FIRESOUND 4
	set WEAPON1_SOUND2TIME 0
	set WEAPON1_SOUND2SOUND 0
	set WEAPON1_RELOADSOUND1 4
	set WEAPON1_RELOADSOUND2 4

	ife cur_weap 1
	{
	set alt_fire_type 20
	set weapon_type 3
		set GUN_AMMO_TYPES 0
		set GUN_SIZE 0

		state RUSTY_REVOLVER_STUFF

			ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp GOLREV_F }

		set gun_mag slot1_mag
		ife kickbackpic 2 { ifand gun_firemode 64 sub slot1_mag 2 else sub slot1_mag 1 }
		ife kickbackpic 3 { add gun_spread 16 set gun_recoil 6 }
		ife kickbackpic 4
		{
		set gunsmoke_angle 64 state spawn_gunsmoke ifand gun_firemode 64 { set gunsmoke_angle -64 state spawn_gunsmoke  }
		}

			ife kickbackpic 14
				{
				state revolver_eject
				sub slot1_mag temp4
				}
			ife kickbackpic 16
				{
			   ifl cur_ammo 6 set slot1_mag cur_ammo else set slot1_mag 6
				}

			ife kickbackpic 32 state revolver_2_eject
			ife kickbackpic 34
				{
			    ifl cur_ammo 12 set slot1_mag cur_ammo
				else set slot1_mag 12
				}


	  ifl slot1_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
	   {
	   ifn cur_ammo 0
		   {
		   setp[].reloading 1
		   setp[].kickback_pic 10
		   }
	   }

	}
}
else // default revolver?
	{
	set alt_fire_type 20
	setarray p_max_ammo[1]  120
	setarray WEAPON_TILE[1] 6839
	ifand guns_akimbo 4 setarray weap_special[1] 53249 else setarray weap_special[1] 53248
	setarray W_AMMO_TILE[1] 6847
	setarray ammo_amount[1] 12

	set WEAPON1_CLIP 0
	set WEAPON1_FIREDELAY 2
	set WEAPON1_RELOAD 30
