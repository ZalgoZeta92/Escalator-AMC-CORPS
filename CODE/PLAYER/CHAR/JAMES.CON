set WEAPON3_SHOOTS REDLASERSHOT
set WEAPON3_INITIALSOUND 4
set WEAPON3_RELOADSOUND1 4
set WEAPON3_RELOADSOUND2 5
set WEAPON3_CLIP 0
set WEAPON3_FIRESOUND 4
set WEAPON3_SHOTSPERBURST 1

	ife cur_weap 3
	{
	set alt_fire_type 0
	set reload_frame_partial 37
	set weapon_type 1
	set GUN_VOLUME 12
	ifand MAGIC_UPGRADE[0] 8
	set GUN_AMMO_TYPES 8192
	else
	set GUN_AMMO_TYPES 0
	set GUN_HANDS 2

	set WEAPON3_FIREDELAY 2
	set WEAPON3_TOTALTIME 3

	set WEAPON3_FLAGS 68

		set GUN_SIZE 1
		set GUN_ACCURACY 8
		set GUN_MAX_SPREAD 32
		ife kickbackpic_2 0 ifsound MELTA_FIRE { stopsound MELTA_FIRE soundonce MELTA_STOP }
		ifg kickbackpic_2 0
			{
			soundonce MELTA_FIRE
			add kickbackpic_2 1
			ife kickbackpic_2 2
				{
				ifand MAGIC_UPGRADE[0] 8
				 ifg p_blue_mana 0
					{
					shoot MELTA_BEAM
					set gun_recoil 2
					sub p_blue_mana 1
					}
				else
				ifg tesla_ammo 0
					{
					shoot MELTA_BEAM
					set gun_recoil 3
					ifge gun_grace 5 add gun_spread 6
					sub tesla_ammo 1
					}
				else state dry_fire
				}
			ife kickbackpic_2 3 set kickbackpic_2 0
			}

		ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp PP19_FIRE }

		ife kickbackpic 2
			{
			ifge gun_grace 5 add gun_spread 3
			set gun_recoil 1
			set gunsmoke_angle 72
			state spawn_gunsmoke
			}

	set gun_mag slot3_mag
	set max_slot3_mag 64

		ife kickbackpic 7 sound PP19_RELOAD
		ife kickbackpic 15 ife slot3_mag 0 shoot SMG_MAG2
		ife kickbackpic 46 sound ENG_SLID

		ife kickbackpic 30
			{
			ifl cur_ammo max_slot3_mag set slot3_mag cur_ammo else set slot3_mag max_slot3_mag
			}


  ifl slot3_mag 1
   ife player[].weapon_pos 0
	ife kickbackpic 0
	 ife kickbackpic_2 0
	   {
		ifn cur_ammo 0
			{
			set WEAPON3_RELOAD 58
			setp[].reloading 1
			setp[].kickback_pic 6
			}
		}

  }

}
else
ife SPECIALIST_EQUIPMENT[110] 2 // Plasma SMG
{
setarray p_max_ammo[3]  300
setarray WEAPON_TILE[3] 23900

ifand guns_akimbo 2 setarray weap_special[3] 20481
else setarray weap_special[3] 20480

setarray W_AMMO_TILE[3] 23899
setarray ammo_amount[3] 40

set WEAPON3_FIREDELAY 2
set WEAPON3_TOTALTIME 3
set WEAPON3_HOLDDELAY 1
set WEAPON3_FLAGS 68
set WEAPON3_SPAWN 0
set WEAPON3_INITIALSOUND 4
set WEAPON3_CLIP 0
set WEAPON3_RELOADSOUND1 4
set WEAPON3_RELOADSOUND2 4
set WEAPON3_FIRESOUND 4
set WEAPON3_SHOOTS NULL_PROJ

	ife cur_weap 3
	{
	set alt_fire_type 5
	set reload_frame_partial 0
	set weapon_type 2
	ifand gun_firemode 1024
		{
		set WEAPON3_SHOTSPERBURST 2
		set GUN_VOLUME 50
		set max_slot3_mag 120
		set GUN_ACCURACY 16
		set GUN_MAX_SPREAD 64
		set WEAPON3_RELOAD 76
		set GUN_HANDS 2
		set GUN_SIZE 2
		}
	else
		{
		set WEAPON3_SHOTSPERBURST 1
		set GUN_VOLUME 25
		set max_slot3_mag 60
		set GUN_ACCURACY 8
		set GUN_MAX_SPREAD 32
		set WEAPON3_RELOAD 40
		set GUN_HANDS 1
		set GUN_SIZE 1
		}
	set GUN_AMMO_TYPES 0
	set gun_mag slot3_mag

	ife kickbackpic 0
		{
		ifg GUN_HEAT[cur_weap] 0
			{
			set temp9 GUN_HEAT[cur_weap]
			sub temp9 2
			setarray GUN_HEAT[cur_weap] temp9
			}
		}

	ife kickbackpic 2
			{
			ifand gun_firemode 1024
				{
				shoot MDF_PLASMA
				setprojectile[MDF_PLASMA].offset -224
				shoot MDF_PLASMA
				setprojectile[MDF_PLASMA].offset 144
				espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp PL_SMGF
				ifge gun_grace 5 add gun_spread 6
				set gun_recoil 6
				set gunsmoke_angle 104 state spawn_gunsmoke
				set gunsmoke_angle -104 state spawn_gunsmoke
				}
			else
				{
				shoot MDF_PLASMA
				espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp PL_SMGF
				ifge gun_grace 5 add gun_spread 6
				set gun_recoil 3
				set gunsmoke_angle 104 state spawn_gunsmoke
				}
			randvar temp2 8
			set temp9 GUN_HEAT[cur_weap]
			add temp9 temp2
			clamp temp9 0 60
			setarray GUN_HEAT[cur_weap] temp9

			}
	ife kickbackpic 13
			{
			ife slot3_mag 0 shoot SCIFI_SMG_MAG
			state smg_mag_out_sounds
			}
	ife kickbackpic 32
			{
			state smg_mag_in_sounds
			ifl cur_ammo max_slot3_mag set slot3_mag cur_ammo else set slot3_mag max_slot3_mag
			ifand gun_firemode 1024 div slot3_mag 2
			}
	ife kickbackpic 49
			{
			shoot SCIFI_SMG_MAG
			state smg_mag_out_sounds
			}
	ife kickbackpic 62
			{
			state smg_mag_in_sounds
			ifl cur_ammo max_slot3_mag set slot3_mag cur_ammo else set slot3_mag max_slot3_mag
			}

	 ifl slot3_mag 1
	  ife kickbackpic 0
		   ife player[].weapon_pos 0
			{
			ifn cur_ammo 0
				{
				ifl cur_ammo 0 setplayer[].ammo_amount 3 0
				setp[].reloading 1
				setp[].kickback_pic 6
				}
			}
	}
}
else // Using the MP7?
{
ifand JAMES_UPGRADE 128 setarray WEAPON_TILE[3] 5365
else setarray WEAPON_TILE[3] 5211
setarray W_AMMO_TILE[3] 5221

ifand guns_akimbo 2 // has two?
	{
	ifand JAMES_UPGRADE 128 // Suppressor upgrade?
		{
		ifand gun_firemode_two 2048 setarray weap_special[3] 21505 else
		setarray weap_special[3] 20481
		}
	else
	setarray weap_special[3] 4097
	}
	else
	{
	ifand JAMES_UPGRADE 128 // Suppressor upgrade?
		{
		ifand gun_firemode_two 2048 setarray weap_special[3] 21504 else
		setarray weap_special[3] 20480
		}
	else
	setarray weap_special[3] 4096
	}

setarray ammo_amount[3] 50

set WEAPON3_HOLDDELAY 2
set WEAPON3_SPAWN 0
set WEAPON3_SHOOTS ZRIFLESHOT
set WEAPON3_INITIALSOUND 4
set WEAPON3_RELOADSOUND1 4
set WEAPON3_RELOADSOUND2 5
set WEAPON3_CLIP 0
set WEAPON3_FIRESOUND 4


	ife cur_weap 3
	{
	set alt_fire_type 6
	set reload_frame_partial 0
	set weapon_type 0
	set GUN_AMMO_TYPES 0
	set GUN_SIZE 0

	ifand gun_firemode 1024 // Are they doubled up?
		{
		set GUN_ACCURACY 16
		set GUN_MAX_SPREAD 64
		set WEAPON3_FIREDELAY 2
		set WEAPON3_TOTALTIME 3
		set WEAPON3_FLAGS 68
		set WEAPON3_SHOTSPERBURST 2
		set WEAPON3_RELOAD 70
		set GUN_HANDS 2
		ife kickbackpic 2 { state pfakebullet state pfakebullet_left }
		}
	else
		{
		set WEAPON3_SHOTSPERBURST 1
		set WEAPON3_RELOAD 35
		set WEAPON3_FIREDELAY 2
		set WEAPON3_TOTALTIME 3
		set WEAPON3_FLAGS 68
		set GUN_HANDS 1
		set GUN_ACCURACY 8
		set GUN_MAX_SPREAD 32
		ife kickbackpic 2 state pfakebullet
		}

	ifand JAMES_UPGRADE 128 set alt_fire_type 6 else set alt_fire_type 0

	ifand JAMES_UPGRADE 128 // Suppressed?
	 ifand gun_firemode_two 2048
		{
		ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp SUP_TMP }
		ifand gun_firemode 1024 set GUN_VOLUME 8 else set GUN_VOLUME 4
		}
		else
		{
		ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp TMPFIRE }
		ifand gun_firemode 1024 set GUN_VOLUME 28 else set GUN_VOLUME 14
		}

	 ife player[].weapon_pos 0
		{
		ifand gun_firemode 1024 nullop else
			{
			state spawn_lasersite
			seta[RETURN].x hitx
			seta[RETURN].y hity
			seta[RETURN].z hitz
			ifand SPECIALIST_CUSTOM[3] 1073741824 seta[RETURN].pal 1
			else ifand SPECIALIST_CUSTOM[3] 2147483648 seta[RETURN].pal 8
			else seta[RETURN].pal 0
			}
		}

	set gun_mag slot3_mag
	ifand gun_firemode 1024
	{ ifand JAMES_UPGRADE 16 set max_slot3_mag 100 else set max_slot3_mag 60 }
	else
	{ ifand JAMES_UPGRADE 16 set max_slot3_mag 50 else set max_slot3_mag 30 }
		ife kickbackpic 1 { ifand gun_firemode 1024 set gun_recoil 3 else set gun_recoil 2 }
		ife kickbackpic 2
			{
			ifge gun_grace 5
				{
				ifand gun_firemode 1024 add gun_spread 8
				else add gun_spread 4
				}

			set gunsmoke_angle 72
			state spawn_gunsmoke
			ifand gun_firemode 1024 { set gunsmoke_angle -72 state spawn_gunsmoke }

			}
		ife kickbackpic 8 { state smg_mag_out_sounds ife slot3_mag 0 shoot SMGMAGAZINE }
		ife kickbackpic 10 state JMOVESOUND2

		ife kickbackpic 44 { state smg_mag_out_sounds shoot SMGMAGAZINE }
		ife kickbackpic 46 state JMOVESOUND2

		ife kickbackpic 22
		{
		state smg_mag_in_sounds
		ifl cur_ammo max_slot3_mag set slot3_mag cur_ammo else set slot3_mag max_slot3_mag
		ifand gun_firemode 1024 div slot3_mag 2
		}
		ife kickbackpic 60
		{
		state smg_mag_in_sounds
		ifl cur_ammo max_slot3_mag set slot3_mag cur_ammo else set slot3_mag max_slot3_mag
		}


  ifl slot3_mag 1
   ife player[].weapon_pos 0
	ife kickbackpic 0
   {
	ifn cur_ammo 0
		{
		setp[].reloading 1
		setp[].kickback_pic 6
		}
	}
  }
 }

