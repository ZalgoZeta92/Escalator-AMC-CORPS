// James' tertiary fire
appendevent EVENT_LOOKRIGHT
   ife CHAR 0
   {
	ife cur_weap 8
		{
		getp[].ammo_amount 8 alt_temp1
		ifg alt_temp1 0
		  ifn SPECIALIST_EQUIPMENT[112] 2 // NOT using rocket punch?
		   ife player[].kickback_pic 0
			{
			sound TNT_BOUNCE
			getp[].i alt_temp2
			ifand gun_firemode 32 espawn PROXONFLOOR_2 else
			espawn PROXONFLOOR
			seta[RETURN].owner alt_temp2
			getp[].ammo_amount 8 alt_temp2
			sub alt_temp2 1
			setp[].ammo_amount 8 alt_temp2
			setp[].kickback_pic 10
			}
	}
  }
endevent

// James's alternate fire code ==================================================================================================
defstate james_alt_fire

ife CHAR 0
{
 ife cur_weap 1
		{
		ife SPECIALIST_EQUIPMENT[88] 2 // Beretta 93R?
		ife kickbackpic 0
		 ifl kickbackpic 6
			{
			set GUN_VOLUME 70
			getp[].ammo_amount 1 alt_temp2
			ifg alt_temp2 0
			 ifg slot1_mag 2
			  ife GEO_MEGA_SHOT[0] 0
				{
				set GUN_ACCURACY 16
				ifge slot1_mag 2 setarray GEO_MEGA_SHOT[0] 2
				else setarray GEO_MEGA_SHOT[0] slot1_mag
				setplayer[].kickback_pic 1
				}
			else soundonce DRY_FIRE
			}
		}

	ife cur_weap 2
		{
		ife SPECIALIST_EQUIPMENT[111] 2 // Super Shotgun
		   ife kickbackpic 0
		   {
			getp[].ammo_amount 2 alt_temp1
			 ifg alt_temp1 1
				{
				ifl slot2_mag 2
					{
					sound SSHOTGOP
					setp[].kickback_pic 6
					setp[].reloading 1
					}
				else
					{
					setp[].kickback_pic 1
					xorvar gun_firemode 256
					sub alt_temp1 1
					setp[].ammo_amount 2 alt_temp1
					}
				}
		   }
		}


	ife cur_weap 3
	 ife SPECIALIST_EQUIPMENT[15] 2 // Laser bizon melta mode
		{
		ife kickbackpic 0
			{
			ifand MAGIC_UPGRADE[0] 8 ifg p_blue_mana 0 { ife kickbackpic_2 0 sound MELTA_START set kickbackpic_2 1 }
			else ifg tesla_ammo 0 { ife kickbackpic_2 0 sound MELTA_START set kickbackpic_2 1 }
			}
		}

	ife cur_weap 4
	 ife alt_fire_type 20
		{
		 ife kickbackpic 0
			{
				getp[].ammo_amount 4 alt_temp1
				ifg alt_temp1 0
				 {
				 ifg slot4_mag 0
					{
					setp[].kickback_pic 3
					sub wepsway_x 10
					sub wepsway_y 10
					globalsound 479
					sub alt_temp1 1
					setp[].ammo_amount 4 alt_temp1
					sub slot4_mag 1
					shoot JRGL_PROJ
					}
				else soundonce DRY_FIRE
				}
			}
		}

	ife cur_weap 2
	 ife alt_fire_type 20
	  ifand MAGIC_UPGRADE[0] 2
		{
		ife kickbackpic 0
		 ife kickbackpic_2 0
		  ifge p_blue_mana 8
			{
			set kickbackpic_2 1
			sub p_blue_mana 8
			sub wepsway_x 3
			sub wepsway_y 3
			espawn SOUND_SPRITE
			state SPAWN_IN_PLAYER_FRONT
			setactorvar[RETURN].temp PROT_ICE
			shoot ICE_BEAM
			shoot ICE_BEAM
			shoot ICE_BEAM
			shoot ICE_BEAM
			shoot ICE_BEAM
			shoot ICE_BEAM
			shoot ICE_BEAM
			}
		}

	ife cur_weap 6 // XM9
	{
	ife SPECIALIST_EQUIPMENT[98] 2 // using the dark matter XM9?
	 ifg p_purple_mana 0
	  ife gun_recoil 0
	   ife kickbackpic 0
		{
		sub p_purple_mana 1
		set gun_recoil 15
		set gun_pushb_disp 15
		espawn SOUND_SPRITE
		state SPAWN_IN_PLAYER_FRONT
		setactorvar[RETURN].temp VOID_MEGA
		shoot VOID_BLAST
		}
	else
	ife alt_fire_type 20
		{
		 ife kickbackpic 0
		  ifand MAGIC_UPGRADE[0] 1
			{
			ifg p_green_mana 0
				{
				setp[].kickback_pic 2
				sub p_green_mana 2
				sub wepsway_x 3
				sub wepsway_y 3
				espawn SOUND_SPRITE
				state SPAWN_IN_PLAYER_FRONT
				setactorvar[RETURN].temp XBOW_GRNF
				setprojectile[GREEN_ARCH_BOLT].cstat 130
				eshoot GREEN_ARCH_BOLT
				setprojectile[GREEN_ARCH_BOLT].cstat 2
				}
			}
		}
	}

	ife cur_weap 9
	 ife alt_fire_type 20
		{
		ife kickbackpic 0
		 ife kickbackpic_2 0
		  ifge p_green_mana 1
			{
			set kickbackpic_2 1
			sub p_green_mana 1
			sub wepsway_x 3
			sub wepsway_y 3
			espawn SOUND_SPRITE
			state SPAWN_IN_PLAYER_FRONT
			setactorvar[RETURN].temp LAVAN_FIRE
			shoot LAVA_NAIL
			}
		}

	ife cur_weap 11 // XM9
	 ife alt_fire_type 20
		{
		 ife kickbackpic 0
		  ifand MAGIC_UPGRADE[0] 1
			{
			ifg p_green_mana 0
				{
				setp[].kickback_pic 2
				sub p_green_mana 2
				sub wepsway_x 3
				sub wepsway_y 3
				espawn SOUND_SPRITE
				state SPAWN_IN_PLAYER_FRONT
				setactorvar[RETURN].temp ARCH_FIRE2
				eshoot RED_ARCH_BOLT
				geta[RETURN].z temp
				add temp 1536
				seta[RETURN].z temp
				}
			}
		}
}
ends

defstate jackhammer_weapon
ife BELT_LOADOUT[CHAR] 5 setarray p_max_ammo[2]  120 else
setarray p_max_ammo[2]  100

setarray WEAPON_TILE[2] 12160
setarray W_AMMO_TILE[2] 5225
setarray ammo_amount[2] 10
setarray weap_special[2] 4

set WEAPON2_CLIP 0
set WEAPON2_RELOAD 62
set WEAPON2_FIREDELAY 3
set WEAPON2_TOTALTIME 7
set WEAPON2_HOLDDELAY 32
set WEAPON2_FLAGS 1024
set WEAPON2_SHOOTS ZRIFLESHOT
set WEAPON2_SPAWNTIME 5
set WEAPON2_SPAWN 0
set WEAPON2_SHOTSPERBURST 6
set WEAPON2_INITIALSOUND 0
set WEAPON2_FIRESOUND 4
set WEAPON2_SOUND2TIME 15
set WEAPON2_SOUND2SOUND 4
set WEAPON2_RELOADSOUND1 4
set WEAPON2_RELOADSOUND2 5

	ife cur_weap 2
	{
	set reload_type 2 // shotgun box mag
	set weapon_type 2
	set GUN_VOLUME 70
	set GUN_ACCURACY 24
	set GUN_MAX_SPREAD 8
	set GUN_SIZE 2
	set GUN_HANDS 2
	set GUN_AMMO_TYPES 0
	set gun_mag alt_slot2_mag
	set max_alt_slot2_mag 10

	ifand BITS_PRESS 4
		  ifg alt_slot2_mag 0
		   ife kickbackpic 0
		   ife player[].ammo_amount 2 0
		   ife need_to_fire 0
		   ife player[].weapon_pos 0
			{
			getp[].ammo_amount 2 hold_ammo_temp
			add hold_ammo_temp 1
			setp[].ammo_amount 2 hold_ammo_temp
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp JACKHAMMER
			setp[].kickback_pic 1
			set need_to_fire 1
			}

	ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp JACKHAMMER }

	ife kickbackpic 3
	ife need_to_fire 1
			{
			setp[].ammo_amount 2 0
			set need_to_fire 0
			}

			ife kickbackpic 2
				{
				state pfakebullet_shotgun
				sub alt_slot2_mag 1
				getp[].ammo_amount 2 hold_ammo_temp
				add hold_ammo_temp 1
				setp[].ammo_amount 2 hold_ammo_temp
				set gunsmoke_angle 96
				state spawn_gunsmoke
				}
			ife kickbackpic 3 { add gun_spread 8 set gun_recoil 6 }
			ife kickbackpic 10 state JMOVESOUND2

			ife kickbackpic 13 { sound DRUM_OUT ife alt_slot2_mag 0 shoot DRUMMAGAZINE }

			ife kickbackpic 30 state JMOVESOUND2
			ife kickbackpic 43
			{
			sound DRUM_IN
			set temp5 alt_slot2_mag
			set temp6 max_alt_slot2_mag
			sub temp6 temp5

				ifg temp6 cur_ammo
					{
					add alt_slot2_mag cur_ammo
					setp[].ammo_amount 2 0
					}
					else
					{
					getp[].ammo_amount 2 hold_ammo_temp
					sub hold_ammo_temp temp6
					setp[].ammo_amount 2 hold_ammo_temp
					set alt_slot2_mag max_alt_slot2_mag
					}
			}

		ifl alt_slot2_mag 1
		   ife player[].weapon_pos 0
			ife kickbackpic 0
		   {
		   ifn cur_ammo 0
			   {
			   setp[].reloading 1
			   setp[].kickback_pic 6
			   }
			}

	}
ends

// JAMES MAIN STATE

defstate PS_JAMES
set P_GENDER MALE

ife TIMEZONE 2 setvar screen_pal 7

qputs 90 MJ12 Injection
qputs 12 Used MJ12 Injection

ife HELMET_LOADOUT[CHAR] 4
	{
	qputs 101 Ghost vision goggles
	qputs 106 Ghost vision on
	qputs 107 Ghost vision off
	}
else
ife HEAT_GOGGLES 1
	{
	qputs 101 Heat vision goggles
	qputs 106 Heat vision on
	qputs 107 Heat vision off
	}
else
	{
	qputs 101 Night vision goggles
	qputs 106 Night vision on
	qputs 107 Night vision off
	}

qputs 6 GiroTek Protective Boots
qputs 75 Protective boots: %d %
set temp player[].boot_amount
ife PERSONNEL_RESEARCH[26] 2 div temp 3 else div temp 2
qsprintf 75 75 temp

qputs 3 Portable Medikit

qputs 89 Airtank

qputs 47 Portable forcefield on
qputs 48 Portable forcefield off
qputs 49 Portable forcefield not found yet!
qputs 51 Portable forcefield
qstrcpy 91 51

qputs 88 Jetpack
qputs 50 Jetpack not found yet!
qputs 52 Jetpack on
qputs 53 Jetpack off

qputs 102 We're gonna fry your ass, Stanfield!

setuserdef[].userquote_xoffset -20
setuserdef[].userquote_yoffset 130

ife booster_item 1
	{
	setp[].sound_pitch -512
	 set current_inittimer 60
	inittimer 60
	sub booster_amount 1
	ifle booster_amount 0
		{
		stopsound J_INJECTION
		sound SLOMO_OFF
		set booster_item 0
		setp[].inven_icon 0
		setp[].steroids_amount 0
		setp[].sound_pitch 0
		set current_inittimer 120
		inittimer 120
		}
	ifg booster_amount 0
	 ife booster_item 0
	  setp[].steroids_amount 400
	}
	else
ife booster_item 0
 ife current_inittimer 60
	{
	sound SLOMO_OFF
	setp[].sound_pitch 0
	set current_inittimer 120
	inittimer 120
	}


getp[].holoduke_on temp
ifn temp -1
	{
	setp[].holoduke_amount holoduke_amount
	seta[temp].cstat 32768
	seta[temp].xrepeat 1
	seta[temp].yrepeat 1
	ife PS_ITEM 0
		{
		stopsound TELEPORTER
		sound PFIELD_ON
		espawn 5208
		seta[RETURN].pal 3
		set temp4 RETURN
		espawn 5208
		seta[RETURN].pal 49
		setactorvar[RETURN].temp8 temp4
		set PS_ITEM 1
		}
	}
else
ife temp -1
	{
	ife PS_ITEM 1
		{
		sound PFIELD_OFF
		set PS_ITEM 0
		}
	else getp[].holoduke_amount holoduke_amount
	}

setarray p_max_ammo[3]  300
setarray p_max_ammo[9]  300

ife injured 1
	{
	ifg sprite[].extra 20 seta[].extra 20
	state lower_weapon
	ife player[].over_shoulder_on 1 setp[].over_shoulder_on 0

	getp[].posxv temp
	mul temp 10
	ifand BITS_PRESS P_SPRINTING
	 ifg p_stamina 0 div temp 12 else div temp 15
	setp[].posxv temp
	getp[].posyv temp
	mul temp 10
	ifand BITS_PRESS P_SPRINTING
	 ifg p_stamina 0 div temp 12 else div temp 15
	setp[].posyv temp

	ifp pstanding nullop else ifrnd 2 spawn BLOODPOOL
	}


ife SHOOTGRENADE THISACTOR { shoot J_GRENADE ifg bomb_throw_power 96 soundonce JEXERT set SHOOTGRENADE -1 }

setp[].knuckle_incs 0

set CPIPEBOMB 1498

ifand CHAR_APP 1 ife UPPER_CUT 17 sound SERVOSND

ifand CHAR_APP 1 ifn TIMEZONE 2 set fist_tile 3158 else set fist_tile 3151

ifand CHAR_APP 512 // Abyssal armour
	{
	state phantom_bike_summon
	set JUMP_BOOTS 1

	set CDETON 5498
	set c_medikit 5230
	set C_HAND_1 19892
	set C_HAND_2 19893
	set CKNEE 28315
	set CHOLDING_R 9438
	set C_PISTOL_R 8991
	set CTIP 19861
	set CKEYCARDTILE 19858
	set CKEYCARDTILE2 19859
	set CKEYCARDTILE3 19860
	set CTRIPBOMB 19858
	set CHOLDING_L 9426
	set CHOLDING_3 19772
	set C_ARM_1 19864
	set C_ARM_2 9001
	set C_ARM_3 5349
	set C_PISTOL_L 8986
	set C_UNIQUE_2 19840
	set C_UNIQUE_3 19841
	set C_UNIQUE_4 12151
	set C_PUNCH 19827
	}
else
ifand CHAR_APP 1 // bionic right hand
	{
	set CDETON 5493
	ifand CHAR_APP 64 set CKNEE 24574
	else set CKNEE 5153
	set c_medikit 5230
	set C_HAND_1 19892
	set C_HAND_2 19893
	set CHOLDING_R 9438
	set C_PISTOL_R 8991
	set CTIP 19861
	set CKEYCARDTILE 19858
	set CKEYCARDTILE2 19859
	set CKEYCARDTILE3 19860
	set CTRIPBOMB 19858
	set CHOLDING_L 9426
	set CHOLDING_3 11893
	set C_ARM_1 5182
	set C_ARM_2 9007
	set C_ARM_3 5350
	set C_PISTOL_L 8988
	set C_UNIQUE_2 5243
	set C_UNIQUE_3 7894
	set C_UNIQUE_4 12152
	set C_PUNCH 5186
	}
else
	{
	set CDETON 5493
	set CKNEE 5132
	set c_medikit 5190
	set C_HAND_1 7893
	set C_HAND_2 7894
	set CHOLDING_R 9426
	set CTIP 5177
	set C_PISTOL_R 8988
	set CKEYCARDTILE 5130
	set CKEYCARDTILE2 5128
	set CKEYCARDTILE3 5127
	set CTRIPBOMB 5129
	set CHOLDING_L 9426
	set CHOLDING_3 11893
	set C_ARM_1 5182
	set C_ARM_2 9007
	set C_ARM_3 5350
	set C_PISTOL_L 8988
	set C_UNIQUE_2 5243
	set C_UNIQUE_3 7894
	set C_UNIQUE_4 12152
	set C_PUNCH 5186
	}


set c_steroids 5192
set c_holoduke 5228


ifand CHAR_APP 512
	{
	set c_jetpack 27825
	set c_nvg_heat 27826
	set c_nvg_normal 27823
	set c_scuba 27827
	set c_boots 27824
	set c_armour 27771
	set c_heavy_armour 27772
	}
else
	{
	set c_jetpack 5233
	set c_nvg_heat 5347
	set c_nvg_normal 5234
	set c_scuba 5232
	set c_boots 5235
	set c_armour 5229
	set c_heavy_armour 5236
	}

state DISP_nvg

ifand CHAR_APP 512 // Revenant James
{
ifg j_regen_timer 0 sub j_regen_timer 1
ifl PHEALTH pmax_health ife j_regen_timer 0
	{
	addphealth 1
	soundonce J_INJECTION
	setactorsoundpitch THISACTOR J_INJECTION -256
	set j_regen_timer 5
	}
ifg sprite[].htextra 0 set j_regen_timer 90
set p_stamina 600
set pmax_stamina 600

	// doesn't need oxygen
	setp[].airleft 390

	// no falling damage
		ife player[].jumping_counter 0
		  ifg player[].falling_counter 8
		  ifl player[].falling_counter 61
			setplayer[THISACTOR].falling_counter 8

ifle sprite[].extra 1
 ife player_dead 0
	{
	add j_resurrect_count 1
	setp[].dead_flag 0
	action PSTAND
	set temp5 player[].max_player_health
	div temp5 4
	sub pmax_health temp5
	screensound J_RES
	setp[].max_player_health pmax_health
	seta[].extra pmax_health
	addphealth 500
	seta[].htextra -1
	}
}
else
{
ifg AGENT_FATIGUE[CHAR] 5000 ifg SKILL_LEVEL 2 set pmax_stamina 90
else set pmax_stamina 120
}

// MELEE

ifp pboosted
{
stopsound PLYR_HARTBEAT
soundonce J_INJECTION
getp[].jumping_counter temp
ifg temp 0 { setp[].poszv -6536 }

iffloordistl 32 { getp[].falling_counter temp ifl temp 61 setp[].falling_counter 8 }

ifl PHEALTH 25 addphealth 3
else ifl PHEALTH 75 addphealth 2
else ifl PHEALTH pmax_health addphealth 1
}

// weapon pickup sounds
setarray wep_get_sound[1] PICK_PISTOL
setarray wep_get_sound[2] PICK_SHOTG
setarray wep_get_sound[3] PICK_SMG
setarray wep_get_sound[4] PICK_BIGGUN

setarray wep_get_sound[6] PICK_ENERG
setarray wep_get_sound[7] PICK_RIFLE
setarray wep_get_sound[9] PICK_RIFLE

// weapon select sounds
set WEAPON1_SELECTSOUND SELECT_PISTOL
set WEAPON2_SELECTSOUND SELECT_SHOTGUN
set WEAPON3_SELECTSOUND SELECT_SMG
set WEAPON4_SELECTSOUND SELECT_WEAPON
set WEAPON6_SELECTSOUND SELECT_HT_ASSAULTR
set WEAPON7_SELECTSOUND SELECT_ASSAULTR
set WEAPON9_SELECTSOUND SELECT_ASSAULTR

ife temp_weap 0
{
ife cur_weap 0
	{
	set gun_mag -1
	ifp pboosted { ife kickbackpic 7 { sound PUNCH shoot 5357 } } else
	ife kickbackpic 15 { sound PUNCH shoot 5357 }
	}

ifp pboosted
	{
	set WEAPON0_TOTALTIME 9
	set WEAPON0_HOLDDELAY 9
	set WEAPON0_FIREDELAY 4
	set WEAPON0_FIRESOUND 532
	set WEAPON0_SHOOTS 5357
	}
else
	{
	set WEAPON0_TOTALTIME 17
	set WEAPON0_HOLDDELAY 17
	set WEAPON0_FIREDELAY 7
	set WEAPON0_FIRESOUND 532
	set WEAPON0_SHOOTS 5357
	}
}

// PISTOL
set WEAPON1_HOLDDELAY 10
set WEAPON1_SPAWNTIME 2
set WEAPON1_SPAWN 0
set WEAPON1_INITIALSOUND 0
set WEAPON1_SOUND2TIME 0
set WEAPON1_SOUND2SOUND 0
set WEAPON1_RELOADSOUND1 4
set WEAPON1_RELOADSOUND2 4
set WEAPON1_CLIP 0

ife SPECIALIST_EQUIPMENT[28] 2 // Using the OTs33?
{
setarray p_max_ammo[1]  400
ifand guns_akimbo 4 setarray weap_special[1] 4097 else setarray weap_special[1] 4096
setarray WEAPON_TILE[1] 13418
setarray W_AMMO_TILE[1] 5981
setarray ammo_amount[1] 40
set WEAPON1_SHOOTS 0
set WEAPON1_FIRESOUND 4
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 3
set WEAPON1_FLAGS 68

	ife cur_weap 1
		{
		set alt_fire_type 0
			set weapon_type 7
			set GUN_MAX_SPREAD 32
			ifand gun_firemode 64
				{
				set GUN_ACCURACY 48
				set GUN_VOLUME 28
				}
				else
				{
				set GUN_ACCURACY 24
				set GUN_VOLUME 14
				}

			set GUN_SIZE 0
		ife kickbackpic 1
			{
			shoot SILVERAMMOSHOT ifand gun_firemode 64 shoot SILVERAMMOSHOT
			ifand gun_firemode 64 sub slot1_mag 2 else sub slot1_mag 1
			}
		ife kickbackpic 2
			{
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp OTS33_FIRE state pfakebullet
			shoot NINEMM_SHELL
			add gun_spread 8
			ifvarl gun_mag 6 sound MAG_LOW
			ifand gun_firemode 64 shoot NINEMM_SHELL_LEFT
			set gun_recoil 5
			set gunsmoke_angle 78
			state spawn_gunsmoke
			ifand gun_firemode 64 { set gunsmoke_angle -70 state spawn_gunsmoke state pfakebullet_left }
			}
		}

}
else
ife SPECIALIST_EQUIPMENT[2] 2 // Using the Fn57?
{
setarray p_max_ammo[1]  200
ifand guns_akimbo 4 setarray weap_special[1] 20481 else setarray weap_special[1] 20480
setarray WEAPON_TILE[1] 10394
setarray W_AMMO_TILE[1] 5220
setarray ammo_amount[1] 12
set WEAPON1_SHOOTS ARMOUR_PIERCING_SHOT
set WEAPON1_FIRESOUND 4
set WEAPON1_FIREDELAY 2
set WEAPON1_TOTALTIME 4
set WEAPON1_FLAGS 16448

ife cur_weap 1
	{
	set alt_fire_type 3
	set weapon_type 1
	set GUN_MAX_SPREAD 0
	ifand gun_firemode 64 set GUN_VOLUME 40 else set GUN_VOLUME 20
	ifand gun_firemode 2048 set GUN_ACCURACY 8 else
		{ ifand gun_firemode 64 set GUN_ACCURACY 64 else set GUN_ACCURACY 32 }
	set GUN_SIZE 0

	ifand gun_firemode 2048
		{
		ifand gun_firemode 64 xorvar gun_firemode 2048
		ife player[].weapon_pos 0
			{
			state spawn_lasersite
			ifand SPECIALIST_CUSTOM[2] 1073741824 seta[RETURN].pal 1
			else ifand SPECIALIST_CUSTOM[2] 2147483648 seta[RETURN].pal 8
			else seta[RETURN].pal 0
			}
		}
		ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp FN57_FIRE }
		ife kickbackpic 2
			{
			state pfakebullet
			shoot NINEMM_SHELL
