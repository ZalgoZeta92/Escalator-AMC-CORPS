// FREEZER

setarray WEAPON_TILE[9] 32419
setarray W_AMMO_TILE[9] 32420
ifand AGENT_UPGRADE 262144 setarray weap_special[9] 16384
else setarray weap_special[9] 0
setarray ammo_amount[9] 50

set WEAPON9_FIREDELAY 27
set WEAPON9_TOTALTIME 50
set WEAPON9_HOLDDELAY 57
set WEAPON9_SHOOTS 22610
set WEAPON9_SHOTSPERBURST 1
set WEAPON9_INITIALSOUND 0
set WEAPON9_FIRESOUND 4
set WEAPON9_FLAGS 6

	ife cur_weap 9
		{
		set weapon_type 9
		set gun_mag -1
		set GUN_VOLUME 15
		set GUN_ACCURACY 2
		set GUN_AMMO_TYPES 0
		set GUN_SIZE 1
		set GUN_HANDS 2
		set GUN_VOLUME 10

		// auto-spin stuff
		ifn player[].weapon_pos 0 setp[].kickback_pic 0
		ifand gun_firemode_two 16
			{
			ife kickbackpic 0 setp[].kickback_pic 1
			ife kickbackpic 25
				{
				ifand BITS_PRESS 4 setp[].kickback_pic 26
				else { soundonce TESLA_ARC setactorsoundpitch THISACTOR TESLA_ARC 256 setp[].kickback_pic 30 }
				}
			ife player[].ammo_amount 9 0 { setp[].kickback_pic 30 stopsound TESLA_ARC sound LIGHTNG_SPINDN xorvar gun_firemode_two 16 }
			ife kickbackpic 31 setp[].kickback_pic 24
			}
		ifge kickbackpic 3
		 ifle kickbackpic 27
			{
			ifand BITS_PRESS 4 nullop else setp[].kickback_pic 29
			}
		ife kickbackpic 3 sound LIGHTNG_SPINUP
		ife kickbackpic 29 sound LIGHTNG_SPINDN
		ife kickbackpic 27
			{
			espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp LIGHTNG_FIRE
			set gunsmoke_angle 64 state spawn_gunsmoke
			set gun_pushback_power -16 state gun_pushback
			set gun_recoil 4
			}
		ife kickbackpic 28
			{
			getp[].ammo_amount 9 temp2
			ifand BITS_PRESS 4 ifg temp2 0 setp[].kickback_pic 26
			}
		}

