// SHRINKER
setarray p_max_ammo[6]  40
setarray WEAPON_TILE[6] 29781
setarray W_AMMO_TILE[6] 29791
setarray weap_special[6] 16896
setarray ammo_amount[6] 5
setarray wep_get_sound[6] PICK_RIFLE

set WEAPON6_FIREDELAY 2

set WEAPON6_INITIALSOUND 4
set WEAPON6_SHOOTS BIGRIFLESHOT
set WEAPON6_FIRESOUND 4
set WEAPON6_SHOTSPERBURST 1
set WEAPON6_FLAGS 16384

setplayer[THISACTOR].gotweapon 11 0

ife cur_weap 6
	{
	ife needs_pump[6] 1 
		{
		ife kickbackpic 37
			{
			setarray needs_pump[6] 0
			setp[].kickback_pic 0
			setp[].reloading 0
			}
		}
	set WEAPON6_TOTALTIME 66
	set reload_frame_partial 42
	set alt_fire_type 2
	
	set max_slot6_mag 10
	set weapon_type 1
	set GUN_VOLUME 80
	set gun_mag slot6_mag
	set GUN_SIZE 2
	set GUN_HANDS 2
	ife scope 1 set GUN_ACCURACY 2
	else set GUN_ACCURACY 16
	set GUN_MAX_SPREAD 64
	set GUN_AMMO_TYPES 0

		ife kickbackpic 1 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp AWM_FIRE }
		ife kickbackpic 2 { sub slot6_mag 1 state pfakebullet }
		ife kickbackpic 3 { set gunsmoke_angle 32 state spawn_gunsmoke set gun_recoil 10 }
		ife kickbackpic 4 add gun_spread 32
		ife kickbackpic 4 ifg slot6_mag 0 setp[].kickback_pic 34
		
		ife kickbackpic 11
			{
			state bgar_mag_out_sounds ife slot6_mag 0 shoot BIG_RIFLE_MAG
			}
		ife kickbackpic 27
			{
			state bgar_mag_in_sounds
			ifl cur_ammo max_slot6_mag { set slot6_mag cur_ammo } else set slot6_mag max_slot6_mag
			}
		ife kickbackpic 10 { ife scope 1 set scope 0 sound AUG_MOVEMENT }
		ife kickbackpic 24 state JMOVESOUND2
		ife kickbackpic 34 sound AUG_MOVEMENT
		ife kickbackpic 43 state JMOVESOUND2
		ife kickbackpic 55 { ife needs_pump[6] 0 shoot RIFLESHELL sound AWMS_COCK }
		

		ifl slot6_mag 1
	   ife player[].weapon_pos 0
		ife kickbackpic 0
		   {
		   setarray needs_pump[6] 0
		   set WEAPON6_RELOAD 66
			ifn cur_ammo 0
				{
				setp[].reloading 1
				setp[].kickback_pic 6
				}
			}
	}

