set WEAPON8_FIREDELAY 2
set WEAPON8_FLAGS 258

ife cur_weap 8
	{
	set weapon_type 6
	set gun_mag -1
	set GUN_VOLUME 0
	set GUN_HANDS 2
	set GUN_SIZE 0
	set GUN_ACCURACY 2
	set GUN_MAX_SPREAD 0
	set GUN_AMMO_TYPES 0

	ifand BITS_PRESS 64
	 ifcount 13
		{
		ifand gun_firemode_two 64 xorvar gun_firemode_two 64 else
		ifand gun_firemode_two 32 { xorvar gun_firemode_two 32 xorvar gun_firemode_two 64 }
		else xorvar gun_firemode_two 32
		resetcount
		}

	}

// FREEZER
ife SPECIALIST_EQUIPMENT[132] 2 // Ice Minigun
{
setarray WEAPON_TILE[9] 26538
setarray W_AMMO_TILE[9] 26545
setarray weap_special[9] 16896
setarray ammo_amount[9] 50
setarray p_max_ammo[9]  300

set WEAPON9_FIREDELAY 27
set WEAPON9_TOTALTIME 50
set WEAPON9_HOLDDELAY 57
set WEAPON9_SHOOTS ICE_BEAM
set WEAPON9_SHOTSPERBURST 1
set WEAPON9_INITIALSOUND 0
set WEAPON9_FIRESOUND 4
set WEAPON9_FLAGS 6

	ife cur_weap 9
		{
		set weapon_type 9
		set gun_mag -1
		set GUN_VOLUME 15
		set GUN_ACCURACY 2
		set GUN_AMMO_TYPES 0
		set GUN_SIZE 3
		set GUN_HANDS 2
		set GUN_VOLUME 10

		// auto-spin stuff
		ifn player[].weapon_pos 0 setp[].kickback_pic 0
		ifand gun_firemode_two 16
			{
			ife kickbackpic 0 setp[].kickback_pic 1
			ife kickbackpic 25
				{
				ifand BITS_PRESS 4 setp[].kickback_pic 26
				else { soundonce MINIGUN_SPIN setactorsoundpitch THISACTOR MINIGUN_SPIN 256 setp[].kickback_pic 30 }
				}
			ife player[].ammo_amount 9 0 { setp[].kickback_pic 30 stopsound MINIGUN_SPIN stopsound KG_ICEMF sound MINIGUN2_STOP xorvar gun_firemode_two 16 }
			ife kickbackpic 31 setp[].kickback_pic 24
			}
		ifge kickbackpic 3
		 ifle kickbackpic 27
			{
			ifand BITS_PRESS 4 nullop else setp[].kickback_pic 29
			}
		ife kickbackpic 3 sound MINIGUN2_START
		ife kickbackpic 30 { stopsound KG_ICEMF sound MINIGUN2_STOP }
		ife kickbackpic 27
			{
			ifactorsound THISACTOR KG_ICEMF nullop else sound KG_ICEMF
			set gunsmoke_angle 64 state spawn_gunsmoke
			set gun_pushback_power -16 state gun_pushback
			set gun_recoil 4
			}
		ife kickbackpic 28
			{
			getp[].ammo_amount 9 temp2
			ifand BITS_PRESS 4 ifg temp2 0 setp[].kickback_pic 26
			}
		ifg kickbackpic 30 ifand BITS_PRESS 4 ifg cur_ammo 0 { set gun_grace 0 setp[].kickback_pic 26 }
		}
}
else
{
setarray WEAPON_TILE[9] 24042
setarray W_AMMO_TILE[9] 27373
setarray ammo_amount[9] 5
setarray p_max_ammo[9]  50

setarray weap_special[9] 0

set WEAPON9_FIRESOUND KAG_MISSL
set WEAPON9_SHOOTS 27372
set WEAPON9_SHOTSPERBURST 10
