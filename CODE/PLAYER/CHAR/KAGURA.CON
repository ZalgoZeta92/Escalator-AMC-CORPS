				else sub flechete_shells 2
				set slot2_mag 2
				}
			else { set flechete_shells 0 set slot2_mag 1 }
			}
		else
			{
			getp[].ammo_amount 2 temp
			ifg temp 1 set slot2_mag 2
			else set slot2_mag 1
			}
		sound SAWNOFF_LOAD
		}
	ife kickbackpic 7 sound SAWNOFF_COCK
	}
