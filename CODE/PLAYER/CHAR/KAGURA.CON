    set WEAPON7_FIRESOUND 4
    set WEAPON7_INITIALSOUND 0
    set WEAPON7_FLAGS 22
    
    set WEAPON7_FIREDELAY 2
    set WEAPON7_TOTALTIME 3
    set WEAPON7_RELOAD 70
    set WEAPON7_FLAGS 4
    set WEAPON7_SELECTSOUND SELECT_HMG

    ife cur_weap 7
        {
		set alt_fire_type 0
        set GUN_VOLUME 25
        set weapon_type 0
        set GUN_SIZE 2
        set GUN_HANDS 2
        set GUN_AMMO_TYPES 0
        set gun_mag slot7_mag
        set max_slot7_mag 100
		set reload_frame 12
		set reload_frame_partial 0
        ife kickbackpic 2 { espawn SOUND_SPRITE state SPAWN_IN_PLAYER_FRONT setactorvar[RETURN].temp KG_HMGF state pfakebullet }

            set GUN_ACCURACY 12
            set GUN_MAX_SPREAD 32
            ife kickbackpic 1 { ifge gun_grace 20 add gun_spread 7 set gun_recoil 4 }
            ife kickbackpic 2 { sub slot7_mag 1 set gunsmoke_angle 64 state spawn_gunsmoke }
        ife kickbackpic 18 sound PKM_BOX_OUT
        ife kickbackpic 35 sound PKM_CHAIN
        ife kickbackpic 50
            {
            sound PKM_BOX_IN
            ifvarvarl cur_ammo max_slot7_mag set slot7_mag cur_ammo else set slot7_mag max_slot7_mag
            }

        ifg GUN_HEAT[cur_weap] 40
            {
            ifg kickbackpic 10 { set gunsmoke_z 9144 set gunsmoke_angle 64 }
            else { set gunsmoke_z 9144 set gunsmoke_angle 64 }
            state spawn_gunsmoke_z
            }
			
      ifl slot7_mag 1
       ife player[].weapon_pos 0
        ife kickbackpic 0
            {
            ifn cur_ammo 0
                {
                setp[].reloading 1
                setp[].kickback_pic reload_frame
                }
            }
        }
	}
else
