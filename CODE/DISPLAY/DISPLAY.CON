		case 2
		case 1
			rotatesprite 160 97 95536 0 6722 shade wep_pal 8 windowx1 windowy1 windowx2 windowy2
		break
	endswitch
ifl vr_goggles_anim 0 // take off anim
	switch vr_goggles_anim
		case -1
		case -2
		case -3
		case -4
		case -5
			rotatesprite 160 157 NNORMALSIZE 0 6718 shade wep_pal 8 windowx1 windowy1 windowx2 windowy2
			break
		case -6
		case -7
		case -8
		case -9
		case -10
