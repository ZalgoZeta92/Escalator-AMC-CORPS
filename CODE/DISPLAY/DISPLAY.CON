 case 20
 guniqhudid 40
 rotatesprite 130 195 45056 0 disp_temp shade CKEYCARDPAL 4096 0 0 xdim ydim // card
  guniqhudid 41
 rotatesprite 200 200 40960 0 CKEYCARDTILE shade arm_pal 4096 0 0 xdim ydim // hand
 guniqhudid 0
