			ife disp_temp5 E1_BOSS rotatesprite 44 120 80304 FLIP 20531 5 disp_temp6 12 0 0 xdim ydim
			ife disp_temp5 GORILLA rotatesprite 44 130 80304 FLIP 22811 5 disp_temp6 12 0 0 xdim ydim
			ife disp_temp5 NAZI rotatesprite 44 135 80304 FLIP 22913 5 disp_temp6 12 0 0 xdim ydim
			ife disp_temp5 PITFIEND rotatesprite 44 130 80304 FLIP 13017 5 disp_temp6 12 0 0 xdim ydim
			ife disp_temp5 BEYONDER rotatesprite 44 130 90304 FLIP 12683 5 disp_temp6 12 0 0 xdim ydim
			ife disp_temp5 ZOMBIE rotatesprite 184 130 80304 FLIP 26255 5 disp_temp6 4 0 0 xdim ydim
			ife disp_temp5 CHRYSSALID rotatesprite 184 135 85304 FLIP 24236 5 disp_temp6 4 0 0 xdim ydim
			ife disp_temp5 SPIDER2 rotatesprite 184 135 85304 FLIP 23516 5 disp_temp6 4 0 0 xdim ydim
			ife disp_temp5 RAPTOR rotatesprite 184 135 85304 FLIP 37894 5 disp_temp6 4 0 0 xdim ydim
			}

		 set disp_temp7 144
		 ife CHAR 0 ife injured 1 set disp_temp5 5363
		 else ifp pdead { set disp_temp7 204 set disp_temp5 player_anims[14] }
		 else ifn player_using_horse -1 ifn player_anims[16] 0 set disp_temp5 player_anims[16]
		 else ifg player_bike 0 ifn player_anims[12] 0 set disp_temp5 player_anims[12]
		 else ifinwater set disp_temp5 player_anims[8]
		 else ifn amc_base 0 set disp_temp5 player_anims[1]
		 else ifl SLIDE_KICK 26 set disp_temp5 player_anims[6]
		 else ifp pjumping set disp_temp5 player_anims[3]
		 else ifp pjetpack
			{
			ifn player_anims[11] 0 set disp_temp5 player_anims[11]
			else set disp_temp5 player_anims[3]
			}
		 else ifp pducking set disp_temp5 player_anims[6]
		 else ifp pfalling set disp_temp5 player_anims[4]
		 else ifl ROUNDHOUSE_KICK 26 set disp_temp5 player_anims[7]
		 else ifl QUICKK 13 set disp_temp5 player_anims[7]
		 else ifp prunning set disp_temp5 player_anims[2]
		 else ifp pwalking
			{
			ifn player_anims[15] 0 set disp_temp5 player_anims[15]
			else set disp_temp5 player_anims[2]
			}
		 else ife player[].holster_weapon 1 set disp_temp5 player_anims[1]
		 else set disp_temp5 player_anims[0]

        rotatesprite 294 disp_temp7 90304 0 disp_temp5 CHARSHADE 4 33 0 0 xdim ydim // CHARACTER SHADOW
        sub disp_temp7 4
        rotatesprite 290 disp_temp7 90304 0 disp_temp5 CHARSHADE player_anims[32] 0 0 0 xdim ydim // CHARACTER
	}

    // darken the background to make menus more visible -- render above ships etc when out of the game
    switch current_menu
        case 0 // main (out of game)
		case 102
		case 103
			break
        case 50 // main (ingame)
            rotatespritea 160 100 98304 0 3584 0 4 0 160 0 0 xdim ydim
            break
        default
            rotatespritea 160 100 98304 0 3584 0 4 0 40 0 0 xdim ydim
            break
    endswitch

    // version display
    screentext STARTALPHANUM 280 195 30000 0 0 VERSION_FOR_MENU -31 12 528 0 5 8 0 0 262146 0 0 xdim ydim

endevent

onevent EVENT_DISPLAYBONUSSCREEN

ife cheated 1 gametext STARTALPHANUM 27 158 8500 0 2 0 0 0 xdim ydim
else
ifg AMC_BUDGET_INCREASE 0
{
qsprintf 1026 1027 AMC_BUDGET_INCREASE
gametext STARTALPHANUM 27 158 1026 0 0 0 0 0 xdim ydim
}
ifg LOADOUT_COST 0
	{
	set temp6 LOADOUT_COST

		// Display 2 digits after the comma
		set disp_temp9 temp6
		div disp_temp9 10
		modvar disp_temp9 10

		set disp_temp8 temp6
		div disp_temp8 100
		modvar disp_temp8 10

	div temp6 1000

		qsprintf 1026 1090 temp6 disp_temp8 disp_temp9
	gametext STARTALPHANUM 27 168 1026 0 2 0 0 0 xdim ydim
	}

readgamevar AMC_BUDGET
qsprintf 1023 1024 AMC_BUDGET
gametext STARTALPHANUM 27 178 1023 0 0 0 0 0 xdim ydim

getp[].palookup disp_temp6

ife CHAR 0 // JAMES
