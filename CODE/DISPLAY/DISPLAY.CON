		gametextz STARTALPHANUM 15 80 7042 0 0 16 0 0 xdim ydim HALFSIZE

		// exit key
		getkeyname 406 6 2
		qsprintf 7023 7023 406
		gametextz STARTALPHANUM 15 90 7023 0 0 16 0 0 xdim ydim HALFSIZE
		}

	rotatespritea 47 28 NORMALSIZE 1024 2483 0 disp_temp4 260 -255 0 0 xdim ydim
	rotatespritea 273 28 NORMALSIZE 0 2483 0 disp_temp4 512 -255 0 0 xdim ydim
	rotatespritea 47 172 NORMALSIZE 1024 2483 0 disp_temp4 256 -255 0 0 xdim ydim
	rotatespritea 273 172 NORMALSIZE 0 2483 0 disp_temp4 516 -255 0 0 xdim ydim

		geta[SET].ang disp_temp3
		add disp_temp3 512
		rotatespritea 306 148 20000 disp_temp3 4813 10 disp_temp4 9 -255 0 0 xdim ydim

		getp[].ang disp_temp3
		add disp_temp3 512
		rotatespritea 306 148 QUARTERSIZE disp_temp3 4812 0 disp_temp4 9 -255 0 0 xdim ydim

}


	ifn userdef[].overhead_on 2
