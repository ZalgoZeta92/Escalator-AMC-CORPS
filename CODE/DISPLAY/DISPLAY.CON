		else ifl shield_reg_disp -10 rotatespritea 160 100 225000 0 19946 disp_temp6 32 0 -255 0 0 xdim ydim
		else ifl shield_reg_disp -5 rotatespritea 160 100 225000 0 19947 disp_temp6 32 0 -255 0 0 xdim ydim
		else rotatespritea 160 100 225000 0 19948 disp_temp6 32 0 -255 0 0 xdim ydim
		}

ifg vr_goggles_anim 0 // put on anim
	switch vr_goggles_anim
		case 26
