			break
		case 21
		case 20
		case 19
		case 18
		case 17
			rotatesprite 160 100 NNORMALSIZE 0 6719 shade wep_pal 8 windowx1 windowy1 windowx2 windowy2
			rotatesprite 60 160 NNORMALSIZE 1024 CHOLDING_L shade wep_pal 12 windowx1 windowy1 windowx2 windowy2
			rotatesprite 260 160 NNORMALSIZE 0 CHOLDING_R shade wep_pal 8 windowx1 windowy1 windowx2 windowy2
			break
		case 16
		case 15
		case 14
		case 13
		case 12
			rotatesprite 160 80 NNORMALSIZE 0 6720 shade wep_pal 8 windowx1 windowy1 windowx2 windowy2
			rotatesprite 50 120 NNORMALSIZE 1024 CHOLDING_L shade wep_pal 12 windowx1 windowy1 windowx2 windowy2
			rotatesprite 270 120 NNORMALSIZE 0 CHOLDING_R shade wep_pal 8 windowx1 windowy1 windowx2 windowy2
			break
		case 11
