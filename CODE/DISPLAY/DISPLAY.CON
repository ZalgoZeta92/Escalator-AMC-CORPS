// ally hud display stuff =====================================================================================================================================================================================

var ally_slot_id 0 1
var ally_slot_x 0 1
var ally_slot_y 0 1

defstate ALLY_STATUS_STUFF
	ife ally_slot_id -1 break
	else
	ifn ally_slot_id -1 // need to double check this for some reason???
	{
	geta[ally_slot_id].statnum disp_temp
	ife disp_temp 1024 set ally_slot_id -1
	ife ally_slot_id -1 break

	 ifn fire_mode_menu 0 set disp_temp7 25
	 else ifn voice_comm_menu 0 set disp_temp7 25
	 else set disp_temp7 0

	geta[ally_slot_id].extra disp_temp
	getav[ally_slot_id].max_health disp_temp5 ifn disp_temp5 0 div disp_temp5 100 // get max health 'percentage'
	geta[ally_slot_id].picnum disp_temp2
	geta[ally_slot_id].pal disp_temp4
	ifg sprite[ally_slot_id].htextra 0 { add ally_slot_y 1 set disp_temp4 124 }
	ifn disp_temp 0 ifn disp_temp5 0 div disp_temp disp_temp5
	// disp_temp = value
	// disp_temp3 = resulting tile
	state circle_bar_disp
	ife hitsprite ally_slot_id set disp_temp6 103 else set disp_temp6 disp_temp4
	ife disp_temp2 JANE rotatesprite ally_slot_x ally_slot_y 12000 0 30206 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 GLORIA rotatesprite ally_slot_x ally_slot_y 13000 0 30195 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 ID_ORC rotatesprite ally_slot_x ally_slot_y 12000 0 30194 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 ID_EARTHM rotatesprite ally_slot_x ally_slot_y 10000 0 30193 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 SHELLY rotatesprite ally_slot_x ally_slot_y 13000 0 30204 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 SKYHV rotatesprite ally_slot_x ally_slot_y 9000 0 19347 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 VLADMIR rotatesprite ally_slot_x ally_slot_y 12000 0 30205 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 FEAR_SOLDIER_ACTIVE rotatesprite ally_slot_x ally_slot_y 12000 0 30192 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 MSSOLDIER_ACTIVE rotatesprite ally_slot_x ally_slot_y 10000 0 7034 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 EDFSOLDIER_ACTIVE rotatesprite ally_slot_x ally_slot_y 14000 0 30197 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 EDF_SUPERSOLDIER rotatesprite ally_slot_x ally_slot_y 13000 0 30200 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 EAFSOLDIER_ACTIVE rotatesprite ally_slot_x ally_slot_y 11000 0 36190 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 RUSSIAN rotatesprite ally_slot_x ally_slot_y 12000 0 30202 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 MINERVA rotatesprite ally_slot_x ally_slot_y 9000 0 30207 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 FIDO rotatesprite ally_slot_x ally_slot_y 10000 0 30201 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 GRANDPA rotatesprite ally_slot_x ally_slot_y 11000 0 30196 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 AMCSOLDIER_ACTIVE rotatesprite ally_slot_x ally_slot_y 12000 0 30203 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 AMC_ASOLDIER_ACTIVE rotatesprite ally_slot_x ally_slot_y 10000 0 30199 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 AMC_MEDIC_ACTIVE rotatesprite ally_slot_x ally_slot_y 20000 0 37036 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 AMC_HEAVY_ACTIVE rotatesprite ally_slot_x ally_slot_y 16000 0 37115 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 AMC_WITCH rotatesprite ally_slot_x ally_slot_y 10000 0 39271 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 AMC_209_ACTIVE rotatesprite ally_slot_x ally_slot_y 8000 0 30198 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 FR_SORCERER rotatesprite ally_slot_x ally_slot_y 12000 0 6293 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else ife disp_temp2 MICKY_BOT rotatesprite ally_slot_x ally_slot_y 11000 0 36861 disp_temp7 disp_temp6 256 0 0 xdim ydim
	else rotatesprite ally_slot_x ally_slot_y 9000 0 disp_temp2 disp_temp7 disp_temp6 256 0 0 xdim ydim
	rotatespritea ally_slot_x ally_slot_y 14979 0 disp_temp3 disp_temp7 0 256 -255 0 0 xdim ydim // Health Bar

        ifl disp_temp 1
        {
           set ally_slot_id -1
           break
        }

	ifg actorvar[ally_slot_id].NPC_SHIELD 0
		{
		set disp_temp4 actorvar[ally_slot_id].NPC_SHIELD
		div disp_temp4 2
		ifg disp_temp4 99 set disp_temp3 9291 else
		ifg disp_temp4 90 set disp_temp3 9292 else
		ifg disp_temp4 80 set disp_temp3 9293 else
		ifg disp_temp4 70 set disp_temp3 9294 else
		ifg disp_temp4 60 set disp_temp3 9295 else
		ifg disp_temp4 50 set disp_temp3 9296 else
		ifg disp_temp4 40 set disp_temp3 9297 else
		ifg disp_temp4 30 set disp_temp3 9298 else
		ifg disp_temp4 20 set disp_temp3 9299 else
		ifg disp_temp4 10 set disp_temp3 9300 else
		ifg disp_temp4 0 set disp_temp3 9301
		rotatespritea ally_slot_x ally_slot_y 11690 0 disp_temp3 disp_temp7 32 256 -255 0 0 xdim ydim // Shield bar
		}

	getav[ally_slot_id].INTERNALCOUNT_3 disp_temp4
	ifg disp_temp4 0
		{
		ife sprite[ally_slot_id].picnum EAFSOLDIER_ACTIVE mul disp_temp4 4
		rotatesprite ally_slot_x ally_slot_y INVENSIZE disp_temp4 9026 0 0 256 0 0 xdim ydim
		}

	getav[ally_slot_id].ALLY_ORDER disp_temp6
	add ally_slot_y 10
	add ally_slot_x 10
	ifand disp_temp6 1 rotatesprite ally_slot_x ally_slot_y NORMALSIZE 0 12912 0 0 256 0 0 xdim ydim
	sub ally_slot_x 10
	ifand disp_temp6 2 rotatesprite ally_slot_x ally_slot_y NORMALSIZE 0 12913 0 0 256 0 0 xdim ydim
	sub ally_slot_y 10

		geta[ally_slot_id].x mx
		geta[ally_slot_id].y my
		getp[].posx x
		getp[].posy y
		sub mx x
		sub my y
		getangle disp_temp8 mx my
		getp[].ang disp_temp7
		sub disp_temp8 disp_temp7
		getav[ally_slot_id].FOLLOW_PLAYER disp_temp
		ife disp_temp 0 rotatesprite ally_slot_x ally_slot_y 45538 disp_temp8 9289 0 0 256 0 0 xdim ydim // compass
		else rotatesprite ally_slot_x ally_slot_y 45538 disp_temp8 9290 0 0 256 0 0 xdim ydim // compass
	}
ends

onevent EVENT_DISPLAYREST
set cursor_tile 5149
ife userdef[].screen_size 0 set hud_disp 0 else ife char_sel_anim 0 set hud_disp 1

ifg dummy_count 0
	{
	sub dummy_count 1
	qsprintf 396 395 dummy_ogdam
	gametext STARTALPHANUM 160 120 396 0 0 0 0 0 xdim ydim
	qsprintf 398 397 dummy_dam
	gametext STARTALPHANUM 160 128 398 0 0 0 0 0 xdim ydim
	}

ifn camerasprite -1 // Is the player in a cutscene?
{
	set MOUSEUP 0
	ife cameratype 4 // flier
	{
	set hud_disp 1
	ife opt_glass_effects YES
		{
		ifand sector[sprite[camerasprite].sectnum].ceilingstat 1 ifg raining 0 rotatespritea 160 100 75000 0 34780 0 sector[sprite[camerasprite].sectnum].ceilingpal 33 -255 0 0 xdim ydim // rain on glass
		rotatespritea 160 80 45960 0 3633 0 20 8 -255 0 0 xdim ydim
		}
	rotatesprite 160 80 45960 0 3632 0 0 8 0 0 xdim ydim
	state helmet_huds
	}

	ife cameratype 5 // camera
	{
	set hud_disp 1
	rotatesprite 47 28 NORMALSIZE 0 2482 0 0 256 0 0 xdim ydim
	rotatesprite 273 28 NORMALSIZE 0 2483 0 0 512 0 0 xdim ydim
	rotatesprite 47 172 NORMALSIZE 1024 2483 0 0 256 0 0 xdim ydim
	rotatesprite 273 172 NORMALSIZE 0 2483 0 0 516 0 0 xdim ydim
	}

	ife cameratype 6 // news
	{
	set hud_disp 1
	rotatesprite 160 150 NORMALSIZE 0 8494 0 0 1024 0 0 xdim ydim
	}

	ife cameratype 7 // news 2
	{
	set hud_disp 1
	rotatesprite 160 150 NORMALSIZE 0 8493 0 0 1024 0 0 xdim ydim
	}

	ife cameratype 8 // in-game hud
	{
	state helmet_huds
	set hud_disp 1
	}

ife cameratype 9 // flier locked on
	{
	getav[camerasprite].cameratime disp_temp
	ifl disp_temp 90 soundonce TRACKED
	ife opt_glass_effects YES
		{
		ifand sector[sprite[camerasprite].sectnum].ceilingstat 1 ifg raining 0 rotatespritea 160 100 75000 0 34780 0 sector[sprite[camerasprite].sectnum].ceilingpal 33 -255 0 0 xdim ydim // rain on glass
		rotatespritea 160 80 45960 0 3633 0 20 8 -255 0 0 xdim ydim
		}
	rotatesprite 160 80 45960 0 3632 0 0 8 0 0 xdim ydim
	set hud_disp 1
	state helmet_huds
	}

	ife cameratype 10 // drone
	{
	set hud_disp 1
	rotatesprite 47 28 NORMALSIZE 0 2482 0 0 256 0 0 xdim ydim
	rotatesprite 273 28 NORMALSIZE 0 2483 0 0 512 0 0 xdim ydim
	rotatesprite 47 172 NORMALSIZE 1024 2483 0 0 256 0 0 xdim ydim
	rotatesprite 273 172 NORMALSIZE 0 2483 0 0 516 0 0 xdim ydim
	}

	ife cameratype 11 // new flier
	{
	set hud_disp 1
	ifand sector[sprite[camerasprite].sectnum].ceilingstat 1 ifg raining 0 rotatespritea 160 100 75000 0 34780 0 sector[sprite[camerasprite].sectnum].ceilingpal 33 -255 0 0 xdim ydim // rain on glass
	rotatesprite 160 100 NORMALSIZE 0 3639 0 0 1024 0 0 xdim ydim
	state helmet_huds
	}

	ife cameratype 12 // rain on glass
	{
	rotatespritea 160 100 75000 0 34780 0 sector[sprite[camerasprite].sectnum].ceilingpal 33 -255 0 0 xdim ydim // rain on glass
	}

	ifn cameratype 0 // CUTSCENE TYPE
	ifn cameratype 4
	ifn cameratype 5
	ifn cameratype 6
	ifn cameratype 7
	ifn cameratype 8
	ifn cameratype 9
	ifn cameratype 10
	{
	set hud_disp 0
	ifn rendmode 0 ife opt_photosensitivity_mode 0 state custom_fade
	rotatesprite 160 100 NNORMALSIZE 0 3542 0 0 1024 0 0 xdim ydim
	}


