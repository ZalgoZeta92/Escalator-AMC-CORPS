			rotatesprite 20 140 77000 1024 CHOLDING_L shade wep_pal 12 windowx1 windowy1 windowx2 windowy2
			rotatesprite 300 140 77000 0 CHOLDING_R shade wep_pal 8 windowx1 windowy1 windowx2 windowy2
		break
		case 6
