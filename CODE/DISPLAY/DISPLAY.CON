			ife disp_temp5 PE_SENTRY rotatesprite 44 135 90304 FLIP 18755 5 disp_temp6 12 0 0 xdim ydim
			ife disp_temp5 TRENTON_SOLARI rotatesprite 184 135 90304 FLIP 19010 5 disp_temp6 12 0 0 xdim ydim
