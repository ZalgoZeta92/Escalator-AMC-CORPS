		else ifg shield_reg_disp 15 rotatespritea 160 100 225000 0 19945 shield_reg_disp 7 0 -255 0 0 xdim ydim
		else ifg shield_reg_disp 10 rotatespritea 160 100 225000 0 19946 shield_reg_disp 7 0 -255 0 0 xdim ydim
