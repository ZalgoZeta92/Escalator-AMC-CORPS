defstate draw_sf_shotgun

ifand gun_firemode_two 64
{
set HANDS_DRAW 1
  set x2 73
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  sub x2 looking_angSR1

  set y2 245
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos
  
  state gunpushback_display2
  
   	ifl gunsmoke_disp2 40 ife INVINC 0
		ifn kickbackpic_2 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		sub y2 35
		add x2 50
		rotatespritea x2 y2 30000 0 29952 gunsmoke_disp2 wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add y2 35
		sub x2 50
		guniqhudid 0
		}

switch kickbackpic_2
case 0
case 1
case 4
 state wep_drawup_rev
  ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
  guniqhudid 20
  rotatesprite x2 y2 40960 weap_disp_temp2 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 2
case 3
 state gun_smoke_display2
 displayrandvar gun_pushb_disp2 10
  sub x2 gun_pushb_disp2
  add y2 gun_pushb_disp2
	sub y2 35
	add x2 50
  displayrandvar rot_flash 2048
  guniqhudid 20
  rotatespritea x2 y2 INVENSIZE rot_flash 16114 0 0 4 -255 windowx1 windowy1 windowx2 windowy2
  add y2 35
  sub x2 50
  ifand SNOWFALL_UPGRADE 16 set tilenum 20820 else set tilenum 20818
  guniqhudid 21
  rotatesprite x2 y2 40960 1024 tilenum 0 wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 5
  ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
  guniqhudid 20
  rotatesprite x2 y2 40960 1008 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 6
  ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
  guniqhudid 20
  rotatesprite x2 y2 40960 992 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 7
  ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
  guniqhudid 20
  rotatesprite x2 y2 40960 1024 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 8
  ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
  guniqhudid 20
  rotatesprite x2 y2 40960 1056 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
}

  set x 243
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 245
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  
    state gunpushback_display
  
  	ifl gunsmoke_disp 40 ife INVINC 0
		ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 19
		sub y 35
		sub x 50
		rotatespritea x y 30000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add y 35
		add x 50
		guniqhudid 0
		}
  
  sub y 25
sub x 50
state flash_scanner
 add y 25
 add x 50


switch weaponcount
case 0
case 1
case 4
  state wep_drawup
  ife HANDS_DRAW 2
		{
	   add y 15
	  sub x 79
	  guniqhudid 10
	  rotatesprite x y 40960 weap_disp_temp2 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub y 15
	  add x 79
		}
	ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
	guniqhudid 11
  rotatesprite x y 40960 weap_disp_temp2 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
case 3
 displayrandvar gun_pushb_disp 10
  add x gun_pushb_disp
  add y gun_pushb_disp
  state gun_smoke_display
	sub y 35
	sub x 50
  displayrandvar rot_flash 2048
  guniqhudid 10
  rotatespritea x y INVENSIZE rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add y 35
  add x 50
  ife HANDS_DRAW 2
		{
	   add y 15
	  sub x 79
	  guniqhudid 11
	  rotatesprite x y 40960 0 C_ARM_2 0 106 4096 windowx1 windowy1 windowx2 windowy2
	  sub y 15
	  add x 79
		}
  ifand SNOWFALL_UPGRADE 16 set tilenum 20820 else set tilenum 20818
  guniqhudid 12
  rotatesprite x y 40960 0 tilenum 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 5
  state gunpushback_display
  ife HANDS_DRAW 2
		{
	   add y 15
	  sub x 79
	  guniqhudid 10
	  rotatesprite x y 40960 16 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub y 15
	  add x 79
		}
  ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
  guniqhudid 11
  rotatesprite x y 40960 16 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 6
  state gunpushback_display
  ife HANDS_DRAW 2
		{
	   add y 15
	  sub x 79
	  guniqhudid 10
	  rotatesprite x y 40960 32 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub y 15
	  add x 79
		}
  ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
  guniqhudid 11
  rotatesprite x y 40960 32 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 7
  state gunpushback_display
  ife HANDS_DRAW 2
		{
	   add y 15
	  sub x 79
	  guniqhudid 10
	  rotatesprite x y 40960 0 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub y 15
	  add x 79
		}
  ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
  guniqhudid 11
  rotatesprite x y 40960 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 8
  state gunpushback_display
  ife HANDS_DRAW 2
		{
	   add y 15
	  sub x 79
	  guniqhudid 10
	  rotatesprite x y 40960 -32 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub y 15
	  add x 79
		}
  ifand SNOWFALL_UPGRADE 16 set tilenum 20819 else set tilenum 20817
  guniqhudid 11
  rotatesprite x y 40960 -32 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

