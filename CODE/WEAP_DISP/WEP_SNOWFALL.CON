defstate draw_honeycomb

ifand gun_firemode_two 64
{
set HANDS_DRAW 1
  set x2 83
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  sub x2 looking_angSR1

  set y2 235
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos
  
  state gunpushback_display2
  
	ifl gunsmoke_disp2 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		add x2 30
		sub y2 35
		rotatespritea x2 y2 30000 0 29952 gunsmoke_disp2 wep_pal 4100 -255 windowx1 windowy1 windowx2 windowy2
		sub x2 30
		add y2 35
		guniqhudid 0
		}

switch kickbackpic_2
case 0
case 1
case 4
 state wep_drawup_rev
  guniqhudid 20
  rotatesprite x2 y2 40960 weap_disp_temp2 29758 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 2
case 3
 state gun_smoke_display2
 displayrandvar gun_pushb_disp2 5
 add gun_pushb_disp2 5
	sub y2 35
	add x2 30
  displayrandvar rot_flash 2048
  guniqhudid 20
  rotatespritea x2 y2 16384 rot_flash 16114 0 0 4 -255 windowx1 windowy1 windowx2 windowy2
  add y2 35
  sub x2 30
  guniqhudid 21
  rotatesprite x2 y2 40960 1024 29759 0 wep_pal 4100 windowx1 windowy1 windowx2 windowy2
