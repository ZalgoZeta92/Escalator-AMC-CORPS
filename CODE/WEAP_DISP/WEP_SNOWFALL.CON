case 28
  add x 6
  add y 6
  guniqhudid 10
  rotatesprite x y 40960 24 38957 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 16
case 27
  add x 7
  add y 7
  guniqhudid 10
  rotatesprite x y 40960 28 38958 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 17
case 18
case 19
case 20
case 21
case 22
case 23
case 24
case 25
case 26
  add x 8
  add y 8
  ife kickbackpic 24 sub y 10
  guniqhudid 10
  rotatesprite x y 40960 32 38959 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate display_snowfall_weapons
set RETURN 1
	ife currentweapon 1 
		{
		ife SPECIALIST_EQUIPMENT[146] 2 state draw_gauss_pistol
		else state draw_hblaster
		}
	else
	ife currentweapon 2
		{
		ife SPECIALIST_EQUIPMENT[143] 2 state draw_honeycomb
		else ife SPECIALIST_EQUIPMENT[100] 2 state draw_spike_shotgun
		else state draw_sf_shotgun
		}
	else
	ife currentweapon 3
		{
		ife SPECIALIST_EQUIPMENT[91] 2 state draw_SF_TAR
		else state draw_SF_AR
		}
	else
	ife currentweapon 4 state draw_sf_rocket
	else
	ife currentweapon 5 state displaypipe else
	ife currentweapon 6
		{
		ife SPECIALIST_EQUIPMENT[96] 2 state draw_arx_assault
		else state draw_sf_cannon
		}
	else
	ife currentweapon 7 
		{
		ife SPECIALIST_EQUIPMENT[166] 2 state disp_bolt_gun
		else state draw_sf_lightning
		}
	else ife currentweapon 8 
	{
	ifg player[].ammo_amount 8 0
			{
			ife SPECIALIST_EQUIPMENT[115] 2 state draw_tron_disc else
			state displaytripbomb
			}
	}
	else
	ife currentweapon 9 
		{
		ife SPECIALIST_EQUIPMENT[165] 2 state disp_gauss_hmg
		else state draw_sf_hmg
		}
	else 
	ife currentweapon 11
		{ 
		ife SPECIALIST_EQUIPMENT[96] 2 state draw_arx_shotgun
		else state draw_sf_cannon
		}
ends
