// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 1 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate drawpcpistol_left 
 set x2 115
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  sub x2 looking_angSR1

  set y2 226
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos

  state gunpushback_display2

	ifl gunsmoke_disp2 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		  add x2 27
		  sub y2 33
		rotatespritea x2 y2 30000 0 29952 gunsmoke_disp2 wep_pal 4100 -255 windowx1 windowy1 windowx2 windowy2
		sub x2 27
		add y2 33
		guniqhudid 0
		}

switch weaponcount

case 0
case 1
  state wep_drawup_rev
  guniqhudid 20
  rotatesprite x2 y2 40960 weap_disp_temp2 22589 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
	add y2 50
	sub x2 15
	guniqhudid 21
	rotatesprite x2 y2 49152 weap_disp_temp2 C_PISTOL_R shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 2
  ife rot_flash 0 displayrandvar rot_flash 2048
    state gun_smoke_display2
    displayrandvar gun_pushb_disp2 5
  add gun_pushb_disp2 5
  add x2 27
  sub y2 33
  guniqhudid 20
  rotatespritea x2 y2 12000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  sub x2 27
  add y2 33
  guniqhudid 21
  rotatesprite x2 y2 40960 1024 22590 0 wep_pal 4100 windowx1 windowy1 windowx2 windowy2
	add y2 50
	sub x2 15
	guniqhudid 22
	rotatesprite x2 y2 49152 1024 C_PISTOL_L 0 wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 3
  add x2 27
  sub y2 33
  guniqhudid 20
  rotatespritea x2 y2 12000 rot_flash 16114 10 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  sub x2 27
  add y2 33
  guniqhudid 21
  rotatesprite x2 y2 40960 1024 22590 0 107 4100 windowx1 windowy1 windowx2 windowy2
	add y2 50
	sub x2 15
	guniqhudid 22
	rotatesprite x2 y2 49152 1024 C_PISTOL_L 0 107 4100 windowx1 windowy1 windowx2 windowy2
  break
case 4
case 5
  guniqhudid 20
  rotatesprite x2 y2 40960 1024 22591 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
	add y2 50
	sub x2 15
	guniqhudid 21
	rotatesprite x2 y2 49152 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 6
case 7
case 8
  guniqhudid 20
  rotatesprite x2 y2 40960 1024 22592 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
	add y2 70
	sub x2 15
	guniqhudid 21
	rotatesprite x2 y2 49152 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
endswitch
ends

defstate drawpcpistol

  set x 205
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 226
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

  state gunpushback_display

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		  sub x 27
		  sub y 33
		rotatespritea x y 30000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 27
		add y 33
		guniqhudid 0
		}

ifand gun_firemode 64 state drawpcpistol_left 

switch weaponcount

case 0
case 1
  ife player[].weapon_pos 9 { set LOWER_WEAPON_SOUND SELECT_PISTOL state sound_lower_weapon }
  ife player[].weapon_pos 3 sound R_HAMMER
  state wep_drawup
  state gunpushback_display
  guniqhudid 10
  rotatesprite x y 40960 weap_disp_temp2 22589 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	add y 50
	add x 15
	guniqhudid 11
	rotatesprite x y 49152 weap_disp_temp2 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
  ife rot_flash 0 displayrandvar rot_flash 2048
  state gun_smoke_display
  displayrandvar gun_pushb_disp 5
  add gun_pushb_disp 5
  sub x 27
  sub y 33
  guniqhudid 10
  rotatespritea x y 12000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 27
  add y 33
  guniqhudid 11
  rotatesprite x y 40960 0 22590 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	add y 50
	add x 15
	guniqhudid 12
	rotatesprite x y 49152 0 C_PISTOL_R 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 3
  sub x 27
  sub y 33
  guniqhudid 10
  rotatespritea x y 12000 rot_flash 16114 10 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 27
  add y 33
  guniqhudid 11
  rotatesprite x y 40960 0 22590 0 107 4096 windowx1 windowy1 windowx2 windowy2
	add y 50
	add x 15
	guniqhudid 12
	rotatesprite x y 49152 0 C_PISTOL_R 0 107 4096 windowx1 windowy1 windowx2 windowy2
  break
case 4
case 5
  guniqhudid 10
  rotatesprite x y 40960 0 22591 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	add y 50
	add x 15
	guniqhudid 11
	rotatesprite x y 49152 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 6
case 7
case 8
  guniqhudid 10
  rotatesprite x y 40960 0 22592 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	add y 70
	add x 15
	guniqhudid 11
	rotatesprite x y 49152 weap_disp_temp2 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 9
case 10
case 11
case 12
case 13
case 14
case 15
  add x weaponcount
  set weap_disp_temp2 weaponcount
  mul weap_disp_temp2 3
  add y weap_disp_temp2
  guniqhudid 10
  rotatesprite x y 40960 0 22592 gs wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	add y 70
	add x 15
	guniqhudid 11
	rotatesprite x y 49152 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
   break
case 16
case 17
case 18
case 19
case 20
case 21
case 22
	add x 16
	add y 40
	guniqhudid 10
	rotatesprite x y 40960 60 22593 gs wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	break
case 23
	add x 18
	add y 44
	guniqhudid 10
	rotatesprite x y 40960 60 22593 gs wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 24
case 25
case 26
	add x 12
	add y 38
	guniqhudid 10
	rotatesprite x y 40960 48 22594 gs wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 27
case 28
case 29
case 30
	add x 6
	add y 22
	guniqhudid 10
	rotatesprite x y 40960 24 22594 gs wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
// second pistol
case 31
case 32
case 33
case 34
case 35
case 36
case 37
  sub x2 weaponcount
  set weap_disp_temp2 weaponcount
  sub weap_disp_temp2 22
  mul weap_disp_temp2 3
  add y2 weap_disp_temp2
  guniqhudid 10
  rotatesprite x2 y2 40960 1024 22592 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
	add y2 70
	sub x2 15
	guniqhudid 11
	rotatesprite x2 y2 49152 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
   break
case 38
case 39
case 40
case 41
case 42
case 43
case 44
	sub x2 16
	add y2 40
	guniqhudid 10
	rotatesprite x2 y2 40960 964 22593 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
	break
case 45
	sub x2 18
	add y2 44
	guniqhudid 10
	rotatesprite x2 y2 40960 964 22593 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 46
case 47
case 48
	sub x2 12
	add y2 38
	guniqhudid 10
	rotatesprite x2 y2 40960 976 22594 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 49
case 50
case 51
case 52
	sub x2 6
	add y2 22
	guniqhudid 10
	rotatesprite x2 y2 40960 1000 22594 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

