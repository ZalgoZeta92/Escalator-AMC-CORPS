// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// SLOT 3 WEAPONS
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate draw_tommygun_left
  set x2 100
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  sub x2 looking_angSR1
  
  set y2 230
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos
  clamp y2 146 320
  
  state gunpushback_display2
  
	ifl gunsmoke_disp2 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		add x2 35
		sub y2 45
		rotatespritea x2 y2 35000 0 29952 gunsmoke_disp2 wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		sub x2 35
		add y2 45
		guniqhudid 0
		}

switch weaponcount
case 0
case 1
  ife player[].weapon_pos 8 soundonce TOMMYG_COCK
  state wep_drawup_rev
  set rot_flash 0
  ifand AMMO_TYPES[weap_disp_temp5] 2 set tilenum 11238 else
  ifand AMMO_TYPES[weap_disp_temp5] 32768 set tilenum 12660 else
  set tilenum 7909
  guniqhudid 20
  rotatesprite x2 y2 40960 weap_disp_temp2 tilenum shade arm_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 2
  state gun_smoke_display2
  displayrandvar gun_pushb_disp2 3
  add gun_pushb_disp2 3
  sub y2 45
  add x2 35
  state fortyfive_flashes_left
  add y2 45
  sub x2 35

  ifand AMMO_TYPES[weap_disp_temp5] 2 set tilenum 11239 else
  ifand AMMO_TYPES[weap_disp_temp5] 32768 set tilenum 12661 else
  set tilenum 7910
  guniqhudid 21
  rotatesprite x2 y2 40960 1024 tilenum shade arm_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 3
  state gunpushback_display2
  sub y2 45
  add x2 35
  ifand AMMO_TYPES[weap_disp_temp5] 2 set weap_disp_temp 17 else set weap_disp_temp 0
  guniqhudid 20
  state random_gun_flash
	 rotatespritea x2 y2 16000 rot_flash rot_flash2 0 weap_disp_temp 4100 -255 windowx1 windowy1 windowx2 windowy2
  add y2 45
  sub x2 35

  ifand AMMO_TYPES[weap_disp_temp5] 2 set tilenum 11239 else
  ifand AMMO_TYPES[weap_disp_temp5] 32768 set tilenum 12661 else
  set tilenum 7910
  guniqhudid 21
  rotatesprite x2 y2 40960 1024 tilenum 0 108 4100 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

defstate draw_tommygun
ifand gun_firemode 1024 set x 220 else
  set x 200
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1
  set y 230
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  clamp y 146 320
  
  state gunpushback_display
  
	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 35
		sub y 45
		rotatespritea x y 35000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 35
		add y 45
		guniqhudid 0
		}
		
ifand gun_firemode 1024 state draw_tommygun_left

set weap_disp_temp5 3

ifg kickbackpic_3 1
	switch kickbackpic_3
	case 0
	case 1
	case 2
	case 3
	case 4
	  guniqhudid 10
	  sub y 10
	  rotatesprite x y 40960 0 9619 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	case 5
	case 6
	case 7
	case 8
	  guniqhudid 10
	  sub y 10
	  rotatesprite x y 40960 0 9620 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	break
	case 9
	case 10
	case 11
	case 12
	  guniqhudid 10
	  sub y 10
	  ife kickbackpic_3 10 sub y 10
	  rotatesprite x y 40960 0 9621 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	break
	case 13
	case 14
	case 15
	case 16
	  guniqhudid 10
	  sub y 5
	  rotatesprite x y 40960 0 9622 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	break
	endswitch
else
switch weaponcount
case 0
case 1
  ife player[].weapon_pos 8 soundonce TOMMYG_COCK
  state wep_drawup
  set rot_flash 0
  ife HANDS_DRAW 2
	  {
	  set x2 x
	  set y2 y
	  sub x2 55
	  add y2 30
	  guniqhudid 10
	  rotatesprite x2 y2 40960 weap_disp_temp2 C_ARM_1 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  }
  ifand AMMO_TYPES[weap_disp_temp5] 2 set tilenum 11238 else
