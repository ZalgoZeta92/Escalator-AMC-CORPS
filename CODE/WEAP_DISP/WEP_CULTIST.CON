  ifand AMMO_TYPES[weap_disp_temp5] 32768 set tilenum 12661 else
  set tilenum 7910
  guniqhudid 12
  rotatesprite x y 40960 0 tilenum 0 108 4096 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

