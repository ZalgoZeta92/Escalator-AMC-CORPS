  add y looking_arc
  sub y gun_pos

  state gunpushback_display

  ifn WEP1_BLOODY 0
	{
	ifg wep_pal 0
	ifl wep_pal 9
	set BLOOD_PAL wep_pal
	else
	ifg wep_pal 100
	set BLOOD_PAL wep_pal
	else set BLOOD_PAL WEP1_BLOODY
	}
	else set BLOOD_PAL 0

switch weaponcount
case 0
  state wep_drawup
	ifand BITS_PRESS 64
	  {
	  sub x 90
	  clamp x 238 360
	  clamp y 160 360
	  guniqhudid 10
	  rotatesprite x y 45056 90 19931 shade wep_pal 4616 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 11
	  ifn BLOOD_PAL 0 rotatesprite x y 45056 90 19940 shade BLOOD_PAL 4616 windowx1 windowy1 windowx2 windowy2
	  }
  else
	  {
	  guniqhudid 10
	  rotatesprite x y 45056 weap_disp_temp2 19931 shade wep_pal 4616 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 11
	  ifn BLOOD_PAL 0 rotatesprite x y 45056 weap_disp_temp2 19940 shade BLOOD_PAL 4616 windowx1 windowy1 windowx2 windowy2
	  }
  break
case 1
case 2
