// James' Plasma SMG===============================================================================================================

defstate draw_plsmg_left

  set x2 65
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  add x2 looking_angSR1

  set y2 230
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos

	state gunpushback_display2

  clamp y2 149 320

  set weap_disp_temp5 60
  sub weap_disp_temp5 GUN_HEAT[cur_weap]

  set HANDS_DRAW 1

  ifg GUN_HEAT[cur_weap] 15 state gun_smoke_display2

	ifl gunsmoke_disp2 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		add x2 40
		sub y2 40
		rotatespritea x2 y2 30000 0 29952 gunsmoke_disp2 1 4100 -255 windowx1 windowy1 windowx2 windowy2
		sub x2 40
		add y2 40
		guniqhudid 0
		}

switch weaponcount
case 0
case 1
  state wep_drawup_rev
  guniqhudid 20
  rotatesprite x2 y2 41000 weap_disp_temp2 23901 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  ifl weap_disp_temp5 30 rotatespritea x2 y2 41000 weap_disp_temp2 23898 weap_disp_temp5 0 4100 -255 windowx1 windowy1 windowx2 windowy2
  break
case 2
  state gun_smoke_display2
  displayrandvar gun_pushb_disp2 10
  displayrandvar rot_flash 2048
  add x2 40
  sub y2 40
  guniqhudid 20
  rotatespritea x2 y2 18000 rot_flash 16115 0 1 4100 -255 windowx1 windowy1 windowx2 windowy2
  sub x2 40
  add y2 40
  guniqhudid 21
  rotatesprite x2 y2 41000 1024 23902 0 103 4100 windowx1 windowy1 windowx2 windowy2
  ifl weap_disp_temp5 30 rotatespritea x2 y2 41000 0 23898 weap_disp_temp5 0 4100 -255 windowx1 windowy1 windowx2 windowy2
  break
case 3
case 4
  guniqhudid 20
  rotatesprite x2 y2 41000 1000 23902 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  ifl weap_disp_temp5 30 rotatespritea x2 y2 41000 1000 23898 weap_disp_temp5 0 4100 -255 windowx1 windowy1 windowx2 windowy2
  break
endswitch
ends

defstate draw_plsmg

  set x 225
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 230
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

	state gunpushback_display

  clamp y 149 320

  set weap_disp_temp5 60
  sub weap_disp_temp5 GUN_HEAT[cur_weap]

  ifg GUN_HEAT[cur_weap] 15 state gun_smoke_display

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 40
		sub y 40
		rotatespritea x y 30000 0 29952 gunsmoke_disp 1 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 40
		add y 40
		guniqhudid 0
		}

sub x 40
sub y 30
state flash_scanner
add x 40
add y 30

ifand gun_firemode 1024 state draw_plsmg_left

switch weaponcount
case 0
case 1
  state wep_drawup
  guniqhudid 10
  rotatesprite x y 40960 weap_disp_temp2 23901 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  ifl weap_disp_temp5 30 rotatespritea x y 40960 weap_disp_temp2 23898 weap_disp_temp5 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  ife HANDS_DRAW 2
	{
	sub x 70
	add y 30
	guniqhudid 11
	rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	}
  break
case 2
  state gun_smoke_display
  displayrandvar gun_pushb_disp 10
  displayrandvar rot_flash 2048
  sub x 40
  sub y 40
  guniqhudid 10
  rotatespritea x y 18000 rot_flash 16115 0 1 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 40
  add y 40
  guniqhudid 11
  rotatesprite x y 40960 0 23902 0 103 4096 windowx1 windowy1 windowx2 windowy2
  ifl weap_disp_temp5 30 rotatespritea x y 40960 0 23898 weap_disp_temp5 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  ife HANDS_DRAW 2
	{
	sub x 70
	add y 30
	guniqhudid 12
	rotatesprite x y 32768 0 C_ARM_2 0 103 4096 windowx1 windowy1 windowx2 windowy2
	}
  break
case 3
case 4
  guniqhudid 10
  rotatesprite x y 40960 24 23902 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  ifl weap_disp_temp5 30 rotatespritea x y 40960 24 23898 weap_disp_temp5 0 4096 -255 windowx1 windowy1 windowx2 windowy2
	ife HANDS_DRAW 2
	{
	sub x 70
	add y 30
	guniqhudid 11
	rotatesprite x y 32768 24 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	}
  break
case 5
case 6
case 7
case 38
case 39
case 40
  guniqhudid 10
  rotatesprite x y 40960 8 23901 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  ifl weap_disp_temp5 30 rotatespritea x y 40960 8 23898 weap_disp_temp5 0 4096 -255 windowx1 windowy1 windowx2 windowy2
	ife HANDS_DRAW 2
	{
	sub x 70
	add y 30
	guniqhudid 11
	rotatesprite x y 32768 8 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	}
