		ifand AMMO_TYPES[cur_weap] 1024 ifg dragon_shells 0 rotatesprite x y 40960 1024 7866 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
		ifand AMMO_TYPES[cur_weap] 65536 ifg silverb_shells 0 rotatesprite x y 40960 1024 3743 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
