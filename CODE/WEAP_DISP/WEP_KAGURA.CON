defstate draw_kagura_firework

  set x 235
  set weap_disp_temp4 wepsway_x
  div weap_disp_temp4 2
  sub x weap_disp_temp4
  add x weapon_xoffset
  sub x looking_angSR1

  set y 185
  div wepsway_y 2
  sub y wepsway_y
  add y looking_arc
  div gun_pos 2
  sub y gun_pos
  
  clamp y 140 320
  
     ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		  sub x 65
		  sub y 35
		rotatespritea x y 40000 0 29952 gunsmoke_disp 2 4608 -255 windowx1 windowy1 windowx2 windowy2
		  add x 65
		  add y 35
		guniqhudid 0
		}



switch weaponcount
case 0
case 1
case 10
case 11
case 12
case 13
case 14
case 15
case 16
  state wep_drawup
  state gunpushback_display
  
  getp[].angvel weap_disp_temp3
  mul weap_disp_temp3 3
  div weap_disp_temp3 2
  set weap_disp_temp4 weapon_xoffset
  mul weap_disp_temp4 3
  add weap_disp_temp3 weap_disp_temp4
	  add y 35
	  sub x 24
	  guniqhudid 10
	  rotatesprite x y 40960 weap_disp_temp3 23919 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2 // Gun's strap
	  sub y 35
	  add x 24
  set rot_flash 0
  guniqhudid 11
  rotatesprite x y 40960 weap_disp_temp2 24043 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  sub x 65
  add y 28
  guniqhudid 12
  rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
  sub x 65
  sub y 35
  ife rot_flash 0 displayrandvar rot_flash 2048
  guniqhudid 10
  rotatespritea x y 20000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 65
  add y 35
  guniqhudid 11
  rotatesprite x y 40960 0 24044 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  sub x 65
  add y 28
  guniqhudid 12
  rotatesprite x y 32768 0 C_ARM_2 0 106 4096 windowx1 windowy1 windowx2 windowy2
  break
case 3
  state gun_smoke_display
  sub x 65
  sub y 35
  guniqhudid 10
  rotatespritea x y 24000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 65
  add y 35
  guniqhudid 11
  rotatesprite x y 40960 0 24044 0 107 4096 windowx1 windowy1 windowx2 windowy2
  sub x 65
  add y 28
  guniqhudid 12
  rotatesprite x y 32768 0 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2
  break
case 4
case 5
case 6
case 7
case 8
case 9
  add x kickbackpic
  add y kickbackpic
  set gun_pushb_disp kickbackpic
  guniqhudid 10
  rotatesprite x y 40960 0 24045 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  sub x 55
  add y 45
  guniqhudid 11
  rotatesprite x y 32768 0 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

defstate draw_kag_frostgun

  set x 230
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 202
  sub y wepsway_y
  add y looking_arc
  div gun_pos 2
  sub y gun_pos

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 60
		sub y 30
		rotatespritea x y 36000 0 29952 gunsmoke_disp 1 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 60
		add y 30
		guniqhudid 0
		}
		
	state long_arm_tilenum

guniqhudid 0
	switch weaponcount
	case 0
	  state wep_drawup
	  guniqhudid 10
	  rotatesprite x y 45056 weap_disp_temp2 26539 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  add x 124
	  sub y 20
	  guniqhudid 11
	  rotatesprite x y 40960 weap_disp_temp2 tilenum shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 1
	case 4
	case 7
	case 10
	case 13
	case 16
	case 19
	case 22
	case 24
	// spin down
	case 31
	case 34
	case 37
	case 40
	case 45
	case 46
	case 47
	case 54
	case 55
	case 56
	case 57
	  guniqhudid 10
	  rotatesprite x y 45056 0 26540 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 11
	  add x 124
	  sub y 20
	  rotatesprite x y 40960 0 tilenum shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 2
	case 5
	case 8
	case 11
	case 14
	case 17
	case 20
	case 25
	// spin down
	case 30
	case 33
	case 36
	case 39
	case 43
	case 44
	case 51
	case 52
	case 53
	  guniqhudid 10
	  rotatesprite x y 45056 0 26541 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 11
	  add x 124
	  sub y 20
	  rotatesprite x y 40960 0 tilenum shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 3
	case 6
	case 9
	case 12
	case 15
	case 18
	case 21
	case 23
	// spin down
	case 29
	case 32
	case 35
	case 38
	case 41
	case 42
	case 48
	case 49
	case 50
		guniqhudid 10
		rotatesprite x y 45056 0 26539 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 11
	  add x 124
	  sub y 20
	  rotatesprite x y 40960 0 tilenum shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 26
	  sub x 60
	  sub y 30
	  displayrandvar rot_flash 2048
	  guniqhudid 10
	  rotatespritea x y 55000 rot_flash 6197 0 1 1 -255 windowx1 windowy1 windowx2 windowy2
	  add x 60
	  add y 30
	  guniqhudid 11
	  rotatesprite x y 45056 0 26542 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 12
	  add x 124
	  sub y 20
	  rotatesprite x y 40960 0 tilenum 0 arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 27
	  sub x 60
	  sub y 30
	  displayrandvar rot_flash 2048
	  guniqhudid 10
	  rotatespritea x y 52000 rot_flash 6197 0 1 1 -255 windowx1 windowy1 windowx2 windowy2
	  add x 60
	  add y 30
	  guniqhudid 11
	  rotatesprite x y 45056 0 26543 0 102 4096 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 12
	  add x 124
	  sub y 20
	  rotatesprite x y 40960 0 tilenum 0 102 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 28
	  sub x 60
	  sub y 30
	  displayrandvar rot_flash 2048
	  state gun_smoke_display
	  guniqhudid 10
	  rotatespritea x y 55000 rot_flash 6197 0 1 1 -255 windowx1 windowy1 windowx2 windowy2
	  add x 60
	  add y 30
	  guniqhudid 11
	  rotatesprite x y 45056 0 26544 0 103 4096 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 12
	  add x 124
	  sub y 20
	  rotatesprite x y 40960 0 tilenum 0 103 4096 windowx1 windowy1 windowx2 windowy2
	  break
	endswitch
guniqhudid 0
ends

