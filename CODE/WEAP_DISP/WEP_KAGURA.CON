defstate display_dragonshotgun

  set x 215
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1


  set y 240
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 40
		sub y 50
		rotatespritea x y 30000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 40
		add y 50
		guniqhudid 0
		}

switch weaponcount
case 0
case 1
case 31
case 32
  ife player[].weapon_pos 8 soundonce SELECT_SHOTGUN
  state wep_drawup
  set rot_flash 0
  set rot_flash2 0
   ife HANDS_DRAW 2
	  {
	  sub x 62
	  add y 20
	  guniqhudid 11
	  rotatesprite x y 32768 -64 C_ARM_2 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  add x 62
	  sub y 20
	  }
  guniqhudid 10
  ifge kickbackpic_4 5 ifle kickbackpic_4 10 set tilenum 29717
  else ifg kickbackpic_4 10 set tilenum 29716
  else ifg kickbackpic_4 0 set tilenum 29716
  else set tilenum 29715
  rotatesprite x y 45152 weap_disp_temp2 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
  state gun_smoke_display
  add x 5
  add y 5
  ifand gun_firemode 256 nullop else { ife gun_mag 2 add x 10 else ife gun_mag 1 sub x 10 }
  sub x 40
  sub y 50
	state random_shotg_flash
	guniqhudid 10
	rotatespritea x y 40960 rot_flash2 rot_flash 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 40
  add y 50
  ifand gun_firemode 256 nullop else { ife gun_mag 2 sub x 10 else ife gun_mag 1 add x 10 }
    ife HANDS_DRAW 2
	  {
	  sub x 62
	  add y 20
	  guniqhudid 13
	  rotatesprite x y 32768 -64 C_ARM_2 0 106 4096 windowx1 windowy1 windowx2 windowy2
	  add x 62
	  sub y 20
	  }
  guniqhudid 11
  rotatesprite x y 45152 0 29715 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 12
  rotatesprite x y 45152 0 29718 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 3
  add x 10
  add y 10
  ifand gun_firemode 256 nullop else { ife gun_mag 1 add x 10 else ife gun_mag 0 sub x 10 }
  sub x 40
  sub y 50
  displayrandvar rot_flash 2048
  guniqhudid 10
  rotatespritea x y 20000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 40
  add y 50
  ifand gun_firemode 256 nullop else { ife gun_mag 1 sub x 10 else ife gun_mag 0 add x 10 }
   ife HANDS_DRAW 2
	  {
	  sub x 62
	  add y 20
	  guniqhudid 13
	  rotatesprite x y 32768 -64 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2
	  add x 62
	  sub y 20
	  }
  guniqhudid 11
  rotatesprite x y 45152 0 29715 0 107 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 12
  rotatesprite x y 45152 0 29718 0 107 4096 windowx1 windowy1 windowx2 windowy2
  break
case 4
  ifand gun_firemode 256 nullop else { ife gun_mag 1 add x 10 else ife gun_mag 0 sub x 10 }
  sub x 40
  sub y 50
  displayrandvar rot_flash 2048
  guniqhudid 10
rotatespritea x y 16000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 40
  add y 50
  ifand gun_firemode 256 nullop else { ife gun_mag 1 sub x 10 else ife gun_mag 0 add x 10 }
   ife HANDS_DRAW 2
	  {
	  sub x 62
	  add y 20
	  guniqhudid 12
	  rotatesprite x y 32768 -64 C_ARM_2 0 arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  add x 62
	  sub y 20
	  }
  guniqhudid 10
  rotatesprite x y 45152 0 29715 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 11
  rotatesprite x y 45152 0 29718 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 5
case 26
case 27
case 28
  guniqhudid 10
    ife HANDS_DRAW 2
	  {
	  sub x 62
	  add y 20
	  guniqhudid 11
	  rotatesprite x y 32768 -64 C_ARM_2 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  add x 62
	  sub y 20
	  } 
  rotatesprite x y 45152 0 29716 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 6
case 29
case 30
    ife HANDS_DRAW 2
	  {
	  sub x 62
	  add y 20
	  guniqhudid 11
	  rotatesprite x y 32768 -64 C_ARM_2 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  add x 62
	  sub y 20
	  }
  guniqhudid 10
  rotatesprite x y 45152 0 29717 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 7 // start reload
case 8
case 23
case 24
case 25
  
   ife HANDS_DRAW 2
	  {
	  sub x 62
	  add y 15
	  guniqhudid 11
	  rotatesprite x y 36864 0 C_ARM_2 shade arm_pal 4104 windowx1 windowy1 windowx2 windowy2
	  add x 62 
	  sub y 15
	  }
  guniqhudid 10
  rotatesprite x y 40960 0 29719 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 9
