endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate display_kagura_weapons
set RETURN 1
	ife currentweapon 1 
		{
		ife SPECIALIST_EQUIPMENT[155] 2 
			{
			ifg kickbackpic_2 0 state draw_yo_sword else
			state draw_seburo
			}
		else state draw_yo_sword
		}
	else
	ife currentweapon 2
		{
		ife SPECIALIST_EQUIPMENT[130] 2 state display_dragonshotgun
		else ife SPECIALIST_EQUIPMENT[103] 2 state draw_dragonblades
		else state draw_dp_12
		}
	else
	ife currentweapon 3
		{
		ife SPECIALIST_EQUIPMENT[131] 2 state draw_jewel_famas
		else ife SPECIALIST_EQUIPMENT[90] 2 state draw_flam4
		else state draw_auto_crossbow
		}
	else
	ife currentweapon 4 
		{
		ife SPECIALIST_EQUIPMENT[181] 2 state draw_MAG_lancer
		else state draw_kagura_rocketl
		}
	else
	ife currentweapon 5 state displaygrenade
	else
	ife currentweapon 6 
		{
		ife SPECIALIST_EQUIPMENT[127] 2 state draw_tesla_SMG
		else state draw_CZN-M22
		}
	else
	ife currentweapon 7
		{
		ife SPECIALIST_EQUIPMENT[133] 2 state display_kg_hmg
		else ife SPECIALIST_EQUIPMENT[104] 2 state draw_dragon_kuwabara
		else state draw_psg1
		}
	else ife currentweapon 8 
	{
	ifg player[].ammo_amount 8 0 state display_talisman
	}
	else
	ife currentweapon 9 
		{
		ife SPECIALIST_EQUIPMENT[132] 2 state draw_kag_frostgun
		else state draw_kagura_firework
		}
	else ife currentweapon 11 state draw_CZN-M22_HV
ends

