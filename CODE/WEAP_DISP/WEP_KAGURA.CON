// TESLA SMG

defstate draw_tesla_SMG

  set x 242
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 235
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  clamp y 148 320
  
  	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 50
		sub y 10
		rotatespritea x y 30000 0 29952 gunsmoke_disp 0 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 50
		add y 10
		guniqhudid 0
		}

state gunpushback_display

switch weaponcount
case 0
case 1
case 4
  ifand gun_firemode 16384
		  {
		  set x 160
		  set weap_disp_temp2 wepsway_x
		  div weap_disp_temp2 2
		  sub x weap_disp_temp2
		  set weap_disp_temp4 weapon_xoffset // set the weapon x sway to displaytemp4
		  div weap_disp_temp4 2 // divide it by 2
		  add x weap_disp_temp4 // add it to x
		  sub x 5 // offset it by 5
		  set y 140
		  set weap_disp_temp3 wepsway_y
		  div weap_disp_temp3 2
		  sub y weap_disp_temp3
		  state gunpushback_sight_display
		  guniqhudid 10
		  add weap_disp_temp8 16384
		  rotatesprite x y weap_disp_temp8 0 29934 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // barrel part of ironsight
		  sub y 40
		  guniqhudid 11
		  rotatespritea x y QUARTERSIZE 0 11046 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2 // red dot
		  set x 160
		  sub x wepsway_x
		  add x weapon_xoffset // add weaponxsway to position
		  sub x 10 // offset it by 10
		  set y 142
		  sub y wepsway_y
		  guniqhudid 12
		  rotatesprite x y weap_disp_temp8 0 29933 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // red dot sight
		  }
		  else
		  {
  state wep_drawup
  set rot_flash 0

	ife HANDS_DRAW 2
		{
	  add y 20
	  sub x 90
