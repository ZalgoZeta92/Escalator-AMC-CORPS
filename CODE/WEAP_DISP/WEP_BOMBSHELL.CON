// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 1 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate draw_deagle_left

  set x2 91
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  sub x2 looking_angSR1

  set y2 230
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos
  
   state gunpushback_display2

	ifl gunsmoke_disp2 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		add x2 33
		sub y2 40
		rotatespritea x2 y2 30000 0 29952 gunsmoke_disp2 wep_pal 4100 -255 windowx1 windowy1 windowx2 windowy2
		sub x2 33
		add y2 40
		guniqhudid 0
		}

  set hand_x x2
  set hand_y y2
  guniqhudid 0
   ifl kickbackpic 7
	ifand gun_firemode 2048
	{
	add x2 28
	guniqhudid 25
	rotatespritea x2 y2 27000 weap_disp_temp2 8623 0 2 4100 -255 windowx1 windowy1 windowx2 windowy2 // laser sight light
	sub x2 28
	}

ifg kickbackpic_2 0
	switch kickbackpic_2
		case 1 
		case 2 
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 19794 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
		case 3
		case 4 
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 19795 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
		case 5
		case 6
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 19796 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
		case 7
		case 8
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 19797 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
		case 9
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 19798 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
	endswitch
else
switch weaponcount
case 0
case 1
  state wep_drawup_rev
  ife slot1_mag 0 set tilenum 10453 else set tilenum 10451
  guniqhudid 20
  rotatesprite x2 y2 32768 1024 10449 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add hand_y 30
  sub hand_x 10
  guniqhudid 21
  rotatesprite hand_x hand_y 40960 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  guniqhudid 22
  rotatesprite x2 y2 32768 1024 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 2
state gun_smoke_display2
displayrandvar gun_pushb_disp2 15
  sub y2 40
  add x2 33
  guniqhudid 20
  state random_gun_flash
  rotatespritea x2 y2 24000 rot_flash rot_flash2 0 0 4100 -255 windowx1 windowy1 windowx2 windowy2
  add y2 40
  sub x2 33
  guniqhudid 21
  rotatesprite x2 y2 32768 1024 10449 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add hand_y 30
  sub hand_x 10
  guniqhudid 22
  rotatesprite hand_x hand_y 40960 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  guniqhudid 23
  rotatesprite x2 y2 32768 1024 10451 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  guniqhudid 24
  rotatesprite x2 y2 32768 1024 10452 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 3
case 5
  rotatesprite x2 y2 32768 1000 10449 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add hand_y 32
  sub hand_x 11
  guniqhudid 21
  rotatesprite hand_x hand_y 40960 1000 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  guniqhudid 22
  rotatesprite x2 y2 32768 1024 10453 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 4
  rotatesprite x2 y2 32768 972 10449 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add hand_y 35
  sub hand_x 11
  guniqhudid 21
  rotatesprite hand_x hand_y 40960 972 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  guniqhudid 22
  rotatesprite x2 y2 32768 1024 10454 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 6
  ife reload_empty 1 set tilenum 10453 else set tilenum 10451
  guniqhudid 20
  rotatesprite x2 y2 32768 992 10449 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add hand_y 25
  sub hand_x 10
  guniqhudid 21
  rotatesprite hand_x hand_y 40960 992 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  guniqhudid 22
  rotatesprite x2 y2 32768 992 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
endswitch
ends

defstate draw_deagle

  set x 229
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 230
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  
   state gunpushback_display

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 33
		sub y 40
		rotatespritea x y 30000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 33
		add y 40
		guniqhudid 0
		}

  guniqhudid 0
   ifl kickbackpic 7
	ifand gun_firemode 2048
	{
	sub x 28
	guniqhudid 15
	rotatespritea x y 27000 weap_disp_temp2 8623 0 2 4096 -255 windowx1 windowy1 windowx2 windowy2 // laser sight light
	add x 28
	}
	
ifand gun_firemode 64 state draw_deagle_left

 set hand_x x
 set hand_y y

ifg kickbackpic_2 0
	switch kickbackpic_2
		case 1 
		case 2 
			guniqhudid 10
			rotatesprite x y 32768 0 19794 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
		case 3
		case 4 
			guniqhudid 10
			rotatesprite x y 32768 0 19795 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
		case 5
		case 6
			guniqhudid 10
			rotatesprite x y 32768 0 19796 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
		case 7
		case 8
			guniqhudid 10
			rotatesprite x y 32768 0 19797 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
		case 9
			guniqhudid 10
			rotatesprite x y 32768 0 19798 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
	endswitch
else
switch weaponcount
case 0
case 1
  set weap_disp_temp2 player[].weapon_pos
  ife weap_disp_temp2 8 { soundonce SILVER_T_SPIN set kickbackpic_2 1 }
  ife weap_disp_temp2 -2 soundonce SILVER_T_SPIN
  state wep_drawup
  add hand_x weap_disp_temp2
  ife slot1_mag 0 set tilenum 10453 else set tilenum 10451
  guniqhudid 10
  rotatesprite x y 32768 0 10449 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add hand_y 30
  add hand_x 10
  guniqhudid 11
  rotatesprite hand_x hand_y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 12
  rotatesprite x y 32768 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
state gun_smoke_display
displayrandvar gun_pushb_disp 15
  sub y 40
  sub x 33
  guniqhudid 10
  state random_gun_flash
  rotatespritea x y 24000 rot_flash rot_flash2 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add y 40
  add x 33
  guniqhudid 11
  rotatesprite x y 32768 0 10449 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add hand_y 30
  add hand_x 10
  guniqhudid 12
  rotatesprite hand_x hand_y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 13
  rotatesprite x y 32768 0 10451 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 14
  rotatesprite x y 32768 0 10452 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 3
case 5
  rotatesprite x y 32768 24 10449 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add hand_y 32
  add hand_x 11
  guniqhudid 11
  rotatesprite hand_x hand_y 40960 24 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 12
  rotatesprite x y 32768 0 10453 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 4
  rotatesprite x y 32768 52 10449 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add hand_y 35
  add hand_x 11
  guniqhudid 11
  rotatesprite hand_x hand_y 40960 52 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 12
  rotatesprite x y 32768 0 10454 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 6
case 7
case 8
case 9
case 10
case 43
  ife reload_empty 1 set tilenum 10453 else set tilenum 10451
  guniqhudid 10
  rotatesprite x y 32768 32 10449 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add hand_y 25
  add hand_x 10
  guniqhudid 11
  rotatesprite hand_x hand_y 40960 32 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 12
  rotatesprite x y 32768 32 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
