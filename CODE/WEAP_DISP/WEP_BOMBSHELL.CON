case 57
case 58
case 59
case 60

case 67
case 68
case 69
  add y2 5
  ife reload_empty 1 set tilenum 10458 else set tilenum 10456
  guniqhudid 10
 rotatesprite x2 y2 32768 1024 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
   add y2 25
