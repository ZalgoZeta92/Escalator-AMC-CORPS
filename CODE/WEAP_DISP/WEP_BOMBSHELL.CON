case 42
  add y 7
	ife weaponcount 12 add y 20
	ife weaponcount 41 ife reload_empty 1 add y 10
  ife reload_empty 1 set tilenum 10457 else set tilenum 10455
  guniqhudid 10
  rotatesprite x y 32768 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	add y 25
