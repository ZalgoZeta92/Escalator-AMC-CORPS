// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 1 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// JANE's handlaser

defstate draw_handlaser

  set x 213
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 245
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 10
		sub y 20
		ifand gun_firemode 1048576 set weap_disp_temp3 2 else set weap_disp_temp3 1
		rotatespritea x y 30000 0 29952 gunsmoke_disp weap_disp_temp3 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 10
		add y 20
		guniqhudid 0
		}
state gunpushback_display

  sub y 20
  sub x 10
  ifand gun_firemode 1048576 set weap_disp_temp3 21 else set weap_disp_temp3 3
  guniqhudid 18
  state laser_muzzleflash
  add y 20
  add x 10

ifg player[].weapon_pos 0 set draw_animation 10
guniqhudid 0
switch weaponcount
case 0
case 1
case 4
case 5
case 6
case 7
case 8
  state wep_drawup
  guniqhudid 10
	ifg draw_animation 0
		{
		ifg draw_animation 7 set tilenum 13636
		else ifg draw_animation 3 set tilenum 13635
		else set tilenum 12903
		}
	else set tilenum 12903
  rotatesprite x y 32768 weap_disp_temp2 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
case 3
    displayrandvar gun_pushb_disp 3
	add gun_pushb_disp 3
    state gun_smoke_display
	ifand gun_firemode 1048576 set weap_disp_temp 2 else set weap_disp_temp 1
  guniqhudid 12
  rotatesprite x y 32768 0 12904 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

defstate draw_p320_left

  set x2 121
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  sub x2 looking_angSR1

  set y2 235
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos
  
  state gunpushback_display2

	ifl gunsmoke_disp2 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		add x2 18
		sub y2 40
		rotatespritea x2 y2 28000 0 29952 gunsmoke_disp2 wep_pal 4100 -255 windowx1 windowy1 windowx2 windowy2
		sub x2 18
		add y2 40
		guniqhudid 0
		}

guniqhudid 0
ifg kickbackpic_2 0
	switch kickbackpic_2
		case 1 
		case 2 
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 39024 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
		case 3
		case 4 
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 39025 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
		case 5
		case 6
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 39026 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
		case 7
		case 8
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 39027 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
		case 9
		case 10
			guniqhudid 20
			rotatesprite x2 y2 32768 1024 39028 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
			break
	endswitch
else
switch weaponcount
case 0
case 1
  state wep_drawup_rev
  ife slot1_mag 0 set tilenum 39030 else set tilenum 39018
  guniqhudid 20
  rotatesprite x2 y2 32768 weap_disp_temp2 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 25
  sub x2 8
  guniqhudid 21
  rotatesprite x2 y2 40960 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 2
displayrandvar gun_pushb_disp2 7
add x2 gun_pushb_disp2
add y2 gun_pushb_disp2
  displayrandvar rot_flash 2048
  state gun_smoke_display2
  sub y2 40
  add x2 18
  guniqhudid 20
  state fortyfive_flashes_left
  add y2 40
  sub x2 18
  guniqhudid 21
  rotatesprite x2 y2 32768 1024 39019 0 wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 25
  sub x2 8
  guniqhudid 22
  rotatesprite x2 y2 40960 1024 C_PISTOL_L 0 107 4100 windowx1 windowy1 windowx2 windowy2
  break
case 3
case 4
  guniqhudid 20
  rotatesprite x2 y2 32768 1016 39018 shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 25
  sub x2 8
  guniqhudid 21
  rotatesprite x2 y2 40960 1016 C_PISTOL_R shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
endswitch
ends

defstate draw_p320

  set x 199
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 235
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  
    state gunpushback_display

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 18
		sub y 40
		rotatespritea x y 28000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 18
		add y 40
		guniqhudid 0
		}
		
ifand gun_firemode 64 state draw_p320_left

guniqhudid 0
ifg kickbackpic_2 0
	switch kickbackpic_2
		case 1 
		case 2 
			guniqhudid 10
			rotatesprite x y 32768 0 39024 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
		case 3
		case 4 
			guniqhudid 10
			rotatesprite x y 32768 0 39025 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
		case 5
		case 6
			guniqhudid 10
			rotatesprite x y 32768 0 39026 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
		case 7
		case 8
			guniqhudid 10
			rotatesprite x y 32768 0 39027 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
		case 9
		case 10
			guniqhudid 10
			rotatesprite x y 32768 0 39028 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
			break
	endswitch
else
switch weaponcount
case 0
case 1
case 3
case 4
  ifand gun_firemode 16384
		  {
		  set x 160
		  set weap_disp_temp2 wepsway_x
		  div weap_disp_temp2 2
		  sub x weap_disp_temp2
		  set weap_disp_temp4 weapon_xoffset // set the weapon x sway to displaytemp4
		  div weap_disp_temp4 2 // divide it by 2
		  add x weap_disp_temp4 // add it to x
		  sub x 5 // offset it by 5
		  set y 140
		  set weap_disp_temp3 wepsway_y
		  div weap_disp_temp3 2
		  sub y weap_disp_temp3
		  state gunpushback_sight_display
		  guniqhudid 10
		  add weap_disp_temp8 16384
		  sub y 40
		  guniqhudid 11
		  rotatespritea x y QUARTERSIZE 0 11046 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2 // red dot
		  set x 160
		  sub x wepsway_x
		  add x weapon_xoffset // add weaponxsway to position
		  sub x 10 // offset it by 10
		  set y 142
		  sub y wepsway_y
		  guniqhudid 12
		  rotatesprite x y weap_disp_temp8 0 39029 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // red dot sight
		  }
	else
		{
	  set weap_disp_temp2 player[].weapon_pos
	  ife weap_disp_temp2 8 soundonce SELECT_PISTOL
	  state wep_drawup
	  ife slot1_mag 0 set tilenum 39030 else set tilenum 39018
	  guniqhudid 10
	  rotatesprite x y 32768 weap_disp_temp2 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  add y 25
	  add x 8
	  guniqhudid 11
	  rotatesprite x y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  }
  break
case 2
  ifand gun_firemode 16384
		  {
		  set x 160
		  guniqhudid 10
		  state fortyfive_flashes
		  set weap_disp_temp2 wepsway_x
		  div weap_disp_temp2 2
		  sub x weap_disp_temp2
		  set weap_disp_temp4 weapon_xoffset // set the weapon x sway to displaytemp4
		  div weap_disp_temp4 2 // divide it by 2
		  add x weap_disp_temp4 // add it to x
		  sub x 5 // offset it by 5
		  set y 140
		  set weap_disp_temp3 wepsway_y
		  div weap_disp_temp3 2
		  sub y weap_disp_temp3
		  state gunpushback_sight_display
		  guniqhudid 10
		  add weap_disp_temp8 16384
		  sub y 40
		  guniqhudid 11
		  rotatespritea x y QUARTERSIZE 0 11046 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2 // red dot
		  set x 160
		  sub x wepsway_x
		  add x weapon_xoffset // add weaponxsway to position
		  sub x 10 // offset it by 10
		  set y 142
		  sub y wepsway_y
		  guniqhudid 12
		  rotatesprite x y weap_disp_temp8 0 39029 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // red dot sight
		  }
	else
		{
	displayrandvar gun_pushb_disp 7
	add x gun_pushb_disp
	add y gun_pushb_disp
	  displayrandvar rot_flash 2048
	  state gun_smoke_display
	  sub y 40
	  sub x 18
	  guniqhudid 10
	  state fortyfive_flashes
	  add y 40
	  add x 18
	  guniqhudid 11
	  rotatesprite x y 32768 0 39019 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  add y 25
	  add x 8
	  guniqhudid 12
	  rotatesprite x y 40960 0 C_PISTOL_R 0 107 4096 windowx1 windowy1 windowx2 windowy2
	  }
  break
case 5
case 6
case 7
case 8
case 9
case 10
  add y 5
  ife slot1_mag 0 set tilenum 39022
  else set tilenum 39020
  guniqhudid 10
  rotatesprite x y 32768 16 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 25
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 16 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 11
case 12
case 13
  add y 7
  ife slot1_mag 0 set tilenum 39022
  else set tilenum 39020
  guniqhudid 10
  rotatesprite x y 32768 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 25
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 14
case 15
case 16
  add y 7
  ife weaponcount 16 add y 5
  ife slot1_mag 0 set tilenum 39023
  else set tilenum 39021
  guniqhudid 10
  rotatesprite x y 32768 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 22
  sub x 6
  guniqhudid 11
  rotatesprite x y 40960 64 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 17
case 18
case 19
case 20
case 21
case 22
case 23
  ife slot1_mag 0 set tilenum 39023
  else set tilenum 39021
  guniqhudid 10
  rotatesprite x y 32768 32 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 20
  sub x 6
  guniqhudid 11
  rotatesprite x y 40960 96 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 24
case 25
case 26
case 27
case 28
case 29
case 30
  add y 5
  ife slot1_mag 0 set tilenum 39023
  else set tilenum 39021
  guniqhudid 10
	rotatesprite x y 32768 64 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 18
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 128 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 31
case 32
case 33
case 34
	ife weaponcount 32 add y 5
  ife slot1_mag 0 set tilenum 39023
  else set tilenum 39021
  guniqhudid 10
	rotatesprite x y 32768 96 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 14
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 160 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 35
case 36
case 37
case 38
  guniqhudid 10
  ife slot1_mag 0 set tilenum 39023
  else set tilenum 39021
	rotatesprite x y 32768 98 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 14
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 162 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 39
case 40
case 41
case 42
case 43
  add y 5
  ife reload_empty 1 ife weaponcount 40 sound P320_C
  set tilenum 39021
  guniqhudid 10
  rotatesprite x y 32768 64 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 18
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 128 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
// left hand gun
case 44
case 45
case 46
  add y2 7
  ife reload_empty 1 set tilenum 39022 
  else set tilenum 39020
  guniqhudid 10
  rotatesprite x2 y2 32768 1024 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 25
  add x2 8
  guniqhudid 11
  rotatesprite x2 y2 40960 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 47
case 48
case 49
  add y2 7
  ife weaponcount 49 add y2 5
  ife reload_empty 1 set tilenum 39023
  else set tilenum 39021
  guniqhudid 10
  rotatesprite x2 y2 32768 1024 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 22
  add x2 6
  guniqhudid 11
  rotatesprite x2 y2 40960 960 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 50
case 51
case 52
case 53
case 54
case 55
case 56
  ife reload_empty 1 set tilenum 39023
  else set tilenum 39021
  guniqhudid 10
  rotatesprite x2 y2 32768 992 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 20
  add x2 6
  guniqhudid 11
  rotatesprite x2 y2 40960 928 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 57
case 58
case 59
case 60
case 61
case 62
case 63
  add y2 5
    ife reload_empty 1 set tilenum 39023
  else set tilenum 39021
  guniqhudid 10
	rotatesprite x2 y2 32768 960 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 18
  add x2 8
  guniqhudid 11
  rotatesprite x2 y2 40960 896 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 64
case 65
case 66
case 67
	ife weaponcount 32 add y2 5
    ife reload_empty 1 set tilenum 39023
  else set tilenum 39021
  guniqhudid 10
	rotatesprite x2 y2 32768 928 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 14
  add x2 8
  guniqhudid 11
  rotatesprite x2 y2 40960 864 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 68
case 69
case 70
case 71
  guniqhudid 10
      ife reload_empty 1 set tilenum 39023
  else set tilenum 39021
	rotatesprite x2 y2 32768 926 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2

  add y2 14
  add x2 8
  guniqhudid 11
  rotatesprite x2 y2 40960 862 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 72
case 73
case 74
case 75
case 76
  add y2 5
  ife reload_empty 1 ife weaponcount 74 sound P320_C
  set tilenum 39021
  guniqhudid 10
  rotatesprite x2 y2 32768 960 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 18
  add x2 8
  guniqhudid 11
  rotatesprite x2 y2 40960 896 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 2 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// UTS-15===============================================================================================================

defstate draw_uts15

  set x 240
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 230
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

  clamp y 148 320

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 57
		sub y 45
		rotatespritea x y 30000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 57
		add y 45
		guniqhudid 0
		}


ifl kickbackpic 18
state gunpushback_display

set pal_2 wep_pal

switch weaponcount
case 0
case 1
case 4
case 5
case 6
case 16
case 17
case 18
  ife player[].weapon_pos 8 soundonce WINCHUP
  state wep_drawup
  state gunpushback_display
  set rot_flash 0
  guniqhudid 10
	rotatesprite x y 36864 weap_disp_temp2 12893 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub x 100
	  add y 10
	  guniqhudid 11
	  rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
	state gun_smoke_display
	set gun_pushb_disp 14
	ife rot_flash 0 displayrandvar rot_flash 2048
  sub x 57
  sub y 45
  guniqhudid 10
  rotatespritea x y 18000 rot_flash 16114 0 94 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 57
  add y 45
  guniqhudid 11
	rotatesprite x y 36864 weap_disp_temp2 12893 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	guniqhudid 12
	rotatesprite x y 36864 weap_disp_temp2 12894 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub x 100
	  add y 10
	  guniqhudid 13
	  rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2
  break
case 3
	set gun_pushb_disp 14
  sub x 57
  sub y 45
  guniqhudid 10
  rotatespritea x y 19000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 57
  add y 45
  guniqhudid 11
	rotatesprite x y 36864 weap_disp_temp2 12893 0 106 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 12
	rotatesprite x y 36864 weap_disp_temp2 12894 0 106 4096 windowx1 windowy1 windowx2 windowy2
	  sub x 100
	  add y 10
	  guniqhudid 13
	  rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 0 106 4096 windowx1 windowy1 windowx2 windowy2
  break
	case 7
	case 8
	case 14
	case 15
		  add x 5
		  add y 3
		  guniqhudid 10
	  rotatesprite x y 36864 0 12895 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub x 100
	  add y 8
	  guniqhudid 11
	  rotatesprite x y 32768 16 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 9
	case 13
		  add x 8
		  add y 5
		  guniqhudid 10
	  rotatesprite x y 36864 0 12896 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub x 100
	  add y 4
	  guniqhudid 11
	  rotatesprite x y 32768 24 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 10
	case 12
		  add x 10
		  add y 7
	 guniqhudid 10
	 rotatesprite x y 36864 0 12897 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub x 95
	  add y 24
	  guniqhudid 11
	  rotatesprite x y 35768 24 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 11
		  add x 10
		  add y 7
		  guniqhudid 10
		  rotatesprite x y 36864 32 12897 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
		  sub x 97
		  add y 17
		  guniqhudid 11
		  rotatesprite x y 35768 56 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
// reloading
	endswitch
ifand gun_firemode_two 8
switch weaponcount
	case 19
	case 20
	case 21
	case 22
	  guniqhudid 0
	  sub x 90
	  guniqhudid 10
	  rotatesprite x y 36864 20 12890 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  add x 25
	  add y 45
	  guniqhudid 11
	  rotatesprite x y 40960 0 C_HAND_1 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  clamp y 148 320
	  /*
	  ifand gun_firemode_two 8
	  {
	  ifand AMMO_TYPES[15] 1 ifg explosive_shells 0 rotatesprite x y 76638 0 7903 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  else ifand AMMO_TYPES[15] 4 ifg flechete_shells 0 rotatesprite x y 76638 0 7867 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  else ifand AMMO_TYPES[15] 64 ifg magnum_shells 0 rotatesprite x y 76638 0 7868 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  else ifand AMMO_TYPES[15] 1024 ifg dragon_shells 0 rotatesprite x y 76638 0 7866 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  else rotatesprite x y 76638 0 7867 shade 25 4096 windowx1 windowy1 windowx2 windowy2
	  }
