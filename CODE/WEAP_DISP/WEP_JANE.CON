// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 8 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate draw_tesla_blaster

  set x 225
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 245
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 50
		sub y 20
		rotatespritea x y 30000 0 29952 gunsmoke_disp 1 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 50
		add y 20
		guniqhudid 0
		}
state gunpushback_display

  sub y 20
  sub x 50
  guniqhudid 18
  ifge weaponcount 1 ifle weaponcount 5 
	{
	set weap_disp_temp3 600
	mul weap_disp_temp3 bomb_throw_power
	rotatespritea x y weap_disp_temp3 rot_flash 36322 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
	}
  add y 20
  add x 50

ifg player[].weapon_pos 0 set draw_animation 30
guniqhudid 0
switch weaponcount
case 0
case 1
case 4 
case 5
case 6
case 7
case 8
case 9
case 10
case 11
case 12
case 13
case 14
case 15
  state wep_drawup
  guniqhudid 10
  ife weaponcount 4 state gun_smoke_display
  rotatesprite x y 40960 weap_disp_temp2 34029 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  ifge bomb_throw_power 55
	  {
	  ifge bomb_throw_power 255 set tilenum 34035
	  else ifge bomb_throw_power 205 set tilenum 34034
	  else ifge bomb_throw_power 155 set tilenum 34033
	  else ifge bomb_throw_power 105 set tilenum 34032
	  else set tilenum 34031
	  rotatesprite x y 40960 weap_disp_temp2 tilenum 0 0 4096 windowx1 windowy1 windowx2 windowy2
	  }
  break
case 2
case 3
    displayrandvar gun_pushb_disp 3
	add gun_pushb_disp 3
	
	set weap_disp_temp4 shade
	set weap_disp_temp5 bomb_throw_power
	div weap_disp_temp5 10
	sub weap_disp_temp4 weap_disp_temp5

  guniqhudid 12
  rotatesprite x y 40960 0 34030 weap_disp_temp4 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  ifge bomb_throw_power 55
  {
  ifge bomb_throw_power 255 set tilenum 34035
  else ifge bomb_throw_power 205 set tilenum 34034
  else ifge bomb_throw_power 155 set tilenum 34033
  else ifge bomb_throw_power 105 set tilenum 34032
  else set tilenum 34031
  rotatesprite x y 40960 weap_disp_temp2 tilenum 0 0 4096 windowx1 windowy1 windowx2 windowy2
  }
  break
endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 9 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~


defstate draw_j_pbeam

  set x 250
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 240
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

  clamp y 155 320
  
    state gunpushback_display

  ifg player[].weapon_pos 0 set draw_animation 16
guniqhudid 0
ifg kickbackpic_2 0
	switch kickbackpic_2 
	case 1
	  set rot_flash 0
		guniqhudid 10
	  rotatesprite x y 40960 0 15174 gs wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 2
	case 3
	add x 5
	add y 5
	set gun_pushb_disp 6
	   sub y 35
	  sub x 55
	 ife rot_flash 0 displayrandvar rot_flash 2048
	 set gun_glowdown 0
	 set gun_glowdown_pal 106
	 guniqhudid 10
	  rotatespritea x y 24000 rot_flash 16115 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
	  add y 35
	  add x 55
	  guniqhudid 11
	  rotatesprite x y 40960 0 15174 0 106 4096 windowx1 windowy1 windowx2 windowy2
	  break
	endswitch
else
	switch weaponcount
	case 0
	case 2
	  state wep_drawup
	  set rot_flash 0
		ifg draw_animation 0
			{
			ife draw_animation 14 soundonce PBEAM_SEL
			ife draw_animation 2 soundonce SERVOSND

			ifg draw_animation 14 set tilenum 15165
			else ifg draw_animation 12 set tilenum 15166
			else ifg draw_animation 10 set tilenum 15167
			else ifg draw_animation 8 set tilenum 15168
			else ifg draw_animation 6 set tilenum 15169
			else ifg draw_animation 4 set tilenum 15170
			else ifg draw_animation 2 set tilenum 15171
			else ifg draw_animation 0 set tilenum 15172
			else set tilenum 15173
			}
			else set tilenum 15173
			guniqhudid 10
	  rotatesprite x y 40960 weap_disp_temp2 tilenum gs wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  ifl gun_glowdown 30 { guniqhudid 11 rotatespritea x y 40960 weap_disp_temp2 15174 gun_glowdown gun_glowdown_pal 4096 -255 windowx1 windowy1 windowx2 windowy2 }
	  break
	case 1
	case 3
	add x 5
	add y 5
	set gun_pushb_disp 6
	   sub y 35
	  sub x 55
	 ife rot_flash 0 displayrandvar rot_flash 2048
	 guniqhudid 10
	  set gun_glowdown 0
	  set gun_glowdown_pal 0
	  rotatespritea x y 82000 rot_flash 16510 0 1 4096 -255 windowx1 windowy1 windowx2 windowy2
	  add y 35
	  add x 55
	  guniqhudid 11
	  rotatesprite x y 40960 weap_disp_temp2 15174 0 0 4096 windowx1 windowy1 windowx2 windowy2
	  break
	endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate display_jane_weapons
set RETURN 1
	ife currentweapon 1 
		{
		ife SPECIALIST_EQUIPMENT[122] 2 state draw_p320
		else state draw_handlaser
		}
	else
	ife currentweapon 2 state draw_uts15
	else
	ife currentweapon 3 
		{
		ife SPECIALIST_EQUIPMENT[128] 2 state draw_beowulf
		else state draw_famas
		}
	else
	ife currentweapon 4 state draw_paw20
	else
	ife currentweapon 5 state displaygrenade 
	else
	ife currentweapon 6 state draw_plas_railgun
	else
	ife currentweapon 7 state draw_m14
	else ife currentweapon 8 
		{
		ife SPECIALIST_EQUIPMENT[156] 2 state draw_tesla_blaster
		else
		ifg player[].ammo_amount 8 0 state displaytripbomb
		}
	else
	ife currentweapon 9 state draw_j_pbeam
ends

