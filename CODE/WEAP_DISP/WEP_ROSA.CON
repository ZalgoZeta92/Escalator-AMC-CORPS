// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate draw_trenchgun


  set x 210
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 245
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
guniqhudid 10

state gunpushback_display

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 43
		sub y 52
		rotatespritea x y 40000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 43
		add y 52
		guniqhudid 0
		}
		
sub y 47
sub x 43
state flash_scanner
 add y 47
 add x 43


ife player[].reloading 1
{
	sub y 40

	switch weaponcount
	case 18
	case 19
	case 20
	  add x 10
	  sub y 8
			sub y 22
			sub x 50
			guniqhudid 10
			rotatesprite x y 45152 10 12177 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2 // Gun's strap
			add y 22
			add x 50
		guniqhudid 11
	  rotatesprite x y 45152 5 32373 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 12
	   add y 40
	  // ifand AMMO_TYPES[cur_weap] 1 rotatesprite x y 40960 5 6094 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  // else ifand AMMO_TYPES[cur_weap] 4 rotatesprite x y 40960 5 6093 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  // else ifand AMMO_TYPES[cur_weap] 64 rotatesprite x y 40960 5 6092 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  // else ifand AMMO_TYPES[cur_weap] 1024 rotatesprite x y 40960 5 6096 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  // else ifand AMMO_TYPES[cur_weap] 65536 rotatesprite x y 40960 5 6093 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  rotatesprite x y 40960 5 32365 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 21
	case 22
	case 23
	  add x 10
	  sub y 5
			sub y 22
			sub x 50
			guniqhudid 10
			rotatesprite x y 45152 10 12177 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2 // Gun's strap
			add y 22
			add x 50
		guniqhudid 11
	  rotatesprite x y 45152 10 32372 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 13
	case 14
	case 15
	case 16
	case 17
	case 24
	case 25
			sub y 22
			sub x 50
			guniqhudid 10
			rotatesprite x y 45152 0 12177 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2 // Gun's strap
			add y 22
			add x 50
		guniqhudid 11
		rotatesprite x y 45152 0 32372 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
		break
	case 26
	case 27
	case 28
	case 29
	case 30
	case 31
		add y 20
			sub y 24
			sub x 40
			guniqhudid 10
			rotatesprite x y 45152 0 12177 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2 // Gun's strap
			add y 24
			add x 40
		guniqhudid 11
		rotatesprite x y 45152 0 32369 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
		  break
	endswitch
guniqhudid 0
}
else
switch weaponcount
case 0
case 1
case 4
case 5
case 6
case 7
case 8
case 9
case 10
case 11
case 20
case 21
case 22
  ife player[].weapon_pos 8 soundonce R870PUMP
  state wep_drawup
		  ife opt_weapon_glow YES // not a glow but it's fluff that can be disabled for perf reasons
			  {
			  getp[].angvel weap_disp_temp3
			  mul weap_disp_temp3 3
			  div weap_disp_temp3 2
			  set weap_disp_temp4 weapon_xoffset
			  mul weap_disp_temp4 3
			  add weap_disp_temp3 weap_disp_temp4
			  sub y 20
			  sub x 40
			  guniqhudid 10
			  rotatesprite x y 45152 weap_disp_temp3 12177 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // Gun's strap
			  add y 20
			  add x 40
			  }
  guniqhudid 11
  rotatesprite x y 45152 weap_disp_temp2 32367 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	sub x 59
	guniqhudid 12
	rotatesprite x y 24576 weap_disp_temp2 C_ARM_2 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
   sub y 52
  sub x 43
  guniqhudid 10
  state random_shotg_flash
  rotatespritea x y 40960 rot_flash2 rot_flash 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add y 52
  add x 43
	ife opt_weapon_glow YES // not a glow but it's fluff that can be disabled for perf reasons
		{
		getp[].angvel weap_disp_temp3
		mul weap_disp_temp3 3
		div weap_disp_temp3 2
		set weap_disp_temp4 weapon_xoffset
		mul weap_disp_temp4 3
		add weap_disp_temp3 weap_disp_temp4
		sub y 20
		sub x 40
		guniqhudid 11
		rotatesprite x y 45152 weap_disp_temp3 12177 0 107 4096 windowx1 windowy1 windowx2 windowy2 // Gun's strap
		add y 20
		add x 40
		}
 guniqhudid 12
	rotatesprite x y 45152 0 32368 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	sub x 59
	guniqhudid 13
	rotatesprite x y 24576 0 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2
  break
case 3
	state gun_smoke_display
    displayrandvar gun_pushb_disp 6
	add gun_pushb_disp 6
   ife rot_flash 0 displayrandvar rot_flash 2048
   sub y 52
  sub x 43
  guniqhudid 10
  rotatespritea x y 18000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add y 52
  add x 43
  
		  ife opt_weapon_glow YES // not a glow but it's fluff that can be disabled for perf reasons
			  {
			  getp[].angvel weap_disp_temp3
			  mul weap_disp_temp3 3
			  div weap_disp_temp3 2
			  set weap_disp_temp4 weapon_xoffset
			  mul weap_disp_temp4 3
			  add weap_disp_temp3 weap_disp_temp4
			  sub y 20
			  sub x 40
			  guniqhudid 12
			  rotatesprite x y 45152 weap_disp_temp3 12177 0 107 4096 windowx1 windowy1 windowx2 windowy2 // Gun's strap
			  add y 20
			  add x 40
			  }
  
 guniqhudid 12
	rotatesprite x y 45152 0 32368 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	sub x 59
	guniqhudid 13
	rotatesprite x y 24576 0 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2
  break
case 12
case 13
case 18
case 19
	sub y 27
	sub x 40
	guniqhudid 10
	rotatesprite x y 45152 weap_disp_temp3 12177 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // Gun's strap
	add y 27
	add x 40
	guniqhudid 11
	rotatesprite x y 45152 0 32369 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	sub x 50
	add y 14
	guniqhudid 12
	rotatesprite x y 24576 48 32337 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 14
case 17
	sub y 30
	sub x 40
	guniqhudid 10
	rotatesprite x y 45152 weap_disp_temp3 12177 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2 // Gun's strap
	 add y 30
	add x 40
  guniqhudid 11
   rotatesprite x y 45152 0 32370 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	sub x 50
	add y 14
	guniqhudid 12
	rotatesprite x y 24576 64 32337 shade arm_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 15
case 16
	sub y 27
	sub x 40
	guniqhudid 10
	rotatesprite x y 45152 weap_disp_temp3 12177 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2 // Gun's strap
	add y 27
	add x 40
  guniqhudid 11
   rotatesprite x y 45152 0 32371 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	sub x 45
	add y 29
	guniqhudid 12
	rotatesprite x y 24576 64 32337 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 3 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate draw_sterling

  set x 155
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 230
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  state gunpushback_display
  clamp y 155 320
	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		add x 14
		sub y 37
		rotatespritea x y 30000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		sub x 14
		add y 37
		guniqhudid 0
		}
guniqhudid 0
switch weaponcount
case 0
case 1
case 4
case 5
case 6
case 7
case 8
case 9
case 10
	set rot_flash 0
	ifand gun_firemode 16384 state default_gun_scope
	else
		{
	  state wep_drawup
	  add x 5
	  add y 30
	  guniqhudid 10
	  rotatesprite x y 32768 0 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub x 5
	  sub y 30
	   guniqhudid 11
	  rotatesprite x y 40960 weap_disp_temp2 32387 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
		}
  break
case 2
case 3
	ifand gun_firemode 16384
		{
			  set x 160
			  set disp_temp2 wepsway_x
			  div disp_temp2 2
			  sub x disp_temp2
			  set y 100
			  set disp_temp3 wepsway_y
			  div disp_temp3 2
			  sub y disp_temp3

			add y 40
			guniqhudid 10
			state random_silver_flash
			guniqhudid 10
			sub rot_size 10000
			rotatespritea x y rot_size rot_flash2 rot_flash 0 1 4096 -255 windowx1 windowy1 windowx2 windowy2
			sub y 40
			state default_gun_scope
		}
	else
		{
	  state gun_smoke_display
	 displayrandvar gun_pushb_disp 5
	  add x gun_pushb_disp
	  add y gun_pushb_disp
	  add x 14
	  sub y 37
	  guniqhudid 10
	state random_silver_flash
	guniqhudid 10
	sub rot_size 14000
	rotatespritea x y rot_size rot_flash2 rot_flash 0 1 4096 -255 windowx1 windowy1 windowx2 windowy2
	  sub x 14
	  add y 37

	  add x 5
	  add y 30
	  guniqhudid 11
	  rotatesprite x y 32768 0 C_ARM_2 0 107 8 windowx1 windowy1 windowx2 windowy2
	  sub x 5
	  sub y 30
	 guniqhudid 12
	  rotatesprite x y 40960 0 32388 0 0 0 windowx1 windowy1 windowx2 windowy2
	   }
  break
case 11
case 12
case 13
case 39
case 40
case 41
  guniqhudid 10
  rotatesprite x y 40960 0 32389 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2

  break
case 14
case 15
case 16
case 36
case 37
case 38
  add y 5
  add x 5
  guniqhudid 10
  rotatesprite x y 40960 0 32390 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	sub x 147
  add y 37
  guniqhudid 11
  rotatesprite x y 40960 128 CHOLDING_3 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 17
case 18
case 19
case 33
case 34
case 35
