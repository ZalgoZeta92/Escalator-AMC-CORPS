// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 1 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// ROSA'S RED9===============================================================================================================

defstate draw_red9_left

  set x2 115
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  sub x2 looking_angSR1

  set y2 230
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos
  clamp y2 138 320
  state gunpushback_display2

	ifl gunsmoke_disp2 40 ife INVINC 0
		ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		  sub y2 44
		  add x2 30
		rotatespritea x2 y2 30000 0 29952 gunsmoke_disp2 wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		  add y2 44
		  sub x2 30
		guniqhudid 0
		}
		
guniqhudid 0
switch weaponcount
case 0
case 1
  state wep_drawup_rev
  guniqhudid 20
  ifand AGENT_UPGRADE 65536 set tilenum 32374 else ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
  rotatesprite x2 y2 40960 weap_disp_temp2 tilenum shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	add y2 49
	sub x2 10
	guniqhudid 21
	rotatesprite x2 y2 40960 weap_disp_temp2 C_PISTOL_L shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
  break
case 2
  state gun_smoke_display2
  set gun_pushb_disp2 7
  sub x2 gun_pushb_disp2
  add y2 gun_pushb_disp2
	  state random_gun_flash
	  sub y2 44
	  add x2 30
	  guniqhudid 20
	  rotatespritea x2 y2 15000 rot_flash rot_flash2 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
	  add y2 44
	  sub x2 30
	  guniqhudid 21
	  ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	  add tilenum 1
  rotatesprite x2 y2 40960 1024 tilenum 0 0 4100 windowx1 windowy1 windowx2 windowy2
	add y2 49
	sub x2 10
	guniqhudid 22
	rotatesprite x2 y2 40960 1024 C_PISTOL_L 0 107 4100 windowx1 windowy1 windowx2 windowy2
  break
 case 3
 case 4
	guniqhudid 20
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 2
	rotatesprite x2 y2 40960 1024 tilenum shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	add y2 49
	sub x2 10
	guniqhudid 21
	rotatesprite x2 y2 40960 1024 C_PISTOL_L shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
  break
endswitch

ends

defstate draw_red9

  set x 205
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 230
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  clamp y 138 320
  state gunpushback_display
	ifl gunsmoke_disp 40 ife INVINC 0
		ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 19
		  sub y 44
		  sub x 30
		rotatespritea x y 30000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		  add y 44
		  add x 30
		guniqhudid 0
		}
		
	ifand gun_firemode 64 state draw_red9_left
	
sub y 34
sub x 30
state flash_scanner
 add y 34
 add x 30
		
guniqhudid 0
switch weaponcount
case 0
case 1
  state wep_drawup
  guniqhudid 10
  ifand AGENT_UPGRADE 65536 set tilenum 32374 else ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
  rotatesprite x y 40960 weap_disp_temp2 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	add y 49
	add x 10
	guniqhudid 11
	rotatesprite x y 40960 weap_disp_temp2 C_PISTOL_R shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 2
  state gun_smoke_display
  set gun_pushb_disp 7
  add x gun_pushb_disp
  add y gun_pushb_disp
	  state random_gun_flash
	  sub y 44
	  sub x 30
	  guniqhudid 10
	  rotatespritea x y 15000 rot_flash rot_flash2 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
	  add y 44
	  add x 30
	  guniqhudid 11
	  ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	  add tilenum 1
  rotatesprite x y 40960 0 tilenum 0 0 4096 windowx1 windowy1 windowx2 windowy2
	add y 49
	add x 10
	guniqhudid 12
	rotatesprite x y 40960 0 C_PISTOL_R 0 107 4096 windowx1 windowy1 windowx2 windowy2
  break
 case 3
 case 4
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 2
	rotatesprite x y 40960 0 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	add y 49
	add x 10
	guniqhudid 11
	rotatesprite x y 40960 0 C_PISTOL_R shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 5
case 6
case 7
case 8
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 3
	rotatesprite x y 40960 0 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	break
case 9
case 10
case 11
case 12
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 4
	rotatesprite x y 40960 0 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	break
case 13
case 14
case 15
case 16
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 5
	rotatesprite x y 40960 16 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	add y 30
	sub x 10
	guniqhudid 11
	rotatesprite x y 40960 -128 CHOLDING_3 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	break
case 17
case 18
case 19
case 20
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 6
	rotatesprite x y 40960 24 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	add y 40
	sub x 5
	guniqhudid 11
	rotatesprite x y 40960 -128 CHOLDING_3 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	break
case 21
case 22
case 23
case 24
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 7
	rotatesprite x y 40960 32 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	add y 70
	sub x 20
	guniqhudid 11
	rotatesprite x y 40960 -128 CHOLDING_3 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	break
case 25
case 26
case 27
case 28
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 8
	rotatesprite x y 40960 24 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	break
case 29
case 30
case 31
case 32
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 9
	rotatesprite x y 40960 16 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	break
case 33
case 34
case 35
case 36
	guniqhudid 10
	add y 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 10
	rotatesprite x y 40960 0 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	add y 49
	add x 10
	guniqhudid 11
	rotatesprite x y 40960 0 C_PISTOL_L shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 40
case 41
case 42
case 43
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 4
	rotatesprite x2 y2 40960 1024 tilenum shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	break
case 44
case 45
case 46
case 47
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 5
	rotatesprite x2 y2 40960 1040 tilenum shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	add y2 30
	add x2 10
	guniqhudid 11
	rotatesprite x2 y2 40960 896 CHOLDING_3 shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	break
case 48
case 49
case 50
case 51
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 6
	rotatesprite x2 y2 40960 1048 tilenum shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	add y2 40
	add x2 5
	guniqhudid 11
	rotatesprite x2 y2 40960 896 CHOLDING_3 shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	break
case 52
case 53
case 54
case 55
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 7
	rotatesprite x2 y2 40960 1056 tilenum shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	add y2 70
	add x2 20
	guniqhudid 11
	rotatesprite x2 y2 40960 896 CHOLDING_3 shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	break
case 56
case 57
case 58
case 59
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 8
	rotatesprite x2 y2 40960 1048 tilenum shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	break
case 60
case 61
case 62
case 63
	guniqhudid 10
	ifand AGENT_UPGRADE 65536 set tilenum 32374 else set tilenum 23270
	add tilenum 9
	rotatesprite x2 y2 40960 1040 tilenum shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2
	break
case 64
