	  rotatespritea x y 55000 rot_flash 6197 0 0 1 -255 windowx1 windowy1 windowx2 windowy2
	  add x 60
	  add y 30
	  guniqhudid 11
	  rotatesprite x y 45056 0 32437 0 103 4096 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 12
	  sub x 75
	  add y 70
	  rotatesprite x y 32768 0 CHOLDING_3 0 103 4104 windowx1 windowy1 windowx2 windowy2
	  break
	endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate display_rosa_weapons
set RETURN 1
	ife currentweapon 1 state draw_red9
	else
	ife currentweapon 2 state draw_trenchgun
	else
	ife currentweapon 3 
		{
		ife SPECIALIST_EQUIPMENT[151] 2 state draw_huot
		else state draw_sterling
		}
	else
	ife currentweapon 4 state draw_firewall
	else
	ife currentweapon 5 state displaygrenade 
	else
	ife currentweapon 6 state draw_rosa_awm
	else
	ife currentweapon 7 state draw_rosa_stakegun
	else ife currentweapon 8 
	{
	ifg player[].ammo_amount 8 0 state displaytripbomb
	}
	else
	ife currentweapon 9 state draw_rosa_teslagun
ends
