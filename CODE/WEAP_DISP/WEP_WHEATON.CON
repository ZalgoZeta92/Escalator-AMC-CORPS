  break
endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 8 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate display_claymore
guniqhudid 0
 add weapon_xoffset 8
 sub gun_pos 10
 ifg weaponcount 6
 {
  div weaponcount 8
  add looking_arc weaponcount
 }
 else
 {
  ifl weaponcount 4
   {
	set x 142
	add x weapon_xoffset
	getp[].look_ang weap_disp_temp
	div weap_disp_temp 2
	sub x weap_disp_temp
	set y 234
	add y looking_arc
	sub y gun_pos
	ife weaponcount 0
		{
		guniqhudid 10
		rotatesprite x y 40960 0 36060 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
		}
	sub x 12
	add y 15
	ife weaponcount 0 set tilenum CHOLDING_R else
	ife weaponcount 1 set tilenum CKEYCARDTILE2 else
	ife weaponcount 2 set tilenum CKEYCARDTILE3
	sub x 70
	guniqhudid 11
	rotatesprite x y 42960 1024 tilenum shade arm_pal 4100 windowx1 windowy1 windowx2 windowy2
	add x 165
	guniqhudid 12
	rotatesprite x y 42960 0 tilenum shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
   }
 }
 guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 9 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate draw_laserkraft

  set x 220
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 220
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  clamp y 140 320
  
  state gunpushback_display

	ifl gunsmoke_disp 40 ife INVINC 0 // melta smoke
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 46
		sub y 38
		rotatespritea x y 30000 0 29952 gunsmoke_disp 2 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 46
		add y 38
		guniqhudid 0
		}


switch weaponcount
case 0
case 3
case 4
  state wep_drawup
   ifand gun_firemode 16384 state default_gun_scope
	else
		{
		guniqhudid 10
	    rotatesprite x y 45056 weap_disp_temp2 35890 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
		sub x 75
		add y 30
		guniqhudid 11
		rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	   }
  break
case 1
  ifand gun_firemode 16384 state default_gun_scope
	else
	{
	  sub x 46
	  sub y 38
	  displayrandvar rot_flash 2048
	  guniqhudid 10
	  rotatespritea x y 80000 rot_flash 7056 0 2 4096 -255 windowx1 windowy1 windowx2 windowy2
	  add x 46
	  add y 38
 guniqhudid 11
  rotatesprite x y 45056 0 35891 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  	sub x 75
	add y 30
	guniqhudid 12
	rotatesprite x y 32768 0 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2
  }
  break
case 2
   ifand gun_firemode 16384 state default_gun_scope
   else
   {
	state gun_smoke_display
	displayrandvar gun_pushb_disp 15
	  sub x 46
	  sub y 38
	  displayrandvar rot_flash 2048
	  guniqhudid 10
	  rotatespritea x y 80000 rot_flash 7056 0 2 4096 -255 windowx1 windowy1 windowx2 windowy2
	  add x 46
	  add y 38
guniqhudid 11
 rotatesprite x y 45056 0 35891 0 106 4096 windowx1 windowy1 windowx2 windowy2
   	sub x 75
	add y 30
	guniqhudid 12
	rotatesprite x y 32768 0 C_ARM_2 0 106 4096 windowx1 windowy1 windowx2 windowy2
  }
  break
endswitch
guniqhudid 0
ends

defstate disp_w_gauss
  set x 245
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 225
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  
  state gunpushback_display
  
  clamp y 143 320
  
  		ifl gunsmoke_disp 40 ife INVINC 0
		 ifn weaponcount 2
			{
			add gunsmoke_disp 1
			guniqhudid 18
			sub x 45
			sub y 25
			rotatespritea x y 40000 0 29952 gunsmoke_disp 2 4096 -255 windowx1 windowy1 windowx2 windowy2
			add y 25
			add x 45
			guniqhudid 0
			}
  
guniqhudid 0
switch weaponcount
case 0
case 1
case 4
  state wep_drawup
  guniqhudid 10
  rotatesprite x y 40960 weap_disp_temp2 29734 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	sub x 80
	add y 45
	guniqhudid 11
	rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // hand graphics
  break
case 2
case 3
	displayrandvar gun_pushb_disp 3
	add gun_pushb_disp 3
	state gun_smoke_display

	sub x 45
	sub y 25
	  state random_gauss_flash
	  guniqhudid 10
	  rotatespritea x y rot_size rot_flash2 rot_flash 0 2 4096 -255 windowx1 windowy1 windowx2 windowy2
	  add x 45
	  add y 25
	  
	  guniqhudid 11
	  rotatesprite x y 40960 0 29734 0 21 4096 windowx1 windowy1 windowx2 windowy2
	  guniqhudid 12
	  rotatesprite x y 40960 0 29735 0 21 4096 windowx1 windowy1 windowx2 windowy2
		sub x 80
		add y 45
		guniqhudid 13
		rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2 // hand graphics
  break
case 5
case 6
case 7
case 8
case 35
case 36
  guniqhudid 10
  rotatesprite x y 40960 0 29734 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 9
case 34
  guniqhudid 10
  rotatesprite x y 40960 0 29736 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 10
case 33
  add x 1
  add y 1
  guniqhudid 10
  rotatesprite x y 40960 4 29736 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 11
case 32
  add x 2
  add y 2
  guniqhudid 10
  rotatesprite x y 40960 8 29736 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 12
case 31
  add x 3
  add y 3
  guniqhudid 10
  rotatesprite x y 40960 12 29736 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 13
case 30
  add x 4
  add y 4
  guniqhudid 10
  rotatesprite x y 40960 16 29736 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 14
case 29
  add x 5
  add y 5
  guniqhudid 10
  rotatesprite x y 40960 20 29736 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 15
case 28
  add x 6
  add y 6
  guniqhudid 10
  rotatesprite x y 40960 24 29737 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 16
case 27
  add x 7
  add y 7
  guniqhudid 10
  rotatesprite x y 40960 28 29737 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 17
case 18
