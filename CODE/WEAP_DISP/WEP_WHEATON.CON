  ife kickbackpic 24 sub y 10
  guniqhudid 10
  rotatesprite x y 40960 32 29737 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate display_wheaton_weapons
set RETURN 1
	ife currentweapon 1 
		{
		ife SPECIALIST_EQUIPMENT[153] 2 state draw_gold_laser
		else ife SPECIALIST_EQUIPMENT[150] 2 state draw_wa_longside
		else state draw_welrod
		}
	else
	ife currentweapon 2
		{
		ife SPECIALIST_EQUIPMENT[152] 2 state disp_gold_spas15
		else ife SPECIALIST_EQUIPMENT[119] 2 state draw_autom_onagre
		else ife SPECIALIST_EQUIPMENT[118] 2 state draw_onagre
		else state draw_wheaton_shotgun
		}
	else
	ife currentweapon 3
		{
		ife SPECIALIST_EQUIPMENT[160] 2 state draw_xm8
		else ife SPECIALIST_EQUIPMENT[117] 2 state draw_mp44
		else state draw_stg46
		}
	else
	ife currentweapon 4 state draw_chinalake
	else
	ife currentweapon 5 state displaygrenade else
	ife currentweapon 6
		{
		ife SPECIALIST_EQUIPMENT[120] 2 state draw_photonDMR
		else state draw_leber
		}
	else
	ife currentweapon 7 
	{
	ife SPECIALIST_EQUIPMENT[158] 2 state disp_MAG_carbine
	else state draw_lasercannon
	}
	else ife currentweapon 8 
	{
	ifg player[].ammo_amount 8 0 state display_claymore
	}
	else
	ife currentweapon 9 
	{
	ife SPECIALIST_EQUIPMENT[147] 2 state disp_w_gauss
	else state draw_laserkraft
	}
ends

