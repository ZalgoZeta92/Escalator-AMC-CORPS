// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 1 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate draw_welrod

  set x 219
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 230
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 33
		sub y 40
		rotatespritea x y 30000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 33
		add y 40
		guniqhudid 0
		}
		
	sub x 33
	sub y 37
	state flash_scanner
	add x 33
	add y 37

switch weaponcount
case 0
case 1
  set weap_disp_temp2 player[].weapon_pos
  state wep_drawup
  state gunpushback_display
  ife slot1_mag 0 set tilenum 35849 else set tilenum 35848
  guniqhudid 10
  rotatesprite x y 40960 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 35
  add x 10
  guniqhudid 11
  rotatesprite x y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
state gun_smoke_display
displayrandvar gun_pushb_disp 15
  state gunpushback_display
  sub y 40
  sub x 33
  guniqhudid 10
  state random_gun_flash
  rotatespritea x y 20000 rot_flash rot_flash2 0 27 4096 -255 windowx1 windowy1 windowx2 windowy2
  add y 40
  add x 33
  guniqhudid 11
  rotatesprite x y 40960 0 35848 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 35
  add x 10
  guniqhudid 12
  rotatesprite x y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 3
case 5
  state gunpushback_display
  guniqhudid 10
  rotatesprite x y 40960 24 35849 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 32
  add x 11
  guniqhudid 11
  rotatesprite x y 40960 24 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 4
  state gunpushback_display
  guniqhudid 10
  rotatesprite x y 40960 52 35849 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 35
  add x 11
  guniqhudid 11
  rotatesprite x y 40960 52 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 6
case 7
case 8
case 9
case 10
case 43
  guniqhudid 10
  rotatesprite x y 40960 32 35854 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  add y 40
  guniqhudid 11
  rotatesprite x y 40960 164 C_PISTOL_R shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 11
case 12
case 13
case 14
case 15
case 16
case 40
case 41
case 42
  add y 7
	ife weaponcount 12 add y 20
	ife weaponcount 41 ife reload_empty 1 add y 10
  guniqhudid 10
  rotatesprite x y 40960 0 35854 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	add y 45
  add x 0
  guniqhudid 11
  rotatesprite x y 40960 190 C_PISTOL_R shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 17
case 18
case 19
case 20
case 21
case 22
case 23
case 37
case 38
case 39
  guniqhudid 10
  rotatesprite x y 40960 32 35854 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	add y 45
  sub x 5
  guniqhudid 11
  rotatesprite x y 40960 204 C_PISTOL_R shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 24
case 25
case 26
case 27
case 34
case 35
case 36
  add y 5
  guniqhudid 10
 rotatesprite x y 40960 0 35855 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
   add y 50
  sub x 5
  guniqhudid 11
  rotatesprite x y 40960 204 C_PISTOL_R shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 28
case 29
case 30
case 31
case 32
case 33
  add y 5
   ife weaponcount 32 sub y 15
  guniqhudid 10
  rotatesprite x y 40960 32 35856 shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
	add y 50
  sub x 5
  guniqhudid 11
  rotatesprite x y 40960 320 C_PISTOL_R shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

// Wheaton's Longslide===============================================================================================================

defstate draw_wa_longside

  set x 199
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 240
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  
    state gunpushback_display

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 33
		sub y 45
		rotatespritea x y 28000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 33
		add y 45
		guniqhudid 0
		}

guniqhudid 0
switch weaponcount
case 0
case 1
  set weap_disp_temp2 player[].weapon_pos
  ife weap_disp_temp2 8 soundonce SELECT_PISTOL
  state wep_drawup
 ife slot1_mag 0 set tilenum 17985 else set tilenum 17983
 guniqhudid 10
  rotatesprite x y 40960 weap_disp_temp2 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 20
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
case 3
  ife weaponcount 3 { displayrandvar gun_pushb_disp 10 add gun_pushb_disp 5 }
  state gun_smoke_display
  displayrandvar rot_flash 2048
  sub y 45
  sub x 33
  guniqhudid 10
  state fortyfive_flashes
  add y 45
  add x 33
  guniqhudid 11
  rotatesprite x y 40960 0 17984 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 20
  add x 8
  guniqhudid 12
  rotatesprite x y 40960 0 C_PISTOL_R 0 107 4096 windowx1 windowy1 windowx2 windowy2
  break
case 4
case 5
 set tilenum 17985
  guniqhudid 10
  rotatesprite x y 40960 8 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 20
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 8 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 6
case 7
case 8
case 9
case 10
  add y 5
  ife slot1_mag 0 set tilenum 17985 else set tilenum 17983
  guniqhudid 10
  rotatesprite x y 40960 16 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 20
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 16 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 11
case 12
case 13
  add y 7
  ife slot1_mag 0 set tilenum 17985 else set tilenum 17983
  guniqhudid 10
  rotatesprite x y 40960 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 20
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 14
case 15
case 16
  add y 7
  ife weaponcount 16 add y 5
  ife slot1_mag 0 set tilenum 17986 else set tilenum 17987
  guniqhudid 10
  rotatesprite x y 40960 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 22
  sub x 6
  guniqhudid 11
  rotatesprite x y 40960 64 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 17
case 18
case 19
case 20
case 21
case 22
case 23
  ife slot1_mag 0 set tilenum 17986 else set tilenum 17987
  guniqhudid 10
	rotatesprite x y 40960 32 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 20
  sub x 6
  guniqhudid 11
  rotatesprite x y 40960 96 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 24
case 25
case 26
case 27
case 28
case 29
case 30
  add y 5
  ife slot1_mag 0 set tilenum 17986 else set tilenum 17987
  guniqhudid 10
	rotatesprite x y 40960 64 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 18
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 128 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 31
case 32
case 33
case 34
	ife weaponcount 32 add y 5
  ife slot1_mag 0 set tilenum2 17986 else set tilenum2 17987
  guniqhudid 10
	rotatesprite x y 40960 96 tilenum2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 14
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 160 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 35
case 36
case 37
case 38
  guniqhudid 10
	rotatesprite x y 40960 98 tilenum2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 14
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 162 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 39
case 40
case 41
case 42
case 43
  add y 5
  ife tilenum2 17986 ife weaponcount 40 sound S1911_SLIDE
  set tilenum 17987
  guniqhudid 10
	rotatesprite x y 40960 64 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 18
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 128 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

defstate draw_gold_laser

  set x 210
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 235
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  
  clamp y 143 320
  
  state gunpushback_display

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
	   sub x 20
	   sub y 45
		rotatespritea x y 40000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
	  add x 20
	  add y 45
		guniqhudid 0
		}

  ifg weaponcount 6 set gun_pushb_disp 0

switch weaponcount
case 0
case 1
case 3
case 4
case 5
  state wep_drawup
  
  guniqhudid 10
  rotatesprite x y 40960 weap_disp_temp2 35576 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  ife HANDS_DRAW 2
	  {
	  sub x 50
	  add y 20
	  guniqhudid 11
	  rotatesprite x y 32768 weap_disp_temp2 C_ARM_3 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  add x 50
	  sub y 20
	  }
    add x 10
	add y 30
	guniqhudid 12
	rotatesprite x y 35768 weap_disp_temp2 C_PISTOL_R shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
  break
case 2
 state gun_smoke_display
 set gun_pushb_disp 10
 displayrandvar rot_flash 2048
   sub x 20
   sub y 45
   guniqhudid 10
  state random_gun_flash
  rotatespritea x y 24000 rot_flash rot_flash2 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 20
  add y 45
  guniqhudid 11
  rotatesprite x y 40960 weap_disp_temp2 35577 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  ife HANDS_DRAW 2
	  {
	  sub x 50
	  add y 20
	  guniqhudid 12
	  rotatesprite x y 32768 weap_disp_temp2 C_ARM_3 0 106 4096 windowx1 windowy1 windowx2 windowy2
	  add x 50
	  sub y 20
	  }
	add x 10
	add y 30
	guniqhudid 13
	rotatesprite x y 35768 weap_disp_temp2 C_PISTOL_R 0 106 4096 windowx1 windowy1 windowx2 windowy2
  break
case 6
case 7
case 8
case 38
case 39
case 40
  guniqhudid 10
  rotatesprite x y 40960 0 35578 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 9
case 10
case 11
case 35
case 36
case 37
  guniqhudid 10
  rotatesprite x y 40960 -64 35579 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 12
case 13
case 14

case 32
case 33
case 34
add y 15
add x 30
  guniqhudid 10
  rotatesprite x y 40960 0 35580 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 15
case 16
case 17

case 29
case 30
case 31
  guniqhudid 10
  rotatesprite x y 40960 0 35581 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  ifge weaponcount 29
		{
		add y 45
		sub x 20
		guniqhudid 11
		rotatesprite x y 40960 1024 C_HAND_2 shade wep_pal 12 windowx1 windowy1 windowx2 windowy2
		}
  break
case 18
case 19
case 20
case 26
case 27
case 28
  add y 5
  guniqhudid 10
  rotatesprite x y 40960 0 35582 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 21
case 22
case 23
case 24
case 25
  add y 5
  guniqhudid 10
  rotatesprite x y 40960 0 35583 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
 endswitch
 guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 2 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate draw_wheaton_shotgun

  set x 240
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 247
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 58
		sub y 52
		rotatespritea x y 40000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 58
		add y 52
		guniqhudid 0
		}

	state gunpushback_display
	guniqhudid 0
	switch weaponcount
	case 0
	case 1
	case 4
	  set rot_flash 0
	  set rot_flash2 0
	ifand gun_firemode 16384 // Ironsight?
	  {
		  set x 160
		  set weap_disp_temp2 wepsway_x
		  div weap_disp_temp2 2
		  sub x weap_disp_temp2
		  set y 140
		  set weap_disp_temp3 wepsway_y
		  div weap_disp_temp3 2
		  sub y weap_disp_temp3
		  set weap_disp_temp4 weapon_xoffset // set the weapon x sway to displaytemp4
		  div weap_disp_temp4 2 // divide it by 2
		  add x weap_disp_temp4 // add it to x
		  sub x 5 // offset it by 5
		  sub y 10
		  state gunpushback_sight_display
		  guniqhudid 10
		  sub weap_disp_temp8 16384
		  rotatesprite x y weap_disp_temp8 0 35903 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // Barrel
		  add weap_disp_temp8 16384
		  sub y 30
		  guniqhudid 11
		  rotatespritea x y 8192 0 11047 0 0 1 -255 windowx1 windowy1 windowx2 windowy2 // holographic crosshair
		  set x 160
		  sub x wepsway_x
		  sub x 10
		  add x weapon_xoffset
		  set y 142
		  sub y wepsway_y
		  guniqhudid 12
		  rotatesprite x y weap_disp_temp8 0 35902 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // holotech sight

				ifl player_shade_diff -5
					{
					set weap_disp_temp3 player_shade_diff
					mul weap_disp_temp3 2
					sub y 30
					guniqhudid 13
					rotatespritea x y 6096 0 2587 player_shade_diff wall_pal 33 weap_disp_temp3 windowx1 windowy1 windowx2 windowy2 // Glass in holosight
					}

	  }
	else
		{
		ife player[].weapon_pos 9 { set LOWER_WEAPON_SOUND SELECT_WEAPON state sound_lower_weapon }
		state wep_drawup
		guniqhudid 10
		rotatesprite x y 40960 weap_disp_temp2 35895 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
		sub x 80
		sub y 5
		guniqhudid 11
		rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
		}
	  break
	case 2
	ifand gun_firemode 16384
		  {
			  set x 160
			  set weap_disp_temp2 wepsway_x
			  div weap_disp_temp2 2
			  sub x weap_disp_temp2
			  set y 140
			  set weap_disp_temp3 wepsway_y
			  div weap_disp_temp3 2
			  sub y weap_disp_temp3
			  set weap_disp_temp4 weapon_xoffset // set the weapon x sway to displaytemp4
			  div weap_disp_temp4 2 // divide it by 2
			  add x weap_disp_temp4 // add it to x
			  sub x 5 // offset it by 5
			  sub y 5
			  sub y 10
			  guniqhudid 10
			  rotatespritea x y 20000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
			  add y 5
			  ife weaponcount 3
			  {
			  set gun_pushb_disp 10
			  state gunpushback_sight_display
			 }
			 guniqhudid 11
			  rotatesprite x y weap_disp_temp8 0 35903 0 106 0 windowx1 windowy1 windowx2 windowy2 // Barrel
			  sub y 30
			  guniqhudid 12
			  rotatespritea x y 8192 0 11047 0 0 1 -255 windowx1 windowy1 windowx2 windowy2 // holographic crosshair
			  set x 160
			  sub x wepsway_x
			  sub x 10
			  add x weapon_xoffset
			  set y 142
			  sub y wepsway_y
			  guniqhudid 13
			  rotatesprite x y weap_disp_temp8 0 35902 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // holotech sight

		  }
  else
		{
		state gun_smoke_display
		displayrandvar gun_pushb_disp 10
		ife weaponcount 3
			  {
			  add x gun_pushb_disp
			  add y gun_pushb_disp
			  }
		  sub x 58
		  sub y 52
		  guniqhudid 10
		  state random_shotg_flash
		  rotatespritea x y 40960 rot_flash2 rot_flash 0 0 8 -255 windowx1 windowy1 windowx2 windowy2
		  add x 58
		  add y 52
		  guniqhudid 11
		  rotatesprite x y 40960 0 35895 0 0 0 windowx1 windowy1 windowx2 windowy2
		  guniqhudid 12
		  rotatesprite x y 40960 0 35896 0 0 0 windowx1 windowy1 windowx2 windowy2
		 sub x 80
		 sub y 5
		 guniqhudid 13
		 rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2
		}
	  break
	case 3
	ife rot_flash 0 displayrandvar rot_flash 2048
	ifand gun_firemode 16384
		  {
			  set x 160
			  set weap_disp_temp2 wepsway_x
			  div weap_disp_temp2 2
			  sub x weap_disp_temp2
			  set y 140
			  set weap_disp_temp3 wepsway_y
			  div weap_disp_temp3 2
			  sub y weap_disp_temp3
			  set weap_disp_temp4 weapon_xoffset // set the weapon x sway to displaytemp4
			  div weap_disp_temp4 2 // divide it by 2
			  add x weap_disp_temp4 // add it to x
			  sub x 5 // offset it by 5
			  sub y 5
			  sub y 10
			  guniqhudid 10
			  rotatespritea x y 20000 rot_flash 16114 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
			  add y 5
			  ife weaponcount 3
			  {
			  set gun_pushb_disp 10
			  state gunpushback_sight_display
			 }
			 guniqhudid 11
			  rotatesprite x y weap_disp_temp8 0 35903 0 106 0 windowx1 windowy1 windowx2 windowy2 // Barrel
			  sub y 30
			  guniqhudid 12
			  rotatespritea x y 8192 0 11047 0 0 1 -255 windowx1 windowy1 windowx2 windowy2 // holographic crosshair
			  set x 160
			  sub x wepsway_x
			  sub x 10
			  add x weapon_xoffset
			  set y 142
			  sub y wepsway_y
			  guniqhudid 13
			  rotatesprite x y weap_disp_temp8 0 35902 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2 // holotech sight

		  }
  else
		{
		state gun_smoke_display
		displayrandvar gun_pushb_disp 10
		ife weaponcount 3
			  {
			  add x gun_pushb_disp
			  add y gun_pushb_disp
			  }
		  sub x 58
		  sub y 52
		  guniqhudid 10
		  rotatespritea x y 20000 rot_flash 16114 0 0 8 -255 windowx1 windowy1 windowx2 windowy2
		  add x 58
		  add y 52
		  guniqhudid 11
		  rotatesprite x y 40960 0 35895 0 0 0 windowx1 windowy1 windowx2 windowy2
		  guniqhudid 12
		  rotatesprite x y 40960 0 35896 0 0 0 windowx1 windowy1 windowx2 windowy2
		 sub x 80
		 sub y 5
		 guniqhudid 13
		 rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2
		}
	  break
	case 5
	case 6
	case 7
	case 8
	case 9
	case 10
	case 11
	case 36
	case 37
	case 38
	case 39
	case 40
	case 41
	case 42
		guniqhudid 10
	  rotatesprite x y 40960 0 35897 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 12
	case 13
	case 14
	case 15
	case 16
	case 17
	case 32
	case 33
	case 34
	case 35
	  sub y 15
	  ife kickbackpic 33 sub y 15
	  guniqhudid 10
	  rotatesprite x y 40960 0 35898 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	  sub x 90
	  add y 45
	  guniqhudid 11
	  rotatesprite x y 40960 96 CHOLDING_3 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	  break
	case 18
	case 19
	case 30
	case 31
	  sub y 15
	  ife kickbackpic 18 add y 15
	  guniqhudid 10
