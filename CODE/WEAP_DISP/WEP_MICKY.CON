case 8
case 9
case 10
case 19
case 20
case 21
case 22
  state gunpushback_display
  guniqhudid 10
  rotatesprite x y 40960 16 22530 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 11
  rotatespritea x y 40960 16 22531 weap_disp_temp5 wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 10
  state pb_hand
  break
case 11
case 12
case 13
case 14
case 15
case 16
case 17
case 18
add x 10
add y 10
  guniqhudid 10
  rotatesprite x y 40960 32 22532 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 11
  rotatespritea x y 40960 32 22533 weap_disp_temp5 wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
	sub x 68
	add y 13
	guniqhudid 12
	rotatesprite x y 36864 32 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

// MICKY'S FLAMETHROWER

defstate draw_mc_flamethrower

  set x 230
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 240
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

	ifl gunsmoke_disp 40 ife INVINC 0
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 45
		sub y 38
		rotatespritea x y 36000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 45
		add y 38
		guniqhudid 0
		}

guniqhudid 0
switch weaponcount
case 0
	state wep_drawup
	sub x 60
	sub y 40
	guniqhudid 10
	ife weap_disp_temp2 -5 soundonce PILOTL
	ife weap_disp_temp2 0 rotatespritea x y QUARTERSIZE 0 16547 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
	add x 60
	add y 40
	guniqhudid 11
	rotatesprite x y 40962 weap_disp_temp2 16543 gs wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	set specular_tile 43777 guniqhudid 25 state specular_gun

	guniqhudid 12
	ifl gun_glowdown 30 rotatespritea x y 40962 weap_disp_temp2 16545 gun_glowdown wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
	
	ife HANDS_DRAW 2
		{
		sub x 75
		add y 17
		guniqhudid 13
		rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 gs wep_pal 4096 windowx1 windowy1 windowx2 windowy2
		guniqhudid 14
		ifl gun_glowdown 30 rotatespritea x y 32768 weap_disp_temp2 C_ARM_2 gun_glowdown 107 4096 -255 windowx1 windowy1 windowx2 windowy2
		}
  break
case 1
case 2
case 3
 displayrandvar weap_disp_temp2 4
  add x weap_disp_temp2
  add y weap_disp_temp2
  set gun_pushb_disp weap_disp_temp2
  
 displayrandvar rot_flash 2048
  set gun_glowdown 0
  state gun_smoke_display
  sub y 38
  sub x 45
  guniqhudid 10
  rotatespritea x y INVENSIZE rot_flash 16115 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add y 38
  add x 45
  guniqhudid 11
  rotatesprite x y 40962 0 16544 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	ife HANDS_DRAW 2
		{
		sub x 75
		add y 17
		guniqhudid 12
		rotatesprite x y 32768 0 C_ARM_2 0 107 4096 windowx1 windowy1 windowx2 windowy2
		}
  break
endswitch
guniqhudid 0
ends

defstate draw_cryo_gun

  set x 240
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 230
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  
  clamp y 144 320

  	state gunpushback_display

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 64
		sub y 30
		rotatespritea x y 30000 0 29952 gunsmoke_disp 1 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 64
		add y 30
		guniqhudid 0
		}

switch weaponcount
case 0
  ife player[].weapon_pos 8 soundonce RIOTGUN_BOLT
  state wep_drawup

	sub x 90
	add y 35
	guniqhudid 10
	rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 shade arm_pal 4096 windowx1 windowy1 windowx2 windowy2
	add x 90
	sub y 35
	
  guniqhudid 11
  rotatesprite x y 40960 weap_disp_temp2 38983 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  state reverse_shade
   guniqhudid 12
  rotatespritea x y 40960 weap_disp_temp2 38985 weap_disp_temp5 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  break
case 1
case 2
case 3
case 4
	state gun_smoke_display
	displayrandvar gun_pushb_disp 10
  sub x 64
  sub y 30
  displayrandvar rot_flash 2048
  guniqhudid 10
  rotatespritea x y 40000 rot_flash 6240 0 1 4097 -255 windowx1 windowy1 windowx2 windowy2
  add x 64
  add y 30

	sub x 90
	add y 35
	guniqhudid 11
	rotatesprite x y 32768 weap_disp_temp2 C_ARM_2 0 102 4096 windowx1 windowy1 windowx2 windowy2
	add x 90
	sub y 35
	
	  guniqhudid 12
  rotatesprite x y 40960 0 38983 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 13
  rotatesprite x y 40960 0 38984 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  state reverse_shade
   guniqhudid 14
  rotatespritea x y 40960 0 38985 weap_disp_temp5 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate display_micky_weapons
set RETURN 1
	ife currentweapon 1
		{
		ife SPECIALIST_EQUIPMENT[148] 2 state draw_mag_pistol
		else ife SPECIALIST_EQUIPMENT[46] 2 state draw_gold_metalstorm_pistol
		else ife SPECIALIST_EQUIPMENT[60] 2 state draw_magnum_megaclass
		else ife SPECIALIST_EQUIPMENT[73] 2 state draw_tecsmg
		else state draw_auto9_pistol
		}
	else
	ife currentweapon 2
		{
		ife SPECIALIST_EQUIPMENT[58] 2 state draw_mc_whiplash
		else ife SPECIALIST_EQUIPMENT[69] 2 state draw_mc_gold_shotgun
		else state draw_mc_shotgun
		}
	else
	ife currentweapon 3
		{
		ife SPECIALIST_EQUIPMENT[140] 2 state draw_mc_gauss_rifle
		else ife SPECIALIST_EQUIPMENT[48] 2 state draw_ar73
		else ifand MICKY_UPGRADE 4 state draw_mc_ar_gl
		else state draw_mc_ar
		}
	else
	ife currentweapon 4 
		{
		ife SPECIALIST_EQUIPMENT[164] 2 state draw_MAG_launcher
		else state draw_mc_rocket
		}
	else
	ife currentweapon 5 state displaypipe 
	else
	ife currentweapon 6 
		{
		ife SPECIALIST_EQUIPMENT[170] 2 state draw_kobra
		else state draw_mc_auto_pulsegun
		}
	else
	ife currentweapon 7
		{
		ife SPECIALIST_EQUIPMENT[54] 2 state draw_mc_meson_cannon
		else state draw_mc_explosive_shotgun
		}
	else ife currentweapon 8 
	{
	ifg player[].ammo_amount 8 0
				{
				ife SPECIALIST_EQUIPMENT[113] 2 state drawmicky_icebeam else
				state draw_mc_icebomb
				}
	}
	else
	ife currentweapon 9
		{
		ife SPECIALIST_EQUIPMENT[173] 2 state draw_cryo_gun
		else ife SPECIALIST_EQUIPMENT[76] 2 state draw_mc_pbeam 
		else state draw_mc_flamethrower
		}
	else ife currentweapon 11 state draw_mc_auto_pulsegun
ends
