		add x 35
		add y 35
		guniqhudid 0
		}
		
  sub y 35
  sub x 35
  set weap_disp_temp3 11
  guniqhudid 18
  state laser_muzzleflash
  add y 35
  add x 35

  ife scope 2 { add x 60 add y 60 set weap_disp_temp9 65056 }
else set weap_disp_temp9 49151



guniqhudid 0
ifg kickbackpic_2 0
switch kickbackpic_2
case 3
case 4
