  rotatesprite x y 45056 weap_disp_temp2 19831 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  sub x 82
  add y 20
  guniqhudid 11
  rotatesprite x y 32768 0 C_ARM_2 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2

	add x 35
