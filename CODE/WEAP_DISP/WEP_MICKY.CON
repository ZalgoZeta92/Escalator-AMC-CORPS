// Micky's Gold Pistol===============================================================================================================

defstate draw_gold_metalstorm_pistol_left 
 set x2 111
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  sub x2 looking_angSR1

  set y2 240
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos

	ifl gunsmoke_disp2 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		add x2 33
		sub y2 40
		rotatespritea x2 y2 22000 0 29952 gunsmoke_disp2 wep_pal 4100 -255 windowx1 windowy1 windowx2 windowy2
		sub x2 33
		add y2 40
		guniqhudid 0
		}

guniqhudid 0
switch weaponcount
case 0
case 1
  state wep_drawup_rev
  state gunpushback_display2
 ife slot1_mag 0 set tilenum 16556 else set tilenum 16554
 guniqhudid 20
  rotatesprite x2 y2 40960 weap_disp_temp2 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 25
  sub x2 8
  guniqhudid 21
  rotatesprite x2 y2 40960 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 2
displayrandvar gun_pushb_disp2 15
sub x2 gun_pushb_disp2
add y2 gun_pushb_disp2
  state gun_smoke_display2
  displayrandvar rot_flash 2048
  sub y2 40
  add x2 33
  guniqhudid 20
  rotatespritea x2 y2 16000 rot_flash 16115 0 0 4100 -255 windowx1 windowy1 windowx2 windowy2
  add y2 40
  sub x2 33
  guniqhudid 21
  rotatesprite x2 y2 40960 1024 16555 0 wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 25
  sub x2 8
  guniqhudid 22
  rotatesprite x2 y2 40960 1024 C_PISTOL_L 0 107 4100 windowx1 windowy1 windowx2 windowy2
  break
case 3
case 4
  state gunpushback_display2
 set tilenum 16556
 guniqhudid 20
  rotatesprite x2 y2 40960 1016 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 25
  sub x2 8
  guniqhudid 21
  rotatesprite x2 y2 40960 1016 C_PISTOL_R shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
endswitch
ends

