	sub x 82
	add y 20
	guniqhudid 11
	rotatesprite x y 32768 -15 C_ARM_3 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 13
case 14
case 23
case 24
	add y 10
	guniqhudid 10
	rotatesprite x y 45056 0 19834 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	sub x 80
	add y 24
	guniqhudid 11
	rotatesprite x y 34152 -15 C_ARM_3 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
