		guniqhudid 28
		add x 45
		rotatespritea x y 25000 0 29952 gunsmoke_disp2 wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		sub x 45
		guniqhudid 0
		}

  ifand gun_firemode 1024 set tilenum 5579 else set tilenum 5577

  switch kickbackpic_2
  case 2
	displayrandvar weap_disp_temp4 5
	sub x weap_disp_temp4
	add y weap_disp_temp4
	state gun_smoke_display2
	  add x 45
	  state random_AR_horzflash
	  guniqhudid 20
	  rotatespritea x y 24638 0 rot_flash 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
	  sub x 45
	  ifand gun_firemode 1024 set tilenum 5580 else set tilenum 5578
  break
  endswitch
  
  guniqhudid 21
  state wep_drawup
  add weap_disp_temp2 1024
  rotatesprite x y 49152 weap_disp_temp2 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
}
ends

