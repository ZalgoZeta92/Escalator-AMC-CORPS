  switch kickbackpic_2
  case 2
    state gun_smoke_display2
	displayrandvar weap_disp_temp4 5
	sub x weap_disp_temp4
	add y weap_disp_temp4

  sub y 40
  add x 40
  guniqhudid 20
  state random_gun_flash
  rotatespritea x y 14000 rot_flash rot_flash2 0 2 4096 -255 windowx1 windowy1 windowx2 windowy2
  add y 40
  sub x 40
  ifand ZAXTOR_UPGRADE 16 set tilenum 5584 else
  set tilenum 5582
  break
  endswitch
