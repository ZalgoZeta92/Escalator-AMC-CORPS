defstate OTHERONE4
ifand gun_firemode 1024
{
  set x 90
  sub x wepsway_x
  sub x weapon_xoffset
  add x looking_angSR1

  set y 240
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

  state gunpushback_display
  ifand ZAXTOR_UPGRADE 16 set tilenum 5583 else
  set tilenum 5581
  
    ifl gunsmoke_disp2 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		add x 40
		sub y 40
