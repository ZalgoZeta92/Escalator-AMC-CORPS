defstate draw_zax_expander

  set x 235
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 250
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

  clamp y 161 320


state long_arm_tilenum
switch weaponcount
case 0
  state wep_drawup
  guniqhudid 10
  rotatesprite x y 49152 weap_disp_temp2 2556 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  getp[].random_club_frame weap_disp_temp
   sin weap_disp_temp weap_disp_temp
   div weap_disp_temp 1024 // 2^10
   add weap_disp_temp 10
   guniqhudid 11
  rotatespritea x y 49152 weap_disp_temp2 2554 weap_disp_temp 25 4096 -255 windowx1 windowy1 windowx2 windowy2
  break
case 1
case 2
case 3
case 4
case 5
 displayrandvar weap_disp_temp 10
  add x weap_disp_temp
  add y weap_disp_temp


  set weap_disp_temp5 kickbackpic
  mul weap_disp_temp5 4096
  set weap_disp_temp6 98304
  sub weap_disp_temp6 weap_disp_temp5
  sub x 25
  guniqhudid 10
  rotatespritea x y weap_disp_temp6 0 6240 0 2 4097 -255 windowx1 windowy1 windowx2 windowy2
  add x 25
  guniqhudid 11
  rotatesprite x y 49152 0 2557 0 0 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 12
  rotatespritea x y 49152 0 2555 0 25 4096 -255 windowx1 windowy1 windowx2 windowy2
  break
endswitch
guniqhudid 0
ends

defstate display_zaxtor_weapons
set RETURN 1
	ife currentweapon 1
		{
		ife SPECIALIST_EQUIPMENT[167] 2 state draw_magnum
		else ife SPECIALIST_EQUIPMENT[82] 2 state draw_mp5k
		else ife SPECIALIST_EQUIPMENT[37] 2 state draw_gold_zrifle
		else state displayzaxrifle
		}
	else
	ife currentweapon 2
		{
		ife SPECIALIST_EQUIPMENT[136] 2 state draw_rotaryshotgun
		else ife SPECIALIST_EQUIPMENT[62] 2 state draw_z_goldshotgun
		else ife SPECIALIST_EQUIPMENT[5] 2 state draw_z_quadshot
		else state draw_z_shotgun
		}
	else
	ife currentweapon 3
		{
		ife SPECIALIST_EQUIPMENT[126] 2 state draw_silver_shooter
		else ife SPECIALIST_EQUIPMENT[23] 2 state draw_rc_zsmg
		else ife SPECIALIST_EQUIPMENT[70] 2 state draw_zsgalil
		else state drawzsmg
		}
	else
	ife currentweapon 4
		{
		ife SPECIALIST_EQUIPMENT[75] 2 state draw_z_plasma_rpg
		else ife SPECIALIST_EQUIPMENT[99] 2 state draw_z_elemental
		else state draw_z_rpg
		}
	else
	ife currentweapon 5 state DISP_zax_pike else
	ife currentweapon 6 state draw_zax_shrinker
	else
	ife currentweapon 7
		{
		ife SPECIALIST_EQUIPMENT[159] 2 state draw_bfg15k 
		else ife SPECIALIST_EQUIPMENT[52] 2 state DISP_zaxfirestorm
		else state DISP_zaxdevi
		}
	else ife currentweapon 8
	{
	ifg player[].ammo_amount 8 0 state displaytripbomb
	}
	else
	ife currentweapon 9
		{
		ife SPECIALIST_EQUIPMENT[93] 2 state draw_annihilator else
		state draw_petrify
		}
	else
	ife currentweapon 10 state drawzdetonator
	else ife currentweapon 11 state draw_zax_expander
ends

