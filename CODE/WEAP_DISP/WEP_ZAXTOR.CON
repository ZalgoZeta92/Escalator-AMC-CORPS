defstate OTHERONE5
guniqhudid 0
ifand gun_firemode 1024
{
  set x 90
  sub x wepsway_x
  sub x weapon_xoffset
  add x looking_angSR1

  set y 220
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos
  
