// ================== PANFLUTE

defstate panflute_heatsink
  ifg GUN_HEAT[cur_weap] 60 set tilenum 38971
  else ifg GUN_HEAT[cur_weap] 30 set tilenum 38970
  else set tilenum 3587
  guniqhudid 11
  rotatespritea x y 40960 weap_disp_temp2 tilenum weap_disp_temp5 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  ifg GUN_HEAT[cur_weap] 30 rotatespritea x y 40960 weap_disp_temp2 38972 weap_disp_temp5 0 4096 -255 windowx1 windowy1 windowx2 windowy2
ends

defstate draw_panflute

  set x 235
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 210
  sub y wepsway_y
  add y looking_arc
  set weap_disp_temp gun_pos
  div weap_disp_temp 2
  sub y weap_disp_temp
  clamp y 152 320
  
  state gunpushback_display
  
  		ifl gunsmoke_disp 40 ife INVINC 0
		 ifn weaponcount 2
			{
			add gunsmoke_disp 1
			guniqhudid 18
			sub x 65
			sub y 30
			rotatespritea x y 40000 0 29952 gunsmoke_disp 2 4096 -255 windowx1 windowy1 windowx2 windowy2
			add y 30
			add x 65
			guniqhudid 0
			}

  set weap_disp_temp5 60
  sub weap_disp_temp5 GUN_HEAT[cur_weap]
  
  ifg player[].weapon_pos 0 set draw_animation 10

switch weaponcount
case 0
case 1
  getp[].ammo_amount 9 weap_disp_temp
  state wep_drawup
  guniqhudid 10
	ifg draw_animation 0
		{
		ife draw_animation 9 sound PANFL_C
		ifg draw_animation 7 set tilenum 38973
		else ifg draw_animation 3 set tilenum 38974
		else set tilenum 38968
		}
		else set tilenum 38968
  rotatesprite x y 40960 weap_disp_temp2 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  state panflute_heatsink
  break
case 2
case 4
  displayrandvar gun_pushb_disp 5
  add gun_pushb_disp 5
  state gun_smoke_display

  sub x 65
  sub y 30
		state random_gauss_flash
	  guniqhudid 10
	  add rot_size 5000
	  rotatespritea x y rot_size rot_flash2 rot_flash 0 2 4096 -255 windowx1 windowy1 windowx2 windowy2
  add x 65
  add y 30
  
  guniqhudid 11
  rotatesprite x y 40960 0 38969 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  state panflute_heatsink
  break
case 3
case 5
case 33
case 34
case 35
case 36
  guniqhudid 10
  rotatesprite x y 40960 0 38974 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  state panflute_heatsink
  break
default
  guniqhudid 10
  rotatesprite x y 40960 0 38973 shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  state panflute_heatsink
  break
endswitch
guniqhudid 0
ends

