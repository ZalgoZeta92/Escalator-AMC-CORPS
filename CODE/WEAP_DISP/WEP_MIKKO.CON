// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate display_mikko_weapons
set RETURN 1
	ife currentweapon 1
		{
		ife SPECIALIST_EQUIPMENT[174] 2 state draw_judgement
		else ife SPECIALIST_EQUIPMENT[4] 2 state draw_MDF_magnum
		else ife SPECIALIST_EQUIPMENT[43] 2 state draw_gold_rose
		else state drawmpistol
		}
	else
	ife currentweapon 2
		{
		ife SPECIALIST_EQUIPMENT[30] 2 state draw_m_assault_shotgun
		else ife SPECIALIST_EQUIPMENT[68] 2 state drawm_gold_shotgun
		else ife SPECIALIST_EQUIPMENT[85] 2 state draw_msc12
		else state drawmshotgun
		}
	else
	ife currentweapon 3
		{
		ife SPECIALIST_EQUIPMENT[145] 2 state draw_msrifle_mk2
		else ife SPECIALIST_EQUIPMENT[21] 2 state draw_msmg
		else ife SPECIALIST_EQUIPMENT[47] 2 state draw_mikko_battle_rifle
		else state drawmassrifle
		}
	else
	ife currentweapon 4 state draw_bolter
	else
	ife currentweapon 5 state displaygrenade else
	ife currentweapon 6
		{
		ife SPECIALIST_EQUIPMENT[59] 2 state draw_awms
		else state drawgreenmgun
		}
	else
	ife currentweapon 7 
		{
		ife SPECIALIST_EQUIPMENT[169] 2 state draw_panflute
		else state drawredmgun
		}
	else ife currentweapon 8 
	{
	ifg player[].ammo_amount 8 0
			{
			ife SPECIALIST_EQUIPMENT[114] 2 state draw_golden_mikko else
			state displaytripbomb
			}
	}
	else
	ife currentweapon 9
		{
		ife SPECIALIST_EQUIPMENT[19] 2 state draw_mdf_plasma else
		ife SPECIALIST_EQUIPMENT[33] 2 state DISP_ms_nailgun else
		state drawmplasma
		}
	else ife currentweapon 11 
		{
		set RETURN 1 ife SPECIALIST_EQUIPMENT[59] 2 state draw_awms_am
		else state drawgreenmgun
		}
ends
