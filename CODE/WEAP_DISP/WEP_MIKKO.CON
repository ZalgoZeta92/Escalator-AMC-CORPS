	case 16
	case 17
	  add x 10
	  sub y 30
	  
	  	sub y 57
		sub x 37
		guniqhudid 10
		rotatesprite x y 65536 1024 12145 shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2 // Gun's strap
		add y 57
		add x 37
	  
	  ifand MIKKO_UPGRADE 32 set tilenum 6975 else set tilenum 6981
	  guniqhudid 11
	  rotatesprite x 106 49152 0 tilenum shade wep_pal 4104 windowx1 windowy1 windowx2 windowy2
		guniqhudid 25 
		ife opt_glass_effects YES 
			ifl player_shade_diff 0
					{
					set total_player_shade_diff shade
					add total_player_shade_diff player_shade_diff
					rotatespritea x y 49152 0 43794 total_player_shade_diff wall_pal 4096 -255 0 0 xdim ydim 
