// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//
// SLOT 1 WEAPONS
//
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

defstate drawmpistol_left

  set x2 121
  sub x2 wepsway_x
  sub x2 weapon_xoffset
  sub x2 looking_angSR1

  set y2 240
  sub y2 wepsway_y
  add y2 looking_arc
  sub y2 gun_pos
  
  state gunpushback_display2

	ifl gunsmoke_disp2 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp2 1
		guniqhudid 28
		add x2 18
		sub y2 40
		rotatespritea x2 y2 28000 0 29952 gunsmoke_disp2 wep_pal 4100 -255 windowx1 windowy1 windowx2 windowy2
		sub x2 18
		add y2 40
		guniqhudid 0
		}

switch weaponcount
case 0
case 1
  state wep_drawup_rev
  ifand MIKKO_UPGRADE 4 { ife slot1_mag 0 set tilenum 7130 else set tilenum 7128 } else { ife slot1_mag 0 set tilenum 7125 else set tilenum 7123 }
  guniqhudid 20
  rotatesprite x2 y2 41000 weap_disp_temp2 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  set specular_tile 43799 guniqhudid 25 state specular_gun_left
  add y2 25
  sub x2 8
  guniqhudid 21
  rotatesprite x2 y2 41000 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 2
displayrandvar gun_pushb_disp2 7
add x2 gun_pushb_disp2
add y2 gun_pushb_disp2
  displayrandvar rot_flash 2048
  state gun_smoke_display2
  sub y2 40
  add x2 18
  guniqhudid 20
  rotatespritea x2 y2 16000 rot_flash 16115 0 0 4100 -255 windowx1 windowy1 windowx2 windowy2
  add y2 40
  sub x2 18
  ifand MIKKO_UPGRADE 4 set tilenum 7129 else set tilenum 7124
  guniqhudid 21
  rotatesprite x2 y2 41000 1024 tilenum 0 wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  add y2 25
  sub x2 8
  guniqhudid 22
  rotatesprite x2 y2 41000 1024 C_PISTOL_L 0 107 4100 windowx1 windowy1 windowx2 windowy2
  break
case 3
case 4
  ifand MIKKO_UPGRADE 4 set tilenum 7130 else set tilenum 7125
  guniqhudid 20
  rotatesprite x2 y2 41000 1016 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  set specular_tile 43799 set weap_disp_temp2 8 guniqhudid 25 state specular_gun_left
  add y2 25
  sub x2 8
  guniqhudid 21
  rotatesprite x2 y2 41000 1016 C_PISTOL_R shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
endswitch
ends

defstate drawmpistol

  set x 199
  sub x wepsway_x
  add x weapon_xoffset
  sub x looking_angSR1

  set y 240
  sub y wepsway_y
  add y looking_arc
  sub y gun_pos

	ifl gunsmoke_disp 40 ife INVINC 0
	 ifn weaponcount 2
		{
		add gunsmoke_disp 1
		guniqhudid 18
		sub x 18
		sub y 40
		rotatespritea x y 28000 0 29952 gunsmoke_disp wep_pal 4096 -255 windowx1 windowy1 windowx2 windowy2
		add x 18
		add y 40
		guniqhudid 0
		}
		
ifand gun_firemode 64 state drawmpistol_left

sub x 18
sub y 10
state flash_scanner
add x 18
add y 10

switch weaponcount
case 0
case 1
  set weap_disp_temp2 player[].weapon_pos
  ife weap_disp_temp2 8 soundonce SELECT_PISTOL
  state wep_drawup
  state gunpushback_display
  ifand MIKKO_UPGRADE 4 { ife slot1_mag 0 set tilenum 7130 else set tilenum 7128 } else { ife slot1_mag 0 set tilenum 7125 else set tilenum 7123 }
  guniqhudid 10
  rotatesprite x y 40960 weap_disp_temp2 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  set specular_tile 43799 guniqhudid 25 state specular_gun
  add y 25
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 2
displayrandvar gun_pushb_disp 7
add x gun_pushb_disp
add y gun_pushb_disp
  displayrandvar rot_flash 2048
  state gun_smoke_display
  sub y 40
  sub x 18
  guniqhudid 10
  rotatespritea x y 16000 rot_flash 16115 0 0 4096 -255 windowx1 windowy1 windowx2 windowy2
  add y 40
  add x 18
  ifand MIKKO_UPGRADE 4 set tilenum 7129 else set tilenum 7124
  guniqhudid 11
  rotatesprite x y 40960 0 tilenum 0 wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  add y 25
  add x 8
  guniqhudid 12
  rotatesprite x y 40960 0 C_PISTOL_R 0 107 4096 windowx1 windowy1 windowx2 windowy2
  break
case 3
case 4
  state gunpushback_display
  ifand MIKKO_UPGRADE 4 set tilenum 7130 else set tilenum 7125
  guniqhudid 10
  rotatesprite x y 40960 8 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  set specular_tile 43799 set weap_disp_temp2 8 guniqhudid 25 state specular_gun
  add y 25
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 8 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 5
case 6
case 7
case 8
case 9
case 10
  add y 5
  ife slot1_mag 0 { ifand MIKKO_UPGRADE 4 set tilenum 7130 else set tilenum 7125 set specular_tile 43800 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7128 else set tilenum 7123 set specular_tile 43799 }
  guniqhudid 10
  rotatesprite x y 40960 16 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 25 set weap_disp_temp2 16 state specular_gun
  add y 25
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 16 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 11
case 12
case 13
  add y 7
  ife slot1_mag 0 { ifand MIKKO_UPGRADE 4 set tilenum 7130 else set tilenum 7125 set specular_tile 43800 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7128 else set tilenum 7123 set specular_tile 43799 }
  guniqhudid 10
  rotatesprite x y 40960 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 25 set weap_disp_temp2 0 state specular_gun
  add y 25
  add x 8
  guniqhudid 11
  rotatesprite x y 40960 0 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 14
case 15
case 16
  add y 7
  ife weaponcount 16 add y 5
  ife slot1_mag 0 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
  guniqhudid 10
  rotatesprite x y 40960 0 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 25 set weap_disp_temp2 0 state specular_gun	
  add y 22
  sub x 6
  guniqhudid 11
  rotatesprite x y 40960 64 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 17
case 18
case 19
case 20
case 21
case 22
case 23
  ife slot1_mag 0 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
  guniqhudid 10
  rotatesprite x y 40960 32 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  guniqhudid 25 set weap_disp_temp2 32 state specular_gun	
  add y 20
  sub x 6
  guniqhudid 11
  rotatesprite x y 40960 96 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 24
case 25
case 26
case 27
case 28
case 29
case 30
  add y 5
  ife slot1_mag 0 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
  guniqhudid 10
	rotatesprite x y 40960 64 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	guniqhudid 25 set weap_disp_temp2 64 state specular_gun	
  add y 18
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 128 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 31
case 32
case 33
case 34
	ife weaponcount 32 add y 5
  ife slot1_mag 0 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
  guniqhudid 10
	rotatesprite x y 40960 96 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	guniqhudid 25 set weap_disp_temp2 96 state specular_gun	
  add y 14
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 160 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 35
case 36
case 37
case 38
  guniqhudid 10
    ife slot1_mag 0 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
	rotatesprite x y 40960 98 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
	guniqhudid 25 set weap_disp_temp2 98 state specular_gun	
  add y 14
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 162 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
case 39
case 40
case 41
case 42
case 43
  add y 5
  ife reload_empty 1 ife weaponcount 40 sound MSPISTOL_SLIDE
  ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127
  guniqhudid 10
  rotatesprite x y 40960 64 tilenum shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  set specular_tile 43802 set weap_disp_temp2 64 guniqhudid 25 state specular_gun	
  add y 18
  sub x 8
  guniqhudid 11
  rotatesprite x y 40960 128 C_PISTOL_R shade wep_pal 4096 windowx1 windowy1 windowx2 windowy2
  break
// left hand gun
case 44
case 45
case 46
  add y2 7
  ife reload_empty 1 { ifand MIKKO_UPGRADE 4 set tilenum 7130 else set tilenum 7125 set specular_tile 43800 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7128 else set tilenum 7123 set specular_tile 43799 }
  guniqhudid 10
  rotatesprite x2 y2 41000 1024 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  guniqhudid 25 set weap_disp_temp2 1024 state specular_gun_left
  add y2 25
  add x2 8
  guniqhudid 11
  rotatesprite x2 y2 41000 1024 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 47
case 48
case 49
  add y2 7
  ife weaponcount 49 add y2 5
  ife reload_empty 1 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
  guniqhudid 10
  rotatesprite x2 y2 41000 1024 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  guniqhudid 25 set weap_disp_temp2 1024 state specular_gun_left	
  add y2 22
  add x2 6
  guniqhudid 11
  rotatesprite x2 y2 41000 960 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 50
case 51
case 52
case 53
case 54
case 55
case 56
  ife reload_empty 1 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
  guniqhudid 10
  rotatesprite x2 y2 41000 992 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  guniqhudid 25 set weap_disp_temp2 992 state specular_gun_left	
  add y2 20
  add x2 6
  guniqhudid 11
  rotatesprite x2 y2 41000 928 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 57
case 58
case 59
case 60
case 61
case 62
case 63
  add y2 5
  ife reload_empty 1 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
  guniqhudid 10
	rotatesprite x2 y2 41000 960 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
	guniqhudid 25 set weap_disp_temp2 960 state specular_gun_left	
  add y2 18
  add x2 8
  guniqhudid 11
  rotatesprite x2 y2 41000 896 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 64
case 65
case 66
case 67
	ife weaponcount 32 add y2 5
  ife reload_empty 1 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
  guniqhudid 10
	rotatesprite x2 y2 41000 928 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
	guniqhudid 25 set weap_disp_temp2 928 state specular_gun_left	
  add y2 14
  add x2 8
  guniqhudid 11
  rotatesprite x2 y2 41000 864 C_PISTOL_L shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
  break
case 68
case 69
case 70
case 71
  guniqhudid 10
    ife reload_empty 1 { ifand MIKKO_UPGRADE 4 set tilenum 7131 else set tilenum 7126 set specular_tile 43801 }
  else { ifand MIKKO_UPGRADE 4 set tilenum 7132 else set tilenum 7127 set specular_tile 43802 }
	rotatesprite x2 y2 41000 926 tilenum shade wep_pal 4100 windowx1 windowy1 windowx2 windowy2
	guniqhudid 25 set weap_disp_temp2 926 state specular_gun_left	
  add y2 14
  add x2 8
