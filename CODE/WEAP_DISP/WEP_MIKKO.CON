case 7
case 8
case 27
case 28
ifand MIKKO_UPGRADE 32 set tilenum 6974 else set tilenum 6980


	  	sub y 27
		sub x 57
		guniqhudid 10
		rotatesprite x y 65536 1024 12145 shade wep_pal 4108 windowx1 windowy1 windowx2 windowy2 // Gun's strap
		add y 27
		add x 57

guniqhudid 11
