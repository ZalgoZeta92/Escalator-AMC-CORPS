	else
	ifspawnedby WTANKPROJ { sizeat 90 90 state global_flash  }
	else
	ifspawnedby 18271 sizeat 64 64 else
	ifspritepal 3 sizeat 64 64 else
	sizeat 32 32
	action EXPLOSION_FRAMES2
}

	geta[].shade temp
	add temp 8
	seta[].shade temp

  ifactioncount 20
	killit

