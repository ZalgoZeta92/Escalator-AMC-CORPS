setdefname AMCSQUAD.DEF
dynamicremap

// Version Definition
define VERSION_FOR_LOG 9000
define VERSION_FOR_MENU 9500

string VERSION_FOR_LOG The AMC Squad - Episode 5 - 5.2.0
string VERSION_FOR_MENU v5.2.0-%s
string 9501

onevent EVENT_INIT
	// print version string
	echo VERSION_FOR_LOG

    qgetsysstr 9501 STR_REVISION
    qsprintf VERSION_FOR_MENU VERSION_FOR_MENU 9501

	// savegame compatibility version (SVN revision) -- alter to invalidate savegames
	setu[].userbyteversion 18030
endevent


