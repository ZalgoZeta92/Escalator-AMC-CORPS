defstate WOODCHUNKSPAWN
shoot SWOODSCRAP
ifg temp 10 shoot SWOODSCRAP
ifg temp 20 shoot SWOODSCRAP
ifg temp 30 shoot SWOODSCRAP
ifg temp 40 shoot SWOODSCRAP
ifg temp 50 shoot SWOODSCRAP
ends

defstate ROCKCHUNKSPAWN
shoot SROCKDEB_4
ifg temp 10 shoot SROCKDEB_4
ifg temp 20 shoot SROCKDEB_4
ifg temp 30 shoot SROCKDEB_4
ifg temp 40 shoot SROCKDEB_4
ifg temp 50 shoot SROCKDEB_4
ends

defstate SPAWN_BIG_SPARKS
ifrnd 64 espawn 9284 else ifrnd 64 espawn 9285 else ifrnd 64 espawn 9286 else espawn 9287
ends

defstate bullet_hit_sounds
	geta[].extra temp6

	switch STEPSOUNDFX
		case 0
		case 5
			set playsound HITNORMAL espawn GUNSMOKE state SPAWN_BEHIND break
		case 1
		case 23
			set playsound HITWOOD espawn GUNSMOKE state SPAWN_BEHIND state WOODCHUNKSPAWN break
		case 2
		case 3
		case 24
			state METAL_HIT_SOUNDS
			spawn GUNSMOKE shoot SPARK shoot SPARK
			state SPAWN_BIG_SPARKS
			state SPAWN_BEHIND
			break
		case 4
		case 22
		case 28
		case 34
			spawn DIRT_SPLASH
			set playsound HITDIRT espawn DUSTSMOKE state SPAWN_BEHIND break
		case 8 spawn SNOW_SPLASH set playsound MELEE_HIT_SNOW1 espawn DUSTSMOKE seta[RETURN].pal 27 state SPAWN_BEHIND break
		case 9
		case 16
			set playsound HITWATER break
		case 10
			set playsound HITDIRT ife FLOORTEX 8067 { espawn DUSTSMOKE seta[RETURN].pal 8 }
			else espawn DUSTSMOKE state SPAWN_BEHIND
			break
		case 11
		case 27
			set playsound HITSTONE state ROCKCHUNKSPAWN espawn GUNSMOKE  state SPAWN_BEHIND break
		case 12 set playsound HITMUD break
		case 14 state METAL_HIT_SOUNDS set playsound HITWATER espawn GUNSMOKE state SPAWN_BEHIND break
		case 15 set playsound HITSTONE set playsound HITWATER espawn GUNSMOKE state SPAWN_BEHIND break
		case 17
			set playsound HITCHAINL espawn GUNSMOKE state SPAWN_BEHIND
			shoot SPARK shoot SPARK state SPAWN_BIG_SPARKS state SPAWN_BEHIND break
		case 18  set playsound HITGLASS espawn GUNSMOKE state SPAWN_BEHIND break
		case 19 set playsound HITCARDB espawn GUNSMOKE state SPAWN_BEHIND break
		case 20 set playsound HITMUD espawn GUNSMOKE state SPAWN_BEHIND break
		case 21 set playsound HITMUD espawn BLOOD state SPAWN_BEHIND ifrnd 64 guts JIBS6 1 break
		case 26
			set playsound HITGLASS espawn GUNSMOKE state SPAWN_BEHIND
			eshoot ICE_DEBRIS setthisprojectile[RETURN].xrepeat 2 setthisprojectile[RETURN].yrepeat 2
			break
		case 30 set playsound HITSTONE espawn GUNSMOKE state SPAWN_BEHIND break
		case 32 set playsound HITMUD spritepal 8 espawn BLOOD seta[RETURN].pal 8 ifrnd 64 guts JIBS6 1 break
		case 33
			set playsound HITDIRT ife FLOORTEX 8067 { espawn DUSTSMOKE seta[RETURN].pal 8 }
			else espawn DUSTSMOKE state SPAWN_BEHIND
			break
	endswitch

	// randomizes pitch depending on bullet strength
	randvar temp4 256
	geta[].extra temp5
	mul temp5 5
	sub temp4 temp5
	ife playsound 0 set playsound HITNORMAL
	soundvar playsound
	setactorsoundpitch THISACTOR playsound temp4
ends

defstate BULLETHITSOUNDS
ifcount 1
	{
	state bullet_hit_sounds
	killit
	}
ends

// Controls melee hit sounds
defstate MELEE_HIT_SOUNDS
		ife STEPSOUNDFX 1 { ifrnd 128 set playsound MELEE_HIT_WOOD1 else set playsound MELEE_HIT_WOOD2 shoot SWOODSCRAP shoot SWOODSCRAP }
		else ife STEPSOUNDFX 23 { ifrnd 128 set playsound MELEE_HIT_WOOD1 else set playsound MELEE_HIT_WOOD2 shoot SWOODSCRAP shoot SWOODSCRAP }
		else ife STEPSOUNDFX 4 { ifrnd 128 set playsound MELEE_HIT_DIRT1 else set playsound MELEE_HIT_DIRT2 spawn DUSTSMOKE }
		else ife STEPSOUNDFX 6 { set playsound MELEE_HIT_CARPET1 }
		else ife STEPSOUNDFX 8 { set playsound MELEE_HIT_SNOW1 espawn DUSTSMOKE seta[RETURN].pal 27 }
		else ife STEPSOUNDFX 9 { sound WATER_SPLASH spawn WATERSPLASH2 }
		else ife STEPSOUNDFX 10 { ifrnd 128 set playsound MELEE_HIT_DIRT1 else set playsound MELEE_HIT_DIRT2 spawn DUSTSMOKE }
		else ife STEPSOUNDFX 11 { set playsound MELEE_HIT_STONE1 shoot SPARK shoot SPARK }
		else ife STEPSOUNDFX 19 { set playsound MELEE_HIT_CARPET1 shoot SPARK shoot SPARK }
		else ife STEPSOUNDFX 20 { ifrnd 128 set playsound MELEE_HIT_DIRT1 else set playsound MELEE_HIT_DIRT2 spawn DUSTSMOKE }
		else ife STEPSOUNDFX 21 { ifrnd 128 set playsound MELEE_HIT_DIRT1 else set playsound MELEE_HIT_DIRT2 spawn DUSTSMOKE }
		else ife STEPSOUNDFX 32 { ifrnd 128 set playsound MELEE_HIT_DIRT1 else set playsound MELEE_HIT_DIRT2 spawn DUSTSMOKE }
		else ife STEPSOUNDFX 28 { set playsound MELEE_HIT_SNOW1 spawn DUSTSMOKE }
		else ife STEPSOUNDFX 32 { ifrnd 128 set playsound MELEE_HIT_DIRT1 else set playsound MELEE_HIT_DIRT2 espawn DUSTSMOKE seta[RETURN].pal 8 }
		else ife STEPSOUNDFX 33 { ifrnd 128 set playsound MELEE_HIT_DIRT1 else set playsound MELEE_HIT_DIRT2 espawn DUSTSMOKE }
		else
			{
			spawn 8433
			shoot SPARK
			shoot SPARK
			ifrnd 96 set playsound METSWIPE else
			ifrnd 96 set playsound METSWIPE2 else
			set playsound METSWIPE3
			}
		// This code randomizes the pitch of the sound a bit based on it's damage
		randvar temp4 128
		ifrnd 128 sub temp4 128
		geta[].extra temp5
		mul temp5 2
		sub temp4 temp5
		soundvar playsound
		setactorsoundpitch THISACTOR playsound temp4
ends

defstate PROJ_HIT_SOUNDS
ifpdistl 16384
	{
		set temp3 temp
		ifl temp3 -16384
		 ifg temp3 -32768 // hitting a wall?
			{
			add temp3 32768 // add 32768 to get the wall's number
			getw[temp3].picnum FLOORTEX
			state CHECKSTEPS
			state MELEE_HIT_SOUNDS
			}
			else
		ifl temp3 32768
		 ifg temp3 16384 // hitting a floor/ceiling?
			{
			sub temp3 16384
			state getfloordist
			ifl z 32 gets[temp3].floorpicnum FLOORTEX
			else gets[temp3].ceilingpicnum FLOORTEX
			state CHECKSTEPS
			state MELEE_HIT_SOUNDS
			}
	}
ends

include CODE/EVENT/EV_KILLIT.CON

defstate model_pitch
	// code by Dan
	geta[].xvel xvel
	geta[].zvel z2
	shiftr z2 4
	getangle temp2 xvel z2
	seta[].pitch temp2
ends

defstate model_owner_pitch
	// code by Dan
	geta[myowner].xvel xvel
	geta[myowner].zvel z2
	shiftr z2 4
	getangle temp2 xvel z2
	seta[].pitch temp2
ends

spritenopal 34489
spritenopal 34495

onevent EVENT_PREGAME
	switch sprite[].picnum
			// stop projectile flashing when player shooting
		case 34494 // dust motes
			seta[].blend 255
			cstator 2
			geta[].ypanning temp
			sub temp 1
			ifle temp 0 set temp 255
			seta[].ypanning temp
			break
		case 18422 // startube
			seta[].blend 255
				geta[].ypanning temp
				ifspritepal 2 sub temp 2 else
				ifspritepal 1 sub temp 3 else
				sub temp 4
				ifle temp 0 set temp 255
				seta[].ypanning temp
			geta[].xpanning temp
			ifspritepal 2 sub temp 1 else
			ifspritepal 1 sub temp 2 else
			sub temp 3
			ifle temp 0 set temp 255
			seta[].xpanning temp
			break
		case 34489 // waterfall
		case 34495 // waterfall
			seta[].blend 255
			geta[].ypanning temp
			ifspritepal 3 sub temp 2 else sub temp 4
			ifle temp 0 set temp 255
			seta[].ypanning temp

			break
		case EMBERS
			state LIGHT_FLICKER
			seta[].blend 255
			cstator 2
			geta[].ypanning temp add temp 2 ifge temp 255 set temp 0 seta[].ypanning temp
			geta[].xpanning temp add temp 1 ifge temp 255 set temp 0 seta[].xpanning temp
			geta[].ang temp2
			add temp2 2 ifge temp 2048 set temp2 0
			seta[].ang temp2
			break
		case 29296 // Tornado
			ifand sprite[].cstat 512 set temp3 16
			else ifand sprite[].cstat 2 set temp3 8
			else set temp3 4
			geta[].ypanning temp add temp temp3 ifge temp 255 set temp 0 seta[].ypanning temp
			geta[].xpanning temp add temp 1 ifge temp 255 set temp 0 seta[].xpanning temp
			geta[].ang temp2
			add temp2 temp3 ifge temp 2048 set temp2 0
			seta[].ang temp2
			break
		case FAKE_BULLET
			state model_pitch
			ifspawnedby APLAYER { ifpdistl 256 cstat 32768 else cstat 130 }
			else cstat 130
			break
		 case 22610
		 case 22536
		 case 27372
		 case 6204
		 case 29076
		   ifspawnedby APLAYER { ifpdistl HIDE_PARTICLE cstat 32768 else cstat 130 }
		   state littlerandtraj
		  break
		case SMALLSMOKE
			ifpdistgvar opt_particle_distance killit
			ifspawnedby 7047 seta[].blend 255 else seta[].blend 255
			seta[].blend 48
			break
		case 18360
			ifoutside seta[].pal sector[].ceilingpal else
			seta[].pal sector[].floorpal
			break
		case SPARK
		case SPARK2
			seta[].cstat 514
			seta[].blend 255
			break
		case 9395
		case 12902
		case 6544
		case 6633
		case 11179
		case 17782
			seta[].cstat 130
			seta[].blend 255
			break
		case 8435
			seta[].cstat 34
			seta[].blend 255
			break
		case 2284
			cstator 32
			break
		case WATERFALL_SPRITES
			seta[].blend 255
			geta[].owner myowner
			seta[].pal sprite[myowner].pal
			state model_pitch
			break
		case COOLEXPLOSION1
		case EXPLOSION2
		case FREEZEBLAST
		case SHRINKSPARK
		case ACID_BLAST
		case WATERBUBBLE
		case WATERBUBBLEMAKER
			cstator 2
			seta[].blend 255
			break
		case DUMMY_PLAYER
			ifand zvel_saved 1 seta[].z zpos_saved
			break
	endswitch
endevent

