defstate clear_precog
				set ps_cycloids 0
				set ps_demons 0
				set ps_zombies 0
				set ps_mercs 0
				set ps_cults 0
				set ps_misc 0
				set ps_shadow 0
				set ps_paradigm 0
				set ps_mj12 0
				set ps_egypt 0
				set ps_necro 0
				set ps_beyond 0
ends

defstate icon_pos
add ei_x 14
ifg ei_x 230 { set ei_x 97 add ei_y 14 }
ends

defstate mini_icon_bodya
ife ENEMY_IN_BST 1 { add ei_x 3 add ei_y 3 rotatespritea ei_x ei_y 6144 0 3059 10 0 0 -255 0 0 xdim ydim 
sub ei_x 3 sub ei_y 3 }
ends

defstate mini_icon_armour
ife ENEMY_IN_BST 1 { add ei_x 3 add ei_y 3 rotatespritea ei_x ei_y 6144 0 21101 10 0 0 -255 0 0 xdim ydim 
sub ei_x 3 sub ei_y 3 }
ends

defstate mini_icon_robot
ife ENEMY_IN_BST 1 { add ei_x 3 add ei_y 3 rotatespritea ei_x ei_y 6144 0 21102 10 0 0 -255 0 0 xdim ydim 
sub ei_x 3 sub ei_y 3 }
ends

