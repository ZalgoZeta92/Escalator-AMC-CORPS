defstate mini_icon_beyond
ife ENEMY_IN_BST 1 { add ei_x 3 add ei_y 3 rotatespritea ei_x ei_y 6144 0 21105 10 0 0 -255 0 0 xdim ydim
sub ei_x 3 sub ei_y 3 }
ends

defstate precog_enemies
set ei_x 83
set ei_y 35
ifn ps_cycloids 0
	{
	ifand ps_cycloids 1 // liztroop
		{
		state icon_pos
		set CHK_ENEMY_IN_BST_PICNUM LIZTROOP
		state isenemyinbestiary
		ife ENEMY_IN_BST 1 set ei_icon 2 else set ei_icon 0
		rotatesprite ei_x ei_y 12288 0 3288 0 ei_icon 0 0 0 xdim ydim 
		}
	ifand ps_cycloids 2 // pigcop
		{
		state icon_pos
		set CHK_ENEMY_IN_BST_PICNUM PIGCOP
