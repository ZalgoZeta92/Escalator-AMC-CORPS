	    add gui_pos_y_temp2 3
		set disp_temp3 MI_HIGHWIRE
		set disp_temp4 C_HIGHWIRE
		state CURSOR_OVER_ITEM
		state char_lo_button
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_SANG
		set disp_temp4 C_SANG
		state CURSOR_OVER_ITEM
		state char_lo_button
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_RUSTY
		set disp_temp4 C_RUSTY
		state CURSOR_OVER_ITEM
		state char_lo_button
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_GEOFFREY
		set disp_temp4 C_GEOFFREY
		state CURSOR_OVER_ITEM
		state char_lo_button
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_MIKKO
		set disp_temp4 C_MIKKO
		state CURSOR_OVER_ITEM
		state char_lo_button
	ife ep2_new_char 1
		{
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_MICKY
		set disp_temp4 C_MICKY
		state CURSOR_OVER_ITEM
		state char_lo_button
		}
	add gui_pos_x 13
	set gui_pos_y 26
	ife ep3_new_char 1
		{
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_SNOWFALL
		set disp_temp4 C_SNOWFALL
		state CURSOR_OVER_ITEM
		state char_lo_button
		}
	ife ep4_new_char 1
		{
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_KAGURA
		set disp_temp4 C_KAGURA
		state CURSOR_OVER_ITEM
		state char_lo_button
		}
	ife ep5_new_char 1
