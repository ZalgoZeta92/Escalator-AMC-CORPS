defstate LOADOUT_INTERFACE
myospal 160 100 3584 30 1024 4
	  add WHEEL_ROTATE 1
	  ifg WHEEL_ROTATE 2048 set WHEEL_ROTATE 0
	  rotatespritea 160 100 40734 WHEEL_ROTATE 12256 20 0 0 -255 0 0 xdim ydim // AMC LOGO
  rotatesprite 30 100 44960 0 13568 0 0 264 0 0 xdim ydim // Left bar
  rotatesprite 290 100 44960 0 13573 0 0 520 0 0 xdim ydim // Right bar
  ife INFO_SEL_2 0 rotatesprite 160 100 27262 0 13389 0 0 8 0 0 xdim ydim // Help
  else rotatesprite 160 100 27262 0 13388 0 0 8 0 0 xdim ydim
		// Help screen
		set gui_pos_x 20
		set gui_pos_y 15
		state CURSOR_OVER_ITEM
		ifl gui_pos_x_temp 10
		 ifg gui_pos_x_temp -10
			ifl gui_pos_y_temp 15
			 ifg gui_pos_y_temp -15
		   {
			ife INFO_SEL_2 0 rotatesprite gui_pos_x gui_pos_y 13800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 13800 0 13567 disp_pulse 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 12192 0 13562 disp_pulse 0 8 0 0 xdim ydim
			state handle_click
			 ife clicked 1
				{
				state SCROLL_POS_RESET
				rotatesprite 248 95 28262 0 13571 0 16 8 0 0 xdim ydim
				set INFO_SEL_3 0
				set INFO_SEL_2 0
				soundonce COMP_SELECT
				}
			}
			else
			{
			ife INFO_SEL_2 0 rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 11192 0 13562 0 0 8 0 0 xdim ydim
			}
		// Artifacts
		add gui_pos_x 20
		state CURSOR_OVER_ITEM
		ifl gui_pos_x_temp 10
		 ifg gui_pos_x_temp -10
			ifl gui_pos_y_temp 15
			 ifg gui_pos_y_temp -15
		   {
			ife INFO_SEL_2 1 rotatesprite gui_pos_x gui_pos_y 13800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 13800 0 13567 disp_pulse 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 12192 0 13564 disp_pulse 0 8 0 0 xdim ydim
			state handle_click
			 ife clicked 1
				{
				state SCROLL_POS_RESET
				rotatesprite 248 95 28262 0 13571 0 16 8 0 0 xdim ydim
				set INFO_SEL_3 0
				set INFO_SEL_2 1
				soundonce COMP_SELECT
				}
			}
		else
			{
			ife INFO_SEL_2 1 rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 11192 0 13564 0 0 8 0 0 xdim ydim
			}
		// Equipment
		add gui_pos_x 20
		state CURSOR_OVER_ITEM
		ifl gui_pos_x_temp 10
		 ifg gui_pos_x_temp -10
			ifl gui_pos_y_temp 15
			 ifg gui_pos_y_temp -15
		   {
			ife INFO_SEL_2 2 rotatesprite gui_pos_x gui_pos_y 13800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 13800 0 13567 disp_pulse 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 12192 0 13565 disp_pulse 0 8 0 0 xdim ydim
			state handle_click
			 ife clicked 1
				{
				state SCROLL_POS_RESET
				rotatesprite 248 95 28262 0 13571 0 16 8 0 0 xdim ydim
				set INFO_SEL_3 0
				set INFO_SEL_2 2
				soundonce COMP_SELECT
				}
			}
		else
			{
			ife INFO_SEL_2 2 rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 11192 0 13565 0 0 8 0 0 xdim ydim
			}
		// Weapons
		add gui_pos_x 20
		state CURSOR_OVER_ITEM
		ifl gui_pos_x_temp 10
		 ifg gui_pos_x_temp -10
			ifl gui_pos_y_temp 15
			 ifg gui_pos_y_temp -15
		   {
			ife INFO_SEL_2 3 rotatesprite gui_pos_x gui_pos_y 13800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 13800 0 13567 disp_pulse 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 12192 0 13566 disp_pulse 0 8 0 0 xdim ydim
			state handle_click
			 ife clicked 1
				{
				state SCROLL_POS_RESET
				rotatesprite 248 95 28262 0 13571 0 16 8 0 0 xdim ydim
				set INFO_SEL_3 0
				set INFO_SEL_2 3
				soundonce COMP_SELECT
				}
			}
		else
			{
			ife INFO_SEL_2 3 rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 11192 0 13566 0 0 8 0 0 xdim ydim
			}
		// Melee
		add gui_pos_x 20
		state CURSOR_OVER_ITEM
		ifl gui_pos_x_temp 10
		 ifg gui_pos_x_temp -10
			ifl gui_pos_y_temp 15
			 ifg gui_pos_y_temp -15
		   {
			ife INFO_SEL_2 4 rotatesprite gui_pos_x gui_pos_y 13800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 13800 0 13567 disp_pulse 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 12192 0 13563 disp_pulse 0 8 0 0 xdim ydim
			state handle_click
			 ife clicked 1
				{
				state SCROLL_POS_RESET
				rotatesprite 248 95 28262 0 13571 0 16 8 0 0 xdim ydim
				set INFO_SEL_3 0
				set INFO_SEL_2 4
				soundonce COMP_SELECT
				}
			}
		else
			{
			ife INFO_SEL_2 4 rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 11192 0 13563 0 0 8 0 0 xdim ydim
			}
		// Ammo
		add gui_pos_x 20
		state CURSOR_OVER_ITEM
		ifl gui_pos_x_temp 10
		 ifg gui_pos_x_temp -10
			ifl gui_pos_y_temp 15
			 ifg gui_pos_y_temp -15
		   {
			ife INFO_SEL_2 5 rotatesprite gui_pos_x gui_pos_y 13800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 13800 0 13567 disp_pulse 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 12192 0 13561 disp_pulse 0 8 0 0 xdim ydim
			state handle_click
			 ife clicked 1
				{
				state SCROLL_POS_RESET
				rotatesprite 248 95 28262 0 13571 0 16 8 0 0 xdim ydim
				set INFO_SEL_3 0
				set INFO_SEL_2 5
				soundonce COMP_SELECT
				}
			}
		else
			{
			ife INFO_SEL_2 5 rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 11192 0 13561 0 0 8 0 0 xdim ydim
			}
		// Special equipment
		add gui_pos_x 20
		state CURSOR_OVER_ITEM
		ifl gui_pos_x_temp 10
		 ifg gui_pos_x_temp -10
			ifl gui_pos_y_temp 15
			 ifg gui_pos_y_temp -15
		   {
			ife INFO_SEL_2 6 rotatesprite gui_pos_x gui_pos_y 13800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 13800 0 13567 disp_pulse 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 12192 0 13560 disp_pulse 0 8 0 0 xdim ydim
			state handle_click
			 ife clicked 1
				{
				state SCROLL_POS_RESET
				rotatesprite 248 95 28262 0 13571 0 16 8 0 0 xdim ydim
				set INFO_SEL_3 0
				set INFO_SEL_2 6
				soundonce COMP_SELECT
				}
			}
		else
			{
			ife INFO_SEL_2 6 rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite gui_pos_x gui_pos_y 12800 0 13567 0 0 8 0 0 xdim ydim
			rotatesprite gui_pos_x gui_pos_y 11192 0 13560 0 0 8 0 0 xdim ydim
			}
getinput[THISACTOR].bits disp_temp
shiftvarr disp_temp 8
andvar disp_temp 0xF
switch disp_temp
 case 10 ifn INFO_SEL_2 0 { soundonce COMP_SELECT set INFO_SEL_2 0 } break
 case 1 ifn INFO_SEL_2 1 { soundonce COMP_SELECT set INFO_SEL_2 1 } break
 case 2 ifn INFO_SEL_2 2 { soundonce COMP_SELECT set INFO_SEL_2 2 } break
 case 3 ifn INFO_SEL_2 3 { soundonce COMP_SELECT set INFO_SEL_2 3 } break
 case 4 ifn INFO_SEL_2 4 { soundonce COMP_SELECT set INFO_SEL_2 4 } break
 case 5 ifn INFO_SEL_2 5 { soundonce COMP_SELECT set INFO_SEL_2 5 } break
 case 6 ifn INFO_SEL_2 6 { soundonce COMP_SELECT set INFO_SEL_2 6 } break
endswitch

	set gui_pos_x 237
	set gui_pos_y 26
	state character_gui_icons

set tilenum 3587
ife INFO_SEL 0
	{
	ifand CHAR_APP 64 set tilenum 25565 else
	ifand CHAR_APP 1 set tilenum 25566 else
	set tilenum 3589
	}
ife INFO_SEL 1 set tilenum 3590
ife INFO_SEL 2
	{
	ifand CHAR_APP 4 set tilenum 25567 else
	set tilenum 3591
	}
ife INFO_SEL 3
	{
	ifand CHAR_APP 16 set tilenum 25568 else
	set tilenum 3593
	}
ife INFO_SEL 4
	{
	ifand CHAR_APP 2 set tilenum 23835 else
	set tilenum 3598
	}
ife INFO_SEL 5 set tilenum 3600
ife INFO_SEL 6 set tilenum 3603
ife INFO_SEL 7 set tilenum 3606
ife INFO_SEL 9 set tilenum 7768
ife INFO_SEL 10 set tilenum 5368
ife INFO_SEL 11 set tilenum 5488
ife INFO_SEL 12 set tilenum 5366
ife INFO_SEL 13
	{
	ifand CHAR_APP 128 set tilenum 18542
	else set tilenum 16600
	}
ife INFO_SEL 14 set tilenum 20984
ife INFO_SEL 16 set tilenum 34672
ife INFO_SEL 17 set tilenum 27262
ife INFO_SEL 18 set tilenum 35840
rotatesprite 289 34 38000 0 tilenum 0 0 8 0 0 xdim ydim
ife INFO_SEL_2 0
{
	rotatesprite 286 97 HALFSIZE 0 13562 0 0 8 0 0 xdim ydim
	// text contained in quotes.con
	screentext STARTALPHANUM 18 30 29500 0 0 3300 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
	screentext STARTALPHANUM 18 35 29500 0 0 3301 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
	screentext STARTALPHANUM 18 40 29500 0 0 3302 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
