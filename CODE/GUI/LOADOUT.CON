define LO_TXT 28674
var DP_PAL 0 0
var DP_SHADE 0 0
defstate gun_dam_type_disp
			ifand gun_damage_types 1 set gun_dam_temp 7 
			else ifand gun_damage_types 64 set gun_dam_temp 124 else set gun_dam_temp 0
			rotatespritea 107 170 16384 0 3059 0 gun_dam_temp 8 -255 0 0 xdim ydim // body armour
			ifand gun_damage_types 2 set gun_dam_temp 7 
			else ifand gun_damage_types 128 set gun_dam_temp 124 else set gun_dam_temp 0
			rotatespritea 127 170 16384 0 21101 0 gun_dam_temp 8 -255 0 0 xdim ydim // armour
			ifand gun_damage_types 4 set gun_dam_temp 7 
			else ifand gun_damage_types 256 set gun_dam_temp 124 else set gun_dam_temp 0
			rotatespritea 147 170 16384 0 21102 0 gun_dam_temp 8 -255 0 0 xdim ydim // robotic
			ifand gun_damage_types 8 set gun_dam_temp 7 
			else ifand gun_damage_types 512 set gun_dam_temp 124 else set gun_dam_temp 0
			rotatespritea 167 170 16384 0 21103 0 gun_dam_temp 8 -255 0 0 xdim ydim // supernatural
			ifand gun_damage_types 16 set gun_dam_temp 7 
			else ifand gun_damage_types 1024 set gun_dam_temp 124 else set gun_dam_temp 0
			rotatespritea 187 170 16384 0 21104 0 gun_dam_temp 8 -255 0 0 xdim ydim // chitin
			ifand gun_damage_types 32 set gun_dam_temp 7 
			else ifand gun_damage_types 2048 set gun_dam_temp 124 else set gun_dam_temp 0
			rotatespritea 207 170 16384 0 21105 0 gun_dam_temp 8 -255 0 0 xdim ydim // beyond
ends
// state for the character loadout buttons
defstate char_lo_button
		ifl gui_pos_x_temp 6
		 ifg gui_pos_x_temp -6
			ifl gui_pos_y_temp 6
			 ifg gui_pos_y_temp -6
			   {
			   set disp_temp5 gui_pos_x
			   add disp_temp5 1
				ife INFO_SEL disp_temp4 rotatesprite disp_temp5 gui_pos_y_temp2 9192 0 13567 disp_pulse 32 8 0 0 xdim ydim
				else rotatesprite disp_temp5 gui_pos_y_temp2 9192 0 13567 disp_pulse 0 8 0 0 xdim ydim
				sub disp_temp5 2
				rotatesprite disp_temp5 gui_pos_y HALFSIZE 0 disp_temp3 disp_pulse 0 8 0 0 xdim ydim
				state handle_click ife clicked 1
					{
					set INFO_SEL disp_temp4
					state SCROLL_POS_RESET
					rotatesprite 248 38 28262 0 13571 0 16 8 0 0 xdim ydim
					soundonce COMP_SELECT
					}
				}
			else
			{
			set disp_temp5 gui_pos_x
			add disp_temp5 1
			ife INFO_SEL disp_temp4 rotatesprite disp_temp5 gui_pos_y_temp2 8192 0 13567 0 32 8 0 0 xdim ydim
			else rotatesprite disp_temp5 gui_pos_y_temp2 8192 0 13567 0 0 8 0 0 xdim ydim
			sub disp_temp5 2
			rotatesprite disp_temp5 gui_pos_y HALFSIZE 0 disp_temp3 0 0 8 0 0 xdim ydim
			}
ends

