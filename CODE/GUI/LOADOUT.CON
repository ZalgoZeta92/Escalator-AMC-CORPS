		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_WHEATON
		set disp_temp4 C_WHEATON
		state CURSOR_OVER_ITEM
		state char_lo_button
		}
	ifand allow_temp_characters 8
		{
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_JANE
		set disp_temp4 C_JANE
		state CURSOR_OVER_ITEM
		state char_lo_button
		}
	ifand allow_temp_characters 2
		{
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_BOMBSHELL
		set disp_temp4 C_BOMBSHELL
		state CURSOR_OVER_ITEM
		state char_lo_button
		}
	ifand allow_temp_characters 4
		{
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_MAARTEN
		set disp_temp4 C_MAARTEN
		state CURSOR_OVER_ITEM
		state char_lo_button
		}
	ifand allow_temp_characters 16
		{
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_ROSA
		set disp_temp4 C_ROSA
		state CURSOR_OVER_ITEM
		state char_lo_button
		}
	ifand allow_temp_characters 1
		{
		add gui_pos_y 12
		set gui_pos_y_temp2 gui_pos_y
	    add gui_pos_y_temp2 3
		set disp_temp3 MI_CULTIST
		set disp_temp4 C_CULTIST
		state CURSOR_OVER_ITEM
		state char_lo_button
		}
ends

defstate ARTIFACT_OWNER_PIC
	set tilenum 3587
	ife ARTIFACTS_LOADOUT[0] disp_temp2 set tilenum 3589
	ife ARTIFACTS_LOADOUT[1] disp_temp2 set tilenum 3590
	ife ARTIFACTS_LOADOUT[2] disp_temp2
		{
		ifand CHAR_APP 4 set tilenum 25567 else set tilenum 3591
		}
	ife ARTIFACTS_LOADOUT[3] disp_temp2
		{
		ifand CHAR_APP 16 set tilenum 25568 else set tilenum 3593
		}
	ife ARTIFACTS_LOADOUT[4] disp_temp2
		{
		ifand CHAR_APP 2 set tilenum 23835 else set tilenum 3598
		}
	ife ARTIFACTS_LOADOUT[5] disp_temp2 set tilenum 3600
	ife ARTIFACTS_LOADOUT[6] disp_temp2 set tilenum 3603
	ife ARTIFACTS_LOADOUT[7] disp_temp2 set tilenum 3606
	ife ARTIFACTS_LOADOUT[9] disp_temp2 set tilenum 7768
	ife ARTIFACTS_LOADOUT[10] disp_temp2 set tilenum 5368
	ife ARTIFACTS_LOADOUT[11] disp_temp2 set tilenum 5488
	ife ARTIFACTS_LOADOUT[12] disp_temp2 set tilenum 5366
	ife ARTIFACTS_LOADOUT[13] disp_temp2 set tilenum 16600
	ife ARTIFACTS_LOADOUT[14] disp_temp2 set tilenum 20984
	ife ARTIFACTS_LOADOUT[16] disp_temp2 set tilenum 34672
	ife ARTIFACTS_LOADOUT[17] disp_temp2 set tilenum 27262
	ife ARTIFACTS_LOADOUT[18] disp_temp2 set tilenum 35840
	rotatesprite 160 150 38000 0 tilenum 0 0 8 0 0 xdim ydim
ends

