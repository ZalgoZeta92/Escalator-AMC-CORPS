defstate FORGE_BUY
ifn TIMEZONE 5
{
ife POLYMERS 0 sound FG_ZERO else ifrnd 32 sound FG_BUY1 else ifrnd 32 sound FG_BUY2 else ifrnd 32 sound FG_BUY3 
else ifrnd 32 sound FG_BUY4 else ifrnd 32 sound FG_BUY5 else ifrnd 32 sound FG_BUY6 else ifrnd 32 sound FG_BUY7
}
ends

defstate FORGE_CANT
soundonce COMP_INVALID
ifn TIMEZONE 5 { ifrnd 48 sound FG_NCASH1 else sound FG_NCASH2 }
ends

include CODE/GUI/EQUIP_SHOP.CON

