set gui_pos_y 95
state CURSOR_OVER_ITEM
 ifn MISSIONSCREEN 0
	ifl gui_pos_x_temp 25
	 ifg gui_pos_x_temp -25
		ifl gui_pos_y_temp 6
		 ifg gui_pos_y_temp -6
			{
			rotatespritea 56 132 34734 0 3261 disp_pulse 21 0 -255 0 0 xdim ydim
			ifand BITS_PRESS 4
				{
				sound PDU_MOVE
				set MISSIONSCREEN 0
				}
			}

