				ifg gui_pos_y_temp -10
				{
				set mouse_hint 3023 // refers to quote in user.con
				sub mouse_hint_timer 2
				}

			}

		add gui_pos_x 31
		ife GOT_FLIPPER 1
			{
			rotatesprite gui_pos_x gui_pos_y HALFSIZE 0 FLIPPER 0 0 0 0 0 xdim ydim

			state CURSOR_OVER_ITEM
