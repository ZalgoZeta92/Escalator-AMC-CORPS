			rotatesprite gui_pos_x gui_pos_y 40768 0 GASMASK 0 0 0 0 0 xdim ydim

			state CURSOR_OVER_ITEM
			ifl gui_pos_x_temp 10
			 ifg gui_pos_x_temp -10
