Feel free to use any code in the game for your own uses; just make
sure to mention the authors and/or "The AMC Squad" in your credits.
--------------------------------------------------------------------------------
NOTES:
Weapon shop keeper
Gun name text is coloured coded!
Blue = default 
Gold = Gold unlock
White = Nelson license only
Green = Matvei license only 
Purple = Faithful license only
Brown = Vreteol license only 
Grey-Brown = Ad/misc
--------------------------------------------------------------------------------
*/

defstate WEAPON_SHOP_INTERFACE
rotatesprite 162 103 43690 0 13539 0 0 8 0 0 xdim ydim

		qputs 409 Budget: %ld
		qsprintf 409 409 AMC_BUDGET
		screentext 2822 240 17 28672 0 0 409 0 1 16 0 5 8 TX_GP 1 0 0 0 xdim ydim

ife INFO_SEL 0 // James
	{
	rotatesprite 206 60 43690 0 3589 20 27 8 0 0 xdim ydim
	set gui_pos_x 35
	set gui_pos_y 45
	state CURSOR_OVER_ITEM
	qputs 409 FN-57 Pistol
	set item_num 2
	ife NEW_IN_STORE[item_num] 0 myospal 81 gui_pos_y 14606 0 0 0
	screentext 2822 gui_pos_x gui_pos_y 28672 0 0 409 0 1 16 0 5 8 TX_GP 1 0 0 0 xdim ydim

	ifl gui_pos_x_temp 10
	 ifg gui_pos_x_temp -50
	  ifl gui_pos_y_temp 5
	   ifg gui_pos_y_temp -5
		{
		ife NEW_IN_STORE[item_num] 0
			{
			setarray NEW_IN_STORE[item_num] 1
			sound COMP_SELECT writearraytofile NEW_IN_STORE F_SHOP_NEW_AMCTC
			}
		screentext 2822 gui_pos_x gui_pos_y 28672 0 0 409 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim

		state handle_click ife clicked 1
			{
				ifg SPECIALIST_EQUIPMENT[item_num] 0 soundonce COMP_INVALID
				else
				ifl AMC_BUDGET 15 soundonce COMP_INVALID
				else
					{
					sub AMC_BUDGET 15
					savegamevar AMC_BUDGET
					setarray SPECIALIST_EQUIPMENT[item_num] 1
					writearraytofile SPECIALIST_EQUIPMENT F_SPECIAL_LOADOUT_AMCTC
					sound CASHREG
					}
			}

		ifg SPECIALIST_EQUIPMENT[item_num] 0 qstrcpy 409 3080
		else qputs 409 Cost: 15
		screentext 2822 163 95 28672 0 0 409 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		rotatesprite 210 64 18000 0 10391 0 0 8 0 0 xdim ydim

		qputs 409 A pistol with armour-piercing rounds;
		screentext 2822 163 123 28672 0 0 409 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		qputs 409 it has a 20-round magazine and comes
		screentext 2822 163 129 28672 0 0 409 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		qputs 409 with a laser-sight, activated with
		screentext 2822 163 135 28672 0 0 409 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		qputs 409 alt-fire.
		screentext 2822 163 141 28672 0 0 409 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		}

	add gui_pos_y 10
	state CURSOR_OVER_ITEM
	qputs 409 MP5
	set item_num 8
	ife NEW_IN_STORE[item_num] 0 myospal 81 gui_pos_y 14606 0 0 0
	screentext 2822 gui_pos_x gui_pos_y 28672 0 0 409 0 1 16 0 5 8 TX_GP 1 0 0 0 xdim ydim

	ifl gui_pos_x_temp 10
	 ifg gui_pos_x_temp -50
	  ifl gui_pos_y_temp 5
	   ifg gui_pos_y_temp -5
		{
		ife NEW_IN_STORE[item_num] 0
			{
			setarray NEW_IN_STORE[item_num] 1
			sound COMP_SELECT writearraytofile NEW_IN_STORE F_SHOP_NEW_AMCTC
