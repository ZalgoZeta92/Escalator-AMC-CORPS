		screentext 2822 gui_pos_x gui_pos_y 28672 0 0 409 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim

		ifg SPECIALIST_EQUIPMENT[item_num] 0 qstrcpy 409 3080
