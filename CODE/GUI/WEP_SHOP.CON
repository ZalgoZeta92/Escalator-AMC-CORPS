					ifg SPECIALIST_EQUIPMENT[item_num] 0 soundonce COMP_INVALID
					else
					ifl AMC_BUDGET 20 soundonce COMP_INVALID
					else
						{
						sub AMC_BUDGET 20
						savegamevar AMC_BUDGET
						setarray SPECIALIST_EQUIPMENT[item_num] 1
						writearraytofile SPECIALIST_EQUIPMENT F_SPECIAL_LOADOUT_AMCTC
						sound CASHREG
						break
						}
					} // End of James slot 2 bracket

		qputs 409 A suppressed submachine gun that
		screentext 2822 163 123 28672 0 0 409 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		qputs 409 uses subsonic rounds; meaning it
		screentext 2822 163 129 28672 0 0 409 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
