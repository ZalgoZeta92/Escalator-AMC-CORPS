						}
							myospalx 160 50 FLECHETE_SHELLS 0 0 0 // Display the sprite
							qputs 1011 Flechette shotgun shells; fires a
							screentext STARTALPHANUM 95 80 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
