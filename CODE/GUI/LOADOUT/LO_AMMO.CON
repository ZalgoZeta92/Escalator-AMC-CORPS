defstate DISP_ammo_loadout
		ife AMMO_LOADOUT[INFO_SEL] 1 myospalx disp_temp7 disp_temp8 EXPL_SHELLS 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 2 myospalx disp_temp7 disp_temp8 FLECHETE_SHELLS 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 3 myospalx disp_temp7 disp_temp8 SILVERAMMO_DRUM 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 4 myospalx disp_temp7 disp_temp8 TESLA_AMMO_SPRITE 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 5 myospalx disp_temp7 disp_temp8 SILVER_CROSSBOW_BOLTS 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 6 myospalx disp_temp7 disp_temp8 MICRO_TORPEDO_PACK 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 7 myospalx disp_temp7 disp_temp8 MAGNUM_SHELLS 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 8 myospalx disp_temp7 disp_temp8 HEAT_SEEK_CARD_PICKUP 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 9 myospalx disp_temp7 disp_temp8 ATOMIC_BOMB_PICKUP 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 10 myospalx disp_temp7 disp_temp8 DUP_MISSILES_PICKUP 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 11 myospalx disp_temp7 disp_temp8 FORTYMM_NADES 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 12 myospalx disp_temp7 disp_temp8 FORTYMM_CASELESS 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 13 myospalx disp_temp7 disp_temp8 5462 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 14 myospalx disp_temp7 disp_temp8 5463 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 15 myospalx disp_temp7 disp_temp8 5476 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 16 myospalx disp_temp7 disp_temp8 FORTYMM_SLUGS 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 19 myospalx disp_temp7 disp_temp8 6542 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 20 myospalx disp_temp7 disp_temp8 DRAGONS_SHELLS 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 21 myospalx disp_temp7 disp_temp8 FORTYMM_ELECTRO 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 22 myospalx disp_temp7 disp_temp8 FORTYMM_CRYO 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 23 myospalx disp_temp7 disp_temp8 INCEND_AMMO_DRUM 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 24 myospalx disp_temp7 disp_temp8 BLUE_MANA_PICKUP 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 25 myospalx disp_temp7 disp_temp8 GREEN_MANA_PICKUP 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 26 myospalx disp_temp7 disp_temp8 ORANGE_MANA_PICKUP 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 27 myospalx disp_temp7 disp_temp8 PURPLE_MANA_PICKUP 0 0 0 // Display the picture 1
		ife AMMO_LOADOUT[INFO_SEL] 28 myospalx disp_temp7 disp_temp8 SILVERBALL_SHELLS 0 0 0 // Display the picture 1
ends

defstate loadout_ammo_tab
screentext STARTALPHANUM 12 190 29500 0 0 3035 0 32 16 0 5 8 TX_GP 1 0 0 0 xdim ydim // instructions
rotatesprite 286 97 HALFSIZE 0 13561 0 0 8 0 0 xdim ydim
		set disp_temp7 289
		set disp_temp8 146
		state DISP_ammo_loadout
set SCROLL_POS_MAX 30
state SCROLL_WHEEL
	set gui_pos_x 12
	set gui_pos_y 40
	state SCROLL_POS
	state CURSOR_OVER_ITEM
	ifg gui_pos_y 39 ifl gui_pos_y 187
		{
		qputs 1011 Unequip ammo
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 0 125 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
			ifle gui_pos_y_temp 3
			 ifge gui_pos_y_temp 0
				{
				screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim // highlight the text
				state handle_click ife clicked 1
					{
					soundonce SPECIAL_AMMO
					setarray AMMO_LOADOUT[INFO_SEL] 0
					setarray AMMO_LOADOUT_COST[INFO_SEL] 0
					}
				}
		}
		ife EQUIPMENT_RESEARCH[1] 2
		{
		add gui_pos_y 7
		state CURSOR_OVER_ITEM
		ifg gui_pos_y 39 ifl gui_pos_y 187
			{
			qputs 1011 Expl. SG Shells
			rotatesprite 12 gui_pos_y INVENSIZE 0 14794 0 13 0 0 0 xdim ydim // Icon
			ife AMMO_LOADOUT[INFO_SEL] 1 set disp_temp4 32 else set disp_temp4 0
			set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 0 disp_temp4 16 0 5 8 TX_GP 1 0 0 0 xdim ydim // display what it is
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
			ifle gui_pos_y_temp 3
			 ifge gui_pos_y_temp 0
					{
					screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim // highlight the text
					state handle_click ife clicked 1
						{
						soundonce SPECIAL_AMMO
						setarray AMMO_LOADOUT[INFO_SEL] 1
						setarray AMMO_LOADOUT_COST[INFO_SEL] 750
						}
							myospalx 160 50 EXPL_SHELLS 0 0 0 // Display the sprite
							qputs 1011 Explosive shotgun shells; fires a
							screentext STARTALPHANUM 95 80 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
							qputs 1011 burst of exploding projectiles. Can
							screentext STARTALPHANUM 95 86 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
							qputs 1011 fit in most standard pump-action
							screentext STARTALPHANUM 95 92 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
							qputs 1011 shotguns.
							screentext STARTALPHANUM 95 98 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
							qputs 1011 Loadout Cost: 0.75
							screentext STARTALPHANUM 95 104 28672 0 0 1011 0 124 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
							set gun_damage_types GDT_RIFLE
							state gun_dam_type_disp
					}
			}
		}
		ife EQUIPMENT_RESEARCH[2] 2
		{
		add gui_pos_y 7
		state CURSOR_OVER_ITEM
		ifg gui_pos_y 39 ifl gui_pos_y 187
			{
			// Flech. SG Shells
			rotatesprite 12 gui_pos_y INVENSIZE 0 14794 0 11 0 0 0 xdim ydim // Icon
			ife AMMO_LOADOUT[INFO_SEL] 2 set disp_temp4 32 else set disp_temp4 0
			set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 267 0 disp_temp4 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
