defstate DISP_equipment_loadout
	ife EQUIPMENT_LOADOUT[INFO_SEL] 2 // First aid kit
		{
		set DP_SHADE 0
		set DP_PAL 0
		state def_faid_pic
		}
	ife EQUIPMENT_LOADOUT[INFO_SEL] 3 rotatesprite disp_temp7 disp_temp8 14000 0 22750 0 0 0 0 0 xdim ydim // riot shield
	ife EQUIPMENT_LOADOUT[INFO_SEL] 4 rotatesprite disp_temp7 disp_temp8 18000 0 4976 0 0 0 0 0 xdim ydim // Merlijn's shield
	ife EQUIPMENT_LOADOUT[INFO_SEL] 5 rotatesprite disp_temp7 disp_temp8 18000 0 5511 0 0 0 0 0 xdim ydim // Zaxtor's hologram
	ife EQUIPMENT_LOADOUT[INFO_SEL] 6 rotatesprite disp_temp7 disp_temp8 24000 0 6003 0 0 0 0 0 xdim ydim // Highwire's radio
	ife EQUIPMENT_LOADOUT[INFO_SEL] 7 rotatesprite disp_temp7 disp_temp8 24000 0 6373 0 0 0 0 0 xdim ydim // Sang's mirror orb
	ife EQUIPMENT_LOADOUT[INFO_SEL] 8 rotatesprite disp_temp7 disp_temp8 24000 0 7091 0 0 0 0 0 xdim ydim // Mikko's backpack
	ife EQUIPMENT_LOADOUT[INFO_SEL] 9 // Micky's turret
		{
		ife PERSONNEL_RESEARCH[2] 2 set disp_temp9 16 else set disp_temp9 0
		ife PERSONNEL_RESEARCH[3] 2 rotatesprite disp_temp7 disp_temp8 24000 0 16551 0 disp_temp9 0 0 0 xdim ydim
		else rotatesprite disp_temp7 disp_temp8 24000 0 16552 0 disp_temp9 0 0 0 xdim ydim
		}
	ife EQUIPMENT_LOADOUT[INFO_SEL] 10 rotatesprite disp_temp7 disp_temp8 24000 0 20982 0 0 0 0 0 xdim ydim // Snowfall's Vajra device
	ife EQUIPMENT_LOADOUT[INFO_SEL] 11 rotatesprite disp_temp7 disp_temp8 24000 0 12926 0 0 0 0 0 xdim ydim // Jane's Arm Blade
	ife EQUIPMENT_LOADOUT[INFO_SEL] 12 rotatesprite disp_temp7 disp_temp8 INVENSIZE 0 12006 0 0 0 0 0 xdim ydim // Maarten's Book of Conjuration
	ife EQUIPMENT_LOADOUT[INFO_SEL] 13 rotatesprite disp_temp7 disp_temp8 24000 0 31199 0 0 0 0 0 xdim ydim // Bombshell's turret
	ife EQUIPMENT_LOADOUT[INFO_SEL] 14 rotatesprite disp_temp7 disp_temp8 24000 0 36074 0 0 0 0 0 xdim ydim // Wheaton's radio
	ife EQUIPMENT_LOADOUT[INFO_SEL] 15 rotatesprite disp_temp7 disp_temp8 24000 0 32472 0 0 0 0 0 xdim ydim // Rosa's vampiric bats
	ife EQUIPMENT_LOADOUT[INFO_SEL] 16 rotatesprite disp_temp7 disp_temp8 24000 0 27383 0 0 0 0 0 xdim ydim // Kagura's ninja potion
ends


defstate DISP_melee_loadout
		ife CHAR 0 ifand JAMES_UPGRADE 32768 set disp_temp9 29793
		else ife CHAR 1 ifand ZAXTOR_UPGRADE 32768 set disp_temp9 29795
		else ife CHAR 2 ifand MERLIJN_UPGRADE 32768 set disp_temp9 29797
		else ife CHAR 3 ifand HIGHWIRE_UPGRADE 32768 set disp_temp9 29799
		else ife CHAR 4 ifand SANG_UPGRADE 32768 set disp_temp9 29801
		else ife CHAR 5 ifand RUSTY_UPGRADE 32768 set disp_temp9 29803
		else ife CHAR 6 ifand GEOFFREY_UPGRADE 32768 set disp_temp9 29805
		else ife CHAR 7 ifand MIKKO_UPGRADE 32768 set disp_temp9 29807
		else ife CHAR 13 ifand MICKY_UPGRADE 32768 set disp_temp9 29809
		else ife CHAR 14 ifand SNOWFALL_UPGRADE 32768 set disp_temp9 29811
		else ife CHAR 17 ifand KAGURA_UPGRADE 32768 set disp_temp9 29813
		else set disp_temp9 13558
		ife MELEE_WEAPON_LOADOUT[INFO_SEL] 1 rotatesprite disp_temp7 disp_temp8 20000 0 disp_temp9 0 0 0 0 0 xdim ydim // Display the picture 1
		ife MELEE_WEAPON_LOADOUT[INFO_SEL] 2 rotatesprite disp_temp7 disp_temp8 20000 0 13556 0 0 0 0 0 xdim ydim  // Display the picture 1
		ife MELEE_WEAPON_LOADOUT[INFO_SEL] 3 rotatesprite disp_temp7 disp_temp8 20000 256 12233 0 0 0 0 0 xdim ydim
		ife MELEE_WEAPON_LOADOUT[INFO_SEL] 4 rotatesprite disp_temp7 disp_temp8 20000 256 11118 0 0 0 0 0 xdim ydim
ends


defstate loadout_equipment_tab
screentext STARTALPHANUM 12 190 29500 0 0 3035 0 32 16 0 5 8 TX_GP 1 0 0 0 xdim ydim // instructions
rotatesprite 286 97 HALFSIZE 0 13565 0 0 8 0 0 xdim ydim
set SCROLL_POS_MAX 30
state SCROLL_WHEEL
rotatespritea 108 108 HALFSIZE 0 3055 23 0 0 -255 0 0 xdim ydim
set disp_temp7 108
set disp_temp8 108
state DISP_equipment_loadout
rotatespritea 158 173 HALFSIZE 0 3056 23 0 0 -255 0 0 xdim ydim
set disp_temp7 158
set disp_temp8 173
state DISP_boot_loadout
rotatespritea 158 146 HALFSIZE 0 3057 23 0 0 -255 0 0 xdim ydim
set disp_temp7 158
set disp_temp8 146
state DISP_belt_loadout
rotatespritea 158 122 HALFSIZE 0 3059 23 0 0 -255 0 0 xdim ydim
set disp_temp7 158
set disp_temp8 122
state DISP_chest_loadout
rotatespritea 158 90 HALFSIZE 0 3058 23 0 0 -255 0 0 xdim ydim
set disp_temp7 158
set disp_temp8 90
state DISP_helmet_loadout
	set gui_pos_x 12
	set gui_pos_y 40
	state SCROLL_POS
	state CURSOR_OVER_ITEM
	ifg gui_pos_y 39 ifl gui_pos_y 187
	{
		qputs 1011 Unequip all
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 0 125 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
			ifle gui_pos_y_temp 3
			 ifge gui_pos_y_temp 0
				{
				set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				state handle_click ife clicked 1
					{
					soundonce COMP_SELECT
					setarray EQUIPMENT_LOADOUT[INFO_SEL] 0
					setarray EQUIPMENT_LOADOUT_COST[INFO_SEL] 0
					setarray CHEST_LOADOUT[INFO_SEL] 0
					setarray CHEST_LOADOUT_COST[INFO_SEL] 0
					setarray BELT_LOADOUT[INFO_SEL] 0
					setarray BELT_LOADOUT_COST[INFO_SEL] 0
					setarray HELMET_LOADOUT[INFO_SEL] 0
					setarray HELMET_LOADOUT_COST[INFO_SEL] 0
					setarray BOOTS_LOADOUT[INFO_SEL] 0
					setarray BOOT_LOADOUT_COST[INFO_SEL] 0
					}
				}
		}
		add gui_pos_y 7
		state CURSOR_OVER_ITEM
		ifg gui_pos_y 39 ifl gui_pos_y 187
		{
		qputs 1011 Chest slot
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 0 125 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		state CURSOR_OVER_ITEM
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
			ifle gui_pos_y_temp 3
			 ifge gui_pos_y_temp 0
				{
				set INFO_SEL_3 400
				set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 disp_pulse 8 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				state handle_click ife clicked 1
					{
					soundonce PUT_ON_EQUIP
					setarray CHEST_LOADOUT[INFO_SEL] 0
					setarray CHEST_LOADOUT_COST[INFO_SEL] 0
					}
				}
		}
		ife INFO_SEL_3 400
			{
			qputs 1011 Chest equipment; generally for
			screentext STARTALPHANUM 95 40 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
			qputs 1011 protective gear.
			screentext STARTALPHANUM 95 46 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
			}
		add gui_pos_y 7
		state CURSOR_OVER_ITEM
		ifg gui_pos_y 39 ifl gui_pos_y 187
		{
		rotatesprite 12 gui_pos_y INVENSIZE 0 14795 0 12 0 0 0 xdim ydim // Icon
		qputs 1011 -Body Armour
		ife CHEST_LOADOUT[INFO_SEL] 1 set disp_temp4 32 else set disp_temp4 126
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 0 disp_temp4 16 0 5 8 TX_GP 1 0 0 0 xdim ydim // display what it is
		state CURSOR_OVER_ITEM
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
			ifle gui_pos_y_temp 3
			 ifge gui_pos_y_temp 0
				{
				set INFO_SEL_3 401
				screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim // highlight the text
				state handle_click ife clicked 1
					{
					soundonce PUT_ON_EQUIP
					setarray CHEST_LOADOUT[INFO_SEL] 1
					setarray CHEST_LOADOUT_COST[INFO_SEL] 1500
					}
				}
		}
		// 36 char limit per line
		ife INFO_SEL_3 401
			{
			set disp_temp7 158
			set disp_temp8 122
			set DP_SHADE disp_pulse
			set DP_PAL 67
			state def_arm_pic
			switch INFO_SEL
			case 0
			case 7
				qputs 1011 This powered combat vest offers
				screentext STARTALPHANUM 95 40 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				qputs 1011 a fusion of ballistic protection with
				screentext STARTALPHANUM 95 46 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				qputs 1011 the perks of being able to recharge
				screentext STARTALPHANUM 95 52 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				qputs 1011 it as well. It offers a damage
				screentext STARTALPHANUM 95 58 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				qputs 1011 reduction of 66%.
				screentext STARTALPHANUM 95 65 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				qputs 1011 Loadout cost: 1.5
				screentext STARTALPHANUM 95 71 28672 0 0 1011 0 124 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				ife PERSONNEL_RESEARCH[4] 2
					{
					qputs 1011 -Armour Strength upgrade
					screentext STARTALPHANUM 95 77 28672 0 0 1011 0 125 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
					}
				ife PERSONNEL_RESEARCH[16] 2
					{
					qputs 1011 -Ablative Plating upgrade
					screentext STARTALPHANUM 95 83 28672 0 0 1011 0 125 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
					}
				break
			case 1
				qputs 1011 Zaxtor's lightweight armoured vest;
				screentext STARTALPHANUM 95 40 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				qputs 1011 it will absorb a third of any kind of
				screentext STARTALPHANUM 95 46 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				qputs 1011 damage received; it also has
				screentext STARTALPHANUM 95 52 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
