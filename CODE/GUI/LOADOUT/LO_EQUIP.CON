defstate DISP_helmet_loadout
	ife HELMET_LOADOUT[INFO_SEL] 1 // ballistic
		{
		rotatesprite disp_temp7 disp_temp8 HALFSIZE 0 22758 0 0 0 0 0 xdim ydim
		}
	ife HELMET_LOADOUT[INFO_SEL] 2 // Heat
		{
		set DP_SHADE 0
		set DP_PAL 0
		state def_heat_pic
		}
	ife HELMET_LOADOUT[INFO_SEL] 3 // Night
		{
		set DP_SHADE 0
		set DP_PAL 0
		state def_night_pic
		}
	ife HELMET_LOADOUT[INFO_SEL] 4 // ghost goggles
		{
		rotatesprite disp_temp7 disp_temp8 HALFSIZE 0 GHOST_GOGGLES 0 0 0 0 0 xdim ydim
		}
	ife HELMET_LOADOUT[INFO_SEL] 6 // Bandana?
		{
		rotatesprite disp_temp7 disp_temp8 HALFSIZE 0 6562 0 0 0 0 0 xdim ydim
		}
ends
