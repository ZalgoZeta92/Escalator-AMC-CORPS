			{
			set DP_PAL 0
			set DP_SHADE 0
			state def_arm_pic
			}
		ife CHEST_LOADOUT[INFO_SEL] 4 myospalx disp_temp7 disp_temp8 117 0 0 0 // Spirit protection vest
