					{
					ife SPECIALIST_EQUIPMENT[161] 2 setarray SPECIALIST_EQUIPMENT[161] 1 // turn the MAG AKM 'off' if they have it
					ife SPECIALIST_EQUIPMENT[7] 2 setarray SPECIALIST_EQUIPMENT[7] 1 // turn the M16A2 'off' if they have it
