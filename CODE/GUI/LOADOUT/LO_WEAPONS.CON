ends

defstate loadout_weapons_tab
{
screentext STARTALPHANUM 12 190 29500 0 0 3035 0 32 16 0 5 8 TX_GP 1 0 0 0 xdim ydim // instructions
rotatesprite 286 97 HALFSIZE 0 13566 0 0 8 0 0 xdim ydim
set SCROLL_POS_MAX 40
state SCROLL_WHEEL
		set disp_temp7 289
		set disp_temp8 146
		state disp_temp_weapon_loadout
	set gui_pos_x 12
	set gui_pos_y 40
	state SCROLL_POS
	state CURSOR_OVER_ITEM
	ifg gui_pos_y 39 ifl gui_pos_y 187
		{
		qputs 1011 Unequip weapon
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 0 125 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
			ifle gui_pos_y_temp 3
			 ifge gui_pos_y_temp 0
				{
				set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				state handle_click ife clicked 1
					{
					setarray temp_WEAPON_LOADOUT[INFO_SEL] 0
					setarray temp_WEAPON_LOADOUT_COST[INFO_SEL] 0
					}
				}
		}
// ================================================================================================================================
	add gui_pos_y 7
	ifg gui_pos_y 39 ifl gui_pos_y 187 
	{
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 440 0 50 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
	}
ife WEAPONS_FOUND[26] 1
	{
	add gui_pos_y 7
	state CURSOR_OVER_ITEM
	ifg gui_pos_y 39 ifl gui_pos_y 187
		{
		// AK-103+GP-30
		rotatesprite gui_pos_x gui_pos_y INVENSIZE 0 14843 0 0 0 0 0 xdim ydim // Icon
		state CURSOR_OVER_ITEM
		ife temp_WEAPON_LOADOUT[INFO_SEL] 26 set disp_temp4 32 else set disp_temp4 0
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 271 0 disp_temp4 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
			ifle gui_pos_y_temp 3
			 ifge gui_pos_y_temp 0
				{
				set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 271 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				state handle_click ife clicked 1
					{
					soundonce SELECT_HT_BIGGUN
					setarray temp_WEAPON_LOADOUT[INFO_SEL] 26
					setarray temp_WEAPON_LOADOUT_COST[INFO_SEL] 750
					}
						myospalx 160 50 AK114SPRITE 0 0 0 // Display the sprite
						qputs 1011 A modern assault rifle; comes
						screentext STARTALPHANUM 95 80 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 equipped with not only a HoloSight,
						screentext STARTALPHANUM 95 86 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 but also a GP-30 launcher that can
						screentext STARTALPHANUM 95 92 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 fire caseless sgrenades.
						screentext STARTALPHANUM 95 98 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 Loadout Cost: 0.75
						screentext STARTALPHANUM 95 104 28672 0 0 1011 0 124 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 Alt-Fire: Toggle holosight
						screentext STARTALPHANUM 95 110 28672 0 0 1011 0 32 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						set gun_damage_types GDT_RIFLE
						state gun_dam_type_disp
				}
		}
	}
ife WEAPONS_RESEARCH[5] 2 // Has the player researched the flamethrower?
	{
	add gui_pos_y 7
	state CURSOR_OVER_ITEM
	ifg gui_pos_y 39 ifl gui_pos_y 187
		{
		// Flamethrower
		rotatesprite gui_pos_x gui_pos_y INVENSIZE 0 14841 0 0 0 0 0 xdim ydim // Icon
		state CURSOR_OVER_ITEM
		ife temp_WEAPON_LOADOUT[INFO_SEL] 18 set disp_temp4 32 else set disp_temp4 0
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 242 0 disp_temp4 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
			ifle gui_pos_y_temp 3
			 ifge gui_pos_y_temp 0
				{
				set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 242 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				state handle_click ife clicked 1
					{
					soundonce SELECT_HT_BIGGUN
					setarray temp_WEAPON_LOADOUT[INFO_SEL] 18
					setarray temp_WEAPON_LOADOUT_COST[INFO_SEL] 750
					}
						myospalx 160 50 FLAMETHROWERSPRITE 0 0 0 // Display the sprite
						qputs 1011 Good against crowds of targets,
						screentext STARTALPHANUM 95 80 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 although the moral implications of
						screentext STARTALPHANUM 95 86 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 using such a weapon are best left
						screentext STARTALPHANUM 95 92 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 unsaid. The flame will also deal 
						screentext STARTALPHANUM 95 98 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 damage over time.
						screentext STARTALPHANUM 95 104 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 Loadout Cost: 0.75
						screentext STARTALPHANUM 95 110 28672 0 0 1011 0 124 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						set gun_damage_types 2960
						state gun_dam_type_disp
				}
		}
	}
