		rotatesprite gui_pos_x gui_pos_y INVENSIZE 0 14845 0 0 0 0 0 xdim ydim // Icon
		ife temp_WEAPON_LOADOUT[INFO_SEL] 3 set disp_temp4 32 else set disp_temp4 0
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 176 0 disp_temp4 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		ifle gui_pos_x_temp 15
		 ifge gui_pos_x_temp -65
			ifle gui_pos_y_temp 3
			 ifge gui_pos_y_temp 0
				{
				set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 176 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
				state handle_click ife clicked 1
					{
					soundonce SELECT_HT_BIGGUN
					setarray temp_WEAPON_LOADOUT[INFO_SEL] 3
					setarray temp_WEAPON_LOADOUT_COST[INFO_SEL] 375
					}
						myospalx 160 55 SMGSPRITE 0 0 0 // Display the sprite
						qputs 1011 The MAC-10 submachine gun is a
						screentext STARTALPHANUM 95 80 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 powerful firearm that shoots .45
						screentext STARTALPHANUM 95 86 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 Auto rounds at a rapid rate.
						screentext STARTALPHANUM 95 92 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 These guns come in a pair, for
						screentext STARTALPHANUM 95 98 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 reasons we can't quite tell.
						screentext STARTALPHANUM 95 104 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						qputs 1011 Loadout Cost: 0.375
						screentext STARTALPHANUM 95 110 28672 0 0 1011 0 124 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
						set gun_damage_types GDT_SOFT
						state gun_dam_type_disp
				}
		}
