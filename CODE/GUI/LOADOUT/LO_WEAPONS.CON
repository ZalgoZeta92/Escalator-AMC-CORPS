defstate disp_temp_weapon_loadout
		ife temp_WEAPON_LOADOUT[INFO_SEL] 1 rotatesprite disp_temp7 disp_temp8 INVENSIZE 0 MINISHRINKERSPRITE 0 0 0 0 0 xdim ydim
		else ife temp_WEAPON_LOADOUT[INFO_SEL] 2 rotatesprite disp_temp7 disp_temp8 INVENSIZE 0 BARRETTRIFLESPRITE 0 0 0 0 0 xdim ydim
		else ife temp_WEAPON_LOADOUT[INFO_SEL] 3 rotatesprite disp_temp7 disp_temp8 INVENSIZE 0 SMGSPRITE 0 0 0 0 0 xdim ydim
