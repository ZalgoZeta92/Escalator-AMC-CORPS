				}
	}
		ife INFO_SEL_3 515
			{
			rotatesprite 288 149 20000 128 4974 0 0 0 0 0 xdim ydim
			qputs 1011 Merlijn's Sword; it can be used
			screentext STARTALPHANUM 95 40 28672 0 0 1011 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
