	ifg gui_pos_y 39 ifl gui_pos_y 187
	{
		qputs 1011 2) Sword
		rotatesprite gui_pos_x gui_pos_y INVENSIZE 0 14822 0 0 0 0 0 xdim ydim // Icon
		set disp_temp9 gui_pos_y sub disp_temp9 3 screentext STARTALPHANUM 18 disp_temp9 28672 0 0 1011 0 125 16 0 5 8 TX_GP 1 0 0 0 xdim ydim // display what it is
		ifle gui_pos_x_temp 15
