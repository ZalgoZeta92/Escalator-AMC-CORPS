ife INFO_SEL 5 // Revolution
	{
	rotatesprite 160 100 MISSION_PIC_SIZE 0 mission_pic 0 mission_pic_pal 0 0 0 xdim ydim // Main Pic
	set disp_temp4 0
	state STANDARD_INFO_BOX
	set m_charselect_forced 1
	set m_charselect_flags FLAG_HIGHWIRE
	or m_charselect_flags FLAG_JAMES
	state mission_charselector
	state MISSION_START_BOX
	ife FACILITIES_OWNED[14] 2 state AIRDROP_BOX
	set skill_mission_id 6 state skill_medals
	ife SAVED_MATVEI 1 rotatesprite 185 115 HALFSIZE 0 14763 0 0 0 0 0 xdim ydim
    state time_medium
	state difficulty_hard
	state PRECOG_BOX
		ife BASE_RESEARCH[5] 2 // has the precog brain?
		 ifand BOX_TOGGLE 1
			{
			rotatesprite 160 80 20000 0 14657 15 18 0 0 0 xdim ydim // Main Pic
			set ps_mercs 224
			state precog_enemies
			
			ife CHIBIS_FOUND[27] 1 rotatesprite 100 110 HALFSIZE 0 24303 0 0 0 0 0 xdim ydim
			else rotatesprite 100 110 HALFSIZE 0 24303 0 33 33 0 0 xdim ydim
			}
	}

ife INFO_SEL 6 // Providence
	{
	rotatesprite 160 100 MISSION_PIC_SIZE 0 mission_pic 0 mission_pic_pal 0 0 0 xdim ydim // Main Pic
	set disp_temp4 0
	state STANDARD_INFO_BOX
	state MISSION_START_BOX
	set m_charselect_forced 1
	set m_charselect_flags FLAG_JAMES
	or m_charselect_flags FLAG_SANG
	state mission_charselector

	ife FACILITIES_OWNED[10] 2 state AIRDROP_BOX
	set skill_mission_id 7 state skill_medals
	readgamevar SAVED_LILITH
	ife SAVED_LILITH 1 rotatesprite 185 115 HALFSIZE 0 14762 0 0 0 0 0 xdim ydim
    state time_medium
	state difficulty_hard
	state PRECOG_BOX
		ife BASE_RESEARCH[5] 2 // has the precog brain?
		 ifand BOX_TOGGLE 1
			{
			rotatesprite 160 80 20000 0 14657 15 18 0 0 0 xdim ydim // Main Pic
			set ps_cults 46122
			state precog_enemies
			
			qputs 1011 EQUIPMENT LOSS POSSIBILITY
			minitext 96 67 1011 0 4
			minitext 96 68 1011 0 2
			qputs 1011 ARTIFACTS DETECTED
			minitext 96 73 1011 0 4
			minitext 96 74 1011 0 49
			qputs 1011 DARK AREAS, THERMAL OPTICS ADVISED
			minitext 96 79 1011 0 4
			minitext 96 80 1011 0 1
			ife CHIBIS_FOUND[1] 1 rotatesprite 100 110 HALFSIZE 0 24284 0 0 0 0 0 xdim ydim
			else rotatesprite 100 110 HALFSIZE 0 24284 0 33 33 0 0 xdim ydim

			ife CHIBIS_FOUND[21] 1 rotatesprite 120 110 HALFSIZE 0 24298 0 0 0 0 0 xdim ydim
			else rotatesprite 120 110 HALFSIZE 0 24298 0 33 33 0 0 xdim ydim

			ifg SPECIALIST_EQUIPMENT[17] 0 // sang ice spell
			rotatesprite 140 100 QUARTERSIZE 0 6383 0 0 8 0 0 xdim ydim
			else
			rotatesprite 140 100 QUARTERSIZE 0 6383 0 33 41 0 0 xdim ydim

			ifg ARTIFACTS_FOUND[1] 0 // GOLD RING
			rotatesprite 140 120 QUARTERSIZE 0 10235 0 0 8 0 0 xdim ydim
			else
			rotatesprite 140 120 QUARTERSIZE 0 10235 0 33 41 0 0 xdim ydim
			}
	}

