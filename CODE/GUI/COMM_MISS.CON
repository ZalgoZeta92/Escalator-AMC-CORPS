// airdrop stuff
// Facility 10 = American airfield
// Facility 12 = Asia Airfield
// Facility 14 = Euro/Africa airfield
// base research 7 = advanced airship

var skill_mission_id 0 0

defstate skill_medals
ifg SKILL_MEDALS[skill_mission_id] 0 rotatesprite 185 125 HALFSIZE 0 14812 0 0 0 0 0 xdim ydim
ifg SKILL_MEDALS[skill_mission_id] 1 rotatesprite 190 125 HALFSIZE 0 14811 0 0 0 0 0 xdim ydim
ifg SKILL_MEDALS[skill_mission_id] 2 rotatesprite 195 125 HALFSIZE 0 14810 0 0 0 0 0 xdim ydim
ifg SKILL_MEDALS[skill_mission_id] 3 rotatesprite 200 125 HALFSIZE 0 14809 0 0 0 0 0 xdim ydim
ifg SKILL_MEDALS[skill_mission_id] 4 rotatesprite 205 125 HALFSIZE 0 14765 0 0 0 0 0 xdim ydim
ends

defstate time_very_short
ife mouse_over_element 1 rotatesprite 108 126 24000 0 21061 0 0 0 0 0 xdim ydim
ends

defstate time_short
ife mouse_over_element 1 rotatesprite 108 126 24000 0 21062 0 11 0 0 0 xdim ydim
ends

defstate time_medium
ife mouse_over_element 1 rotatesprite 108 126 24000 0 21063 0 23 0 0 0 xdim ydim
ends

defstate time_long
ife mouse_over_element 1 rotatesprite 108 126 24000 0 21064 0 21 0 0 0 xdim ydim
ends

defstate time_very_long
ife mouse_over_element 1 rotatesprite 108 126 24000 0 21065 0 49 0 0 0 xdim ydim
ends


defstate difficulty_very_easy
ife mouse_over_element 1 rotatesprite 119 130 HALFSIZE 0 21066 0 0 0 0 0 xdim ydim
ends

defstate difficulty_easy
ife mouse_over_element 1 rotatesprite 119 130 HALFSIZE 0 21067 0 0 0 0 0 xdim ydim
ends

defstate difficulty_medium
ife mouse_over_element 1 rotatesprite 119 130 HALFSIZE 0 21068 0 0 0 0 0 xdim ydim
ends

defstate difficulty_hard
ife mouse_over_element 1 rotatesprite 119 130 HALFSIZE 0 21069 0 0 0 0 0 xdim ydim
ends

defstate difficulty_very_hard
ife mouse_over_element 1 rotatesprite 119 130 HALFSIZE 0 21070 0 0 0 0 0 xdim ydim
ends

defstate command_mission_boxes

set airdrop_available 0

ife INFO_SEL 2 // MEGABASE
	{
	rotatesprite 160 100 MISSION_PIC_SIZE 0 mission_pic 0 mission_pic_pal 0 0 0 xdim ydim // Main Pic
	set disp_temp4 0

	state STANDARD_INFO_BOX
	state MISSION_START_BOX
	state mission_charselector

	ife FACILITIES_OWNED[10] 2 state AIRDROP_BOX
	set skill_mission_id 1 state skill_medals
	state time_short
	state difficulty_easy
	state PRECOG_BOX
		ife BASE_RESEARCH[5] 2 // has the precog brain?
		 ifand BOX_TOGGLE 1
			{
			rotatesprite 160 80 20000 0 14657 15 18 0 0 0 xdim ydim // Main Pic
			set ps_cycloids 1049087
			state precog_enemies

			// AMC soldier chibi
			ife CHIBIS_FOUND[5] 1 rotatesprite 100 110 HALFSIZE 0 24287 0 0 0 0 0 xdim ydim
			else rotatesprite 100 110 HALFSIZE 0 24287 0 33 33 0 0 xdim ydim

			ife TECH_LEVEL_A[2] 1 // scientist
			rotatesprite 120 110 QUARTERSIZE 0 8175 0 0 8 0 0 xdim ydim
			else
			rotatesprite 120 110 QUARTERSIZE 0 8175 0 33 41 0 0 xdim ydim

			ife TECH_LEVEL_A[3] 1 // scientist
			rotatesprite 135 110 QUARTERSIZE 0 8175 0 0 8 0 0 xdim ydim
			else
			rotatesprite 135 110 QUARTERSIZE 0 8175 0 33 41 0 0 xdim ydim

			ife TECH_LEVEL_A[4] 1 // scientist
			rotatesprite 150 110 QUARTERSIZE 0 8175 0 0 8 0 0 xdim ydim
			else
			rotatesprite 150 110 QUARTERSIZE 0 8175 0 33 41 0 0 xdim ydim
			}
	}

ife INFO_SEL 3 // Millhaven
	{
	rotatesprite 160 100 MISSION_PIC_SIZE 0 mission_pic 0 mission_pic_pal 0 0 0 xdim ydim // Main Pic
	set disp_temp4 0
	state STANDARD_INFO_BOX
	state MISSION_START_BOX
	set m_charselect_forced 1
	set m_charselect_flags FLAG_RUSTY
	state mission_charselector

	ife FACILITIES_OWNED[10] 2 state AIRDROP_BOX
	set skill_mission_id 4 state skill_medals
    state time_medium
	state difficulty_medium
	state PRECOG_BOX
		ife BASE_RESEARCH[5] 2 // has the precog brain?
		 ifand BOX_TOGGLE 1
			{
			rotatesprite 160 80 20000 0 14657 15 18 0 0 0 xdim ydim // Main Pic
			set ps_cults 38274
			set ps_demons 7
			state precog_enemies
			ife CHIBIS_FOUND[23] 1 rotatesprite 100 110 HALFSIZE 0 24300 0 0 0 0 0 xdim ydim
			else rotatesprite 100 110 HALFSIZE 0 24300 0 33 33 0 0 xdim ydim

			ifg SPECIALIST_EQUIPMENT[26] 0 // Merlijn long axe
			rotatesprite 130 100 QUARTERSIZE 0 13403 0 0 8 0 0 xdim ydim
			else
			rotatesprite 130 100 QUARTERSIZE 0 13403 0 33 41 0 0 xdim ydim

			ifg SPECIALIST_EQUIPMENT[25] 0 // James' auto-5
			rotatesprite 130 120 QUARTERSIZE 0 13385 0 0 8 0 0 xdim ydim
			else
			rotatesprite 130 120 QUARTERSIZE 0 13385 0 33 41 0 0 xdim ydim

			ifg ARTIFACTS_FOUND[3] 0 // book of nails
			rotatesprite 170 100 QUARTERSIZE 0 10232 0 0 8 0 0 xdim ydim
			else
			rotatesprite 170 100 QUARTERSIZE 0 10232 0 33 41 0 0 xdim ydim

			ifg ARTIFACTS_FOUND[2] 0 // lightstep boots
			rotatesprite 170 120 QUARTERSIZE 0 10233 0 0 8 0 0 xdim ydim
			else
			rotatesprite 170 120 QUARTERSIZE 0 10233 0 33 41 0 0 xdim ydim
			}
	}

