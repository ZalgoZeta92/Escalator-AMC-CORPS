 		screentext 2822 gui_pos_x gui_pos_y 28672 0 0 409 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		
		state handle_click
		ife clicked 1
		 ife MEAL_BUFF[CHAR] 0
			{
				ifl SUPPLY_LEVEL 5 soundonce COMP_INVALID 
				else
					{
					sub SUPPLY_LEVEL 5
					setarray MEAL_BUFF[CHAR] 5
					writearraytofile MEAL_BUFF F_MEAL_AMCTC
					sound TICKET_PUNCH
