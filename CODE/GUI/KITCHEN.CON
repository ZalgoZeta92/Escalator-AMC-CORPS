ends

spriteshadow 28650

useractor notenemy 28650 // Kitchen Staff

ifaction 0
{
strength 250
espawn 12263
set actor_return RETURN
seta[RETURN].owner THISACTOR
geta[RETURN].z temp
sub temp 16384
seta[RETURN].z temp
action FIVE_ANG
}



ifaction FIVE_ANG
{

ifp palive
 ife player[].newowner -1 // prevent viewscreen bugs
  ifp pfacing
   ifpdistl 1526
    ifspritepal 3
	  {
	  ife MOUSEUP 0 state use_prompt
	   ife use_action_allowed 1
			{
				ife MOUSEUP 0
					{
					soundonce CONVERSATION
					seta[actor_return].shade 20 // darken 'speech' bubble to show they've been spoken to
					getp[].horiz PHORIZ
					getp[].ang PANG
					set PCINTER 20
					set INFO_SEL 26
					set MOUSEUP 1
					}
				else
				ife MOUSEUP 1
					{
					stopsound ELEV_MUZAK2
					set PCINTER 0
					set MOUSEUP 0
					}
			state setIgnoreUse
			}
	   }
}
enda

