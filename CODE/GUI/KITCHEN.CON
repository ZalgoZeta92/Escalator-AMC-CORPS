			}

		qputs 409 Cost: 5 Supplies
 		screentext 2822 163 95 28672 0 0 409 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		rotatesprite 210 61 16384 0 16794 0 0 0 0 0 xdim ydim

		qputs 409 A warm broth eaten during winter.
 		screentext 2822 163 120 28672 0 0 409 0 0 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		qputs 409 Cold damage reduces much quicker
 		screentext 2822 163 126 28672 0 0 409 0 8 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		qputs 409 for one mission.
 		screentext 2822 163 132 28672 0 0 409 0 8 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		}
	}

