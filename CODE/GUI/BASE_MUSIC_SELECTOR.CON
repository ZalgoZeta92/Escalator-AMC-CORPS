	{
	add gui_pos_y 7
	state CURSOR_OVER_ITEM
	qputs 1011 SUDA ^32-Completed 'The Dream' 
 	screentext STARTALPHANUM gui_pos_x gui_pos_y 28672 0 0 1011 0 125 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
	ifl gui_pos_x_temp 30
	 ifg gui_pos_x_temp -255
	    ifl gui_pos_y_temp 3
		 ifg gui_pos_y_temp -3
			{
 			screentext STARTALPHANUM gui_pos_x gui_pos_y 28672 0 0 1011 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
			state handle_click
			 ife clicked 1
				{
				soundonce MOUSE_CLICK_ON
				starttrackslot 7 29
				set BASE_MUSIC 2097152
				savegamevar BASE_MUSIC
				}
			}
	}

	add gui_pos_y 7
	state CURSOR_OVER_ITEM

	ife PLAY_SHUFFLE 1
		{
		qputs 1011 Shuffle ON - will randomly play through all tracks sequentially
 		screentext STARTALPHANUM gui_pos_x gui_pos_y 28672 0 0 1011 0 123 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		}
	else
		{
		qputs 1011 Shuffle OFF - will play chosen track
 		screentext STARTALPHANUM gui_pos_x gui_pos_y 28672 0 0 1011 0 126 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
		}
	ifl gui_pos_x_temp 30
	 ifg gui_pos_x_temp -255
	    ifl gui_pos_y_temp 3
		 ifg gui_pos_y_temp -3
			{
 			screentext STARTALPHANUM gui_pos_x gui_pos_y 28672 0 0 1011 disp_pulse 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
			state handle_click
			 ife clicked 1
				{
				ife PLAY_SHUFFLE 1 { soundonce MOUSE_CLICK_OFF set PLAY_SHUFFLE 0 } else
				{ soundonce MOUSE_CLICK_ON set PLAY_SHUFFLE 1 }
				savegamevar PLAY_SHUFFLE
				}
			}

ends
