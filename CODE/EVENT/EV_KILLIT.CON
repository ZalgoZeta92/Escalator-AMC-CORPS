onevent EVENT_KILLIT

switch sprite[].picnum
	case MJ12_MECH_LEG
		spawn MJ12_MECH_LEG_FLOOR
		break
	case MJ12_MECH_ARM
		spawn MJ12_MECH_ARM_FLOOR
