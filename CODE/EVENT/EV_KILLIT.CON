			{
			shoot SPARK shoot SPARK shoot SPARK shoot SPARK shoot SPARK shoot SPARK
			}
		break
	case SAWBLADE_BOUNCE
		sound SAWBL_IMP2
		geta[].htmovflag temp
		state PROJ_HIT_SOUNDS
