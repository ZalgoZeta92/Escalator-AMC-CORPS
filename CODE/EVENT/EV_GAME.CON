			{
			getp[].shield_amount temp
			add temp 2
			clamp temp 0 200
			setp[].shield_amount temp
			addphealth 5
			}
			else
		addphealth 2

	  ife CHAR 0 add INEBRIATION 100
	ife CHAR 1 add INEBRIATION 150
	  ife CHAR 2 add INEBRIATION 50
