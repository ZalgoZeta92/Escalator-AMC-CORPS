case HOMING_MISSILE /*Set up with faction flag to prevent each of the faction actors missile homing direct to player.*/

	ifspawnedby SCORPIONESS
		{
		seta[].extra 25
		setthisprojectile[].extra 25
		set faction_flag 2048
		}
		else
	ifspawnedby CYBERALIEN
		{
		seta[].extra 25
		setthisprojectile[].extra 25
		set faction_flag 8
		}
		else
	ifspawnedby LIZBOSS
		{
		seta[].extra 25
		setthisprojectile[].extra 25
		set faction_flag 8
		}
		else
	ifspawnedby CYBERTOUR
		{
		seta[].extra 25
		setthisprojectile[].extra 25
		set faction_flag 16
		}
		else
	ifspawnedby MJ12_MECH /*Added to prevent missile homing to the player.*/
		{
		seta[].extra 25
		setthisprojectile[].extra 25
		set faction_flag 512
		}
		else
			// HEATSEEKER
			ifspawnedby APLAYER
			{
				seta[].cstat 0
				set faction_flag ALLIED_FACTION_FLAG // needed for target check to run correctly
				set weight_increase 0 // don't contribute to weight score

				add INTERNALCOUNT 1

				ifg INTERNALCOUNT 2
				{
					geta[].ang angvar_backup

					ife my_target -1
						state checkfortarget

					geta[].ang angvar

					// don't do an instant 180, turn more gradually
					ifg angvar_backup angvar
					{
						sub angvar_backup 16
						ifl angvar_backup angvar
							set angvar_backup angvar
					}
					else ifl angvar_backup angvar
					{
						add angvar_backup 16
						ifg angvar_backup angvar
							set angvar_backup angvar
					}

					seta[].ang angvar_backup

					set INTERNALCOUNT 0
				}

				ifn my_target -1
				{
					// if the coordinates overlap long enough then there's a bug, just destroy the missile
					ldist temp THISACTOR my_target

					ifl temp 1024
						add INTERNALCOUNT_2 1

					// seems to get stuck on TROR layers rarely
					ifnotmoving
						set INTERNALCOUNT_2 15

					ifge INTERNALCOUNT_2 15
					{
						hitradius 1024 35 75 112 150
						spawn MISSILE_EXPLOSION
						sound RPG_EXPLODE
						killit
					}

					ifn player_in_vehicle 1 ifcansee set PLAYER_VOICEOVER 22
					soundonce HEAT_SEEK

					geta[].ang angvar_backup
					state fronttowardstarget
					geta[].ang angvar

					// don't do an instant 180, turn more gradually
					ifg angvar_backup angvar
					{
						sub angvar_backup 64
						ifl angvar_backup angvar
							set angvar_backup angvar
					}
					else ifl angvar_backup angvar
					{
						add angvar_backup 64
						ifg angvar_backup angvar
							set angvar_backup angvar
					}

					seta[].ang angvar_backup

					set PROJECTILE_VEL 700

					// z offset = sprite height / 2
					set temp2 my_target
					state getspriteheight
					div return_getspriteheight 2
					set CALCZ_TARGET_OFFSET return_getspriteheight
					state calczvel
					seta[].zvel temp3
				}
			}
			else
				{
					ifpdistg 16384 set temp2 -256
					else ifpdistg 10240 set temp2 -128
					else ifpdistg 8192 set temp2 0
					else ifpdistg 6144 set temp2 128
					else ifpdistg 4096 set temp2 256
					else ifpdistg 2048 set temp2 384
					else set temp2 512
					soundonce HEAT_SEEK
					setactorsoundpitch THISACTOR HEAT_SEEK temp2

					ifpdistg 2048
					 ife temp8 0
						{
						getp[].posx mx
						getp[].posy my
						geta[].x x
						geta[].y y
						sub mx x
						sub my y
						getangle angvar mx my
						seta[].ang angvar
						getp[].posz temp2
						geta[].z temp
						ifvarvarl temp temp2 { add temp 40 seta[].z temp }
						ifvarvarg temp temp2 { sub temp 40 seta[].z temp }
						}
					else
					set temp8 1
				}
break
