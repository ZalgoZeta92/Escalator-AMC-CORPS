	ife CHAR 14 add INEBRIATION 10
	ife CHAR 17
		{
		ifrnd 8 sound YO_DRUNK
		add INEBRIATION 150
		}
	ife CHAR 18 add INEBRIATION 175
	killit
	}
  break
