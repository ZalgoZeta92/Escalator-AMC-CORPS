useractor notenemy FEAR_SOLDIER 200 0
fall
ifaction 0
{
cstator 257
sizeat 22 22
action FIVE_ANG
}

state spawn_cold_breathe

	ifcount 26
		{
		findnearspritez SHOOTME 6432 107456 temp
		ifn temp -1 { spawn FEAR_SOLDIER_ACTIVE killit }
		resetcount
		}

enda

defstate captive_edf
fall
ifaction 0
{
cstator 257
sizeat 22 22
action AEDFSTAND
}

state spawn_cold_breathe

ifaction AEDFSTAND
	{
	ifrnd 2 move STOP randomangle
	else move STOP
	checkactivatormotion 21711
	ife RETURN 1
		{
		spawn BLOODPOOL
		killit
		}
	}
ends

useractor notenemy 8916 state captive_edf enda
useractor notenemy 9854 state captive_edf enda


action MSSOLDIER_ID_DIE 2118 6 1 1 11
action MSSOLDIER_ID_DEAD 2123 1 1 1 11

useractor notenemy MSSOLDIER 100 0
fall
ifaction 0
{
ifspritepal 21 sizeat 27 27 else
sizeat 24 24
ifn hitag_saved 0 cstator 256
action AEDFSTAND
}

state spawn_cold_breathe

ife hitag_saved 0
{
ifspritepal 21 nullop
else
	{
	ife CHAR 7
	{
	getp[].palookup temp
	ife temp 0 set temp 11
	seta[].pal temp
	}
	else spritepal 11
	}

ifcount 26
	{
	findnearspritez SHOOTME 6432 107456 temp
	ifn temp -1 { spawn MSSOLDIER_ACTIVE killit }
	resetcount
	}
}
else
ifn hitag_saved 0
{
ifaction AEDFSTAND
	{
	sleeptime 0
	ifhitweapon
		{
		action MSSOLDIER_ID_DIE
		spawn BLOOD
		spawn BLOODPOOL
		randvar temp 30
		ifsound MS_PRAET3 stopsound MS_PRAET3
		ifl temp 10 sound EDFSOLD_DIE1 else
		ifl temp 20 sound EDFSOLD_DIE2 else
		sound EDFSOLD_DIE3
		}
	}
	else
	ifaction MSSOLDIER_ID_DIE
		{
		ifactioncount 5
			{
			action MSSOLDIER_ID_DEAD
			cstat 0
			state BODY_FALL_NOISES_SOUNDONCE
			}
		}
}

enda

move fall_slow 15 64

defstate ally_parachute
ifn hitag_saved 0
	{
	cstat 32768
	checkactivatormotion hitag_saved
	ife RETURN 1 { set actor_return 1 set hitag_saved 0 }
	}
else
ife actor_return 1 // count down till it appears
	{
	ifg lotag_saved 0 sub lotag_saved 1
	ife lotag_saved 0 set actor_return 0
	}
else
	{
	cstat 0
	sizeat 24 24
	ifmove 0 { sound PARACH ifactor WHEATON_PARACHUTE move fall_slow getv geth else move fall_slow getv geth randomangle }
	ifactorsound THISACTOR FLAG_AMBIENT nullop else sound FLAG_AMBIENT
	iffloordistl 16
		{
		ifactor AMCM_PARACHUTE cactor AMC_MEDIC_ACTIVE
		ifactor AMCH_PARACHUTE cactor AMC_HEAVY_ACTIVE
		ifactor AMCS_PARACHUTE cactor AMCSOLDIER_ACTIVE
		ifactor EDF_PARACHUTE cactor EDFSOLDIER_ACTIVE
		ifactor WHEATON_PARACHUTE killit
		stopactorsound THISACTOR FLAG_AMBIENT
		spawn BIG_SMOKE2
		sound EQUIPMENT_OFF
		}
	}
ends

spriteshadow AMCM_PARACHUTE
spriteshadow AMCH_PARACHUTE
spriteshadow AMCS_PARACHUTE
spriteshadow EDF_PARACHUTE
spriteshadow WHEATON_PARACHUTE

useractor notenemy AMCM_PARACHUTE ifn PERSONNEL_RESEARCH[45] 2 cactor AMCS_PARACHUTE state ally_parachute enda
useractor notenemy AMCH_PARACHUTE ifn WEAPONS_RESEARCH[13] 2 cactor AMCS_PARACHUTE state ally_parachute enda
useractor notenemy AMCS_PARACHUTE state ally_parachute enda
useractor notenemy EDF_PARACHUTE state ally_parachute enda
useractor notenemy WHEATON_PARACHUTE state ally_parachute enda

// This is used for the dummy in the AMC Base target range. It is spawned in front of the target the AMC soldier shoots at.
// It is killed and respawned regularly so the soldier doesn't shoot at it constantly.
useractor notenemy 9462
	cstat 256

	ifaction 0
	{
		geta[].z z
		sub z 8192
		seta[].z z
		
		espawn SHOOTME
		strength 150
		sizeat 64 64
		action ZERO
	}

	ifcount 190 killit

	ifdead killit
enda

