move AMCSTILL 0
move AMCMOVE 266
move AMCMOVESLOW 96

// disables blocking if the player is close by
defstate player_walkthru
ifdead nullop else
	{
	  ifpdistl 1024
		cstat 256
	else cstat 257
	}
ends

defstate special_npc_teleport
ifpdistg 16384
ife FOLLOW_PLAYER 1
{
ifp pfacing ifcansee nullop else 
	{
	state getxycoords_behind_player

				ife RETURN 1
				{
					spawn 8433
					seta[].x BEHIND_PLAYER_X
					seta[].y BEHIND_PLAYER_Y
					getp[].posz temp8
					sub temp8 256
					seta[].z temp8
				}
	}
}
ends

defstate clear_ally_death
ife ALLYSLOT1 THISACTOR set ALLYSLOT1 -1
ife ALLYSLOT2 THISACTOR set ALLYSLOT2 -1
ife ALLYSLOT3 THISACTOR set ALLYSLOT3 -1
ife ALLYSLOT4 THISACTOR set ALLYSLOT4 -1
ife ALLYSLOT5 THISACTOR set ALLYSLOT5 -1
ife ALLYSLOT6 THISACTOR set ALLYSLOT6 -1
ife ALLYSLOT7 THISACTOR set ALLYSLOT7 -1
ife ALLYSLOT8 THISACTOR set ALLYSLOT8 -1
ends

defstate civilian_pals
	ifrnd 32 spritepal 23
	else ifrnd 32 spritepal 36
	else ifrnd 32 spritepal 21
	else ifrnd 32 spritepal 49
	else ifrnd 32 spritepal 43
	else ifrnd 32 spritepal 44
	else ifrnd 32 spritepal 35
	else ifrnd 32 spritepal 37
	else ifrnd 32 spritepal 38
	else ifrnd 32 spritepal 39
	else ifrnd 32 spritepal 16
	else ifrnd 32 spritepal 15
	else ifrnd 32 spritepal 14
	else ifrnd 32 spritepal 13
	else ifrnd 32 spritepal 3
	else ifrnd 32 spritepal 11
	else ifrnd 32 spritepal 10
	else spritepal 12
ends

var cur_allied_target -1 2
var closest_allied_target -1 2
var closest_ally_distance -1 2

defstate do_healAlly
	switch sprite[closest_allied_target].picnum
		case APLAYER
			addphealth 200
			ife camerasprite -1 // don't do this during cutscenes, but still heal them
				{
				set PLAYER_VOICEOVER 17
				state green_flash
				sound MEDIC_HEAL
				}
			break
		default
			geta[closest_allied_target].extra temp2 
			set PERCENTAGE_IN actorvar[closest_allied_target].max_health
			set PERCENTAGE_PERCENT 50
			state getpercentage
			add temp2 PERCENTAGE_OUT  
			clamp temp2 0 actorvar[closest_allied_target].max_health
			seta[closest_allied_target].extra temp2
			setactorvar[closest_allied_target].effect_countd 30
			setactorvar[closest_allied_target].effect_type 2
			ife camerasprite -1 sound MEDIC_HEAL
			break
	endswitch
ends

// In this state, define the selection criteria an actor must use to "target" an ally
defstate defs_allySelect
	switch sprite[].picnum
		case AMC_MEDIC_ACTIVE
		case EDFSOLDIER_ACTIVE
		case MINERVA
		case ID_EARTHM
		case AMC_WITCH
			switch sprite[cur_allied_target].picnum
				case APLAYER
					ifphealthl 50 
						nullop 
					else 
						set cur_allied_target -1
					break
				default
					ife sprite[cur_allied_target].picnum AMC_209_ACTIVE
						set cur_allied_target -1
					else ifge sprite[cur_allied_target].extra actorvar[cur_allied_target].max_health
						set cur_allied_target -1
					break
			endswitch
			break
		default
			break
	endswitch
ends

// In this state, define the actions to actually perform on the previously selected ally
defstate defs_allyDo
	switch sprite[].picnum
		case AMC_MEDIC_ACTIVE
		case EDFSOLDIER_ACTIVE
		case MINERVA
		case ID_EARTHM
		case AMC_WITCH
			state do_healAlly
			break
		default
			break
	endswitch
ends

defstate checkForClosestAlly
	set temp -1
	set targets_iterator 0
	set cur_allied_target -1
	set closest_allied_target -1

	whilel targets_iterator targets_range
	{
		set temp targets[targets_iterator]

		ife temp -2
		{
			set targets_iterator targets_range
			exit
		}

		ifge temp 0
		{
			// Ignore self? Maybe not though. If you want some allies to heal themselves, remove this here and plop it in the defs_allySelect state instead on case-by-case basis?
			ife temp THISACTOR
				nullop
			else
			{
				getav[temp].faction_flag temp2
				ifand temp2 faction_flag // same faction
				{
					set cur_allied_target temp
					state defs_allySelect
					
					// Found a suitable allied target, check if it is the closest of all suitable targets
					ifn cur_allied_target -1
					{
						ldist temp2 THISACTOR cur_allied_target
						ife closest_allied_target -1
						{
							set closest_allied_target cur_allied_target
							set closest_ally_distance temp2
						}
						else ifl temp2 closest_ally_distance
						{
							set closest_allied_target cur_allied_target
							set closest_ally_distance temp2
						}
					}
				}
			}
		}

		add targets_iterator 1
	}
	
	// Output: closest_allied_target
ends

defstate nu_heal_allies
	state checkForClosestAlly
	
	ifn closest_allied_target -1
		state defs_allyDo
	else // heal themselves if need be
	  ifl sprite[].extra actorvar[].max_health 
		{
		geta[].extra temp2 
		set PERCENTAGE_IN actorvar[].max_health
		set PERCENTAGE_PERCENT 50
		state getpercentage
		add temp2 PERCENTAGE_OUT  
		clamp temp2 0 actorvar[].max_health
		seta[].extra temp2
		setactorvar[].effect_countd 30
		setactorvar[].effect_type 2
		ife camerasprite -1 sound MEDIC_HEAL
		}
ends

