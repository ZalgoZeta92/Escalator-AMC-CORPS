defstate SOLDIER_NAMEDROP
ife CHAR 0
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Sure thing James.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 39
}
sound EDFS_JAMES
}
else ife CHAR 1
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Sure thing Zaxtor.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 46
}
sound EDFS_ZAXTOR
}
else ife CHAR 2
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Sure thing Merlijn.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 40
}
sound EDFS_MERLIJN
}
else ife CHAR 3
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Sure thing Highwire.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 47
}
sound EDFS_HIGHWIRE
}
else ife CHAR 4
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Sure thing Sang.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 41
}
