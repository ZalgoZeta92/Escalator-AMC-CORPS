defstate SORCERER_NAMES
switch LAST_NAME
case 0
redefinequote 573 ^1L'vc Rft
break
case 1
redefinequote 573 ^1B'r Lr
break
case 2
redefinequote 573 ^1Bl' Ch
break
case 3
redefinequote 573 ^1C'mp Bll
break
case 4
redefinequote 573 ^1Ch'mb Rs
break
case 5
redefinequote 573 ^1D'rl Th
break
case 6
redefinequote 573 ^1Edd' Yjr
break
case 7
redefinequote 573 ^1Ell' Sn
break
case 8
redefinequote 573 ^1G' Mn
break
case 9
redefinequote 573 ^1Gr'en Brg
break
case 10
redefinequote 573 ^1H' Wrd
break
case 11
redefinequote 573 ^1J'hn Sn
break
case 12
redefinequote 573 ^1J'Sh
break
case 13
redefinequote 573 ^1K' Ng
break
case 14
redefinequote 573 ^1K't Tnr
break
case 15
redefinequote 573 ^1L'i Br
break
case 16
redefinequote 573 ^1L' Gtt
break
case 17
redefinequote 573 ^1M'c Hn
break
case 18
redefinequote 573 ^1Pr' Ce
break
case 19
redefinequote 573 ^1Sh' A
break
case 20
redefinequote 573 ^1Sm' th
break
case 21
redefinequote 573 ^1P'e
break
case 22
redefinequote 573 ^1T'r Ney
break
endswitch
ends

defstate SORCERER_FOLLOW_VOICES
state SORCERER_NAMES
ifg ALLY_VOICE 0
{
sub ALLY_VOICE 1
ife ALLY_VOICE 1
{
ifrnd 128
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Master...
qsprintf ALLY_SUBTITLE 7502 573
set ally_subt 70
}
soundonce SORC_FOLLOW1
}
else
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Yes...
qsprintf ALLY_SUBTITLE 7502 573
set ally_subt 68
}
soundonce SORC_FOLLOW2
}
}
}
else
ifl ALLY_VOICE 0
{
add ALLY_VOICE 1
ife ALLY_VOICE -1
{
ifrnd 128
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0I shall guard the area...
qsprintf ALLY_SUBTITLE 7502 573
set ally_subt 97
}
soundonce SORC_GUARD1
}
else
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0I shall KILL all intruders...
qsprintf ALLY_SUBTITLE 7502 573
set ally_subt 122
}
soundonce SORC_GUARD2
}
}
}
ends

defstate SORCERER_ATTACK_VOICES
ifrnd 16
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0See me, and know fear!
qsprintf ALLY_SUBTITLE 7502 573
set ally_subt 128
}
soundonce SORC_ATTACK1
}
else ifrnd 16
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Die!
qsprintf ALLY_SUBTITLE 7502 573
set ally_subt 84
}
soundonce SORC_ATTACK2
}
else ifrnd 16
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Yessss!
