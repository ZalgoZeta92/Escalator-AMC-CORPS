}
else ife CHAR 5
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Sure thing Rusty.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 44
}
sound EDFS_RUSTY
}
else ife CHAR 6
{
ife ally_subt 0
{
qputs 7502 ^60%s: ^0Sure thing Geoffrey.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 42
}
