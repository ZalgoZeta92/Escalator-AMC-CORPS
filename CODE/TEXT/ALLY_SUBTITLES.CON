defstate EDFSOLD_INCOMING
getav[my_target].myowner temp6
geta[temp6].picnum temp7
switch temp7
case LPOWERSUIT
case HPOWERSUIT
case VILMOS_ROBOT
case CYBERTOUR
case OGRE
case CYBERALIEN
case PE_SENTRY
case SENTRY
case TANK
ifrnd 32
{
ife ally_subt 0
ifpdistl 8192
{
qputs 7502 ^60%s: ^0We've got heavy armour here.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 47
}
sound EDFS_H_ARM
}
break
case SORCERER
case DARKAVATAR
case LOST
case SPIRIT
ifrnd 32
{
ife ally_subt 0
ifpdistl 8192
{
qputs 7502 ^60%s: ^0We've got papa tangos here.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 55
}
sound EDFS_PARA_1
}
else ifrnd 32
{
ife ally_subt 0
ifpdistl 8192
{
qputs 7502 ^60%s: ^0We've got sierra tangos here.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 59
}
sound EDFS_PARA_2
}
break
default
ifrnd 8
{
ife ally_subt 0
ifpdistl 8192
{
qputs 7502 ^60%s: ^0We've got incoming.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 40
}
sound EDFS_INCOMING_1
}
else ifrnd 8
{
ife ally_subt 0
ifpdistl 8192
{
qputs 7502 ^60%s: ^0Enemies incoming.
qsprintf ALLY_SUBTITLE 7502 LAST_NAME
set ally_subt 37
}
sound EDFS_INCOMING_2
}
break
endswitch
ends

