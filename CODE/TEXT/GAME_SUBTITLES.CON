	else ifl swear_random 100 { ifand jibs_track 16 jump swear_addr ife gp_subt 0 { xorvar jibs_track 16 ifg jibs_track max_voice_num set jibs_track 16 set subt_id 10417 set gp_subt 81 } set playsound MTAUNT5 }
