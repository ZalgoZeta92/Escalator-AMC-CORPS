else ifactor SIREN ifrnd 64 { ife gp_subt 0 { set subt_id 10411 set gp_subt 68 } set playsound M_SANG_KILL1 }
else ife cur_weap 3 ifrnd 64 { ife gp_subt 0 { set subt_id 10400 set gp_subt 93 } set playsound M_AXE1 }
