include CODE/TEXT/GST_STRINGS.CON
include CODE/TEXT/ALLY_SUBTITLES.CON

var max_voice_num 0 1 // contains the total bitfield of the player's taunts

// =======================================================================================================================================================================================================
// PLAYER
// =======================================================================================================================================================================================================


defstate merlijn_slash_kills
ifand userdef.voicetoggle 1 nullop else break
ife cur_weap 3 ifrnd 32 { ife gp_subt 0 { set subt_id 10400 set gp_subt 93 } set playsound M_AXE1 }
else ife cur_weap 3 ifrnd 32 { ife gp_subt 0 { set subt_id 10401 set gp_subt 130 } set playsound M_AXE2 }
else ife cur_weap 3 ifrnd 32 { ife gp_subt 0 { set subt_id 10402 set gp_subt 64 } set playsound M_AXE3 }
else { randvar swear_random 120 ifl swear_random 20 { ife gp_subt 0 { set subt_id 10403 set gp_subt 49 } set playsound M_SWORD_TAUNT1 }
else ifl swear_random 40 { ife gp_subt 0 { set subt_id 10404 set gp_subt 58 } set playsound M_SWORD_TAUNT2 }
else ifl swear_random 60 { ife gp_subt 0 { set subt_id 10405 set gp_subt 69 } set playsound M_SWORD_TAUNT3 }
else ifl swear_random 80 { ife gp_subt 0 { set subt_id 10406 set gp_subt 83 } set playsound M_SWORD_TAUNT4 }
else ifl swear_random 100 { ife gp_subt 0 { set subt_id 10407 set gp_subt 57 } set playsound M_SWORD_TAUNT5 }
else { ife gp_subt 0 { set subt_id 10408 set gp_subt 57 } set playsound M_SWORD_TAUNT6 } }
ends

defstate sword_kill_sounds
ifand userdef.voicetoggle 1 nullop else break
set playsound 0
ifrnd SWEARFREQUENCY ifg PHEALTH 0 ife voice_cooldown 0 ifn TIMEZONE 13
{
ifinwater break
ife CHAR C_JAMES
	{
	randvar swear_random 120 ifl swear_random 20 { ife gp_subt 0 { set subt_id 10001 set gp_subt 40 } set playsound J_SWORD_TAUNT1 }
	else ifl swear_random 40 { ife gp_subt 0 { set subt_id 10002 set gp_subt 50 } set playsound J_SWORD_TAUNT2 }
	else ifl swear_random 60 { ife gp_subt 0 { set subt_id 10003 set gp_subt 84 } set playsound J_SWORD_TAUNT3 }
	else ifl swear_random 80 { ife gp_subt 0 { set subt_id 10004 set gp_subt 91 } set playsound J_SWORD_TAUNT4 }
	else ifl swear_random 100 { ife gp_subt 0 { set subt_id 10005 set gp_subt 94 } set playsound J_SWORD_TAUNT5 }
	else { ife gp_subt 0 { set subt_id 10006 set gp_subt 111 } set playsound J_SWORD_TAUNT6 }
	}
else
ife CHAR 2 state merlijn_slash_kills
else
ife CHAR 4
	{
	randvar swear_random 100 ifl swear_random 20 { ife gp_subt 0 { set subt_id 10800 set gp_subt 104 } set playsound S_SWORD_TAUNT1 }
	else ifl swear_random 40 { ife gp_subt 0 { set subt_id 10801 set gp_subt 133 } set playsound S_SWORD_TAUNT2 }
	else ifl swear_random 60 { ife gp_subt 0 { set subt_id 10802 set gp_subt 138 } set playsound S_SWORD_TAUNT3 }
	else ifl swear_random 80 { ife gp_subt 0 { set subt_id 10803 set gp_subt 104 } set playsound S_SWORD_TAUNT4 }
	else { ife gp_subt 0 { set subt_id 10804 set gp_subt 73 } set playsound S_SWORD_TAUNT5 }
	}
else
ife CHAR 5
	{
	randvar swear_random 100 ifl swear_random 20 { ife gp_subt 0 { set subt_id 11000 set gp_subt 72 } set playsound RN_SWORD_TAUNT1 }
	else ifl swear_random 40 { ife gp_subt 0 { set subt_id 11001 set gp_subt 48 } set playsound RN_SWORD_TAUNT2 }
	else ifl swear_random 60 { ife gp_subt 0 { set subt_id 11002 set gp_subt 159 } set playsound RN_SWORD_TAUNT3 }
	else ifl swear_random 80 { ife gp_subt 0 { set subt_id 11003 set gp_subt 104 } set playsound RN_SWORD_TAUNT4 }
	else { ife gp_subt 0 { set subt_id 11004 set gp_subt 105 } set playsound RN_SWORD_TAUNT5 }
	}
else
ife CHAR 6 { ifrnd 128 { ife gp_subt 0 { set subt_id 11209 set gp_subt 75 } set playsound G_ANIME1 } }
else
ife CHAR 7
	{
	ifrnd 128 { ife gp_subt 0 { set subt_id 11400 set gp_subt 39 } set playsound MS_SWORD_TAUNT1 }
	else { ife gp_subt 0 { set subt_id 11401 set gp_subt 85 } set playsound MS_SWORD_TAUNT2 }
	}
else
ife CHAR 14
	{
	randvar swear_random 120 ifl swear_random 20 { ife gp_subt 0 { set subt_id 11800 set gp_subt 40 } set playsound SF_SWORD_TAUNT1 }
	else ifl swear_random 40 { ife gp_subt 0 { set subt_id 11801 set gp_subt 47 } set playsound SF_SWORD_TAUNT2 }
	else ifl swear_random 60 { ife gp_subt 0 { set subt_id 11802 set gp_subt 69 } set playsound SF_SWORD_TAUNT3 }
	else ifl swear_random 80 { ife gp_subt 0 { set subt_id 11803 set gp_subt 63 } set playsound SF_SWORD_TAUNT4 }
	else ifl swear_random 100 { ife gp_subt 0 { set subt_id 11804 set gp_subt 72 } set playsound SF_SWORD_TAUNT5 }
	else { ife gp_subt 0 { set subt_id 11805 set gp_subt 42 } set playsound SF_SWORD_TAUNT6 }
	}
ifn playsound 0
	{
	ife fake_shrunk 1 // has to be brute forced
		{ getp[].sound_pitch temp setp[].sound_pitch 512 globalsoundvar playsound setp[].sound_pitch temp }
	else globalsoundvar playsound ife fake_shrunk 1 setactorsoundpitch THISACTOR playsound 512
	}
set voice_cooldown opt_voice_cd_length
}
ends

