defstate HORSE_START
ifand userdef.voicetoggle 1 nullop else break
set CUS_WACK 1 ifrnd 64 sound HORSE_NEIGH1 sound HORSE_CRACK
ifrnd 96
{
ife CHAR 0 { ifrnd 8 { ife gp_subt 0 { set subt_id 10131 set gp_subt 45 } sound J_SILVERAWAY } else sound J_HYEAH }
ife CHAR 1 { ifrnd 64 { ife gp_subt 0 { set subt_id 10296 set gp_subt 45 } sound ZN_HORSE_GO } }
ife CHAR 2 { ifrnd 96 soundonce ML_HORSGO1 else ifrnd 128 soundonce M_MELEE_1 else soundonce M_MELEE_2 }
ife CHAR 3 { ifrnd 96 { ife gp_subt 0 { set subt_id 10692 set gp_subt 39 } sound HW_HORSEGO2 } else soundonce HW_HORSEGO1 }
ife CHAR 4 { ifrnd 32 { ife gp_subt 0 { set subt_id 10930 set gp_subt 71 } sound S_ONWARDS } else sound S_HYEAH }
ife CHAR 5 { ifrnd 96 { ife gp_subt 0 { set subt_id 11105 set gp_subt 45 } sound RN_GIDDYU } }
ife CHAR 6 sound G_HORSEST
ife CHAR 12 { ifrnd 32 { ifrnd 128 { ife gp_subt 0 { set subt_id 12704 set gp_subt 25 } sound JA_HORSE2 } else { ife gp_subt 0 { set subt_id 12705 set gp_subt 20 } sound JA_HORSE3 } } else sound JA_HORSE1 }
ife CHAR 13 sound MC_HYAH
ife CHAR 14 sound SF_HYEAH
ife CHAR 17
	{
	ifrnd 96 { ife gp_subt 0 { set subt_id 12135 set gp_subt 23 } sound KG_HGALLOP1 }
	else ifrnd 96 { ife gp_subt 0 { set subt_id 12136 set gp_subt 16 } sound KG_HGALLOP2 }
	else ifrnd 96 { ife gp_subt 0 { set subt_id 12137 set gp_subt 22 } sound KG_HGALLOP3 }
	}
ife CHAR 18 sound WH_HYEAH
set CUS_WACK 1
}
ends

defstate HORSE_STOP
// randomly play a voice
// don't do it every time cause that gets old real fast
ifrnd 96
{
ifand userdef.voicetoggle 1 nullop else break
ife CHAR 0 { ife gp_subt 0 { set subt_id 10132 set gp_subt 30 } sound J_WOAH }
else ife CHAR 1 { ife gp_subt 0 { set subt_id 10297 set gp_subt 30 } sound ZN_HORSE_STOP }
else ife CHAR 2 { ife gp_subt 0 { set subt_id 10478 set gp_subt 35 } sound ML_HORSTP1 }
else ife CHAR 3 { ifrnd 128 sound HW_HORSTOP1 else sound HW_HORSTOP2 }
else ife CHAR 4 { ifrnd 16 { ife gp_subt 0 { set subt_id 10931 set gp_subt 85 } sound S_WOAH2 } else { ife gp_subt 0 { set subt_id 10932 set gp_subt 49 } sound S_WOAH1 } }
else ife CHAR 5 { ife gp_subt 0 { set subt_id 11106 set gp_subt 30 } sound RN_WOAH }
else ife CHAR 6 { ife gp_subt 0 { set subt_id 11319 set gp_subt 29 } sound G_HORSTOP }
else ife CHAR 12 { ife gp_subt 0 { set subt_id 12706 set gp_subt 45 } sound JA_HORSTOP }
else ife CHAR 13 { ife gp_subt 0 { set subt_id 11710 set gp_subt 30 } sound MC_WOAHW }
else ife CHAR 14 { ife gp_subt 0 { set subt_id 11934 set gp_subt 36 } sound SF_WOAH }
else ife CHAR 17
	{
	ifrnd 16 { ife gp_subt 0 { set subt_id 12138 set gp_subt 25 } sound KG_HORSTOP1 }
	else ifrnd 16 { ife gp_subt 0 { set subt_id 12139 set gp_subt 76 } sound KG_HORSTOP2 }
	else { ife gp_subt 0 { set subt_id 12140 set gp_subt 23 } sound KG_HORSTOP3 }
	}
}
ends

