else
	{
	getcurraddress swear_addr randvar swear_random 100 set max_voice_num 31
	ifl swear_random 20 { ifand jibs_track 1 jump swear_addr ife gp_subt 0 { xorvar jibs_track 1 ifge jibs_track max_voice_num set jibs_track 1 set subt_id 13114 set gp_subt 45 } set playsound WH_BLEACH }
