else ifactor DRAGON ifrnd 128 { ifrnd 128 { ife gp_subt 0 { set subt_id 10505 set gp_subt 74 } set playsound ML_DRAGK1 } else { ife gp_subt 0 { set subt_id 10506 set gp_subt 88 } set playsound ML_DRAGK2 } }
