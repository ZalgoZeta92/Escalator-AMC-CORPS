	ifrnd 64 { ife gp_subt 0 { set subt_id 10646 set gp_subt 24 } sound R_COVER set ALLY_VOICE 24 } else ifrnd 64 { ife gp_subt 0 { set subt_id 10647 set gp_subt 29 } sound R_FOLLOW set ALLY_VOICE 29 }
