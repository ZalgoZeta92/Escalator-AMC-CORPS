	ifrnd 96 { ife gp_subt 0 { set subt_id 10866 set gp_subt 67 } sound S_FOLLOW2 set ALLY_VOICE 67 }
	else ifrnd 96 { ife gp_subt 0 { set subt_id 10867 set gp_subt 40 } sound S_BACKUP set ALLY_VOICE 40 }
	else { ife gp_subt 0 { set subt_id 10868 set gp_subt 47 } sound S_FOLLOW set ALLY_VOICE 47 }
	}
ife CHAR 5
