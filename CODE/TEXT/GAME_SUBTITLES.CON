defstate James_taunts
ifand userdef.voicetoggle 1 nullop else break
ifactor ORC ifrnd 64 { ifrnd 128 { ife gp_subt 0 { set subt_id 10050 set gp_subt 113 } set playsound J_ORCK1 } else { ife gp_subt 0 { set subt_id 10144 set gp_subt 98 } set playsound J_ORCK2 } }
else ifactor DRAGON_FLIGHT { ifrnd 128 { ife gp_subt 0 { set subt_id 10149 set gp_subt 99 } set playsound J_DRAGK1 } else { ife gp_subt 0 { set subt_id 10150 set gp_subt 121 } set playsound J_DRAGK2 } }
else ifactor DRAGON ifrnd 128 { ifrnd 128 { ife gp_subt 0 { set subt_id 10149 set gp_subt 99 } set playsound J_DRAGK1 } else { ife gp_subt 0 { set subt_id 10150 set gp_subt 121 } set playsound J_DRAGK2 } }
else ifactor BEHOLDER ifrnd 128
	{
	ifrnd 85 { ife gp_subt 0 { set subt_id 10146 set gp_subt 110 } set playsound JBEHOLDK1 }
	else ifrnd 170 { ife gp_subt 0 { set subt_id 10147 set gp_subt 93 } set playsound JBEHOLDK2 }
	else { ife gp_subt 0 { set subt_id 10148 set gp_subt 46 } set playsound JBEHOLDK3 }
	}
else ifactor ARCHER ifrnd 64 { ifrnd 128 { ife gp_subt 0 { set subt_id 10051 set gp_subt 104 } set playsound J_ARCHK1 } else { ife gp_subt 0 { set subt_id 10145 set gp_subt 85 } set playsound J_ARCHK2 } }
else ifactor OGRE ifrnd 32 { ife gp_subt 0 { set subt_id 10052 set gp_subt 71 } set playsound J_OGREK1 }
else ifactor TROLL ifrnd 64 { ife gp_subt 0 { set subt_id 10053 set gp_subt 136 } set playsound J_TROLLK1 }
else ifactor CULTIST ifrnd 64 { ifrnd 128 { ife gp_subt 0 { set subt_id 10007 set gp_subt 80 } set playsound JCULTISTKILL } else { ife gp_subt 0 { set subt_id 10008 set gp_subt 97 } set playsound JCULTISTKILL2 } }
else ifactor TRIAD ifrnd 64 { ifrnd 128 { ife gp_subt 0 { set subt_id 10009 set gp_subt 120 } set playsound J_TRIADKILL } else { ife gp_subt 0 { set subt_id 10010 set gp_subt 90 } set playsound J_TRIADKILL2 } }
else ifactor THOTH ifrnd 64 { ifrnd 96 { ife gp_subt 0 { set subt_id 10011 set gp_subt 90 } set playsound J_EGYPTKILL1 } else ifrnd 128 { ife gp_subt 0 { set subt_id 10012 set gp_subt 125 } set playsound J_EGYPTKILL2 } }
else ifactor ANUBIS_MUMMY ifrnd 64
	{
	ifrnd 96 { ife gp_subt 0 { set subt_id 10011 set gp_subt 90 } set playsound J_EGYPTKILL1 }
	else ifrnd 128 { ife gp_subt 0 { set subt_id 10012 set gp_subt 125 } set playsound J_EGYPTKILL2 }
	else { ife gp_subt 0 { set subt_id 10013 set gp_subt 150 } set playsound J_EGYPTKILL3 }
	}
else ifactor SORCERER ifrnd 64 { ifrnd 128 { ife gp_subt 0 { set subt_id 10014 set gp_subt 75 } set playsound J_SUPERN_KILL1 } else { ife gp_subt 0 { set subt_id 10015 set gp_subt 75 } set playsound J_SUPERN_KILL2 } }
else ifactor SIREN ifrnd 64 { ifrnd 128 { ife gp_subt 0 { set subt_id 10014 set gp_subt 75 } set playsound J_SUPERN_KILL1 } else { ife gp_subt 0 { set subt_id 10015 set gp_subt 75 } set playsound J_SUPERN_KILL2 } }
else ifactor DARKAVATAR ifrnd 64 { ifrnd 128 { ife gp_subt 0 { set subt_id 10014 set gp_subt 75 } set playsound J_SUPERN_KILL1 } else { ife gp_subt 0 { set subt_id 10015 set gp_subt 75 } set playsound J_SUPERN_KILL2 } }
else ifg HEADSHOT 0 ifrnd 128
	{
	ifrnd 96 { ife gp_subt 0 { set subt_id 10016 set gp_subt 72 } set playsound JHEADSHOT1 }
	else ifrnd 96 { ife gp_subt 0 { set subt_id 10017 set gp_subt 72 } set playsound JHEADSHOT2 }
	else { ife gp_subt 0 { set subt_id 10018 set gp_subt 53 } set playsound JHEADSHOT3 }
	}
else
	{
	set max_voice_num 1023
	getcurraddress swear_addr randvar swear_random 200
	ifl swear_random 20 { ifand jibs_track 1 jump swear_addr ife gp_subt 0 { xorvar jibs_track 1 ifge jibs_track max_voice_num set jibs_track 1 set subt_id 10019 set gp_subt 74 } set playsound JFIREHOLE }
	else ifl swear_random 40 { ifand jibs_track 2 jump swear_addr ife gp_subt 0 { xorvar jibs_track 2 ifge jibs_track max_voice_num set jibs_track 2 set subt_id 10020 set gp_subt 71 } set playsound JBLEACH }
