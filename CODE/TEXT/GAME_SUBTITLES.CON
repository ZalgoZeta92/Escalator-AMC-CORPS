	else ifrnd 96 { ife gp_subt 0 { set subt_id 10445 set gp_subt 15 } sound M_COVER set ALLY_VOICE 15 } else { ife gp_subt 0 { set subt_id 10446 set gp_subt 35 } sound M_BACKUP set ALLY_VOICE 35 }
	}
ife CHAR 3
