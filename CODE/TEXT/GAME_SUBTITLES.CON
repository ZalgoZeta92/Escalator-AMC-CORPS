	else ifl swear_random 80 { ifand jibs_track 8 jump swear_addr ife gp_subt 0 { xorvar jibs_track 8 ifge jibs_track max_voice_num set jibs_track 8 set subt_id 10022 set gp_subt 35 } set playsound JMASTER }
	else ifl swear_random 100 { ifand jibs_track 16 jump swear_addr ife gp_subt 0 { xorvar jibs_track 16 ifge jibs_track max_voice_num set jibs_track 16 set subt_id 10023 set gp_subt 83 } set playsound JSUGAR }
	else ifl swear_random 120 { ifand jibs_track 32 jump swear_addr ife gp_subt 0 { xorvar jibs_track 32 ifge jibs_track max_voice_num set jibs_track 32 set subt_id 10024 set gp_subt 72 } set playsound JWANTSOME }
	else ifl swear_random 140 { ifand jibs_track 64 jump swear_addr ife gp_subt 0 { xorvar jibs_track 64 ifge jibs_track max_voice_num set jibs_track 64 set subt_id 10025 set gp_subt 63 } set playsound J_SMALLTIME }
	else ifl swear_random 160 { ifand jibs_track 128 jump swear_addr ife gp_subt 0 { xorvar jibs_track 128 ifge jibs_track max_voice_num set jibs_track 128 set subt_id 10026 set gp_subt 74 } set playsound J_STRETCHED }
	else ifl swear_random 180 { ifand jibs_track 256 jump swear_addr ife gp_subt 0 { xorvar jibs_track 256 ifge jibs_track max_voice_num set jibs_track 256 set subt_id 10027 set gp_subt 66 } set playsound J_STEPRIGHTUP }
	else { ifand jibs_track 512 jump swear_addr ife gp_subt 0 { xorvar jibs_track 512 ifg jibs_track max_voice_num set jibs_track 512 set subt_id 10028 set gp_subt 65 } set playsound J_PEEK }
	ifge jibs_track max_voice_num set jibs_track 0
	}
ends

