// =======================================================================================================================================================================================================
//
// PLAYER ORDER ALLY VOICEOVERS
//
// =======================================================================================================================================================================================================

defstate follow_sounds
ifand userdef.voicetoggle 1 nullop
else break
ife CHAR 0
	{
	ifg VOLUME 3 ifn VOLUME 6 ifn VOLUME 6
		{
		ifrnd 64 { ife gp_subt 0 { set subt_id 10156 set gp_subt 53 } sound JR_FOLL1 set ALLY_VOICE 53 } else ifrnd 64 { ife gp_subt 0 { set subt_id 10157 set gp_subt 51 } sound JR_FOLL2 set ALLY_VOICE 51 }
		else ifrnd 64 { ife gp_subt 0 { set subt_id 10158 set gp_subt 50 } sound JR_FOLL3 set ALLY_VOICE 50 } else { ife gp_subt 0 { set subt_id 10159 set gp_subt 54 } sound JR_FOLL4 set ALLY_VOICE 54 }
		}
	else 
		{
		ifrnd 64 { ife gp_subt 0 { set subt_id 10055 set gp_subt 24 } sound J_COVER set ALLY_VOICE 24 } else ifrnd 64 { ife gp_subt 0 { set subt_id 10056 set gp_subt 30 } sound J_FOLLOW set ALLY_VOICE 30 }
		else ifrnd 64 { ife gp_subt 0 { set subt_id 10057 set gp_subt 40 } sound J_MOVEOUT set ALLY_VOICE 40 } else { ife gp_subt 0 { set subt_id 10058 set gp_subt 29 } sound J_TREE set ALLY_VOICE 29 }
		}
	}
ife CHAR 1
	{
	ifrnd 96 { ife gp_subt 0 { set subt_id 10246 set gp_subt 17 } sound Z_COVER set ALLY_VOICE 17 }
	else ifrnd 96 { ife gp_subt 0 { set subt_id 10247 set gp_subt 26 } sound Z_BACKUP set ALLY_VOICE 26 }
	else { ife gp_subt 0 { set subt_id 10248 set gp_subt 18 } sound Z_MOVEOUT set ALLY_VOICE 18 }
