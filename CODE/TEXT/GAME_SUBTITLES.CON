	ifrnd 64 { ife gp_subt 0 { set subt_id 11046 set gp_subt 19 } sound RN_ALLYF1 set ALLY_VOICE 28 }
	else ifrnd 64 { ife gp_subt 0 { set subt_id 11047 set gp_subt 19 } sound RN_COVER set ALLY_VOICE 19 }
	else ifrnd 64 { ife gp_subt 0 { set subt_id 11048 set gp_subt 28 } sound RN_BACKUP set ALLY_VOICE 28 }
