	else ifl swear_random 40 { ifand jibs_track 2 jump swear_addr ife gp_subt 0 { xorvar jibs_track 2 ifg jibs_track max_voice_num set jibs_track 2 set subt_id 10414 set gp_subt 88 } set playsound MTAUNT2 }
	else ifl swear_random 60 { ifand jibs_track 4 jump swear_addr ife gp_subt 0 { xorvar jibs_track 4 ifg jibs_track max_voice_num set jibs_track 4 set subt_id 10415 set gp_subt 43 } set playsound MTAUNT3 }
