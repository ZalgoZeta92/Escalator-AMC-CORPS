// =========================================================================================================================================================================================
// Main taunts state
// =========================================================================================================================================================================================

defstate jib_sounds
set playsound 0
ifrnd SWEARFREQUENCY ifg PHEALTH 0 ife voice_cooldown 0 ifand userdef.voicetoggle 1 ifn TIMEZONE 13 set actor_return 1
ifinwater set actor_return 0
ife actor_return 1
{
ife sprite[].htowner PLAYER_IDENTITY
	{
	switch CHAR
	case 0 ifg VOLUME 3 ifn VOLUME 6 state Rev_James_taunts else state James_taunts break
	case 1 state Zaxtor_taunts break
	case 2 state Merlijn_taunts break
	case 3 state Highwire_taunts break
	case 4 state Sang_taunts break
	case 5 state Rusty_Main_taunts break
	case 6 state Geoffrey_taunts break
	case 7 state Mikko_taunts break
	case 9 state Cultist_taunts break
	case 10 state Bombshell_taunts break
	case 11 state Maarten_taunts break
	case 12 state Jane_taunts break
	case 13 state Micky_taunts break
	case 14 state Snowfall_taunts break
	case 16 state Rosa_taunts break
	case 17 state Kagura_taunts break
	case 18 state Wheaton_taunts break
	endswitch

	ifn playsound 0
		{
		ife fake_shrunk 1 // has to be brute forced
		{ getp[].sound_pitch temp setp[].sound_pitch 512 globalsoundvar playsound setp[].sound_pitch temp }
		else globalsoundvar playsound ife fake_shrunk 1 setactorsoundpitch THISACTOR playsound 512
		}
	}
set voice_cooldown opt_voice_cd_length
}
ends

