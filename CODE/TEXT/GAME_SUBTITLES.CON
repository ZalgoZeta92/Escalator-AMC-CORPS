defstate stay_sounds
ifand userdef.voicetoggle 1 nullop else break
ife CHAR 0 
		{
		ifg VOLUME 3 ifn VOLUME 6 
			{ 
			ifrnd 96 { ife gp_subt 0 { set subt_id 10164 set gp_subt 22 } sound JR_STAY1 set ALLY_VOICE -22 } 
			else ifrnd 96 { ife gp_subt 0 { set subt_id 10165 set gp_subt 67 } sound JR_STAY2 set ALLY_VOICE -67 } 
