defstate Wheaton_taunts
ifand userdef.voicetoggle 1 nullop else break
ifactor ARCHER ifrnd 64 { ife gp_subt 0 { set subt_id 13108 set gp_subt 93 } set playsound WH_ARCHK1 } else ifactor BEHOLDER ifrnd 64 { ife gp_subt 0 { set subt_id 13110 set gp_subt 102 } set playsound WH_BEHOLDK1 }
else ifactor CULTIST ifrnd 64 { ifrnd 128 { ife gp_subt 0 { set subt_id 13127 set gp_subt 55 } set playsound WH_CULTK } else { ife gp_subt 0 { set subt_id 13126 set gp_subt 62 } set playsound WH_CULTK2 } }
else ifactor DRAGON ifrnd 64 { ifrnd 128 { ife gp_subt 0 { set subt_id 13133 set gp_subt 141 } set playsound WH_DRAGK1 } else { ife gp_subt 0 { set subt_id 13134 set gp_subt 84 } set playsound WH_DRAGK2 } }
