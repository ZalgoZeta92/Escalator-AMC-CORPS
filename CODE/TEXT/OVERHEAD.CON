var maptext_y 0 1
onevent EVENT_DISPLAYOVERHEADMAPTEXT
setvar RETURN 1
getp[].ang disp_temp2
ifg disp_temp2 1919 myospalx 160 160 2858 0 0 0
else ifg disp_temp2 1663 { myospalx 157 160 2867 0 0 0 myospalx 163 160 2858 0 0 0 }
else ifg disp_temp2 1408 myospalx 160 160 2867 0 0 0
else ifg disp_temp2 1151 { myospalx 157 160 2867 0 0 0 myospalx 163 160 2876 0 0 0 }
else ifg disp_temp2 895 myospalx 160 160 2876 0 0 0
else ifg disp_temp2 639 { myospalx 157 160 2872 0 0 0 myospalx 163 160 2876 0 0 0 }
else ifg disp_temp2 383 myospalx 160 160 2872 0 0 0
else ifg disp_temp2 127 { myospalx 157 160 2872 0 0 0 myospalx 163 160 2858 0 0 0 }
else myospalx 160 160 2858 0 0 0
ife userdef[].overhead_on 2
{
set maptext_y 7
ife HUB_MAP 0
{
// Display Episode Name
switch VOLUME
case 0 set disp_txt 310 break
case 1 set disp_txt 311 break
case 2 set disp_txt 312 break
case 3 set disp_txt 313 break
case 4 set disp_txt 314 break
case 5 set disp_txt 315 break
case 6 set disp_txt 316 break
endswitch
screentext 2822 -50 maptext_y 28672 0 0 disp_txt 5 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
// Display Level Name
ife VOLUME 0 ife LEVEL 7 qgetsysstr 403 STR_USERMAPFILENAME
else qgetsysstr 403 STR_MAPNAME
add maptext_y 5
screentext 2822 -50 maptext_y 28672 0 0 403 10 2 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
// MAP AUTHORS ======================================================
add maptext_y 5
screentext 2822 -50 maptext_y 28672 0 0 405 0 8 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
