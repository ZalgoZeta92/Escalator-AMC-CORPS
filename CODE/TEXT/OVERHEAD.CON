ifg player[].max_secret_rooms 0
{
add maptext_y 5
ife player[].secret_rooms player[].max_secret_rooms
	{
	qputs 1049 ALL SECRETS FOUND
	screentext 2822 -50 maptext_y 28672 0 0 1049 disp_pulse 8 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
	}
else
	{
	qputs 1049 SECRETS:  %ld/%ld
	qsprintf 1049 1049 player[].secret_rooms player[].max_secret_rooms
	screentext 2822 -50 maptext_y 28672 0 0 1049 0 29 16 0 5 8 TX_GP 1 0 0 0 xdim ydim
	}
}
