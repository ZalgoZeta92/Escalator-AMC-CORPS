		qputs 350 ^2Magnus: ^0The World is undergoing Armageddon...
	}
	else ifge cs_timer 126 ifl cs_timer 238 { set cs_textl 2 set speaker 39
		qputs 350 ^2Magnus: ^0The Beyonders are moving in to pervert 
		qputs 351 whatever will be left...
	}
	else ifge cs_timer 238 ifl cs_timer 328 { set cs_textl 1 set speaker 50
		qputs 350 ^2Magnus: ^0And I failed in all my objectives.
