 ife cuts_sound 0 { globalsound SEMAJ_04 set yvel_saved 774 set cuts_sound 1 }
	 ifge cs_timer 0 ifl cs_timer 159 {  set cs_textl 2
		qputs 350 ^7Father: ^0There is one thing though, that you 
