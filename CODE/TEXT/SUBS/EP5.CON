ife cuts_txt 7540 
{
 ife cuts_sound 0 { globalsound SEMAJ_01 set yvel_saved 1032 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 151 { set cs_textl 1
		qputs 350 ^7^7Father: ^0^0Cassandra...I shouldn't even have the right to say your name. 
	}
	else ifge cs_timer 151 ifl cs_timer 324 { set cs_textl 2
		qputs 350 ^7^7Father: ^0^0I gave you up not once but twice, 
		qputs 351 first to MJ12 and then to Axon.
	}
	else ifge cs_timer 324 ifl cs_timer 471 {
		qputs 350 ^7Father: ^0I can only take comfort in that he will
		qputs 351 care for you more than I was ever capable of.
	}
	else ifge cs_timer 471 ifl cs_timer 610 { set cs_textl 1
		qputs 350 ^7Father: ^0I won't rattle off excuses...they're all equally pathetic.
	}
	else ifge cs_timer 610 ifl cs_timer 822 { set cs_textl 2
		qputs 350 ^7Father: ^0We're on route to Triton, we're supposed to pull someone 
		qputs 351 called 'Snowfall' out of whatever's left of the facility there.
	}
	else ifge cs_timer 822 ifl cs_timer 942 { set cs_textl 2
		qputs 350 ^7Father: ^0No idea what Magnus wants with him, 
		qputs 351 but apparently it's important.
	}
	else ifge cs_timer 942 { set cs_textl 1
		qputs 350 ^7Father: ^0An ambush by the Beyonders is almost inevitable.
	}
}
ife cuts_txt 7541 
{
 ife cuts_sound 0 { globalsound SEMAJ_02 set yvel_saved 819 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 90 {  set cs_textl 1
		qputs 350 ^7Father: ^0I am sorry for everything.
	}
	else ifge cs_timer 90 ifl cs_timer 273 {  set cs_textl 2
		qputs 350 ^7Father: ^0That you inherited immortality, that the only way death 
		qputs 351 will claim you is by external forces.
	}
	else ifge cs_timer 273 ifl cs_timer 486 {
		qputs 350 ^7Father: ^0There is no passing away peacefully in your sleep, surrounded 
		qputs 351 by loved ones or family, for those who walk this path.
	}
	else ifge cs_timer 486 {  set cs_textl 3
		qputs 350 ^7Father: ^0That you inherited Revelion's time powers...that you've had to
		qputs 351 subject yourself to unimaginable danger time and time again just to 
		qputs 352 prolong the lifes of others in timelines that you'll never see the fruits of.
	}
}
ife cuts_txt 7542 
{
 ife cuts_sound 0 { globalsound SEMAJ_03 set yvel_saved 627 set cuts_sound 1 }
ifge cs_timer 0 ifl cs_timer 264 {  set cs_textl 3
    qputs 350 ^7Father: ^0For all my failures, my betrayal of all I stood for...
    qputs 351 there was only one good thing I ever managed to contribute 
	qputs 352 to this world, and that was you.
}
else ifge cs_timer 264 ifl cs_timer 459 {  set cs_textl 2
    qputs 350 ^7Father: ^0And what world was that? A nightmare, where humanity 
    qputs 351 is all but extinct and clinging on for dear life?
}
else ifge cs_timer 459 {
    qputs 350 ^7Father: ^0Desperately evading the inevitable, which come to think of it 
    qputs 351 was what kick started this whole thing off wasn't it? 
}
}
ife cuts_txt 7543 
