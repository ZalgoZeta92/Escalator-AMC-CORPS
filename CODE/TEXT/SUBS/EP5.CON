ife cuts_txt 6815
{
set cs_textl 2
ife cuts_sound 0 { globalsound CARC_09 setactorvar[camerasprite].cameratime 930 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 336 { set speaker 35
		qputs 350 ^8Urbaros:^0 Of a sort yes...We were an antideluvian offshoot 
		qputs 351 of humanity once; we ruled the world from corner to corner. 
	}
	else ifge cs_timer 336 ifl cs_timer 592 { set speaker 36
