		qputs 350 ^8Urbaros:^0 You most likely just brought 
		qputs 351 the timetable forward a few centuries.
	}
	else ifge cs_timer 555 { set speaker 35
		qputs 350 ^8Urbaros:^0 These Beyonders were already moving throughout the Galaxy at 
		qputs 351 this point regardless, but now they are fundamentally aware of Earth.
}
}
ife cuts_txt 6824
{
set cs_textl 1
ife cuts_sound 0 { globalsound CARC_18 setactorvar[camerasprite].cameratime 294 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 102 {
		qputs 350 ^8James:^0 Earth's days have been numbered ever since then.
	}
	else ifge cs_timer 102 ifl cs_timer 228 { set speaker 0
		qputs 350 ^8James:^0 Perhaps it is fortunate I am here, not there to witness it.
	}
	else ifge cs_timer 228 { set speaker -1
		qputs 350 ^8James:^0 I wonder what the point of it all was then.
	}
}
ife cuts_txt 6825
{
ife cuts_sound 0 { globalsound CARC_19 setactorvar[camerasprite].cameratime 1470 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 202 { set cs_textl 2
		qputs 350 ^8Urbaros:^0 Everything that has ever existed has had a number 
		qputs 351 on it since the moment of its conception.
	}
	else ifge cs_timer 202 ifl cs_timer 511 {
		qputs 350 ^8Urbaros:^0 Without that, you would get this place - the Abyss, 
		qputs 351 A churning, meaningless wasteland where nothing begins or ends.
	}
	else ifge cs_timer 511 ifl cs_timer 715 {
		qputs 350 ^8Urbaros:^0 It is only through belief, and hope, that we 
		qputs 351 are both stood here on neutral grounds.
	}
	else ifge cs_timer 715 ifl cs_timer 901 { set cs_textl 1
		qputs 350 ^8Urbaros:^0 Things can and must end, but there is a point to all of it.
	}
	else ifge cs_timer 901 ifl cs_timer 1287 { set cs_textl 3
		qputs 350 ^8Urbaros:^0 Our actions create meaning - and that meaning gives purpose
		qputs 351 to our existence, even when all life eventually ends and the Universe 
		qputs 352 collapses in upon itself.
	}
	else ifge cs_timer 1287 { set cs_textl 1
		qputs 350 ^8Urbaros:^0 That, in and of itself, is enough to keep ourselves going.
	}
}
ife cuts_txt 6826
