else ifge cs_timer 142 ifl cs_timer 228 {  set cs_textl 1
    qputs 350 ^8James: ^0But I have no control over time itself...
}
else ifge cs_timer 228 ifl cs_timer 361 {  set cs_textl 2
    qputs 350 ^8James: ^0It still remains to be seen if there 
    qputs 351 was a point to it beyond the power I now have.
}
else ifge cs_timer 361 { set cs_textl 1
    qputs 350 ^8James: ^0Why cannot I just follow you back through your...portal?
}
 
}
