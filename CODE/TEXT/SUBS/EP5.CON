		qputs 351 we killed the Despot, we broke the seal.
	}
	else ifge cs_timer 243 { set cs_textl 1 set speaker 0
		qputs 350 ^8James:^0 I...apologise, for our short sightedness.
	}
}
ife cuts_txt 6823
{
ife cuts_sound 0 { globalsound CARC_17 setactorvar[camerasprite].cameratime 849 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 220 { set cs_textl 2 set speaker 35
		qputs 350 ^8Urbaros:^0 Yes; though I should make it clear that this pact 
		qputs 351 would have not lasted for eternity regardless.
	}
	else ifge cs_timer 220 ifl cs_timer 394 { set speaker -1
