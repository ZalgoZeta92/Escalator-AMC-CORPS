ife cuts_txt 6817
{
set cs_textl 2
ife cuts_sound 0 { globalsound CARC_11 setactorvar[camerasprite].cameratime 756 set cuts_sound 1 }
ifge cs_timer 0 ifl cs_timer 324 { set speaker 36
    qputs 350 ^8Urbaros:^0 Partially - the visitors from the cosmos, the Engineers 
    qputs 351 as you called them, came and uplifted a portion of us to the stars.
}
else ifge cs_timer 324 ifl cs_timer 598 { set speaker 35
    qputs 350 ^8Urbaros:^0 The rest remained on Earth, worshipping these new 'gods'
    qputs 351 until they left as suddenly as they arrived...
}
else ifge cs_timer 598 { set speaker -1
    qputs 350 ^8Urbaros:^0 And in their wake came horrors from beyond 
    qputs 351 our worst nightmares.
}
}
ife cuts_txt 6818
{
ife cuts_sound 0 { globalsound CARC_12 setactorvar[camerasprite].cameratime 630 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 139 { set cs_textl 1 set speaker -1
		qputs 350 ^8James:^0 This was...was when they initiated their great experiment.
	}
	else ifge cs_timer 139 ifl cs_timer 385 { set cs_textl 2 set speaker 0
		qputs 350 ^8James:^0 The Ringworld systems, they sacrificed unfathomable 
		qputs 351 number of lives to create an afterlife for themselves.
	}
	else ifge cs_timer 385 ifl cs_timer 525 { set speaker -1
		qputs 350 ^8James:^0 I began to realise that they are also most 
		qputs 351 likely to thank for the existence of this place. 
	}
	else ifge cs_timer 525 { set cs_textl 1 set speaker 0
		qputs 350 ^8James:^0 So they really did just leave you to fend for yourselves?
	}
}
ife cuts_txt 6819
{
ife cuts_sound 0 { globalsound CARC_13 setactorvar[camerasprite].cameratime 930 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 403 { set cs_textl 2 set speaker 35
		qputs 350 ^8Urbaros:^0 Yes...the colonies they had established throughout Sol were left to die, 
		qputs 351 and those of us on Earth were subjected to the aftermath of their great 'triumph'; 
	}
	else ifge cs_timer 403 ifl cs_timer 564 { set speaker 36
		qputs 350 ^8Urbaros:^0 Until one day we made contact with a greater power 
		qputs 351 from the Abyss.
	}
	else ifge cs_timer 564 { set speaker -1
		qputs 350 ^8Urbaros:^0 It offered us protection, that it could shield the entire solar 
		qputs 351 system from the effects of the Engineer's work, in exchange for our eternal souls.
	}
}
ife cuts_txt 6820
{
set cs_textl 2
ife cuts_sound 0 { globalsound CARC_14 setactorvar[camerasprite].cameratime 162 set cuts_sound 1 }
	ifge cs_timer 0 {
		qputs 350 ^8James:^0 And...you took this offer? I can hardly  
		qputs 351 see what was in it for yourselves.
	}
}
ife cuts_txt 6821
{
ife cuts_sound 0 { globalsound CARC_15 setactorvar[camerasprite].cameratime 1215 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 136 { set cs_textl 1
		qputs 350 ^8Urbaros:^0 There was nothing in it for us. 
	}
	else ifge cs_timer 136 ifl cs_timer 402 { set cs_textl 2 set speaker 35
		qputs 350 ^8Urbaros:^0 The Engineers had commited the ultimate act of selfishness,
		qputs 351 and most likely doomed Earth to a terrible fate.
	}
	else ifge cs_timer 402 ifl cs_timer 619 { set cs_textl 1 set speaker -1
		qputs 350 ^8Urbaros:^0 So we argued, debated, than agreed - we would do the opposite.
	}
	else ifge cs_timer 619 ifl cs_timer 901 { set cs_textl 2 set speaker 36
		qputs 350 ^8Urbaros:^0 We would sacrifice ourselves, our future, our very souls,  
		qputs 351 so that Earth would remain protected.
	}
	else ifge cs_timer 901 { set speaker 35
		qputs 350 ^8Urbaros:^0 Our only hope then was that the more primitive humans still
		qputs 351 dwelling in caves would live to perservere...and you did.
	}
}
ife cuts_txt 6822
{
ife cuts_sound 0 { globalsound CARC_16 setactorvar[camerasprite].cameratime 354 set cuts_sound 1 }
	ifge cs_timer 0 ifl cs_timer 243 { set cs_textl 2 set speaker -1
