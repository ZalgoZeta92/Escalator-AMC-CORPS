ife cuts_txt 8029 
{
 ife cuts_sound 0 { globalsound MGEND_01_MG setactorvar[camerasprite].cameratime 372 set cuts_sound 1 }
	 ifge cs_timer 0 ifl cs_timer 202 { set cs_textl 2
		qputs 350 ^2Magnus: ^0Greetings, James...It feels strange to 
		qputs 351 compose a message to a dead man, but here we are.
	}
	else ifge cs_timer 202 ifl cs_timer 289 { set cs_textl 1 set speaker 39
		qputs 350 ^2Magnus: ^0One corpse speaking to another.
	}
	else ifge cs_timer 289 { set cs_textl 2 set speaker 50
		qputs 350 ^2Magnus: ^0Things slipped out of my hand 
		qputs 351 in the last few months of my life.
	}
}
ife cuts_txt 8030 
{
 ife cuts_sound 0 { globalsound MGEND_02_MG setactorvar[camerasprite].cameratime 673 set cuts_sound 1 }
	 ifge cs_timer 0 ifl cs_timer 142 { set cs_textl 1
		qputs 350 ^2Magnus: ^0When we first met, I was young and brash.
	}
	else ifge cs_timer 142 ifl cs_timer 265 { set speaker 39
		qputs 350 ^2Magnus: ^0Revelion was a sledgehammer to fulfil the council's goals,
	}
	else ifge cs_timer 265 ifl cs_timer 397 { set speaker 40
		qputs 350 ^2Magnus: ^0To wipe the slate clean and rebuild with only the greatest.
	}
	else ifge cs_timer 397 ifl cs_timer 630 { set cs_textl 2 set speaker 50
		qputs 350 ^2Magnus: ^0As that plan failed, and time progressed, the filter 
		qputs 351 became ever tighter and stricter until..
	}
	else ifge cs_timer 630 { set cs_textl 1 set speaker 41
		qputs 350 ^2Magnus: ^0Well, here we are.
	}
}
ife cuts_txt 8031 
{
 ife cuts_sound 0 { globalsound MGEND_03_MG setactorvar[camerasprite].cameratime 483 set cuts_sound 1 }
