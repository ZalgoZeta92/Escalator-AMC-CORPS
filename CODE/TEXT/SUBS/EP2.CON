}
}
ife cuts_txt 359
{
set cs_textl 2
ifl cs_timer 146
{
qputs 350 ^8James: ^0Finally, Magnus Giesler has reared his
qputs 351 head once again...bringing MJ12 with him.
}
else
{
qputs 350 ^8James: ^0I can only imagine how he wrestled control of
