}
}
ife cuts_txt 360
{
ifl cs_timer 97
{
set cs_textl 1
qputs 350 ^8James: ^0The Telekinetic metal monstrosity nearly killed me;
}
else
ifl cs_timer 284
{
set cs_textl 3
