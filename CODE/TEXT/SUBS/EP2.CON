}
}
ife cuts_txt 358
{
ifl cs_timer 113
{
set cs_textl 2
qputs 350 ^8James: ^0Micky managed to infiltrate the mines
qputs 351 and start the prototype Oxygen generator.
}
else
{
set cs_textl 3
